<!DOCTYPE html>
<html class="light" lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>Sổ trọ - Giải pháp quản lý phòng trọ chuyên nghiệp</title>
    <!-- TailwindCSS CDN -->
