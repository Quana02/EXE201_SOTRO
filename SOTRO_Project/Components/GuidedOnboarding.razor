@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

@if (IsVisible && currentRect != null && Steps.Count > 0)
{
    var step = Steps[CurrentStepIndex];
    var total = Steps.Count;
    var panelWidth = Math.Min(420, Math.Max(280, viewportWidth - 32));
    var panelLeft = GetPanelLeft(currentRect, panelWidth);
    var panelTop = GetPanelTop(currentRect, panelLeft, panelWidth);
    var panelMaxHeight = GetPanelMaxHeight(currentRect, panelTop, panelLeft, panelWidth);

    <div class="fixed inset-0 z-[310] pointer-events-none" role="dialog" aria-modal="true" aria-label="@step.Title">
        <div class="absolute pointer-events-auto left-0 top-0 right-0 bg-slate-950/60 backdrop-blur-[1px]" style="height:@($"{Math.Max(0, currentRect.Top - Padding)}px")"></div>
        <div class="absolute pointer-events-auto left-0 bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{Math.Max(0, currentRect.Top - Padding)}px"); width:@($"{Math.Max(0, currentRect.Left - Padding)}px"); height:@($"{currentRect.Height + Padding * 2}px")"></div>
        <div class="absolute pointer-events-auto bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{Math.Max(0, currentRect.Top - Padding)}px"); left:@($"{currentRect.Right + Padding}px"); right:0; height:@($"{currentRect.Height + Padding * 2}px")"></div>
        <div class="absolute pointer-events-auto left-0 right-0 bottom-0 bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{currentRect.Bottom + Padding}px")"></div>

        <div class="absolute z-[340] pointer-events-none rounded-2xl border-4 border-blue-400 shadow-[0_0_0_6px_rgba(59,130,246,0.24),0_24px_60px_rgba(15,23,42,0.35)]"
             style="left:@($"{currentRect.Left - Padding}px"); top:@($"{currentRect.Top - Padding}px"); width:@($"{currentRect.Width + Padding * 2}px"); height:@($"{currentRect.Height + Padding * 2}px")">
        </div>

        <div @key="panelRenderKey"
             class="absolute z-[370] pointer-events-auto w-[min(420px,calc(100vw-32px))] overflow-y-auto bg-white rounded-2xl shadow-2xl border border-blue-100 p-5"
             style="left:@($"{panelLeft}px"); top:@($"{panelTop}px"); max-height:@($"{panelMaxHeight}px")">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <p class="text-xs font-bold uppercase tracking-wider text-blue-700">Bước @(CurrentStepIndex + 1)/@total</p>
                    <h3 class="text-xl font-bold text-gray-900 leading-tight">@step.Title</h3>
                </div>
                @if (AllowSkip)
                {
                    <button type="button"
                            class="shrink-0 p-2 rounded-full text-gray-500 hover:bg-slate-100 hover:text-gray-900 transition-colors"
                            title="Đóng hướng dẫn"
                            aria-label="Đóng hướng dẫn"
                            @onclick="SkipAsync">
                        <span class="material-symbols-outlined text-[22px]">close</span>
                    </button>
                }
            </div>

            <p class="text-sm text-gray-600 leading-6 mb-4">@step.Description</p>

            @if (!string.IsNullOrWhiteSpace(step.ActionHint))
            {
                <div class="flex items-start gap-3 rounded-xl bg-blue-50 border border-blue-100 p-3 mb-4">
                    <span class="material-symbols-outlined text-blue-700">touch_app</span>
                    <p class="text-sm font-medium text-blue-900 leading-6">@step.ActionHint</p>
                </div>
            }

            <div class="rounded-xl bg-slate-50 border border-slate-200 p-3 mb-4">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined text-blue-700 text-[20px]">checklist</span>
                    <p class="text-sm font-bold text-slate-800">Cách thực hiện</p>
                </div>
                <ol class="list-decimal pl-5 space-y-1 text-sm text-slate-600 leading-6">
                    <li>Quan sát vùng có viền xanh, đó là nơi cần thao tác ở bước này.</li>
                    <li>@GetInteractionInstruction(step)</li>
                    <li>Nếu đã hiểu bước này, dùng nút bên dưới để chuyển bước hoặc hoàn tất hướng dẫn.</li>
                </ol>
            </div>

            <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-4">
                <div class="h-full bg-blue-700 rounded-full transition-all" style="width:@($"{(CurrentStepIndex + 1) * 100 / total}%")"></div>
            </div>

            <div class="flex items-center justify-between gap-3">
                <button type="button"
                        class="px-4 py-2 rounded-xl border border-slate-200 text-gray-600 font-bold disabled:opacity-40 disabled:cursor-not-allowed"
                        disabled="@(CurrentStepIndex == 0)"
                        @onclick="PreviousAsync">
                    Quay lại
                </button>

                <div class="flex items-center justify-end gap-2">
                    @if (!string.IsNullOrWhiteSpace(step.ActionUrl))
                    {
                        <button type="button" class="px-5 py-2.5 rounded-xl bg-blue-700 text-white font-bold hover:bg-blue-800 transition-colors" @onclick="CompleteAndNavigateAsync">
                            @(string.IsNullOrWhiteSpace(step.ActionLabel) ? "Đi tiếp" : step.ActionLabel)
                        </button>
                    }
                    else if (step.AdvanceOnTargetClick)
                    {
                        <button type="button" class="px-5 py-2.5 rounded-xl bg-blue-700 text-white font-bold hover:bg-blue-800 transition-colors" @onclick="NextAsync">
                            Tiếp tục
                        </button>
                    }
                    else
                    {
                        <button type="button" class="px-5 py-2.5 rounded-xl bg-blue-700 text-white font-bold hover:bg-blue-800 transition-colors" @onclick="NextAsync">
                            @(CurrentStepIndex == total - 1 ? "Hoàn tất" : "Tiếp tục")
                        </button>
                    }
                </div>
            </div>
        </div>

        @if (AllowSkip)
        {
            <button type="button"
                    class="fixed bottom-6 right-6 z-[390] pointer-events-auto flex items-center gap-2 px-5 py-3 rounded-full bg-white text-gray-700 font-bold shadow-2xl border border-slate-200 hover:bg-slate-50 hover:text-blue-700 transition-colors"
                    @onclick="SkipAsync">
                <span class="material-symbols-outlined text-[20px]">skip_next</span>
                <span>Bỏ qua</span>
            </button>
        }
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public IReadOnlyList<GuidedStep> Steps { get; set; } = Array.Empty<GuidedStep>();
    [Parameter] public string StorageKey { get; set; } = string.Empty;
    [Parameter] public bool AllowSkip { get; set; } = true;
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter] public EventCallback OnSkipped { get; set; }

    private const int Padding = 8;
    private const int PanelGap = 16;
    private const int EstimatedPanelHeight = 620;
    private const int MinPanelHeight = 260;
    private ElementRect? currentRect;
    private double viewportWidth = 1280;
    private double viewportHeight = 720;
    private DotNetObjectReference<GuidedOnboarding>? dotNetRef;
    private int CurrentStepIndex;
    private int lastFocusedStepIndex = -1;
    private int panelRenderKey;
    private bool wasVisible;

    protected override void OnParametersSet()
    {
        if (IsVisible && !wasVisible)
        {
            CurrentStepIndex = 0;
            currentRect = null;
            lastFocusedStepIndex = -1;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible || Steps.Count == 0)
        {
            if (wasVisible)
            {
                await ClearFocusAsync();
                currentRect = null;
                lastFocusedStepIndex = -1;
            }
            wasVisible = false;
            return;
        }

        wasVisible = true;
        dotNetRef ??= DotNetObjectReference.Create(this);
        if (currentRect == null || lastFocusedStepIndex != CurrentStepIndex)
        {
            await PositionCurrentStepAsync();
        }
    }

    private async Task PositionCurrentStepAsync()
    {
        var step = Steps[Math.Clamp(CurrentStepIndex, 0, Steps.Count - 1)];
        try
        {
            var rect = await JS.InvokeAsync<ElementRect?>("sotroGuidedOnboarding.focus", step.TargetSelector, dotNetRef, step.AdvanceOnTargetClick);
            if (rect != null)
            {
                currentRect = rect;
                lastFocusedStepIndex = CurrentStepIndex;
                viewportWidth = rect.ViewportWidth;
                viewportHeight = rect.ViewportHeight;
                panelRenderKey++;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Guided onboarding focus error: {ex.Message}");
        }
    }

    private async Task PreviousAsync()
    {
        if (CurrentStepIndex == 0) return;
        CurrentStepIndex--;
        currentRect = null;
        await PositionCurrentStepAsync();
    }

    private async Task NextAsync()
    {
        if (CurrentStepIndex >= Steps.Count - 1)
        {
            await CompleteAsync();
            return;
        }

        CurrentStepIndex++;
        currentRect = null;
        await PositionCurrentStepAsync();
    }

    private async Task CompleteAsync()
    {
        await ClearFocusAsync();
        if (!string.IsNullOrWhiteSpace(StorageKey))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "true");
        }
        if (OnCompleted.HasDelegate)
        {
            await OnCompleted.InvokeAsync();
        }
    }

    private async Task CompleteAndNavigateAsync()
    {
        var step = Steps[Math.Clamp(CurrentStepIndex, 0, Steps.Count - 1)];
        await CompleteAsync();
        if (!string.IsNullOrWhiteSpace(step.ActionUrl))
        {
            Navigation.NavigateTo(step.ActionUrl);
        }
    }

    private async Task SkipAsync()
    {
        await ClearFocusAsync();
        CurrentStepIndex = 0;
        currentRect = null;
        lastFocusedStepIndex = -1;
        if (!string.IsNullOrWhiteSpace(StorageKey))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "true");
        }
        if (OnSkipped.HasDelegate)
        {
            await OnSkipped.InvokeAsync();
        }
    }

    [JSInvokable]
    public async Task NotifyTargetClicked()
    {
        await NextAsync();
    }

    [JSInvokable]
    public async Task NotifyTargetPositionChanged(ElementRect rect)
    {
        currentRect = rect;
        viewportWidth = rect.ViewportWidth;
        viewportHeight = rect.ViewportHeight;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ClearFocusAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sotroGuidedOnboarding.clear");
        }
        catch
        {
        }
    }

    private static string GetInteractionInstruction(GuidedStep step)
    {
        if (!string.IsNullOrWhiteSpace(step.ActionUrl))
        {
            return string.IsNullOrWhiteSpace(step.ActionLabel)
                ? "Bấm nút Đi tiếp trong hộp hướng dẫn để chuyển sang màn hình liên quan."
                : $"Bấm nút {step.ActionLabel} trong hộp hướng dẫn để chuyển sang màn hình liên quan.";
        }

        return step.AdvanceOnTargetClick
            ? "Click trực tiếp vào vùng đang sáng. Hướng dẫn sẽ tự chuyển sang bước kế tiếp sau khi thao tác."
            : "Click hoặc nhập dữ liệu trực tiếp trong vùng đang sáng, rồi bấm Tiếp tục khi đã xong.";
    }

    private double GetPanelLeft(ElementRect rect, double panelWidth)
    {
        var minLeft = 16d;
        var maxLeft = Math.Max(minLeft, viewportWidth - panelWidth - 16);
        var leftSpace = rect.Left - PanelGap - minLeft;
        var rightSpace = viewportWidth - rect.Right - PanelGap - 16;

        if (rightSpace >= panelWidth)
        {
            return Clamp(rect.Right + PanelGap, minLeft, maxLeft);
        }

        if (leftSpace >= panelWidth)
        {
            return Clamp(rect.Left - panelWidth - PanelGap, minLeft, maxLeft);
        }

        var targetCenter = rect.Left + rect.Width / 2;
        var preferredLeft = targetCenter < viewportWidth / 2
            ? rect.Right + PanelGap
            : rect.Left - panelWidth - PanelGap;

        if (rect.Width + Padding * 2 > viewportWidth - panelWidth - PanelGap * 2)
        {
            preferredLeft = targetCenter - panelWidth / 2;
        }

        return Clamp(preferredLeft, minLeft, maxLeft);
    }

    private double GetPanelTop(ElementRect rect, double panelLeft, double panelWidth)
    {
        var panelRight = panelLeft + panelWidth;
        var targetLeft = rect.Left - Padding;
        var targetRight = rect.Right + Padding;
        var horizontalOverlap = panelLeft < targetRight && panelRight > targetLeft;
        var clampedTop = Math.Min(Math.Max(rect.Top - 96, 16), Math.Max(16, viewportHeight - EstimatedPanelHeight - 24));

        if (!horizontalOverlap)
        {
            return clampedTop;
        }

        var belowTop = rect.Bottom + PanelGap;
        var belowSpace = viewportHeight - belowTop - 16;
        if (belowSpace >= MinPanelHeight)
        {
            return belowTop;
        }

        var aboveSpace = rect.Top - PanelGap - 16;
        if (aboveSpace >= MinPanelHeight)
        {
            return Math.Max(16, rect.Top - PanelGap - Math.Min(EstimatedPanelHeight, aboveSpace));
        }

        return belowSpace >= aboveSpace
            ? belowTop
            : 16;
    }

    private double GetPanelMaxHeight(ElementRect rect, double panelTop, double panelLeft, double panelWidth)
    {
        var panelRight = panelLeft + panelWidth;
        var targetLeft = rect.Left - Padding;
        var targetRight = rect.Right + Padding;
        var horizontalOverlap = panelLeft < targetRight && panelRight > targetLeft;

        if (!horizontalOverlap)
        {
            return Math.Max(MinPanelHeight, viewportHeight - panelTop - 16);
        }

        if (panelTop >= rect.Bottom)
        {
            return Math.Max(MinPanelHeight, viewportHeight - panelTop - 16);
        }

        if (panelTop < rect.Top)
        {
            return Math.Max(MinPanelHeight, rect.Top - PanelGap - panelTop);
        }

        return Math.Max(MinPanelHeight, viewportHeight - panelTop - 16);
    }

    private static double Clamp(double value, double min, double max)
    {
        return Math.Min(Math.Max(value, min), max);
    }

    public async ValueTask DisposeAsync()
    {
        await ClearFocusAsync();
        dotNetRef?.Dispose();
    }

    public sealed record GuidedStep(
        string TargetSelector,
        string Title,
        string Description,
        string ActionHint,
        bool AdvanceOnTargetClick = false,
        string? ActionLabel = null,
        string? ActionUrl = null);

    public sealed class ElementRect
    {
        public double Top { get; set; }
        public double Left { get; set; }
        public double Right { get; set; }
        public double Bottom { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
        public double ViewportWidth { get; set; }
        public double ViewportHeight { get; set; }
    }
}
