@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IAsyncDisposable

@if (IsVisible && currentRect != null && Steps.Count > 0)
{
    var step = Steps[CurrentStepIndex];
    var total = Steps.Count;
    var panelTop = Math.Min(Math.Max(currentRect.Top + currentRect.Height + 16, 96), Math.Max(96, viewportHeight - 320));
    var panelLeft = currentRect.Left + currentRect.Width / 2 < viewportWidth / 2
        ? Math.Min(currentRect.Right + 20, Math.Max(16, viewportWidth - 430))
        : Math.Max(16, currentRect.Left - 420);

    <div class="fixed inset-0 z-[310]" role="dialog" aria-modal="true" aria-label="@step.Title">
        <div class="absolute left-0 top-0 right-0 bg-slate-950/60 backdrop-blur-[1px]" style="height:@($"{Math.Max(0, currentRect.Top - Padding)}px")"></div>
        <div class="absolute left-0 bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{Math.Max(0, currentRect.Top - Padding)}px"); width:@($"{Math.Max(0, currentRect.Left - Padding)}px"); height:@($"{currentRect.Height + Padding * 2}px")"></div>
        <div class="absolute bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{Math.Max(0, currentRect.Top - Padding)}px"); left:@($"{currentRect.Right + Padding}px"); right:0; height:@($"{currentRect.Height + Padding * 2}px")"></div>
        <div class="absolute left-0 right-0 bottom-0 bg-slate-950/60 backdrop-blur-[1px]" style="top:@($"{currentRect.Bottom + Padding}px")"></div>

        <div class="absolute z-[340] pointer-events-none rounded-2xl border-4 border-blue-400 shadow-[0_0_0_6px_rgba(59,130,246,0.24),0_24px_60px_rgba(15,23,42,0.35)]"
             style="left:@($"{currentRect.Left - Padding}px"); top:@($"{currentRect.Top - Padding}px"); width:@($"{currentRect.Width + Padding * 2}px"); height:@($"{currentRect.Height + Padding * 2}px")">
        </div>

        <div class="absolute z-[370] w-[min(400px,calc(100vw-32px))] bg-white rounded-2xl shadow-2xl border border-blue-100 p-5"
             style="left:@($"{panelLeft}px"); top:@($"{panelTop}px")">
            <div class="flex items-start justify-between gap-4 mb-4">
                <div>
                    <p class="text-xs font-bold uppercase tracking-wider text-blue-700">Bước @(CurrentStepIndex + 1)/@total</p>
                    <h3 class="text-xl font-bold text-gray-900 leading-tight">@step.Title</h3>
                </div>
                @if (AllowSkip)
                {
                    <button type="button" class="flex items-center gap-1 px-3 py-2 rounded-full text-sm font-bold text-gray-500 hover:bg-slate-100 transition-colors" @onclick="SkipAsync">
                        <span>Bỏ qua</span>
                        <span class="material-symbols-outlined text-gray-600">close</span>
                    </button>
                }
            </div>

            <p class="text-sm text-gray-600 leading-6 mb-4">@step.Description</p>

            @if (!string.IsNullOrWhiteSpace(step.ActionHint))
            {
                <div class="flex items-start gap-3 rounded-xl bg-blue-50 border border-blue-100 p-3 mb-4">
                    <span class="material-symbols-outlined text-blue-700">touch_app</span>
                    <p class="text-sm font-medium text-blue-900 leading-6">@step.ActionHint</p>
                </div>
            }

            <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-4">
                <div class="h-full bg-blue-700 rounded-full transition-all" style="width:@($"{(CurrentStepIndex + 1) * 100 / total}%")"></div>
            </div>

            <div class="flex items-center justify-between gap-3">
                <button type="button"
                        class="px-4 py-2 rounded-xl border border-slate-200 text-gray-600 font-bold disabled:opacity-40 disabled:cursor-not-allowed"
                        disabled="@(CurrentStepIndex == 0)"
                        @onclick="PreviousAsync">
                    Quay lại
                </button>

                @if (!string.IsNullOrWhiteSpace(step.ActionUrl))
                {
                    <button type="button" class="px-5 py-2.5 rounded-xl bg-blue-700 text-white font-bold hover:bg-blue-800 transition-colors" @onclick="CompleteAndNavigateAsync">
                        @(string.IsNullOrWhiteSpace(step.ActionLabel) ? "Đi tiếp" : step.ActionLabel)
                    </button>
                }
                else if (step.AdvanceOnTargetClick)
                {
                    <span class="text-xs text-gray-500 font-medium">Hãy click vùng đang sáng</span>
                }
                else
                {
                    <button type="button" class="px-5 py-2.5 rounded-xl bg-blue-700 text-white font-bold hover:bg-blue-800 transition-colors" @onclick="NextAsync">
                        @(CurrentStepIndex == total - 1 ? "Hoàn tất" : "Tiếp tục")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public IReadOnlyList<GuidedStep> Steps { get; set; } = Array.Empty<GuidedStep>();
    [Parameter] public string StorageKey { get; set; } = string.Empty;
    [Parameter] public bool AllowSkip { get; set; } = true;
    [Parameter] public EventCallback OnCompleted { get; set; }
    [Parameter] public EventCallback OnSkipped { get; set; }

    private const int Padding = 8;
    private ElementRect? currentRect;
    private double viewportWidth = 1280;
    private double viewportHeight = 720;
    private DotNetObjectReference<GuidedOnboarding>? dotNetRef;
    private int CurrentStepIndex;
    private int lastFocusedStepIndex = -1;
    private bool wasVisible;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible || Steps.Count == 0)
        {
            if (wasVisible)
            {
                await ClearFocusAsync();
                currentRect = null;
                lastFocusedStepIndex = -1;
            }
            wasVisible = false;
            return;
        }

        wasVisible = true;
        dotNetRef ??= DotNetObjectReference.Create(this);
        if (currentRect == null || lastFocusedStepIndex != CurrentStepIndex)
        {
            await PositionCurrentStepAsync();
        }
    }

    private async Task PositionCurrentStepAsync()
    {
        var step = Steps[Math.Clamp(CurrentStepIndex, 0, Steps.Count - 1)];
        try
        {
            var rect = await JS.InvokeAsync<ElementRect?>("sotroGuidedOnboarding.focus", step.TargetSelector, dotNetRef, step.AdvanceOnTargetClick);
            if (rect != null)
            {
                currentRect = rect;
                lastFocusedStepIndex = CurrentStepIndex;
                viewportWidth = rect.ViewportWidth;
                viewportHeight = rect.ViewportHeight;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Guided onboarding focus error: {ex.Message}");
        }
    }

    private async Task PreviousAsync()
    {
        if (CurrentStepIndex == 0) return;
        CurrentStepIndex--;
        currentRect = null;
        await PositionCurrentStepAsync();
    }

    private async Task NextAsync()
    {
        if (CurrentStepIndex >= Steps.Count - 1)
        {
            await CompleteAsync();
            return;
        }

        CurrentStepIndex++;
        currentRect = null;
        await PositionCurrentStepAsync();
    }

    private async Task CompleteAsync()
    {
        await ClearFocusAsync();
        if (!string.IsNullOrWhiteSpace(StorageKey))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "true");
        }
        if (OnCompleted.HasDelegate)
        {
            await OnCompleted.InvokeAsync();
        }
    }

    private async Task CompleteAndNavigateAsync()
    {
        var step = Steps[Math.Clamp(CurrentStepIndex, 0, Steps.Count - 1)];
        await CompleteAsync();
        if (!string.IsNullOrWhiteSpace(step.ActionUrl))
        {
            Navigation.NavigateTo(step.ActionUrl);
        }
    }

    private async Task SkipAsync()
    {
        await ClearFocusAsync();
        if (!string.IsNullOrWhiteSpace(StorageKey))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, "true");
        }
        if (OnSkipped.HasDelegate)
        {
            await OnSkipped.InvokeAsync();
        }
    }

    [JSInvokable]
    public async Task NotifyTargetClicked()
    {
        await NextAsync();
    }

    private async Task ClearFocusAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sotroGuidedOnboarding.clear");
        }
        catch
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        await ClearFocusAsync();
        dotNetRef?.Dispose();
    }

    public sealed record GuidedStep(
        string TargetSelector,
        string Title,
        string Description,
        string ActionHint,
        bool AdvanceOnTargetClick = false,
        string? ActionLabel = null,
        string? ActionUrl = null);

    private sealed class ElementRect
    {
        public double Top { get; set; }
        public double Left { get; set; }
        public double Right { get; set; }
        public double Bottom { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
        public double ViewportWidth { get; set; }
        public double ViewportHeight { get; set; }
    }
}
