@page "/xac-minh-email"
@layout EmptyLayout

<PageTitle>Xác minh Email - Sổ trọ</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        body {
            background-color: #f8f9fa;
        }
        .verification-card {
            box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.05);
        }
    

    </style>
}


<!-- TopNavBar -->
<header class="bg-surface-container-lowest dark:bg-surface-container-lowest border-b border-outline-variant dark:border-outline-variant w-full top-0 sticky z-50">
<div class="flex justify-between items-center px-margin-desktop h-16 max-w-container-max-width mx-auto">
<div class="flex items-center gap-3">
<img alt="Logo Sổ trọ" class="w-8 h-8 object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCrTuGgO59RgNbmnmN-8Tx79guQ-CuJhGOK5McAwqa5cvSW0rg2oXxHxI6GyqUC1zzkch2qtcd8DooPxBJiKA0aKLeDp_CIv5n8eAAu3YI8qqZArbq9SPFwT8U57gtAWyKfHoqbes1P1c6qEq1O8d3MuMkrw9ef-ptJHzpBRMW2-29p6lC3odDRZeVNu_wkb1NuZQ5A8vCTFRQ8XD7FZ4TTB-uK9NcXz9tOZWSLzrWlIwp2OjhlpRi-W891mdf_CFemSXNjWjP9_c4r">
<span class="text-headline-sm font-headline-sm text-primary dark:text-primary-fixed">Sổ trọ</span>
</div>
<nav class="hidden md:flex gap-8">
<a class="text-on-secondary-container dark:text-on-secondary-container font-label-md text-label-md hover:text-primary dark:hover:text-primary-fixed transition-colors cursor-pointer transition-all duration-200" href="#">Trang chủ</a>
<a class="text-on-secondary-container dark:text-on-secondary-container font-label-md text-label-md hover:text-primary dark:hover:text-primary-fixed transition-colors cursor-pointer transition-all duration-200" href="#">Tính năng</a>
<a class="text-on-secondary-container dark:text-on-secondary-container font-label-md text-label-md hover:text-primary dark:hover:text-primary-fixed transition-colors cursor-pointer transition-all duration-200" href="#">Bảng giá</a>
<a class="text-on-secondary-container dark:text-on-secondary-container font-label-md text-label-md hover:text-primary dark:hover:text-primary-fixed transition-colors cursor-pointer transition-all duration-200" href="#">Liên hệ</a>
</nav>
<button class="bg-primary-container text-on-primary font-label-md text-label-md px-6 py-2 rounded-xl cursor-pointer transition-all duration-200 hover:opacity-90">
                Đăng nhập
            </button>
</div>
</header>
<!-- Main Content Canvas -->
<main class="flex-grow flex items-center justify-center px-margin-mobile py-12 md:py-20">
<div class="max-w-md w-full">
<!-- Glassmorphism-style subtle gradient background for the container -->
<div class="verification-card bg-surface-container-lowest rounded-xl p-8 md:p-12 text-center border border-outline-variant">
<!-- Email Icon Illustration -->
<div class="relative inline-block mb-8">
<div class="w-24 h-24 rounded-full bg-primary/5 flex items-center justify-center animate-pulse">
<span class="material-symbols-outlined text-primary text-[48px]" style="font-variation-settings: 'FILL' 1;">mark_email_unread</span>
</div>
<div class="absolute -bottom-1 -right-1 bg-primary text-on-primary w-8 h-8 rounded-full flex items-center justify-center shadow-lg">
<span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'wght' 700;">check</span>
</div>
</div>
<!-- Text Content -->
<h1 class="font-headline-md text-headline-md text-primary mb-4">Kiểm tra email của bạn</h1>
<p class="font-body-md text-body-md text-on-secondary-container mb-8 leading-relaxed">
                    Chúng tôi vừa gửi mã xác minh gồm 6 chữ số đến địa chỉ email <span class="font-semibold text-on-surface">user@@example.com</span>. Vui lòng nhập mã để hoàn tất đăng ký.
                </p>
<!-- Actions -->
<div class="flex flex-col gap-4">
<a class="bg-primary-container text-on-primary py-4 px-6 rounded-xl font-label-md text-label-md hover:opacity-95 transition-all flex items-center justify-center gap-2 shadow-md" href="mailto:">
<span class="material-symbols-outlined">open_in_new</span>
                        Mở ứng dụng Email
                    </a>
<button class="text-primary font-label-md text-label-md py-4 px-6 rounded-xl border border-primary/20 hover:bg-primary/5 transition-all" id="resendBtn">
                        Gửi lại mã xác minh <span class="ml-1 text-on-secondary-container" id="timer">(59s)</span>
</button>
</div>
<!-- Secondary Instructions -->
<div class="mt-10 pt-8 border-t border-outline-variant">
<p class="font-caption text-caption text-on-secondary-container mb-2">
                        Không nhận được email?
                    </p>
<ul class="text-left inline-block font-caption text-caption text-on-secondary-container space-y-1">
<li class="flex items-center gap-2">
<span class="w-1.5 h-1.5 rounded-full bg-outline-variant"></span>
                            Kiểm tra thư mục Spam hoặc Junk.
                        </li>
<li class="flex items-center gap-2">
<span class="w-1.5 h-1.5 rounded-full bg-outline-variant"></span>
                            Đảm bảo email nhập vào là chính xác.
                        </li>
</ul>
</div>
</div>
<!-- Back Link -->
<div class="mt-8 text-center">
<a class="text-on-secondary-container font-label-md text-label-md flex items-center justify-center gap-1 hover:text-primary transition-colors" href="#">
<span class="material-symbols-outlined text-[18px]">arrow_back</span>
                    Quay lại trang đăng ký
                </a>
</div>
</div>
</main>
<!-- Footer -->
<footer class="bg-surface-container-low dark:bg-surface-container-low border-t border-outline-variant dark:border-outline-variant w-full bottom-0">
<div class="flex flex-col md:flex-row justify-between items-center px-margin-desktop py-base max-w-container-max-width mx-auto">
<div class="flex items-center gap-4 mb-4 md:mb-0">
<span class="font-headline-sm text-headline-sm text-primary dark:text-primary-fixed">Sổ trọ</span>
<span class="font-caption text-caption text-on-secondary-container">© 2024 Sổ trọ. Tất cả quyền được bảo lưu.</span>
</div>
<div class="flex gap-6">
<a class="font-caption text-caption text-on-secondary-container hover:underline transition-opacity hover:opacity-80" href="#">Điều khoản</a>
<a class="font-caption text-caption text-on-secondary-container hover:underline transition-opacity hover:opacity-80" href="#">Bảo mật</a>
<a class="font-caption text-caption text-on-secondary-container hover:underline transition-opacity hover:opacity-80" href="#">Trợ giúp</a>
</div>
</div>
</footer>
<script>
        // Simple countdown timer for the resend button
        let timeLeft = 59;
        const timerElement = document.getElementById('timer');
        const resendBtn = document.getElementById('resendBtn');

        const countdown = setInterval(() => {
            if (timeLeft <= 0) {
                clearInterval(countdown);
                timerElement.innerText = '';
                resendBtn.disabled = false;
            } else {
                timerElement.innerText = `(${timeLeft}s)`;
                timeLeft--;
            }
        }, 1000);

        resendBtn.addEventListener('click', () => {
            if (timeLeft <= 0) {
                // Reset timer logic for demo purposes
                timeLeft = 59;
                timerElement.innerText = `(${timeLeft}s)`;
                // Logic to call API would go here
                alert('Mã xác minh mới đã được gửi!');
                // Restart timer logic omitted for brevity
            }
        });
    </script>


@code {
    private const string CustomStyles = "XacMinhEmail";
}