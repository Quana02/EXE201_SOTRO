@page "/dang-nhap"
@using SOTRO_Project.Components.Layout
@inject NavigationManager Navigation
@inject IAuthApiService AuthApi
@inject IJSRuntime JS
@inject IConfiguration Configuration
@implements IDisposable

<PageTitle>Đăng nhập - Sổ trọ</PageTitle>

<HeaderLanding />

@if (ShowError)
{
    <div class="fixed inset-0 z-[999] flex items-center justify-center bg-black/30">
        <div class="bg-white rounded-xl shadow-2xl border border-red-200 p-8 w-[360px] text-center">
            <div class="text-5xl mb-4">!</div>
            <h2 class="text-xl font-bold text-red-600 mb-2">Đăng nhập thất bại</h2>
            <p class="text-gray-600 mb-6">@ErrorMessage</p>
            <button @onclick="CloseError"
                    class="px-6 py-3 bg-red-600 text-white rounded-lg font-semibold hover:bg-red-700">
                Đóng
            </button>
        </div>
    </div>
}

<main class="pt-24 flex-grow flex items-center justify-center py-12 px-4">
    <div class="w-full max-w-md">
        <div class="bg-white rounded-xl shadow border border-gray-200 p-8 md:p-10">
            <div class="text-center mb-8">
                <img alt="Sổ trọ Logo"
                     class="h-16 w-16 mx-auto mb-4 object-contain"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuCrTuGgO59RgNbmnmN-8Tx79guQ-CuJhGOK5McAwqa5cvSW0rg2oXxHxI6GyqUC1zzkch2qtcd8DooPxBJiKA0aKLeDp_CIv5n8eAAu3YI8qqZArbq9SPFwT8U57gtAWyKfHoqbes1P1c6qEq1O8d3MuMkrw9ef-ptJHzpBRMW2-29p6lC3odDRZeVNu_wkb1NuZQ5A8vCTFRQ8XD7FZ4TTB-uK9NcXz9tOZWSLzrWlIwp2OjhlpRi-W891mdf_CFemSXNjWjP9_c4r" />

                <h1 class="text-3xl font-bold text-blue-700 mb-2">Chào mừng trở lại</h1>
                <p class="text-gray-600">Quản lý nhà trọ chuyên nghiệp & hiệu quả</p>
            </div>

            <form class="space-y-6" @onsubmit="Login" @onsubmit:preventDefault>
                <div class="space-y-1.5">
                    <label class="text-sm font-semibold text-gray-600 block">Email</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">person</span>
                        <input @bind="LoginModel.Email"
                               class="w-full pl-10 pr-4 py-3 bg-white rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-1 focus:ring-blue-700 outline-none"
                               placeholder="name@example.com"
                               type="email" />
                    </div>
                    @ShowFieldError(nameof(LoginModel.Email))
                </div>

                <div class="space-y-1.5">
                    <div class="flex justify-between items-center">
                        <label class="text-sm font-semibold text-gray-600 block">Mật khẩu</label>
                        <a class="text-sm text-blue-700 hover:underline" href="/quen-mat-khau">Quên mật khẩu?</a>
                    </div>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">lock</span>
                        <input @bind="LoginModel.Password"
                               class="w-full pl-10 pr-4 py-3 bg-white rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-1 focus:ring-blue-700 outline-none"
                               placeholder="••••••••"
                               type="password" />
                    </div>
                    @ShowFieldError(nameof(LoginModel.Password))
                </div>

                <button disabled="@IsLoading"
                        type="submit"
                        class="w-full py-4 bg-blue-700 text-white rounded-xl text-lg font-bold hover:bg-blue-800 shadow-md transition-all active:scale-[0.98] flex items-center justify-center gap-2 disabled:opacity-60">
                    @(IsLoading ? "Đang đăng nhập..." : "Đăng nhập")
                    <span class="material-symbols-outlined">login</span>
                </button>
            </form>

            <div class="relative my-8">
                <div class="absolute inset-0 flex items-center">
                    <span class="w-full border-t border-gray-200"></span>
                </div>
                <div class="relative flex justify-center text-xs bg-white px-4 uppercase tracking-widest text-gray-400">
                    Hoặc đăng nhập bằng
                </div>
            </div>

            <button @onclick="LoginWithGoogle"
                    disabled="@IsGoogleLoading"
                    type="button"
                    class="w-full flex items-center justify-center gap-3 py-3 border border-gray-300 rounded-xl hover:bg-gray-50 disabled:opacity-60">
                <span class="font-bold text-red-500">G</span>
                @(IsGoogleLoading ? "Đang đăng nhập Google..." : "Google")
            </button>

            <div class="mt-8 text-center">
                <p class="text-gray-600">
                    Chưa có tài khoản?
                    <a class="text-blue-700 font-bold hover:underline" href="/dang-ky">Đăng ký ngay</a>
                </p>
            </div>
        </div>
    </div>
</main>

<FooterLanding />

<div class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none overflow-hidden opacity-30">
    <div class="absolute -top-[10%] -right-[10%] w-[50%] h-[50%] bg-blue-100 blur-[120px] rounded-full"></div>
    <div class="absolute -bottom-[10%] -left-[10%] w-[40%] h-[40%] bg-gray-200 blur-[100px] rounded-full"></div>
</div>

@code {
    private LoginRequest LoginModel { get; set; } = new();
    private bool ShowError { get; set; }
    private bool IsLoading { get; set; }
    private bool IsGoogleLoading { get; set; }
    private string ErrorMessage { get; set; } = "Sai email hoặc mật khẩu";
    private Dictionary<string, string> Errors { get; set; } = new();
    private DotNetObjectReference<DangNhap>? GoogleCallbackRef { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        GoogleCallbackRef = DotNetObjectReference.Create(this);
        await InitializeGoogleAsync();
    }

    private async Task Login()
    {
        if (!ValidateLogin())
        {
            ShowError = false;
            return;
        }

        IsLoading = true;
        ShowError = false;
        LoginModel.Email = LoginModel.Email.Trim();

        var response = await AuthApi.LoginAsync(LoginModel);
        if (response.Success && response.Data != null)
        {
            await SaveAuthData(response.Data);

            if (response.Data.RequiresProfileCompletion)
            {
                Navigation.NavigateTo($"/complete-profile?email={Uri.EscapeDataString(response.Data.Email)}");
                return;
            }

            Navigation.NavigateTo("/nha-tro");
        }
        else
        {
            ErrorMessage = string.IsNullOrWhiteSpace(response.Message) ? "Sai email hoặc mật khẩu" : response.Message;
            ShowError = true;
        }

        IsLoading = false;
    }

    private async Task LoginWithGoogle()
    {
        var clientId = Configuration["Authentication:Google:ClientId"];
        if (string.IsNullOrWhiteSpace(clientId) || clientId == "YOUR_GOOGLE_CLIENT_ID")
        {
            ErrorMessage = "Chưa cấu hình Google ClientId trong appsettings.json.";
            ShowError = true;
            return;
        }

        var initialized = await InitializeGoogleAsync();
        if (!initialized)
        {
            ErrorMessage = "Không thể khởi tạo Google Login. Vui lòng tải lại trang và thử lại.";
            ShowError = true;
            return;
        }

        var prompted = await JS.InvokeAsync<bool>("sotroGoogleAuth.prompt");
        if (!prompted)
        {
            ErrorMessage = "Không thể mở đăng nhập Google. Vui lòng tải lại trang và thử lại.";
            ShowError = true;
        }
    }

    [JSInvokable]
    public async Task HandleGoogleCredential(string credential)
    {
        try
        {
            IsGoogleLoading = true;
            ShowError = false;

            var profile = DecodeGoogleCredential(credential);
            if (profile == null)
            {
                ErrorMessage = "Không đọc được thông tin tài khoản Google.";
                ShowError = true;
                return;
            }

            var response = await AuthApi.GoogleLoginAsync(new GoogleLoginRequest
            {
                Email = profile.Email,
                FullName = profile.FullName,
                GoogleId = profile.GoogleId,
                AvatarUrl = profile.AvatarUrl
            });

            if (response.Success && response.Data != null)
            {
                await SaveAuthData(response.Data);

                if (response.Data.RequiresProfileCompletion)
                {
                    Navigation.NavigateTo($"/complete-profile?email={Uri.EscapeDataString(response.Data.Email)}");
                    return;
                }

                Navigation.NavigateTo("/nha-tro");
            }
            else
            {
                ErrorMessage = string.IsNullOrWhiteSpace(response.Message) ? "Đăng nhập Google thất bại." : response.Message;
                ShowError = true;
            }
        }
        finally
        {
            IsGoogleLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<bool> InitializeGoogleAsync()
    {
        if (GoogleCallbackRef == null)
        {
            return false;
        }

        var clientId = Configuration["Authentication:Google:ClientId"] ?? string.Empty;
        return await JS.InvokeAsync<bool>("sotroGoogleAuth.init", clientId, GoogleCallbackRef);
    }

    private async Task SaveAuthData(AuthResponse authResponse)
    {
        var email = authResponse.User?.Email ?? authResponse.Email;
        var fullName = authResponse.User?.FullName ?? authResponse.FullName ?? string.Empty;
        var phoneNumber = authResponse.User?.PhoneNumber ?? authResponse.PhoneNumber ?? string.Empty;

        await JS.InvokeVoidAsync("localStorage.setItem", "sotro_token", authResponse.Token);
        await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_email", email);
        await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_name", fullName);
        await JS.InvokeVoidAsync("localStorage.setItem", "sotro_phone_number", phoneNumber);
    }

    private bool ValidateLogin()
    {
        Errors = new Dictionary<string, string>();

        if (string.IsNullOrWhiteSpace(LoginModel.Email))
        {
            Errors[nameof(LoginModel.Email)] = "Email không được để trống.";
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(LoginModel.Email.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            Errors[nameof(LoginModel.Email)] = "Email không đúng định dạng.";
        }

        if (string.IsNullOrWhiteSpace(LoginModel.Password))
        {
            Errors[nameof(LoginModel.Password)] = "Mật khẩu không được để trống.";
        }

        return Errors.Count == 0;
    }

    private void CloseError()
    {
        ShowError = false;
    }

    private static GoogleProfile? DecodeGoogleCredential(string credential)
    {
        var parts = credential.Split('.');
        if (parts.Length < 2)
        {
            return null;
        }

        var payload = parts[1].Replace('-', '+').Replace('_', '/');
        payload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');
        var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
        using var document = System.Text.Json.JsonDocument.Parse(json);
        var root = document.RootElement;

        var email = root.TryGetProperty("email", out var emailElement) ? emailElement.GetString() : null;
        var name = root.TryGetProperty("name", out var nameElement) ? nameElement.GetString() : null;
        var sub = root.TryGetProperty("sub", out var subElement) ? subElement.GetString() : null;
        var picture = root.TryGetProperty("picture", out var pictureElement) ? pictureElement.GetString() : null;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(sub))
        {
            return null;
        }

        return new GoogleProfile
        {
            Email = email,
            FullName = string.IsNullOrWhiteSpace(name) ? email : name,
            GoogleId = sub,
            AvatarUrl = picture
        };
    }

    private RenderFragment ShowFieldError(string fieldName) => builder =>
    {
        if (!Errors.TryGetValue(fieldName, out var error))
        {
            return;
        }

        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "mt-1 text-sm text-red-600");
        builder.AddContent(2, error);
        builder.CloseElement();
    };

    public void Dispose()
    {
        GoogleCallbackRef?.Dispose();
    }

    private class GoogleProfile
    {
        public string Email { get; set; } = string.Empty;
        public string FullName { get; set; } = string.Empty;
        public string GoogleId { get; set; } = string.Empty;
        public string? AvatarUrl { get; set; }
    }
}
