@code {
    private const string CustomStyles = "NguoiThue";
    private bool showSampleTenants => false;
    private List<SOTRO_Project.Models.Tenant.TenantResponse> tenants = new();
    private SOTRO_Project.Models.Tenant.TenantStatsResponse tenantStats = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadTenants();
    }

    private async Task LoadTenants()
    {
        var tenantResponse = await TenantApi.GetTenantsAsync();
        tenants = tenantResponse.Data ?? new();

        var statsResponse = await TenantApi.GetTenantStatsAsync();
        tenantStats = statsResponse.Data ?? new();
    }

    private async Task DeleteTenant(int tenantId)
    {
        var response = await TenantApi.DeleteTenantAsync(tenantId);
        if (response.Success)
            await LoadTenants();
    }

    private void EditTenant(int tenantId)
    {
        Navigation.NavigateTo($"/sua-nguoi-thue/{tenantId}");
    }

    private async Task ExportTenantsToExcel()
    {
        var rows = tenants.Select(tenant => new[]
        {
            tenant.TenantCode,
            tenant.FullName,
            tenant.PhoneNumber ?? string.Empty,
            tenant.Email ?? string.Empty,
            tenant.RoomCode ?? string.Empty,
            FormatDate(tenant.StartDate),
            GetStatusLabel(tenant.Status),
            tenant.DepositAmount?.ToString("N0") ?? "0"
        }).ToList();

        var html = BuildExcelHtml(rows);
        var fileName = $"danh-sach-nguoi-thue-{DateTime.Now:yyyyMMdd-HHmm}.xls";
        await JSRuntime.InvokeVoidAsync("sotroDownloadFile", fileName, "application/vnd.ms-excel;charset=utf-8", html);
    }

    private static string BuildExcelHtml(List<string[]> rows)
    {
        static string Cell(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

        var builder = new System.Text.StringBuilder();
        builder.Append("<html><head><meta charset=\"utf-8\"></head><body>");
        builder.Append("<table border=\"1\">");
        builder.Append("<thead><tr>");
        foreach (var header in new[] { "Mã người thuê", "Họ tên", "Số điện thoại", "Email", "Phòng", "Ngày bắt đầu", "Trạng thái", "Tiền cọc" })
        {
            builder.Append("<th style=\"background-color:#003f87;color:#ffffff;font-weight:bold;\">")
                .Append(Cell(header))
                .Append("</th>");
        }
        builder.Append("</tr></thead><tbody>");

        foreach (var row in rows)
        {
            builder.Append("<tr>");
            for (var index = 0; index < row.Length; index++)
            {
                if (index == 0)
                {
                    builder.Append("<td style=\"background-color:#d7e2ff;color:#003f87;font-weight:bold;\">")
                        .Append(Cell(row[index]))
                        .Append("</td>");
                }
                else
                {
                    builder.Append("<td>")
                        .Append(Cell(row[index]))
                        .Append("</td>");
                }
            }
            builder.Append("</tr>");
        }

        builder.Append("</tbody></table></body></html>");
        return builder.ToString();
    }

    private static string GetInitials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "?";

        var words = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(words.TakeLast(2).Select(w => w[0])).ToUpperInvariant();
    }

    private static string FormatDate(DateOnly? value) => value?.ToString("dd/MM/yyyy") ?? "-";

    private static string FormatMoney(decimal? value) => value.HasValue ? $"{value.Value:N0}đ" : "0đ";

    private static string FormatCompactMoney(decimal value)
    {
        if (value >= 1_000_000)
            return $"{Math.Round(value / 1_000_000, 0):N0}tr";

        return $"{value:N0}đ";
    }

    private static string GetStatusLabel(string? status) => status switch
    {
        "Active" => "Đang hiệu lực",
        "Reserved" => "Đã đặt cọc",
        "Inactive" => "Đã rời đi",
        "Blacklist" => "Nợ cọc",
        _ => "Không rõ"
    };

