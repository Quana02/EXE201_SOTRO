@page "/hoa-don"
@layout EmptyLayout
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject ITenantApiService TenantApiService
@inject IBuildingApiService BuildingApiService
@using SOTRO_Project.Models.Room
@using SOTRO_Project.Models.Tenant
@using SOTRO_Project.Models.Building

<PageTitle>SOTRO - Quản lý Hóa đơn</PageTitle>

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
</style>

<HeaderDashboard OnHelpClicked="OpenInvoiceTour" />
<SideNavBar />

<main class="flex-1 flex flex-col min-w-0 overflow-hidden relative ml-64">
    <div class="flex-1 overflow-y-auto bg-background p-gutter">
        <div id="invoice-page-header" class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <div>
                <h1 class="font-headline-md text-headline-md text-on-surface mb-1">Quản lý Hóa đơn</h1>
                <p class="text-body-md text-on-surface-variant">Theo dõi công nợ, gửi nhắc thanh toán và xuất hóa đơn cho từng người thuê.</p>
            </div>
            <div class="flex flex-wrap gap-3">
                <button id="invoice-bulk-reminder" @onclick="SendBulkReminder" class="flex items-center gap-2 px-4 py-2.5 bg-tertiary-container text-on-tertiary-container rounded-xl font-label-md text-label-md hover:brightness-95 transition-all">
                    <span class="material-symbols-outlined text-[20px]">bolt</span>
                    <span>Gửi thông báo nợ (VIP)</span>
                </button>
                <button id="invoice-bulk-create" @onclick="CreateBulkInvoices" class="flex items-center gap-2 px-6 py-2.5 bg-primary text-on-primary rounded-xl font-label-md text-label-md hover:shadow-lg transition-all">
                    <span class="material-symbols-outlined text-[20px]">add_circle</span>
                    <span>Tạo hóa đơn hàng loạt</span>
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(toastMessage))
        {
            <div class="mb-6 p-4 rounded-xl border @(toastIsError ? "bg-red-50 border-red-200 text-red-700" : "bg-green-50 border-green-200 text-green-700") flex items-center gap-2">
                <span class="material-symbols-outlined">@(toastIsError ? "error" : "check_circle")</span>
                <span>@toastMessage</span>
            </div>
        }

        <div id="invoice-stats" class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="bg-surface-container-lowest p-6 rounded-full border border-outline-variant shadow-sm flex flex-col">
                <span class="text-caption text-on-surface-variant uppercase tracking-wider mb-2">Tổng hóa đơn</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline-sm text-headline-sm font-bold">@filteredInvoices.Count</span>
                    <span class="text-caption text-primary">Tháng này</span>
                </div>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-full border border-outline-variant shadow-sm flex flex-col">
                <span class="text-caption text-on-surface-variant uppercase tracking-wider mb-2">Đã thanh toán</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline-sm text-headline-sm font-bold text-primary">@PaidCount</span>
                    <span class="text-caption text-primary">@PaidRate%</span>
                </div>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-full border border-outline-variant shadow-sm flex flex-col">
                <span class="text-caption text-on-surface-variant uppercase tracking-wider mb-2">Chờ thanh toán</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline-sm text-headline-sm font-bold text-secondary">@PendingCount</span>
                    <span class="text-caption text-secondary">@FormatPrice(PendingAmount)</span>
                </div>
            </div>
            <div class="bg-error-container p-6 rounded-full border border-error/10 shadow-sm flex flex-col">
                <span class="text-caption text-on-error-container uppercase tracking-wider mb-2">Quá hạn</span>
                <div class="flex items-baseline gap-2">
                    <span class="font-headline-sm text-headline-sm font-bold text-error">@OverdueCount</span>
                    <span class="text-caption text-error">Cần nhắc ngay</span>
                </div>
            </div>
        </div>

        <div id="invoice-filter-bar" class="flex flex-col md:flex-row items-center justify-between gap-4 mb-6 bg-surface-container-low p-4 rounded-xl">
            <div class="flex items-center gap-4 w-full md:w-auto">
                <div class="flex items-center gap-2 px-3 py-2 bg-surface-container-lowest rounded-lg border border-outline-variant min-w-[150px]">
                    <span class="material-symbols-outlined text-outline text-[20px]">calendar_today</span>
                    <select value="@selectedMonth" @onchange="OnMonthChanged" class="bg-transparent border-none text-label-md focus:ring-0 w-full cursor-pointer">
                        @foreach (var month in availableMonths)
                        {
                            <option value="@month">@month</option>
                        }
                    </select>
                </div>
                <div class="flex items-center gap-2 px-3 py-2 bg-surface-container-lowest rounded-lg border border-outline-variant min-w-[160px]">
                    <span class="material-symbols-outlined text-outline text-[20px]">filter_list</span>
                    <select value="@statusFilter" @onchange="OnStatusChanged" class="bg-transparent border-none text-label-md focus:ring-0 w-full cursor-pointer">
                        <option value="">Tất cả trạng thái</option>
                        <option value="Paid">Đã thanh toán</option>
                        <option value="Pending">Chờ thanh toán</option>
                        <option value="Overdue">Quá hạn</option>
                    </select>
                </div>
            </div>
            <button @onclick="ExportFullExcel" class="flex-1 md:flex-none flex items-center justify-center gap-2 px-4 py-2 border border-outline-variant rounded-lg font-label-md text-label-md hover:bg-surface-variant transition-colors">
                <span class="material-symbols-outlined text-[20px]">file_download</span>
                <span>Xuất Excel</span>
            </button>
        </div>

        <div id="invoice-table" class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm">
            @if (isLoading)
            {
                <div class="py-20 flex flex-col items-center gap-3">
                    <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
                    <p class="text-on-surface-variant">Đang tải hóa đơn...</p>
                </div>
            }
            else
            {
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface-container-low border-b border-outline-variant">
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Mã hóa đơn</th>
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Người thuê / Phòng</th>
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Kỳ thanh toán</th>
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Tổng tiền</th>
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                            <th class="px-6 py-4 font-label-md text-label-md text-on-surface-variant uppercase tracking-wider text-right">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @if (pagedInvoices.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="px-6 py-16 text-center text-on-surface-variant">Không có hóa đơn phù hợp.</td>
                            </tr>
                        }
                        @foreach (var invoice in pagedInvoices)
                        {
                            <tr class="hover:bg-surface-bright transition-colors">
                                <td class="px-6 py-4 font-bold text-primary">@invoice.InvoiceCode</td>
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="font-medium text-on-surface">@invoice.TenantName</span>
                                        <span class="text-caption text-on-surface-variant">@invoice.RoomCode</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-on-surface-variant">@invoice.PeriodText</td>
                                <td class="px-6 py-4 font-bold @(invoice.Status == "Overdue" ? "text-error" : "text-on-surface")">@FormatPrice(invoice.TotalAmount)</td>
                                <td class="px-6 py-4">
                                    <span class="px-3 py-1 @GetStatusBadgeClass(invoice) rounded-full text-caption font-bold">@invoice.StatusLabel</span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <button id="invoice-detail-action" @onclick="() => ShowInvoiceDetail(invoice)" class="p-2 hover:bg-surface-container rounded-full transition-colors" title="Xem chi tiết">
                                        <span class="material-symbols-outlined text-outline">visibility</span>
                                    </button>
                                    @if (invoice.Status == "Paid")
                                    {
                                        <button id="invoice-export-action" @onclick="() => ExportInvoicePdf(invoice)" class="p-2 hover:bg-surface-container rounded-full transition-colors text-primary" title="Xuất hóa đơn PDF">
                                            <span class="material-symbols-outlined">print</span>
                                        </button>
                                    }
                                    else if (invoice.Status == "Overdue")
                                    {
                                        <button id="invoice-overdue-action" @onclick="() => SendZaloPaymentMessage(invoice)" class="p-2 hover:bg-error-container hover:text-error rounded-full transition-colors text-error" title="Gửi tin nhắn quá hạn qua Zalo">
                                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">warning</span>
                                        </button>
                                    }
                                    else
                                    {
                                        <button id="invoice-send-action" @onclick="() => SendZaloPaymentMessage(invoice)" class="p-2 hover:bg-surface-container rounded-full transition-colors text-tertiary" title="Gửi tin nhắn thanh toán qua Zalo">
                                            <span class="material-symbols-outlined">send</span>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <div id="invoice-pagination" class="px-6 py-4 flex items-center justify-between border-t border-outline-variant bg-surface-container-low">
                    <span class="text-caption text-on-surface-variant">
                        Hiển thị @PageStart - @PageEnd trong tổng số @filteredInvoices.Count hóa đơn
                    </span>
                    <div class="flex items-center gap-1">
                        <button class="p-2 rounded-lg hover:bg-surface-container disabled:opacity-30" disabled="@(currentPage == 1)" @onclick="PreviousPage">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        @for (var page = 1; page <= TotalPages; page++)
                        {
                            var pageNumber = page;
                            <button @onclick="() => GoToPage(pageNumber)" class="w-8 h-8 rounded-lg text-label-md font-bold @(currentPage == pageNumber ? "bg-primary text-on-primary" : "hover:bg-surface-container")">@pageNumber</button>
                        }
                        <button class="p-2 rounded-lg hover:bg-surface-container disabled:opacity-30" disabled="@(currentPage == TotalPages)" @onclick="NextPage">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</main>

@if (selectedInvoice != null)
{
    <div class="fixed inset-0 z-[220] bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl border border-outline-variant w-full max-w-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-outline-variant flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-primary uppercase">Chi tiết hóa đơn</p>
                    <h3 class="text-xl font-black text-on-surface">@selectedInvoice.InvoiceCode</h3>
                </div>
                <button @onclick="CloseInvoiceDetail" class="p-2 rounded-full hover:bg-surface-container">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-[1fr_180px] gap-6">
                <div class="space-y-4">
                    <div>
                        <p class="text-xs uppercase text-on-surface-variant font-bold">Người thuê</p>
                        <p class="font-bold">@selectedInvoice.TenantName - @selectedInvoice.RoomCode</p>
                    </div>
                    <div class="grid grid-cols-2 gap-3 text-sm">
                        <p>Tiền phòng</p><p class="font-bold text-right">@FormatPrice(selectedInvoice.RoomPrice)</p>
                        <p>Điện</p><p class="font-bold text-right">@FormatPrice(selectedInvoice.ElectricFee)</p>
                        <p>Nước</p><p class="font-bold text-right">@FormatPrice(selectedInvoice.WaterFee)</p>
                        <p>Dịch vụ</p><p class="font-bold text-right">@FormatPrice(selectedInvoice.ServiceFee)</p>
                        <p class="border-t pt-3 font-bold">Tổng thanh toán</p><p class="border-t pt-3 font-black text-right text-primary">@FormatPrice(selectedInvoice.TotalAmount)</p>
                    </div>
                </div>
                <div class="rounded-xl bg-surface-container-low p-3 flex flex-col items-center justify-center text-center">
                    @if (!string.IsNullOrWhiteSpace(bankQrDataUrl))
                    {
                        <img src="@bankQrDataUrl" alt="QR chuyển khoản" class="w-36 h-36 object-contain rounded-lg bg-white border border-outline-variant" />
                        <p class="text-xs mt-2 font-bold">@bankName</p>
                        <p class="text-[11px] text-on-surface-variant">@bankAccountNumber</p>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-5xl text-on-surface-variant">qr_code_2</span>
                        <p class="text-xs text-on-surface-variant mt-2">Chưa có QR chuyển khoản</p>
                    }
                </div>
            </div>
            <div class="px-6 py-4 border-t border-outline-variant flex justify-end gap-3">
                @if (selectedInvoice.Status != "Paid")
                {
                    <button @onclick="() => MarkAsPaid(selectedInvoice)" class="px-4 py-2 rounded-xl bg-primary text-white font-bold">Đánh dấu đã thanh toán</button>
                }
                <button @onclick="CloseInvoiceDetail" class="px-4 py-2 rounded-xl border border-outline-variant font-bold">Đóng</button>
            </div>
        </div>
    </div>
}

@if (zaloInvoice != null)
{
    <div class="fixed inset-0 z-[230] bg-black/50 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl border border-outline-variant w-full max-w-md overflow-hidden">
            <div class="px-6 py-4 border-b border-outline-variant flex items-center justify-between">
                <div>
                    <p class="text-xs font-bold text-primary uppercase">Gửi hóa đơn qua Zalo</p>
                    <h3 class="text-xl font-black text-on-surface">@zaloInvoice.InvoiceCode</h3>
                </div>
                <button @onclick="CloseZaloInvoicePopup" class="p-2 rounded-full hover:bg-surface-container">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6 text-center">
                <div id="zalo-bill-preview" class="mx-auto mb-4 w-full max-w-[300px] rounded-2xl border border-blue-100 bg-white shadow-sm overflow-hidden text-left">
                    <div class="bg-primary text-white px-4 py-3">
                        <p class="text-[11px] uppercase font-bold tracking-wide">Bill PNG</p>
                        <p class="text-lg font-black">@zaloInvoice.InvoiceCode</p>
                    </div>
                    <div class="p-4 space-y-3">
                        <div>
                            <p class="text-[11px] text-slate-500 uppercase font-bold">Nhà trọ</p>
                            <p class="text-sm font-black text-slate-900">@buildingName</p>
                            <p class="text-[11px] text-slate-500 leading-4">@buildingAddress</p>
                        </div>
                        <div class="grid grid-cols-[1fr_82px] gap-3 items-center">
                            <div class="space-y-1 text-xs">
                                <p><span class="text-slate-500">Người thuê:</span> <strong>@zaloInvoice.TenantName</strong></p>
                                <p><span class="text-slate-500">SĐT:</span> <strong>@(string.IsNullOrWhiteSpace(zaloInvoice.TenantPhone) ? "Chưa có" : zaloInvoice.TenantPhone)</strong></p>
                                <p><span class="text-slate-500">Phòng:</span> <strong>@zaloInvoice.RoomCode</strong></p>
                                <p><span class="text-slate-500">Kỳ:</span> <strong>@zaloInvoice.PeriodText</strong></p>
                            </div>
                            <div class="w-20 h-20 rounded-lg border border-slate-200 bg-slate-50 flex items-center justify-center overflow-hidden">
                                @if (!string.IsNullOrWhiteSpace(bankQrDataUrl))
                                {
                                    <img src="@bankQrDataUrl" alt="QR chuyển khoản" class="w-full h-full object-contain p-1" />
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-slate-400">qr_code_2</span>
                                }
                            </div>
                        </div>
                        <div class="border-t border-slate-200 pt-3 flex justify-between text-sm">
                            <span class="font-bold text-slate-600">Tổng thanh toán</span>
                            <span class="font-black text-primary">@FormatPrice(zaloInvoice.TotalAmount)</span>
                        </div>
                    </div>
                </div>
                <h4 class="font-black text-lg text-on-surface">Bill PNG đã sẵn sàng</h4>
                <p class="text-sm text-on-surface-variant mt-2 leading-6">
                    Hóa đơn dạng ảnh gồm thông tin phòng, địa chỉ trọ, các khoản phí, tổng thanh toán và QR chuyển khoản.
                </p>
                <div class="mt-4 rounded-xl bg-surface-container-low p-4 text-left text-sm space-y-2">
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">Người thuê</span>
                        <span class="font-bold text-right">@zaloInvoice.TenantName</span>
                    </div>
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">SĐT</span>
                        <span class="font-bold text-right">@(string.IsNullOrWhiteSpace(zaloInvoice.TenantPhone) ? "Chưa có" : zaloInvoice.TenantPhone)</span>
                    </div>
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">Phòng</span>
                        <span class="font-bold">@zaloInvoice.RoomCode</span>
                    </div>
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">Tổng tiền</span>
                        <span class="font-black text-primary">@FormatPrice(zaloInvoice.TotalAmount)</span>
                    </div>
                </div>
            </div>
            <div class="px-6 py-4 border-t border-outline-variant grid grid-cols-1 sm:grid-cols-2 gap-3">
                <button id="zalo-copy-png-button" @onclick="CopyInvoicePngAsync" class="px-4 py-3 rounded-xl border border-primary text-primary font-bold flex items-center justify-center gap-2 hover:bg-blue-50">
                    <span class="material-symbols-outlined">content_copy</span>
                    <span>Copy PNG</span>
                </button>
                <button id="zalo-open-button" @onclick="GoToTenantZaloAsync" class="px-4 py-3 rounded-xl bg-primary text-white font-bold flex items-center justify-center gap-2 hover:shadow-lg">
                    <span class="material-symbols-outlined">open_in_new</span>
                    <span>Chuyển đến Zalo</span>
                </button>
            </div>
        </div>
    </div>
}

<GuidedOnboarding IsVisible="showInvoiceTour"
                  Steps="invoiceGuidedSteps"
                  StorageKey="sotro_invoice_guided_seen"
                  AllowSkip="true"
                  OnCompleted="CloseInvoiceTour"
                  OnSkipped="CloseInvoiceTour" />

<GuidedOnboarding IsVisible="showZaloPopupTour"
                  Steps="zaloPopupGuidedSteps"
                  StorageKey="sotro_zalo_bill_popup_guided_seen"
                  AllowSkip="true"
                  OnCompleted="CloseZaloPopupTour"
                  OnSkipped="CloseZaloPopupTour" />

@code {
    private const int PageSize = 10;
    private List<InvoiceItem> invoices = new();
    private bool isLoading = true;
    private bool showInvoiceTour;
    private bool showZaloPopupTour;
    private string selectedMonth = string.Empty;
    private string statusFilter = string.Empty;
    private int currentPage = 1;
    private string? toastMessage;
    private bool toastIsError;
    private InvoiceItem? selectedInvoice;
    private InvoiceItem? zaloInvoice;
    private string bankQrMode = "auto";
    private string bankName = string.Empty;
    private string bankAccountNumber = string.Empty;
    private string bankAccountHolder = string.Empty;
    private string bankQrDataUrl = string.Empty;
    private string buildingName = "Sổ Trọ";
    private string buildingAddress = "Chưa cập nhật địa chỉ";
    private readonly string[] availableMonths =
    {
        $"{DateTime.Today.Month:00}/{DateTime.Today.Year}",
        $"{DateTime.Today.AddMonths(-1).Month:00}/{DateTime.Today.AddMonths(-1).Year}"
    };

    private IReadOnlyList<GuidedOnboarding.GuidedStep> invoiceGuidedSteps => new[]
    {
        new GuidedOnboarding.GuidedStep("#invoice-page-header", "Quản lý hóa đơn", "Trang này dùng để theo dõi từng hóa đơn của người thuê, gửi nhắc thanh toán, xuất hóa đơn và cập nhật trạng thái đã thanh toán.", "Bắt đầu từ khu vực tiêu đề để biết các thao tác chính của trang."),
        new GuidedOnboarding.GuidedStep("#invoice-stats", "Thống kê công nợ", "Các ô thống kê cho biết tổng hóa đơn, số đã thanh toán, số chờ thanh toán và số quá hạn.", "Xem nhanh khu vực này để biết tình hình thu tiền trong tháng."),
        new GuidedOnboarding.GuidedStep("#invoice-filter-bar", "Lọc hóa đơn", "Bạn có thể lọc hóa đơn theo tháng hoặc trạng thái để xử lý đúng nhóm cần quan tâm.", "Chọn tháng hoặc trạng thái trước khi thao tác hàng loạt."),
        new GuidedOnboarding.GuidedStep("#invoice-table", "Danh sách hóa đơn theo người thuê", "Mỗi dòng là một hóa đơn của người thuê, luôn có nút xem chi tiết. Hóa đơn đã thanh toán có nút xuất, hóa đơn chờ thanh toán có nút gửi tin nhắn, hóa đơn quá hạn có nút cảnh báo.", "Dùng các icon ở cột thao tác để xử lý từng hóa đơn."),
        new GuidedOnboarding.GuidedStep("#invoice-pagination", "Phân trang", "Mỗi trang hiển thị 10 hóa đơn để danh sách gọn và dễ theo dõi.", "Dùng nút chuyển trang khi có nhiều hơn 10 hóa đơn.")
    };

    private IReadOnlyList<GuidedOnboarding.GuidedStep> zaloPopupGuidedSteps => new[]
    {
