                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">SĐT</span>
                        <span class="font-bold text-right">@(string.IsNullOrWhiteSpace(zaloInvoice.TenantPhone) ? "Chưa có" : zaloInvoice.TenantPhone)</span>
                    </div>
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">Phòng</span>
                        <span class="font-bold">@zaloInvoice.RoomCode</span>
                    </div>
                    <div class="flex justify-between gap-3">
                        <span class="text-on-surface-variant">Tổng tiền</span>
                        <span class="font-black text-primary">@FormatPrice(zaloInvoice.TotalAmount)</span>
