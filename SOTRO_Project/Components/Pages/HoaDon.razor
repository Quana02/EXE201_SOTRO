    private async Task DeleteInvoice(InvoiceItem invoice)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa hóa đơn {invoice.InvoiceCode}? Thao tác này sẽ ẩn bill khỏi danh sách.");
        if (!confirmed)
        {
            return;
        }

        if (invoice.InvoiceId > 0)
        {
            var response = await InvoiceApiService.DeleteInvoiceAsync(invoice.InvoiceId);
            if (!response.Success)
            {
                ShowToast(response.Message, true);
                return;
            }
        }

        invoices.RemoveAll(i => i.InvoiceId == invoice.InvoiceId && invoice.InvoiceId > 0 || i.InvoiceKey == invoice.InvoiceKey);
        selectedInvoice = null;
        currentPage = Math.Clamp(currentPage, 1, TotalPages);
        ShowToast($"Đã xóa hóa đơn {invoice.InvoiceCode}.");
    }

