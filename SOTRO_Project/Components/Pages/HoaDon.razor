                <button id="zalo-open-button" @onclick="GoToTenantZaloAsync" class="px-4 py-3 rounded-xl bg-primary text-white font-bold flex items-center justify-center gap-2 hover:shadow-lg">
                    <span class="material-symbols-outlined">open_in_new</span>
                    <span>Chuyển đến Zalo</span>
                </button>
            </div>
        </div>
    </div>
}

