    private List<InvoiceItem> filteredInvoices => invoices
        .Where(i => selectedMonthKeys.Count == 0 || selectedMonthKeys.Contains(i.MonthKey))
        .Where(i => string.IsNullOrWhiteSpace(statusFilter) || i.Status == statusFilter)
        .ToList();

    private List<InvoiceItem> pagedInvoices => filteredInvoices
        .Skip((currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)filteredInvoices.Count / PageSize));
    private int PageStart => filteredInvoices.Count == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int PageEnd => Math.Min(currentPage * PageSize, filteredInvoices.Count);
    private int PaidCount => filteredInvoices.Count(i => i.Status == "Paid");
    private int PendingCount => filteredInvoices.Count(i => i.Status == "Pending");
    private int OverdueCount => filteredInvoices.Count(i => i.Status == "Overdue");
    private decimal PendingAmount => filteredInvoices.Where(i => i.Status != "Paid").Sum(i => i.TotalAmount);
    private int PaidRate => filteredInvoices.Count == 0 ? 0 : (int)Math.Round((double)PaidCount * 100 / filteredInvoices.Count);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        SetDefaultMonthFilter();
        await LoadInvoices(generateMissing: true);
        await LoadBankSettings();
        await LoadBuildingInfo();
        await LoadPremiumAccess();
        await ShowMissingQrNoticeIfNeeded();
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadInvoices(bool generateMissing)
    {
        var built = new List<InvoiceItem>();
        var paidKeys = new HashSet<string>();

        try
        {
             var buildingIdText = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
             int.TryParse(buildingIdText, out var buildingId);
             activeBuildingId = buildingId;
             if (buildingId <= 0)
             {
                 invoices = new();
                 ShowToast("Chưa chọn nhà trọ.", true);
                 return;
             }

             paidKeys = await LoadPaidKeys();
            if (buildingId > 0 && selectedMonthKeys.Count > 0)
            {
                var loadedInvoices = new List<InvoiceItem>();
                var monthKeys = selectedMonthKeys
                    .Select(ParseMonthKey)
                    .Where(month => month.HasValue)
                    .Select(month => month!.Value)
                    .OrderByDescending(month => month.Year)
                    .ThenByDescending(month => month.Month)
                    .ToList();

                foreach (var month in monthKeys)
                {
                    var shouldGenerate = generateMissing && month.Month == DateTime.Today.Month && month.Year == DateTime.Today.Year;
                    var invoiceResponse = shouldGenerate
                        ? await InvoiceApiService.GenerateMonthlyInvoicesAsync(await BuildGenerateInvoiceRequest(buildingId, month.Month, month.Year))
                        : await InvoiceApiService.GetInvoicesAsync(buildingId, month.Month, month.Year);

                    if (invoiceResponse.Success && invoiceResponse.Data != null)
                    {
                        loadedInvoices.AddRange(invoiceResponse.Data.Select(MapInvoiceResponse));
                        continue;
                    }

                    ShowToast(invoiceResponse.Message, true);
                }

                invoices = loadedInvoices
                    .GroupBy(invoice => invoice.InvoiceId > 0 ? $"db:{invoice.InvoiceId}" : invoice.InvoiceKey)
                    .Select(group => group.First())
                    .ToList();
                return;
            }

            var tenantsResponse = await TenantApiService.GetTenantsAsync(buildingId);
            var roomsResponse = buildingId > 0
                ? await RoomApiService.GetRoomsByBuildingAsync(buildingId)
                : null;
            var tenants = tenantsResponse.Data ?? new();
            var rooms = roomsResponse?.Data ?? new();
            var activeTenants = tenants
                .Where(t => t.Status == null || t.Status == "Active")
                .GroupBy(GetTenantIdentityKey)
                .Select(g => g.OrderByDescending(t => t.UpdatedAt ?? t.CreatedAt ?? DateTime.MinValue).First())
                .ToList();

            foreach (var tenant in activeTenants)
            {
                var room = rooms.FirstOrDefault(r => r.RoomId == tenant.RoomId || r.RoomCode == tenant.RoomCode);
                built.Add(CreateInvoiceFromTenant(tenant, room, paidKeys, built.Count + 1));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Invoice load error: {ex.Message}");
        }

        if (built.Count == 0)
        {
            built = CreateSampleInvoices(paidKeys);
        }

        invoices = built;
    }

    private InvoiceItem CreateInvoiceFromTenant(TenantResponse tenant, RoomResponse? room, HashSet<string> paidKeys, int index)
    {
        var dueDate = ResolveDueDate(tenant, room);
        var code = $"INV-{DateTime.Today:yyMM}-{index:000}";
        var invoiceKey = BuildInvoiceKey(tenant, room);
        var roomPrice = tenant.MonthlyRent ?? room?.BasePrice ?? 0;
        var electricFee = room?.ElectricPrice.HasValue == true ? room.ElectricPrice.Value * 30 : 0;
        var waterFee = room?.WaterPrice.HasValue == true ? room.WaterPrice.Value * 4 : 0;
        var serviceFee = room?.ServiceFee ?? 0;
        var status = paidKeys.Contains(invoiceKey) ? "Paid" : (DateTime.Today.Date > dueDate.Date ? "Overdue" : "Pending");

        return new InvoiceItem
        {
            InvoiceKey = invoiceKey,
            InvoiceCode = code,
            TenantName = tenant.FullName,
            TenantPhone = tenant.PhoneNumber ?? string.Empty,
            RoomCode = tenant.RoomCode ?? room?.RoomCode ?? "Chưa gán phòng",
            MonthKey = $"{DateTime.Today.Month:00}/{DateTime.Today.Year}",
            PeriodText = $"01/{DateTime.Today.Month:00} - {DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month)}/{DateTime.Today.Month:00}",
            RoomPrice = roomPrice,
            ElectricFee = electricFee,
            WaterFee = waterFee,
            ServiceFee = serviceFee,
            DueDate = dueDate,
            Status = status
        };
    }

    private static InvoiceItem MapInvoiceResponse(InvoiceResponse invoice)
    {
        var status = invoice.Status switch
        {
            "Paid" => "Paid",
            "Overdue" => "Overdue",
            "PartiallyPaid" => "Pending",
            _ => "Pending"
        };

        return new InvoiceItem
        {
            InvoiceId = invoice.InvoiceId,
            InvoiceKey = $"db:{invoice.InvoiceId}",
            InvoiceCode = invoice.InvoiceCode,
            TenantName = invoice.TenantName,
            TenantPhone = invoice.TenantPhone,
            RoomCode = invoice.RoomCode,
            MonthKey = $"{invoice.Month:00}/{invoice.Year}",
            PeriodText = $"01/{invoice.Month:00} - {DateTime.DaysInMonth(invoice.Year, invoice.Month)}/{invoice.Month:00}",
            RoomPrice = invoice.RoomPrice,
            ElectricFee = invoice.ElectricCost,
            WaterFee = invoice.WaterCost,
            ServiceFee = invoice.ServiceCost + invoice.OtherCost - invoice.DiscountAmount,
            DueDate = invoice.DueDate ?? new DateTime(invoice.Year, invoice.Month, 5),
            Status = status
        };
    }

    private List<InvoiceItem> CreateSampleInvoices(HashSet<string> paidKeys)
    {
        var names = new[] { "Trần Minh Quân", "Lê Thị Hoa", "Nguyễn Văn Ba", "Phạm Nhật Vượng", "Lý Quốc Sư", "Hoàng An", "Mai Thanh", "Đỗ Minh", "Ngọc Hân", "Tuấn Kiệt", "Bảo Trâm", "Quốc Huy" };
        var result = new List<InvoiceItem>();
        for (var i = 0; i < names.Length; i++)
        {
            var code = $"INV-{DateTime.Today:yyMM}-{i + 1:000}";
            var invoiceKey = $"sample:{DateTime.Today:yyyyMM}:{i + 1}";
            var status = paidKeys.Contains(invoiceKey) ? "Paid" : i % 5 == 2 ? "Overdue" : i % 3 == 0 ? "Paid" : "Pending";
            result.Add(new InvoiceItem
            {
                InvoiceKey = invoiceKey,
                InvoiceCode = code,
                TenantName = names[i],
                TenantPhone = string.Empty,
                RoomCode = $"P.{(i + 1) * 101}",
                MonthKey = $"{DateTime.Today.Month:00}/{DateTime.Today.Year}",
                PeriodText = $"01/{DateTime.Today.Month:00} - {DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month)}/{DateTime.Today.Month:00}",
                RoomPrice = 2500000 + i * 150000,
                ElectricFee = 180000 + i * 10000,
                WaterFee = 80000,
                ServiceFee = 120000,
                DueDate = DateTime.Today.AddDays(i % 5 == 2 ? -3 : 5),
                Status = status
            });
        }
        return result;
    }

    private static string GetTenantIdentityKey(TenantResponse tenant)
    {
        if (tenant.TenantId > 0)
        {
            return $"tenant:{tenant.TenantId}";
        }

        var roomPart = tenant.RoomId?.ToString() ?? tenant.RoomCode ?? "no-room";
        var phonePart = tenant.PhoneNumber ?? tenant.IdentityNumber ?? tenant.FullName;
        return $"tenant:{roomPart}:{phonePart}".ToLowerInvariant();
    }

    private static bool TryParseMonth(string value, out int month, out int year)
    {
        month = DateTime.Today.Month;
        year = DateTime.Today.Year;
        var parts = value.Split('/', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 2)
        {
            return false;
        }

        return int.TryParse(parts[0], out month) &&
               int.TryParse(parts[1], out year) &&
               month is >= 1 and <= 12 &&
               year is >= 2000 and <= 9999;
    }

    private static string BuildMonthKey(int month, int year) => $"{month:00}/{year}";

    private static (int Month, int Year)? ParseMonthKey(string value)
    {
        return TryParseMonth(value, out var month, out var year)
            ? (month, year)
            : null;
    }

    private static string FormatMonthKey(string value)
    {
        return TryParseMonth(value, out var month, out var year)
            ? $"Tháng {month} {year}"
            : "Chọn tháng";
    }

    private static string BuildInvoiceKey(TenantResponse tenant, RoomResponse? room)
    {
        var monthKey = DateTime.Today.ToString("yyyyMM");
        if (tenant.TenantId > 0)
        {
            return $"tenant:{tenant.TenantId}:{monthKey}";
        }

        var roomPart = tenant.RoomId?.ToString() ?? room?.RoomId.ToString() ?? tenant.RoomCode ?? room?.RoomCode ?? "no-room";
        var tenantPart = tenant.TenantCode;
        if (string.IsNullOrWhiteSpace(tenantPart))
        {
            tenantPart = tenant.PhoneNumber ?? tenant.IdentityNumber ?? tenant.FullName;
        }

        return $"tenant:{roomPart}:{tenantPart}:{monthKey}".ToLowerInvariant();
    }

    private static DateTime ResolveDueDate(TenantResponse tenant, RoomResponse? room)
    {
        var dueDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, Math.Clamp(room?.PaymentDueDay ?? 5, 1, 28));
        var startDate = tenant.StartDate?.ToDateTime(TimeOnly.MinValue) ?? tenant.CreatedAt?.Date;

        if (startDate.HasValue &&
            startDate.Value.Year == DateTime.Today.Year &&
            startDate.Value.Month == DateTime.Today.Month &&
            startDate.Value.Date > dueDate.Date)
        {
            return startDate.Value.Date.AddDays(7);
        }

        return dueDate;
    }

    private async Task<HashSet<string>> LoadPaidKeys()
    {
        try
        {
            await EnsureActiveBuildingIdAsync();
            var raw = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_paid_invoice_keys_v2"));
            return string.IsNullOrWhiteSpace(raw)
                ? new HashSet<string>()
                : raw.Split('|', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        }
        catch
        {
            return new HashSet<string>();
        }
    }

    private async Task SavePaidKeys()
    {
        await EnsureActiveBuildingIdAsync();
        var paid = invoices.Where(i => i.Status == "Paid").Select(i => i.InvoiceKey);
        await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_paid_invoice_keys_v2"), string.Join('|', paid));
    }

    private async Task LoadBankSettings()
    {
        await EnsureActiveBuildingIdAsync();
        bankQrMode = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_qr_mode")) ?? "auto";
        bankName = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_name")) ?? string.Empty;
        bankAccountNumber = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_account_number")) ?? string.Empty;
        bankAccountHolder = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_account_holder")) ?? string.Empty;
        bankQrDataUrl = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_qr_data_url")) ?? string.Empty;
        if (bankQrMode == "auto")
        {
            bankQrDataUrl = BuildGeneratedBankQrUrl();
        }
    }

    private async Task ShowMissingQrNoticeIfNeeded()
    {
        if (string.IsNullOrWhiteSpace(bankQrDataUrl))
        {
            await ShowMissingQrNoticeAsync();
        }
    }

    private async Task ShowMissingQrNoticeAsync()
    {
        qrRedirectCts?.Cancel();
        qrRedirectCts?.Dispose();
        qrRedirectCts = new CancellationTokenSource();
        qrRedirectCountdown = 3;
        showQrSetupNotice = true;
        StateHasChanged();
        _ = RunQrRedirectCountdownAsync(qrRedirectCts.Token);
        await Task.CompletedTask;
    }

    private async Task RunQrRedirectCountdownAsync(CancellationToken cancellationToken)
    {
        try
        {
            while (qrRedirectCountdown > 0)
            {
                await Task.Delay(1000, cancellationToken);
                qrRedirectCountdown--;
                await InvokeAsync(StateHasChanged);
            }

            GoToQrSettings();
        }
        catch (TaskCanceledException)
        {
            // User closed the notice or left the page.
        }
    }

    private void CloseQrSetupNotice()
    {
        qrRedirectCts?.Cancel();
        showQrSetupNotice = false;
    }

    private void GoToQrSettings()
    {
        qrRedirectCts?.Cancel();
        var query = activeBuildingId > 0 ? $"?buildingId={activeBuildingId}" : string.Empty;
        Navigation.NavigateTo($"/cai-dat{query}#bank-qr-settings");
    }

    private async Task LoadBuildingInfo()
    {
        try
        {
            var buildingIdText = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var cachedName = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
            if (!string.IsNullOrWhiteSpace(cachedName))
            {
                buildingName = cachedName;
            }

            if (int.TryParse(buildingIdText, out var buildingId) && buildingId > 0)
            {
                activeBuildingId = buildingId;
                var response = await BuildingApiService.GetBuildingByIdAsync(buildingId);
                if (response.Success && response.Data != null)
                {
                    buildingName = response.Data.BuildingName ?? buildingName;
                    buildingAddress = response.Data.Address ?? buildingAddress;
                }
            }
        }
        catch
        {
            // Keep the cached/default building information for printable invoices.
        }
    }

    private async Task SendPaymentMessage(InvoiceItem invoice)
    {
        await LoadBankSettings();
        if (string.IsNullOrWhiteSpace(bankQrDataUrl))
        {
            await ShowMissingQrNoticeAsync();
            return;
        }

        var message = BuildPaymentMessage(invoice);
        await JS.InvokeVoidAsync("alert", message);
        var paidNow = await JS.InvokeAsync<bool>("confirm", "Người thuê đã thanh toán khoản này chưa? Nếu đã thanh toán, hệ thống sẽ cập nhật trạng thái hóa đơn.");
        if (paidNow)
        {
            await MarkAsPaid(invoice);
        }
        else
        {
            ShowToast("Đã gửi nội dung nhắc thanh toán kèm QR chuyển khoản.");
        }
    }

