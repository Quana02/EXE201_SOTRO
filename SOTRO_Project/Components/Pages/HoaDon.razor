               "</head><body><div class='invoice'>" +
               $"<div class='header'><div><div class='brand'>{H(buildingName)}</div><div class='muted'>Hóa đơn thanh toán tiền trọ</div><div class='building'><strong>Địa chỉ:</strong> {H(buildingAddress)}</div></div>" +
               $"<div><div class='muted'>Mã hóa đơn</div><div class='code'>{H(invoice.InvoiceCode)}</div><div class='muted'>Kỳ: {H(invoice.PeriodText)}</div></div></div>" +
               "<div class='grid'><div>" +
               $"<p><strong>Người thuê:</strong> {H(invoice.TenantName)}</p>" +
               $"<p><strong>SĐT:</strong> {H(string.IsNullOrWhiteSpace(invoice.TenantPhone) ? "Chưa có" : invoice.TenantPhone)}</p>" +
               $"<p><strong>Phòng:</strong> {H(invoice.RoomCode)}</p>" +
               $"<p><strong>Ngày đến hạn:</strong> {invoice.DueDate:dd/MM/yyyy}</p>" +
               $"<span class='paid'>{H(invoice.StatusLabel)}</span><div class='notice'>{H(note)}</div></div><div>{qrHtml}" +
               $"<div class='muted' style='margin-top:8px;'>{H(bankName)} - {H(bankAccountNumber)}</div><div class='muted'>{H(bankAccountHolder)}</div></div></div>" +
               "<table><tr><th>Khoản thu</th><th style='text-align:right;'>Số tiền</th></tr>" +
               $"<tr><td>Tiền phòng</td><td style='text-align:right;'>{FormatPrice(invoice.RoomPrice)}</td></tr>" +
               $"<tr><td>Điện</td><td style='text-align:right;'>{FormatPrice(invoice.ElectricFee)}</td></tr>" +
               $"<tr><td>Nước</td><td style='text-align:right;'>{FormatPrice(invoice.WaterFee)}</td></tr>" +
               $"<tr><td>Dịch vụ</td><td style='text-align:right;'>{FormatPrice(invoice.ServiceFee)}</td></tr>" +
               $"<tr class='total'><td>Tổng thanh toán</td><td style='text-align:right;'>{FormatPrice(invoice.TotalAmount)}</td></tr>" +
               "</table></div></body></html>";
    }

    private async Task SendBulkReminder()
    {
        var targets = filteredInvoices.Where(i => i.Status != "Paid").ToList();
        if (targets.Count == 0)
        {
            ShowToast("Không có hóa đơn cần nhắc thanh toán.");
            return;
        }
        await LoadBankSettings();
        if (string.IsNullOrWhiteSpace(bankQrDataUrl))
        {
            var goToSettings = await JS.InvokeAsync<bool>("confirm", "Chưa có QR chuyển khoản trong Cài đặt. Chuyển đến Cài đặt để thêm QR?");
            if (goToSettings) Navigation.NavigateTo("/cai-dat");
            return;
        }
        ShowToast($"Đã gửi nhắc thanh toán cho {targets.Count} hóa đơn.");
    }

    private void ShowToast(string message, bool isError = false)
    {
        toastMessage = message;
        toastIsError = isError;
        StateHasChanged();
    }

    private void OnMonthChanged(ChangeEventArgs e)
    {
        selectedMonth = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        statusFilter = e.Value?.ToString() ?? string.Empty;
        currentPage = 1;
    }

    private void PreviousPage() => currentPage = Math.Max(1, currentPage - 1);
    private void NextPage() => currentPage = Math.Min(TotalPages, currentPage + 1);
    private void GoToPage(int page) => currentPage = Math.Clamp(page, 1, TotalPages);
    private void OpenInvoiceTour() => showInvoiceTour = true;
    private void CloseInvoiceTour() => showInvoiceTour = false;

    private static string FormatPrice(decimal value) => $"{value:N0}đ";

    private string GetShareableQrText()
    {
        if (bankQrMode == "auto" && !string.IsNullOrWhiteSpace(bankQrDataUrl))
        {
            return bankQrDataUrl;
        }

        return "QR đã được chủ trọ lưu trong hệ thống, vui lòng xem ảnh QR đi kèm bill.";
    }

    private static string H(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

    private string BuildGeneratedBankQrUrl()
    {
        if (string.IsNullOrWhiteSpace(bankName) || string.IsNullOrWhiteSpace(bankAccountNumber) || string.IsNullOrWhiteSpace(bankAccountHolder))
        {
            return string.Empty;
        }

        var bankCode = Uri.EscapeDataString(bankName.Trim().ToUpperInvariant());
        var accountNumber = Uri.EscapeDataString(bankAccountNumber.Trim().Replace(" ", ""));
        var accountName = Uri.EscapeDataString(bankAccountHolder.Trim().ToUpperInvariant());
        return $"https://img.vietqr.io/image/{bankCode}-{accountNumber}-compact2.png?accountName={accountName}";
    }

    private static string GetStatusBadgeClass(InvoiceItem invoice) => invoice.Status switch
    {
        "Paid" => "bg-primary-fixed text-on-primary-fixed-variant",
        "Overdue" => "bg-error-container text-on-error-container",
        _ => "bg-secondary-fixed text-on-secondary-fixed-variant"
    };

    private sealed class InvoiceItem
    {
        public string InvoiceKey { get; set; } = string.Empty;
        public string InvoiceCode { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public string TenantPhone { get; set; } = string.Empty;
        public string RoomCode { get; set; } = string.Empty;
        public string PeriodText { get; set; } = string.Empty;
        public string MonthKey { get; set; } = string.Empty;
        public decimal RoomPrice { get; set; }
        public decimal ElectricFee { get; set; }
        public decimal WaterFee { get; set; }
        public decimal ServiceFee { get; set; }
        public DateTime DueDate { get; set; }
        public string Status { get; set; } = "Pending";
        public decimal TotalAmount => RoomPrice + ElectricFee + WaterFee + ServiceFee;
        public int OverdueDays => Math.Max(1, (DateTime.Today.Date - DueDate.Date).Days);
        public string StatusLabel => Status switch
        {
            "Paid" => "Đã thanh toán",
            "Overdue" => $"Quá hạn {OverdueDays} ngày",
            _ => "Chờ thanh toán"
        };
    }
}
