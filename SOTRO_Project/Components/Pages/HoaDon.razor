            </div>
            <div class="px-6 py-4 border-t border-outline-variant grid grid-cols-1 sm:grid-cols-2 gap-3">
                <button id="zalo-copy-png-button" @onclick="CopyInvoicePngAsync" class="px-4 py-3 rounded-xl border border-primary text-primary font-bold flex items-center justify-center gap-2 hover:bg-blue-50">
                    <span class="material-symbols-outlined">content_copy</span>
                    <span>Copy PNG</span>
