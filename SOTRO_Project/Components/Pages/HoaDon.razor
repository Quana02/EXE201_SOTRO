    private async Task MarkAsPaid(InvoiceItem invoice)
    {
        if (invoice.InvoiceId > 0)
        {
            var response = await InvoiceApiService.MarkPaidAsync(invoice.InvoiceId, new MarkInvoicePaidRequest
            {
                Amount = invoice.TotalAmount,
                PaymentMethod = "BankTransfer",
                Note = "Cập nhật thanh toán từ trang hóa đơn"
            });

            if (!response.Success)
            {
                ShowToast(response.Message, true);
                return;
            }
        }

        invoice.Status = "Paid";
        await SavePaidKeys();
        selectedInvoice = null;
        ShowToast($"Đã cập nhật {invoice.InvoiceCode} thành Đã thanh toán.");
    }

    private void OpenMarkUnpaidDialog(InvoiceItem invoice)
    {
        markUnpaidInvoice = invoice;
    }

    private void CloseMarkUnpaidDialog()
    {
        markUnpaidInvoice = null;
    }

    private async Task ConfirmMarkAsUnpaid()
    {
        if (markUnpaidInvoice == null)
        {
            return;
        }

        var invoice = markUnpaidInvoice;
        if (invoice.InvoiceId > 0)
        {
            var response = await InvoiceApiService.MarkUnpaidAsync(invoice.InvoiceId);
            if (!response.Success)
            {
                ShowToast(response.Message, true);
                return;
            }
        }

        invoice.Status = invoice.DueDate.Date < DateTime.Today ? "Overdue" : "Pending";
        await SavePaidKeys();
        markUnpaidInvoice = null;
        selectedInvoice = null;
        ShowToast($"Đã đặt lại {invoice.InvoiceCode} về trạng thái chưa thanh toán.");
    }

