    private List<InvoiceItem> filteredInvoices => invoices
        .Where(i => string.IsNullOrWhiteSpace(selectedMonth) || i.MonthKey == selectedMonth)
        .Where(i => string.IsNullOrWhiteSpace(statusFilter) || i.Status == statusFilter)
        .ToList();

    private List<InvoiceItem> pagedInvoices => filteredInvoices
        .Skip((currentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)filteredInvoices.Count / PageSize));
    private int PageStart => filteredInvoices.Count == 0 ? 0 : ((currentPage - 1) * PageSize) + 1;
    private int PageEnd => Math.Min(currentPage * PageSize, filteredInvoices.Count);
    private int PaidCount => filteredInvoices.Count(i => i.Status == "Paid");
    private int PendingCount => filteredInvoices.Count(i => i.Status == "Pending");
    private int OverdueCount => filteredInvoices.Count(i => i.Status == "Overdue");
    private decimal PendingAmount => filteredInvoices.Where(i => i.Status != "Paid").Sum(i => i.TotalAmount);
    private int PaidRate => filteredInvoices.Count == 0 ? 0 : (int)Math.Round((double)PaidCount * 100 / filteredInvoices.Count);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        selectedMonth = availableMonths[0];
        await LoadInvoices();
        await LoadBankSettings();
        await LoadBuildingInfo();
        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadInvoices()
    {
        var paidKeys = await LoadPaidKeys();
        var built = new List<InvoiceItem>();

        try
        {
            var buildingIdText = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            int.TryParse(buildingIdText, out var buildingId);
            var tenantsResponse = await TenantApiService.GetTenantsAsync();
            var roomsResponse = buildingId > 0
                ? await RoomApiService.GetRoomsByBuildingAsync(buildingId)
                : null;
            var tenants = tenantsResponse.Data ?? new();
            var rooms = roomsResponse?.Data ?? new();
            var activeTenants = tenants
                .Where(t => t.Status == null || t.Status == "Active")
                .GroupBy(GetTenantIdentityKey)
                .Select(g => g.OrderByDescending(t => t.UpdatedAt ?? t.CreatedAt ?? DateTime.MinValue).First())
                .ToList();

            foreach (var tenant in activeTenants)
            {
                var room = rooms.FirstOrDefault(r => r.RoomId == tenant.RoomId || r.RoomCode == tenant.RoomCode);
                built.Add(CreateInvoiceFromTenant(tenant, room, paidKeys, built.Count + 1));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Invoice load error: {ex.Message}");
        }

        if (built.Count == 0)
        {
            built = CreateSampleInvoices(paidKeys);
        }

        invoices = built;
    }

    private InvoiceItem CreateInvoiceFromTenant(TenantResponse tenant, RoomResponse? room, HashSet<string> paidKeys, int index)
    {
        var dueDate = ResolveDueDate(tenant, room);
        var code = $"INV-{DateTime.Today:yyMM}-{index:000}";
        var invoiceKey = BuildInvoiceKey(tenant, room);
        var roomPrice = tenant.MonthlyRent ?? room?.BasePrice ?? 0;
        var electricFee = room?.ElectricPrice.HasValue == true ? room.ElectricPrice.Value * 30 : 0;
        var waterFee = room?.WaterPrice.HasValue == true ? room.WaterPrice.Value * 4 : 0;
        var serviceFee = room?.ServiceFee ?? 0;
        var status = paidKeys.Contains(invoiceKey) ? "Paid" : (DateTime.Today.Date > dueDate.Date ? "Overdue" : "Pending");

        return new InvoiceItem
        {
            InvoiceKey = invoiceKey,
            InvoiceCode = code,
            TenantName = tenant.FullName,
            TenantPhone = tenant.PhoneNumber ?? string.Empty,
            RoomCode = tenant.RoomCode ?? room?.RoomCode ?? "Chưa gán phòng",
            MonthKey = $"{DateTime.Today.Month:00}/{DateTime.Today.Year}",
            PeriodText = $"01/{DateTime.Today.Month:00} - {DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month)}/{DateTime.Today.Month:00}",
            RoomPrice = roomPrice,
            ElectricFee = electricFee,
            WaterFee = waterFee,
            ServiceFee = serviceFee,
            DueDate = dueDate,
            Status = status
        };
    }

    private List<InvoiceItem> CreateSampleInvoices(HashSet<string> paidKeys)
    {
        var names = new[] { "Trần Minh Quân", "Lê Thị Hoa", "Nguyễn Văn Ba", "Phạm Nhật Vượng", "Lý Quốc Sư", "Hoàng An", "Mai Thanh", "Đỗ Minh", "Ngọc Hân", "Tuấn Kiệt", "Bảo Trâm", "Quốc Huy" };
        var result = new List<InvoiceItem>();
        for (var i = 0; i < names.Length; i++)
        {
            var code = $"INV-{DateTime.Today:yyMM}-{i + 1:000}";
            var invoiceKey = $"sample:{DateTime.Today:yyyyMM}:{i + 1}";
            var status = paidKeys.Contains(invoiceKey) ? "Paid" : i % 5 == 2 ? "Overdue" : i % 3 == 0 ? "Paid" : "Pending";
            result.Add(new InvoiceItem
            {
                InvoiceKey = invoiceKey,
                InvoiceCode = code,
                TenantName = names[i],
                TenantPhone = string.Empty,
                RoomCode = $"P.{(i + 1) * 101}",
                MonthKey = $"{DateTime.Today.Month:00}/{DateTime.Today.Year}",
                PeriodText = $"01/{DateTime.Today.Month:00} - {DateTime.DaysInMonth(DateTime.Today.Year, DateTime.Today.Month)}/{DateTime.Today.Month:00}",
                RoomPrice = 2500000 + i * 150000,
                ElectricFee = 180000 + i * 10000,
                WaterFee = 80000,
                ServiceFee = 120000,
                DueDate = DateTime.Today.AddDays(i % 5 == 2 ? -3 : 5),
                Status = status
            });
        }
        return result;
    }

    private static string GetTenantIdentityKey(TenantResponse tenant)
    {
        if (tenant.TenantId > 0)
        {
            return $"tenant:{tenant.TenantId}";
        }

        var roomPart = tenant.RoomId?.ToString() ?? tenant.RoomCode ?? "no-room";
        var phonePart = tenant.PhoneNumber ?? tenant.IdentityNumber ?? tenant.FullName;
        return $"tenant:{roomPart}:{phonePart}".ToLowerInvariant();
    }

    private static string BuildInvoiceKey(TenantResponse tenant, RoomResponse? room)
    {
        var monthKey = DateTime.Today.ToString("yyyyMM");
        if (tenant.TenantId > 0)
        {
            return $"tenant:{tenant.TenantId}:{monthKey}";
        }

        var roomPart = tenant.RoomId?.ToString() ?? room?.RoomId.ToString() ?? tenant.RoomCode ?? room?.RoomCode ?? "no-room";
        var tenantPart = tenant.TenantCode;
        if (string.IsNullOrWhiteSpace(tenantPart))
        {
            tenantPart = tenant.PhoneNumber ?? tenant.IdentityNumber ?? tenant.FullName;
        }

        return $"tenant:{roomPart}:{tenantPart}:{monthKey}".ToLowerInvariant();
    }

    private static DateTime ResolveDueDate(TenantResponse tenant, RoomResponse? room)
    {
        var dueDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, Math.Clamp(room?.PaymentDueDay ?? 5, 1, 28));
        var startDate = tenant.StartDate?.ToDateTime(TimeOnly.MinValue) ?? tenant.CreatedAt?.Date;

        if (startDate.HasValue &&
            startDate.Value.Year == DateTime.Today.Year &&
            startDate.Value.Month == DateTime.Today.Month &&
            startDate.Value.Date > dueDate.Date)
        {
            return startDate.Value.Date.AddDays(7);
        }

        return dueDate;
    }

    private async Task<HashSet<string>> LoadPaidKeys()
    {
        try
        {
            var raw = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_paid_invoice_keys_v2");
            return string.IsNullOrWhiteSpace(raw)
                ? new HashSet<string>()
                : raw.Split('|', StringSplitOptions.RemoveEmptyEntries).ToHashSet();
        }
        catch
        {
            return new HashSet<string>();
        }
    }

