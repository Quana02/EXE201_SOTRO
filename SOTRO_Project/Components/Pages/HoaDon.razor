    private string GetShareableQrText()
    {
        if (bankQrMode == "auto" && !string.IsNullOrWhiteSpace(bankQrDataUrl))
        {
            return bankQrDataUrl;
        }

        return "QR đã được chủ trọ lưu trong hệ thống, vui lòng xem ảnh QR đi kèm bill.";
    }

    private static string H(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

    private string BuildGeneratedBankQrUrl()
    {
        if (string.IsNullOrWhiteSpace(bankName) || string.IsNullOrWhiteSpace(bankAccountNumber) || string.IsNullOrWhiteSpace(bankAccountHolder))
        {
            return string.Empty;
        }

        var bankCode = Uri.EscapeDataString(bankName.Trim().ToUpperInvariant());
        var accountNumber = Uri.EscapeDataString(bankAccountNumber.Trim().Replace(" ", ""));
        var accountName = Uri.EscapeDataString(bankAccountHolder.Trim().ToUpperInvariant());
        return $"https://img.vietqr.io/image/{bankCode}-{accountNumber}-compact2.png?accountName={accountName}";
    }

