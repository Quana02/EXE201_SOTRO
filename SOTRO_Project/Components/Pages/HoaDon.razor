    private async Task ToggleMonthSelection(int month)
    {
        var monthKey = BuildMonthKey(month, filterPanelYear);
        if (!selectedMonthKeys.Add(monthKey))
        {
            selectedMonthKeys.Remove(monthKey);
        }

        if (selectedMonthKeys.Count == 0)
        {
            SetDefaultMonthFilter();
        }
        else
        {
            SyncPrimaryMonthFromSelection();
        }

        await ReloadFilteredInvoicesAsync();
    }

    private async Task ResetAllFilters()
    {
        statusFilter = string.Empty;
        SetDefaultMonthFilter();
        showMonthFilterPanel = false;
        await ReloadFilteredInvoicesAsync(generateMissing: true);
    }

    private async Task ReloadFilteredInvoicesAsync(bool generateMissing = false)
    {
        currentPage = 1;
        isLoading = true;
        StateHasChanged();
        await LoadInvoices(generateMissing);
        isLoading = false;
    }

    private void SetDefaultMonthFilter()
    {
        filterMonth = DateTime.Today.Month;
        filterYear = DateTime.Today.Year;
        filterPanelYear = filterYear;
        selectedMonth = BuildMonthKey(filterMonth, filterYear);
        selectedMonthKeys = new HashSet<string>(StringComparer.Ordinal) { selectedMonth };
    }

    private void SyncPrimaryMonthFromSelection()
    {
        var primaryMonth = selectedMonthKeys
            .Select(ParseMonthKey)
            .Where(month => month.HasValue)
            .Select(month => month!.Value)
            .OrderByDescending(month => month.Year)
            .ThenByDescending(month => month.Month)
            .FirstOrDefault();

        if (primaryMonth.Month <= 0)
        {
            return;
        }

        filterMonth = primaryMonth.Month;
        filterYear = primaryMonth.Year;
        selectedMonth = BuildMonthKey(filterMonth, filterYear);
    }

    private async Task<GenerateMonthlyInvoicesRequest> BuildGenerateInvoiceRequest(int buildingId, int month, int year)
    {
        return new GenerateMonthlyInvoicesRequest
        {
            BuildingId = buildingId,
            Month = month,
            Year = year,
            TrashFee = await GetDecimalSetting("sotro_common_trash_fee", buildingId),
            InternetFee = await GetDecimalSetting("sotro_common_internet_fee", buildingId),
            CleaningFee = await GetDecimalSetting("sotro_common_cleaning_fee", buildingId),
            ManagementFee = await GetDecimalSetting("sotro_common_management_fee", buildingId)
        };
    }

    private async Task<decimal> GetDecimalSetting(string key, int? buildingId = null)
    {
        var rawValue = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey(key, buildingId));
        if (decimal.TryParse(rawValue, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var value))
        {
            return value;
        }

        return decimal.TryParse(rawValue, out value) ? value : 0m;
    }

    private async Task EnsureActiveBuildingIdAsync()
    {
        if (activeBuildingId > 0)
        {
            return;
        }

        var buildingIdText = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
        int.TryParse(buildingIdText, out activeBuildingId);
    }

    private string ScopedSettingKey(string key, int? buildingId = null)
    {
        var scopedBuildingId = buildingId.GetValueOrDefault(activeBuildingId);
        return scopedBuildingId > 0 ? $"{key}_b{scopedBuildingId}" : key;
    }

