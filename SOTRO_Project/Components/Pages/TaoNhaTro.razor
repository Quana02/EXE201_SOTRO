@page "/tao-nha-tro"
@layout EmptyLayout

<PageTitle>Tạo nhà trọ - Sổ trọ</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .form-focus-glow:focus-within {
            box-shadow: 0 0 0 3px rgba(0, 86, 179, 0.1);
        }
    

    </style>
}


<!-- TopNavBar -->
<HeaderDashboard/>
<!-- Main Content Canvas -->
<main class="min-h-[calc(100vh-128px)] py-12 px-margin-mobile md:px-margin-desktop">
    <div class="max-w-[800px] mx-auto">
        <!-- Breadcrumbs & Header -->
        <div class="mb-8">
            <nav class="flex items-center gap-2 text-caption text-secondary mb-4">
                <a class="hover:text-primary" href="#">Danh sách nhà trọ</a>
                <span class="material-symbols-outlined text-[16px]" data-icon="chevron_right">chevron_right</span>
                <span class="text-primary font-medium">Tạo nhà trọ mới</span>
            </nav>
            <h1 class="font-headline-md text-headline-md text-on-surface">Tạo nhà trọ mới</h1>
            <p class="text-body-md text-on-surface-variant mt-2">Điền thông tin chi tiết để bắt đầu quản lý cơ sở kinh doanh mới của bạn.</p>
        </div>
        <!-- Form Card -->
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-sm p-8">
            <form class="space-y-8" id="createPropertyForm">
                <!-- Section 1: Basic Info -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="col-span-2 flex flex-col gap-2">
                        <label class="font-label-md text-on-surface-variant" for="propertyName">Tên nhà trọ <span class="text-error">*</span></label>
                        <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary transition-all text-body-md placeholder:text-outline outline-none" id="propertyName" placeholder="Nhập tên nhà trọ (ví dụ: Sổ Trọ Central)" type="text">
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="font-label-md text-on-surface-variant" for="propertyType">Loại nhà trọ <span class="text-error">*</span></label>
                        <div class="relative">
                            <select class="w-full appearance-none bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary transition-all text-body-md outline-none" id="propertyType">
                                <option disabled="" selected="" value="">Chọn loại hình</option>
                                <option value="traditional">Nhà trọ truyền thống</option>
                                <option value="mini_apartment">Chung cư mini</option>
                                <option value="serviced">Căn hộ dịch vụ</option>
                                <option value="dorm">Ký túc xá</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-secondary" data-icon="expand_more">expand_more</span>
                        </div>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="font-label-md text-on-surface-variant" for="floors">Số tầng <span class="text-error">*</span></label>
                        <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary transition-all text-body-md placeholder:text-outline outline-none" id="floors" min="1" placeholder="Ví dụ: 5" type="number">
                    </div>
                    <div class="col-span-2 flex flex-col gap-2">
                        <label class="font-label-md text-on-surface-variant" for="address">Địa chỉ <span class="text-error">*</span></label>
                        <div class="relative">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-secondary" data-icon="location_on">location_on</span>
                            <input class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg pl-10 pr-4 py-3 focus:border-primary focus:ring-1 focus:ring-primary transition-all text-body-md placeholder:text-outline outline-none" id="address" placeholder="Số nhà, tên đường, phường, quận, thành phố" type="text">
                        </div>
                    </div>
                </div>
                <!-- Decorative Separator -->
                <div class="h-px bg-outline-variant"></div>
                <!-- Additional Details / Visual Element -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="md:col-span-1">
                        <h3 class="font-label-md font-bold text-on-surface uppercase tracking-wider mb-2">Ảnh đại diện</h3>
                        <p class="text-caption text-on-surface-variant">Sử dụng ảnh chất lượng cao để tăng khả năng thu hút khách thuê.</p>
                    </div>
                    <div class="md:col-span-2">
                        <div class="border-2 border-dashed border-outline-variant rounded-xl p-8 flex flex-col items-center justify-center bg-surface-container-low hover:bg-surface-container transition-colors cursor-pointer group">
                            <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors text-4xl mb-2" data-icon="add_a_photo">add_a_photo</span>
                            <p class="text-body-md font-medium text-secondary">Tải ảnh lên hoặc kéo thả</p>
                            <p class="text-caption text-outline mt-1">PNG, JPG tối đa 5MB</p>
                        </div>
                    </div>
                </div>
                <!-- Actions -->
                <div class="flex flex-col sm:flex-row items-center justify-end gap-4 pt-6">
                    <button class="w-full sm:w-auto px-8 py-3 rounded-full font-label-md text-primary hover:bg-surface-container-low transition-all cursor-pointer" type="button">
                        Hủy
                    </button>
                    <button class="w-full sm:w-auto px-8 py-3 rounded-full font-label-md bg-primary text-on-primary hover:bg-primary-container shadow-sm hover:shadow-md transition-all active:scale-[0.98] cursor-pointer" type="submit">
                        Tạo nhà trọ
                    </button>
                </div>
            </form>
        </div>
        <!-- Contextual Tip -->
        <div class="mt-8 flex gap-4 p-4 bg-tertiary-container/10 rounded-lg border border-tertiary-container/20">
            <span class="material-symbols-outlined text-tertiary" data-icon="lightbulb">lightbulb</span>
            <div>
                <h4 class="font-label-md font-bold text-tertiary">Mẹo chuyên nghiệp</h4>
                <p class="text-caption text-on-tertiary-fixed-variant mt-1">Sau khi tạo nhà trọ, bạn có thể thiết lập các phòng riêng lẻ và cấu hình bảng giá điện nước ngay tại Dashboard của nhà trọ đó.</p>
            </div>
        </div>
    </div>
</main>
<!-- Footer -->
<script>
        // Form submission animation effect
        document.getElementById('createPropertyForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalContent = btn.innerHTML;
            
            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin" data-icon="progress_activity">progress_activity</span> Äang táº¡o...';
            
            // Simulating a success interaction
            setTimeout(() => {
                btn.classList.replace('bg-primary', 'bg-success-container');
                btn.classList.add('bg-green-600'); // Fallback color
                btn.innerHTML = '<span class="material-symbols-outlined" data-icon="check">check</span> ÄÃ£ táº¡o thÃ nh cÃ´ng';
                
                setTimeout(() => {
                    alert('NhÃ  trá» má»›i Ä‘Ã£ Ä‘Æ°á»£c táº¡o thÃ nh cÃ´ng!');
                    btn.innerHTML = originalContent;
                    btn.disabled = false;
                    btn.classList.remove('bg-green-600');
                }, 1000);
            }, 1500);
        });

        // Dropdown interaction effect
        const selectElement = document.getElementById('propertyType');
        selectElement.addEventListener('change', function() {
            this.classList.add('text-on-surface');
            this.classList.remove('text-outline');
        });
    </script>




@code {
    private const string CustomStyles = "TaoNhaTro";
}