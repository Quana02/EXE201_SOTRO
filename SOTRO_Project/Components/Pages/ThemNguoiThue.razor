    [JSInvokable]
    public async Task<List<string>> GetSuggestions(string query)
    {
        try
        {
            var response = await BuildingApi.SuggestAddressAsync(query);
            if (response.Success && response.Data != null)
            {
                return response.Data;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching suggestions: {ex.Message}");
        }
        return new List<string>();
    }

    private bool Validate()
    {
        errors.Clear();

        if (string.IsNullOrWhiteSpace(tenant.FullName))
        {
            errors["FullName"] = "Họ và tên là bắt buộc.";
        }

        if (string.IsNullOrWhiteSpace(tenant.PhoneNumber))
        {
            errors["PhoneNumber"] = "Số điện thoại là bắt buộc.";
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(tenant.PhoneNumber, @"^\d+$"))
        {
            errors["PhoneNumber"] = "Số điện thoại chỉ được nhập số.";
        }

        if (!string.IsNullOrWhiteSpace(tenant.Email))
        {
            if (!tenant.Email.Contains("@") || !System.Text.RegularExpressions.Regex.IsMatch(tenant.Email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            {
                errors["Email"] = "Email không đúng định dạng (phải chứa @ và tên miền hợp lệ).";
            }
        }

        if (string.IsNullOrWhiteSpace(tenant.IdentityNumber))
        {
            errors["IdentityNumber"] = "Số CCCD/Passport là bắt buộc.";
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(tenant.IdentityNumber, @"^\d+$"))
        {
            errors["IdentityNumber"] = "Số CCCD/Passport chỉ được nhập số.";
        }

        if (tenant.DateOfBirth == null)
        {
            errors["DateOfBirth"] = "Ngày sinh là bắt buộc.";
        }
        else
        {
            var ageLimitDate = DateOnly.FromDateTime(DateTime.Today).AddYears(-16);
            if (tenant.DateOfBirth > ageLimitDate)
            {
                errors["DateOfBirth"] = "Ngày sinh phải từ 16 tuổi trở lên.";
            }
        }

        if (tenant.RoomId <= 0)
        {
            errors["RoomId"] = "Vui lòng chọn phòng thuê.";
        }

        if (tenant.StartDate == default)
        {
            errors["StartDate"] = "Ngày bắt đầu ở là bắt buộc.";
        }

        var selectedRoom = availableRooms.FirstOrDefault(r => r.RoomId == tenant.RoomId);
        decimal roomPrice = selectedRoom?.BasePrice ?? 0;
        if (tenant.DepositAmount.HasValue)
        {
            if (tenant.DepositAmount.Value < 0)
            {
                errors["DepositAmount"] = "Tiền đặt cọc không được là số âm.";
            }
            else if (tenant.DepositAmount.Value > roomPrice)
            {
                errors["DepositAmount"] = $"Tiền đặt cọc ({tenant.DepositAmount.Value:N0} VNĐ) không được vượt quá giá thuê phòng ({roomPrice:N0} VNĐ).";
            }
        }

        return errors.Count == 0;
    }

    private async Task SaveTenant()
    {
        if (!Validate())
        {
            StateHasChanged();
            return;
        }

        isSaving = true;
        tenant.MonthlyRent = availableRooms.FirstOrDefault(r => r.RoomId == tenant.RoomId)?.BasePrice;
        var response = IsEditMode
            ? await TenantApi.UpdateTenantAsync(TenantId.GetValueOrDefault(), tenant)
            : await TenantApi.CreateTenantAsync(tenant);
        isSaving = false;

        if (response.Success)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_tenant_form_guided_seen", "true");
            errors.Clear();
            showSuccessPopup = true;
            StateHasChanged();

            popupCts = new System.Threading.CancellationTokenSource();
            try
            {
                for (int i = 3; i > 0; i--)
                {
                    countdown = i;
                    StateHasChanged();
                    await Task.Delay(1000, popupCts.Token);
                }
                RedirectToTenants();
            }
            catch (TaskCanceledException)
            {
                // Redirected manually
            }
        }
        else
        {
            errors["Submit"] = response.Message ?? "Đã xảy ra lỗi khi lưu thông tin người thuê.";
            StateHasChanged();
        }
    }

    private void RedirectToTenants()
    {
        popupCts?.Cancel();
        Navigation.NavigateTo(TenantListHref);
    }

    private void Cancel()
    {
        Navigation.NavigateTo(TenantListHref);
    }

    private static bool IsRoomAvailableForNewTenant(SOTRO_Project.Models.Room.RoomResponse room)
    {
        if (room.Status == "Maintenance")
            return false;

        if (!room.Capacity.HasValue || room.Capacity.Value <= 0)
            return true;

        return (room.CurrentTenantCount ?? 0) < room.Capacity.Value;
    }

