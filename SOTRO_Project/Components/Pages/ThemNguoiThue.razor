</div>
</div>
<!-- Form Grid -->
@if (errors.ContainsKey("Submit"))
{
    <div class="p-4 bg-red-50 text-red-700 rounded-lg border border-red-200 text-sm flex items-center gap-2 mb-6">
        <span class="material-symbols-outlined text-red-500" data-icon="error">error</span>
        <span>@errors["Submit"]</span>
    </div>
}
<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_380px] gap-8 items-start">
<!-- Left Column: Primary Info -->
<div class="flex flex-col gap-8 min-w-0">
<!-- Section: Thông tin cá nhân -->
