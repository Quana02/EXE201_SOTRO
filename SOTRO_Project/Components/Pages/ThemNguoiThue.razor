<div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
<span class="material-symbols-outlined text-primary" data-icon="person">person</span>
<h4 class="font-headline-sm text-body-lg font-bold text-primary">Thông tin cá nhân</h4>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
<div class="flex flex-col gap-2">
