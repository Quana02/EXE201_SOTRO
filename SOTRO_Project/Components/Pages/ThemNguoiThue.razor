<label class="font-label-md text-label-md text-on-surface-variant">Ảnh chân dung</label>
<label id="tenant-portrait-upload" class="group relative w-full h-64 bg-surface-container rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center overflow-hidden hover:border-primary transition-all cursor-pointer">
<InputFile class="hidden" accept="image/*" OnChange="OnPortraitSelected" />
@if (!string.IsNullOrWhiteSpace(portraitPreviewUrl))
