@if (!string.IsNullOrWhiteSpace(identityFrontPreviewUrl))
{
<img alt="CCCD mặt trước" class="absolute inset-0 w-full h-full object-cover" src="@identityFrontPreviewUrl">
}
else
{
<div class="flex flex-col items-center gap-2 text-on-surface-variant group-hover:text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="id_card">id_card</span>
<span class="text-caption">Nhấn để tải lên</span>
</div>
}
</label>
</div>
<!-- ID Card Back -->
<div class="flex flex-col gap-3">
<label class="font-label-md text-label-md text-on-surface-variant">CCCD Mặt sau</label>
<label class="group relative w-full h-44 bg-surface-container rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center overflow-hidden hover:border-primary transition-all cursor-pointer">
<InputFile class="hidden" accept="image/*" OnChange="OnIdentityBackSelected" />
@if (!string.IsNullOrWhiteSpace(identityBackPreviewUrl))
{
<img alt="CCCD mặt sau" class="absolute inset-0 w-full h-full object-cover" src="@identityBackPreviewUrl">
}
else
{
<div class="flex flex-col items-center gap-2 text-on-surface-variant group-hover:text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="badge">badge</span>
<span class="text-caption">Nhấn để tải lên</span>
</div>
}
</label>
</div>
</div>
</div>
<div class="mt-6 p-4 rounded-lg bg-surface-container-low border border-outline-variant">
<p class="text-caption text-on-surface-variant flex gap-2">
<span class="material-symbols-outlined text-[16px] text-primary" data-icon="info">info</span>
                                        Định dạng hỗ trợ: JPG, PNG, PDF. Dung lượng tối đa 5MB mỗi file.
                                    </p>
</div>
</section>
</div>
</div>
</div>
<!-- Spacer -->
<div class="h-12"></div>
</main>

@if (showSuccessPopup)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm transition-all duration-300">
        <div class="bg-white rounded-2xl shadow-xl border border-outline-variant max-w-md w-full p-6 mx-4 transform transition-all flex flex-col items-center text-center">
            <!-- Check Circle Icon with background -->
            <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mb-4 text-green-600 shadow-inner">
                <span class="material-symbols-outlined text-4xl" data-icon="check_circle">check_circle</span>
            </div>
            
            <h3 class="text-headline-sm font-bold text-primary mb-2">Thao tác thành công!</h3>
            <p class="text-body-md text-on-surface-variant mb-6">
                Thông tin người thuê đã được lưu thành công vào hệ thống.
            </p>
            
            <div class="text-caption text-secondary mb-4 flex items-center gap-1.5 justify-center">
                <span class="material-symbols-outlined text-[16px] animate-spin">sync</span>
                <span>Tự động quay lại sau <strong class="text-primary font-bold">@countdown</strong> giây...</span>
            </div>
            
            <button @onclick="RedirectToTenants" class="w-full py-2.5 rounded-xl bg-primary-container text-on-primary font-label-md hover:opacity-90 transition-all font-bold">
                Đóng
            </button>
        </div>
    </div>
}
<script>
        // Simple micro-interaction for room selection
        const roomSelect = document.getElementById('tenant-room-select');
        const priceInput = document.getElementById('room-price');

        roomSelect?.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const price = selectedOption.getAttribute('data-price');
            if (price) {
                priceInput.value = price;
                priceInput.classList.add('text-primary');
                // Pulse effect
                priceInput.animate([
                    { transform: 'scale(1)' },
                    { transform: 'scale(1.02)' },
                    { transform: 'scale(1)' }
                ], { duration: 200 });
            } else {
                priceInput.value = '0';
                priceInput.classList.remove('text-primary');
            }
        });

        // Hover animations for cards
        document.querySelectorAll('section').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.transform = 'translateY(-2px)';
                card.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'translateY(0)';
            });
        });
</script>

<GuidedOnboarding IsVisible="showTenantFormTour"
                  Steps="tenantFormGuidedSteps"
                  StorageKey="sotro_tenant_form_guided_seen"
                  AllowSkip="true"
                  OnCompleted="CloseTenantFormTour"
                  OnSkipped="CloseTenantFormTour" />


@code {
    private const string CustomStyles = "ThemNguoiThue";
    [Parameter] public int? TenantId { get; set; }

    private readonly SOTRO_Project.Models.Tenant.UpdateTenantRequest tenant = new()
    {
        StartDate = DateOnly.FromDateTime(DateTime.Today),
        Status = "Active"
    };
    private List<SOTRO_Project.Models.Room.RoomResponse> availableRooms = new();
    private int? activeBuildingId;
    private bool isSaving;
    private string? portraitPreviewUrl;
    private string? identityFrontPreviewUrl;
    private string? identityBackPreviewUrl;

    private bool IsEditMode => TenantId.HasValue;
    private string PageTitleText => IsEditMode ? "Chỉnh sửa người thuê" : "Thêm người thuê mới";
    private string SelectedRoomPrice => availableRooms.FirstOrDefault(r => r.RoomId == tenant.RoomId)?.BasePrice?.ToString("N0") ?? "0";

    [SupplyParameterFromQuery(Name = "buildingId")]
    public int? BuildingId { get; set; }

    // Validation and popup state
    private Dictionary<string, string> errors = new();
    private bool showSuccessPopup;
    private int countdown = 3;
    private System.Threading.CancellationTokenSource? popupCts;
    private DotNetObjectReference<ThemNguoiThue>? dotNetHelper;
    private bool showTenantFormTour;
    private bool hasCheckedTenantFormTour;
    private readonly IReadOnlyList<GuidedOnboarding.GuidedStep> tenantFormGuidedSteps = new[]
    {
        new GuidedOnboarding.GuidedStep(
            "#tenant-fullname-input",
            "Nhập họ tên người thuê",
            "Đây là thông tin chính để nhận diện người thuê trong danh sách, hợp đồng và hóa đơn.",
            "Click vào ô đang sáng và nhập họ tên đầy đủ."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-phone-input",
            "Nhập số điện thoại",
            "Số điện thoại dùng để liên hệ, nhắc thanh toán và hỗ trợ các tính năng tự động sau này.",
            "Click vào ô đang sáng và nhập số điện thoại chỉ gồm chữ số."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-identity-input",
            "Nhập CCCD hoặc Passport",
            "Thông tin giấy tờ giúp hồ sơ người thuê đầy đủ và dễ đối chiếu khi cần.",
            "Click vào ô đang sáng và nhập số CCCD/Passport."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-dob-input",
            "Chọn ngày sinh",
            "Ngày sinh giúp hoàn thiện hồ sơ cá nhân. Hệ thống đang kiểm tra người thuê phải từ 16 tuổi trở lên.",
            "Click vào ô đang sáng và chọn ngày sinh."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-room-select",
            "Chọn phòng thuê",
            "Người thuê phải được gắn vào đúng phòng để hệ thống cập nhật trạng thái phòng, số người đang ở và tỷ lệ lấp đầy.",
            "Click vào ô đang sáng và chọn phòng trống hoặc phòng còn sức chứa."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-start-date-input",
            "Chọn ngày bắt đầu ở",
            "Ngày bắt đầu ở là mốc để theo dõi hợp đồng, tiền cọc và chu kỳ thu tiền.",
            "Click vào ô đang sáng và chọn ngày bắt đầu thuê."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-deposit-input",
            "Nhập tiền đặt cọc",
            "Tiền cọc giúp bạn theo dõi khoản đang giữ của người thuê. Có thể để trống nếu chưa thu cọc.",
            "Click vào ô đang sáng và nhập số tiền cọc nếu có."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-portrait-upload",
            "Tải ảnh chân dung",
            "Ảnh chân dung giúp hồ sơ người thuê dễ nhận diện hơn. Đây là bước khuyến nghị, không bắt buộc.",
            "Click vùng đang sáng để tải ảnh, hoặc bấm Tiếp tục nếu chưa có ảnh."),
        new GuidedOnboarding.GuidedStep(
            "#tenant-save-button",
            "Lưu người thuê",
            "Sau khi lưu, người thuê sẽ xuất hiện trong danh sách và phòng được cập nhật trạng thái sử dụng.",
            "Click nút Lưu người thuê sau khi đã nhập các thông tin bắt buộc.",
            true)
    };

    protected override async Task OnInitializedAsync()
    {
        activeBuildingId = await ResolveActiveBuildingIdAsync();
        if (activeBuildingId is null or <= 0)
        {
            Navigation.NavigateTo("/nha-tro", replace: true);
            return;
        }

        var rooms = await RoomApi.GetRoomsByBuildingAsync(activeBuildingId.Value);
        availableRooms = rooms.Data?.Where(IsRoomAvailableForNewTenant).ToList() ?? new();

        if (IsEditMode)
        {
            var tenantResponse = await TenantApi.GetTenantByIdAsync(TenantId.GetValueOrDefault());
            var data = tenantResponse.Data;
            if (data == null)
                return;

            tenant.FullName = data.FullName;
            tenant.PhoneNumber = data.PhoneNumber ?? string.Empty;
            tenant.Email = data.Email;
            tenant.IdentityNumber = data.IdentityNumber ?? string.Empty;
            tenant.DateOfBirth = data.DateOfBirth;
            tenant.PermanentAddress = data.PermanentAddress;
            tenant.RoomId = data.RoomId ?? 0;
            tenant.StartDate = data.StartDate ?? DateOnly.FromDateTime(DateTime.Today);
            tenant.EndDate = data.EndDate;
            tenant.DepositAmount = data.DepositAmount;
            tenant.MonthlyRent = data.MonthlyRent;
            tenant.Status = data.Status ?? "Active";

            var currentRoom = rooms.Data?.FirstOrDefault(r => r.RoomId == tenant.RoomId);
            if (currentRoom != null && availableRooms.All(r => r.RoomId != currentRoom.RoomId))
                availableRooms.Insert(0, currentRoom);

            return;
        }

        var firstRoom = availableRooms.FirstOrDefault();
        if (firstRoom != null)
        {
            tenant.RoomId = firstRoom.RoomId;
            tenant.MonthlyRent = firstRoom.BasePrice;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetHelper = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("window.initAddressAutocomplete", "tenant-hometown-input", dotNetHelper, nameof(OnAddressSelected));
            await StartTenantFormTourIfNeeded();
        }
    }

    private async Task StartTenantFormTourIfNeeded()
    {
        if (hasCheckedTenantFormTour || IsEditMode)
        {
            return;
        }

        hasCheckedTenantFormTour = true;

        try
        {
            var dismissed = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_tenant_form_guided_seen");
            showTenantFormTour = string.IsNullOrWhiteSpace(dismissed);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Tenant form guided tour error: {ex.Message}");
        }
    }

    private void CloseTenantFormTour()
    {
        showTenantFormTour = false;
    }

    private void OpenTenantFormTour()
    {
        if (IsEditMode)
        {
            return;
        }

        showTenantFormTour = true;
        StateHasChanged();
    }

    private async Task<int?> ResolveActiveBuildingIdAsync()
    {
        if (BuildingId is > 0)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "active_building_id", BuildingId.Value.ToString());
            return BuildingId.Value;
        }

        try
        {
            var idText = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            return int.TryParse(idText, out var id) && id > 0 ? id : null;
        }
        catch
        {
            return null;
        }
    }

    private string TenantListHref => activeBuildingId is > 0
        ? $"/nguoi-thue?buildingId={activeBuildingId.Value}"
        : "/nguoi-thue";

    [JSInvokable]
    public void OnAddressSelected(string address)
