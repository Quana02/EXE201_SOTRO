@page "/them-nguoi-thue"
@layout EmptyLayout
@page "/sua-nguoi-thue/{TenantId:int}"
@inject NavigationManager Navigation
@inject IBuildingApiService BuildingApi
@inject IRoomApiService RoomApi
@inject ITenantApiService TenantApi

<PageTitle>@PageTitleText - SOTRO</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Inter', sans-serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(8px);
            border: 1px solid #E9ECEF;
        }
        .sidebar-active {
            background-color: #dae4ee;
            color: #003f87;
            font-weight: 700;
            border-radius: 0.5rem;
        }
    

    </style>
}

<HeaderDashboard />
<SideNavBar />
<!-- Main Content Area -->
<main class="ml-64 p-gutter w-[calc(100%-16rem)]">
<div class="flex flex-col gap-6 max-w-[1280px] mx-auto">
<!-- Page Header -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
<div>
<nav aria-label="Breadcrumb" class="flex mb-2">
<ol class="inline-flex items-center space-x-1 md:space-x-3 text-caption text-on-surface-variant">
<li class="inline-flex items-center">
<a class="hover:text-primary" href="#">Người thuê</a>
</li>
<li>
<div class="flex items-center">
<span class="material-symbols-outlined text-sm mx-1" data-icon="chevron_right">chevron_right</span>
<span class="font-medium text-on-surface">@(IsEditMode ? "Chỉnh sửa" : "Thêm mới")</span>
</div>
</li>
</ol>
</nav>
<h3 class="font-headline-md text-headline-md text-primary">@PageTitleText</h3>
</div>
<div class="flex items-center gap-3">
<button @onclick="Cancel" class="px-6 py-2.5 rounded-xl border border-outline text-on-surface font-label-md hover:bg-surface-container transition-all">Hủy</button>
<button @onclick="SaveTenant" disabled="@isSaving" class="px-6 py-2.5 rounded-xl bg-primary-container text-on-primary font-label-md hover:opacity-90 shadow-lg shadow-primary-container/20 transition-all flex items-center gap-2">
<span class="material-symbols-outlined text-[20px]" data-icon="save">save</span>
                                @(isSaving ? "Đang lưu..." : IsEditMode ? "Cập nhật người thuê" : "Lưu người thuê")
                            </button>
</div>
</div>
<!-- Form Grid -->
<div class="grid grid-cols-1 lg:grid-cols-[minmax(0,2fr)_380px] gap-8 items-start">
<!-- Left Column: Primary Info -->
<div class="flex flex-col gap-8 min-w-0">
<!-- Section: Thông tin cá nhân -->
<section class="p-6 rounded-xl bg-white shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-[#E9ECEF]">
<div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
<span class="material-symbols-outlined text-primary" data-icon="person">person</span>
<h4 class="font-headline-sm text-body-lg font-bold text-primary">Thông tin cá nhân</h4>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Họ và tên *</label>
<input @bind="tenant.FullName" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="Nguyễn Văn A" type="text">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Số điện thoại *</label>
<input @bind="tenant.PhoneNumber" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="090x xxx xxx" type="tel">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Email</label>
<input @bind="tenant.Email" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="example@gmail.com" type="email">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Số CCCD/Passport *</label>
<input @bind="tenant.IdentityNumber" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="001xxxxxxxxx" type="text">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Ngày sinh</label>
<input @bind="tenant.DateOfBirth" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" type="date">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Quê quán</label>
<input @bind="tenant.PermanentAddress" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="Thành phố Hồ Chí Minh" type="text">
</div>
</div>
</section>
<!-- Section: Thông tin thuê phòng -->
<section class="p-6 rounded-xl bg-white shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-[#E9ECEF]">
<div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
<span class="material-symbols-outlined text-primary" data-icon="meeting_room">meeting_room</span>
<h4 class="font-headline-sm text-body-lg font-bold text-primary">Thông tin thuê phòng</h4>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-4">
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Chọn phòng *</label>
<select @bind="tenant.RoomId" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none bg-white" id="room-select">
<option value="">Chọn phòng trống</option>
@foreach (var room in availableRooms)
{
<option data-price="@room.BasePrice?.ToString("N0")" value="@room.RoomId">@room.RoomCode - @(room.RoomName ?? $"Tầng {room.FloorNumber}")</option>
}
</select>
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Ngày bắt đầu ở *</label>
<input @bind="tenant.StartDate" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" type="date">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Tiền đặt cọc (VNĐ)</label>
<input @bind="tenant.DepositAmount" class="px-4 py-2.5 rounded-lg border border-[#DEE2E6] focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all outline-none" placeholder="Ví dụ: 3500000" type="number">
</div>
<div class="flex flex-col gap-2">
<label class="font-label-md text-label-md text-on-surface-variant">Giá thuê niêm yết</label>
<div class="relative">
<input class="w-full px-4 py-2.5 rounded-lg border border-[#DEE2E6] bg-surface-container-low text-on-surface font-bold outline-none" id="room-price" placeholder="0" readonly="" type="text" value="@SelectedRoomPrice">
<span class="absolute right-4 top-1/2 -translate-y-1/2 text-caption text-on-surface-variant">VNĐ/tháng</span>
</div>
</div>
</div>
</section>
</div>
<!-- Right Column: Documents -->
<div class="flex flex-col gap-8 sticky top-24 min-w-0">
<section class="p-6 rounded-xl bg-white shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-[#E9ECEF] flex flex-col h-full">
<div class="flex items-center gap-2 mb-6 border-b border-outline-variant pb-4">
<span class="material-symbols-outlined text-primary" data-icon="attachment">attachment</span>
<h4 class="font-headline-sm text-body-lg font-bold text-primary">Giấy tờ đính kèm</h4>
</div>
<div class="space-y-6 flex-1">
<!-- Portrait Photo -->
<div class="flex flex-col gap-3">
<label class="font-label-md text-label-md text-on-surface-variant">Ảnh chân dung</label>
<label class="group relative w-full h-64 bg-surface-container rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center overflow-hidden hover:border-primary transition-all cursor-pointer">
<InputFile class="hidden" accept="image/*" OnChange="OnPortraitSelected" />
@if (!string.IsNullOrWhiteSpace(portraitPreviewUrl))
{
<img alt="Ảnh chân dung" class="absolute inset-0 w-full h-full object-cover" src="@portraitPreviewUrl">
}
else
{
<div class="flex flex-col items-center gap-2 text-on-surface-variant group-hover:text-primary">
<span class="material-symbols-outlined text-4xl" data-icon="add_a_photo">add_a_photo</span>
<span class="text-caption">Tải lên ảnh chân dung</span>
</div>
}
</label>
</div>
<div class="grid grid-cols-1 gap-6">
<!-- ID Card Front -->
<div class="flex flex-col gap-3">
<label class="font-label-md text-label-md text-on-surface-variant">CCCD Mặt trước</label>
<label class="group relative w-full h-44 bg-surface-container rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center overflow-hidden hover:border-primary transition-all cursor-pointer">
<InputFile class="hidden" accept="image/*" OnChange="OnIdentityFrontSelected" />
@if (!string.IsNullOrWhiteSpace(identityFrontPreviewUrl))
{
<img alt="CCCD mặt trước" class="absolute inset-0 w-full h-full object-cover" src="@identityFrontPreviewUrl">
}
else
{
<div class="flex flex-col items-center gap-2 text-on-surface-variant group-hover:text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="id_card">id_card</span>
<span class="text-caption">Nhấn để tải lên</span>
</div>
}
</label>
</div>
<!-- ID Card Back -->
<div class="flex flex-col gap-3">
<label class="font-label-md text-label-md text-on-surface-variant">CCCD Mặt sau</label>
<label class="group relative w-full h-44 bg-surface-container rounded-xl border-2 border-dashed border-outline-variant flex flex-col items-center justify-center overflow-hidden hover:border-primary transition-all cursor-pointer">
<InputFile class="hidden" accept="image/*" OnChange="OnIdentityBackSelected" />
@if (!string.IsNullOrWhiteSpace(identityBackPreviewUrl))
{
<img alt="CCCD mặt sau" class="absolute inset-0 w-full h-full object-cover" src="@identityBackPreviewUrl">
}
else
{
<div class="flex flex-col items-center gap-2 text-on-surface-variant group-hover:text-primary">
<span class="material-symbols-outlined text-3xl" data-icon="badge">badge</span>
<span class="text-caption">Nhấn để tải lên</span>
</div>
}
</label>
</div>
</div>
</div>
<div class="mt-6 p-4 rounded-lg bg-surface-container-low border border-outline-variant">
<p class="text-caption text-on-surface-variant flex gap-2">
<span class="material-symbols-outlined text-[16px] text-primary" data-icon="info">info</span>
                                        Định dạng hỗ trợ: JPG, PNG, PDF. Dung lượng tối đa 5MB mỗi file.
                                    </p>
</div>
</section>
</div>
</div>
</div>
<!-- Spacer -->
<div class="h-12"></div>
</main>
<script>
        // Simple micro-interaction for room selection
        const roomSelect = document.getElementById('room-select');
        const priceInput = document.getElementById('room-price');

        roomSelect.addEventListener('change', function() {
            const selectedOption = this.options[this.selectedIndex];
            const price = selectedOption.getAttribute('data-price');
            if (price) {
                priceInput.value = price;
                priceInput.classList.add('text-primary');
                // Pulse effect
                priceInput.animate([
                    { transform: 'scale(1)' },
                    { transform: 'scale(1.02)' },
                    { transform: 'scale(1)' }
                ], { duration: 200 });
            } else {
                priceInput.value = '0';
                priceInput.classList.remove('text-primary');
            }
        });

        // Hover animations for cards
        document.querySelectorAll('section').forEach(card => {
            card.addEventListener('mouseenter', () => {
                card.style.transform = 'translateY(-2px)';
                card.style.transition = 'all 0.3s cubic-bezier(0.4, 0, 0.2, 1)';
            });
            card.addEventListener('mouseleave', () => {
                card.style.transform = 'translateY(0)';
            });
        });
    </script>


@code {
    private const string CustomStyles = "ThemNguoiThue";
    [Parameter] public int? TenantId { get; set; }

    private readonly SOTRO_Project.Models.Tenant.UpdateTenantRequest tenant = new()
    {
        StartDate = DateOnly.FromDateTime(DateTime.Today),
        Status = "Active"
    };
    private List<SOTRO_Project.Models.Room.RoomResponse> availableRooms = new();
    private bool isSaving;
    private string? portraitPreviewUrl;
    private string? identityFrontPreviewUrl;
    private string? identityBackPreviewUrl;

    private bool IsEditMode => TenantId.HasValue;
    private string PageTitleText => IsEditMode ? "Chỉnh sửa người thuê" : "Thêm người thuê mới";
    private string SelectedRoomPrice => availableRooms.FirstOrDefault(r => r.RoomId == tenant.RoomId)?.BasePrice?.ToString("N0") ?? "0";

    protected override async Task OnInitializedAsync()
    {
        var buildings = await BuildingApi.GetBuildingsAsync();
        var buildingId = buildings.Data?.FirstOrDefault()?.BuildingId;
        if (buildingId == null)
            return;

        var rooms = await RoomApi.GetRoomsByBuildingAsync(buildingId.Value);
        availableRooms = rooms.Data?.Where(IsRoomAvailableForNewTenant).ToList() ?? new();

        if (IsEditMode)
        {
            var tenantResponse = await TenantApi.GetTenantByIdAsync(TenantId.GetValueOrDefault());
            var data = tenantResponse.Data;
            if (data == null)
                return;

            tenant.FullName = data.FullName;
            tenant.PhoneNumber = data.PhoneNumber ?? string.Empty;
            tenant.Email = data.Email;
            tenant.IdentityNumber = data.IdentityNumber ?? string.Empty;
            tenant.DateOfBirth = data.DateOfBirth;
            tenant.PermanentAddress = data.PermanentAddress;
            tenant.RoomId = data.RoomId ?? 0;
            tenant.StartDate = data.StartDate ?? DateOnly.FromDateTime(DateTime.Today);
            tenant.EndDate = data.EndDate;
            tenant.DepositAmount = data.DepositAmount;
            tenant.MonthlyRent = data.MonthlyRent;
            tenant.Status = data.Status ?? "Active";

            var currentRoom = rooms.Data?.FirstOrDefault(r => r.RoomId == tenant.RoomId);
            if (currentRoom != null && availableRooms.All(r => r.RoomId != currentRoom.RoomId))
                availableRooms.Insert(0, currentRoom);

            return;
        }

        var firstRoom = availableRooms.FirstOrDefault();
        if (firstRoom != null)
        {
            tenant.RoomId = firstRoom.RoomId;
            tenant.MonthlyRent = firstRoom.BasePrice;
        }
    }

    private async Task SaveTenant()
    {
        isSaving = true;
        tenant.MonthlyRent = availableRooms.FirstOrDefault(r => r.RoomId == tenant.RoomId)?.BasePrice;
        var response = IsEditMode
            ? await TenantApi.UpdateTenantAsync(TenantId.GetValueOrDefault(), tenant)
            : await TenantApi.CreateTenantAsync(tenant);
        isSaving = false;

        if (response.Success)
            Navigation.NavigateTo("/nguoi-thue");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/nguoi-thue");
    }

    private static bool IsRoomAvailableForNewTenant(SOTRO_Project.Models.Room.RoomResponse room)
    {
        if (room.Status == "Maintenance")
            return false;

        if (!room.Capacity.HasValue || room.Capacity.Value <= 0)
            return true;

        return (room.CurrentTenantCount ?? 0) < room.Capacity.Value;
    }

    private async Task OnPortraitSelected(InputFileChangeEventArgs e)
    {
        portraitPreviewUrl = await BuildPreviewUrl(e.File);
    }

    private async Task OnIdentityFrontSelected(InputFileChangeEventArgs e)
    {
        identityFrontPreviewUrl = await BuildPreviewUrl(e.File);
    }

    private async Task OnIdentityBackSelected(InputFileChangeEventArgs e)
    {
        identityBackPreviewUrl = await BuildPreviewUrl(e.File);
    }

    private static async Task<string> BuildPreviewUrl(IBrowserFile file)
    {
        const long maxPreviewSize = 5 * 1024 * 1024;
        await using var stream = file.OpenReadStream(maxPreviewSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        return $"data:{file.ContentType};base64,{base64}";
    }
}
