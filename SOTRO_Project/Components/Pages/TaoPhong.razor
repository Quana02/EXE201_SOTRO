    // ── Input handlers với format tiền tệ ──
    private void OnBasePriceInput(ChangeEventArgs e)
    {
        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        request.BasePrice = raw;
        basePriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
