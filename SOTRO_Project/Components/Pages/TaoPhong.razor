                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá điện</span>
                            <span class="material-symbols-outlined text-amber-500">bolt</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@electricPriceDisplay" @oninput="OnElectricPriceInput" @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/kWh</span>
                        </div>
                    </div>
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá nước</span>
                            <span class="material-symbols-outlined text-blue-500">water_drop</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@waterPriceDisplay" @oninput="OnWaterPriceInput" @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/m³</span>
                        </div>
                    </div>
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Phí dịch vụ</span>
                            <span class="material-symbols-outlined text-purple-500">handyman</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@serviceFeeDisplay" @oninput="OnServiceFeeInput" @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/tháng</span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Section: Preview danh sách phòng -->
            @if (batchItems.Count > 0)
            {
                <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-primary-fixed flex items-center justify-center">
                                <span class="material-symbols-outlined text-primary">format_list_bulleted</span>
                            </div>
                            <div>
                                <h3 class="font-headline-sm text-headline-sm text-on-surface">Danh sách @batchItems.Count phòng sẽ được tạo</h3>
                                <p class="text-caption text-on-surface-variant">Bạn có thể chỉnh sửa mã phòng hoặc xóa từng phòng</p>
                            </div>
                        </div>
                        <span class="text-caption font-bold text-primary bg-primary-fixed px-3 py-1 rounded-full">
                            @batchItems.Count(r => r.IsSaved) / @batchItems.Count đã tạo
                        </span>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
                        @for (int i = 0; i < batchItems.Count; i++)
                        {
                            var idx = i;
                            var item = batchItems[idx];
                            var cardBorder = item.IsSaved ? "border-secondary bg-secondary-container/20"
                                           : item.HasError ? "border-error bg-error-container/20"
                                           : "border-outline-variant bg-surface-container-low";
                            <div class="p-3 rounded-xl border @cardBorder flex flex-col gap-2 relative">
                                <!-- Status icon top-right -->
                                <div class="flex items-center justify-between">
                                    @if (item.IsSaved)
                                    {
                                        <span class="material-symbols-outlined text-secondary text-base">check_circle</span>
                                    }
                                    else if (item.HasError)
                                    {
                                        <span class="material-symbols-outlined text-error text-base" title="@item.ErrorMessage">error</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-on-surface-variant text-base">meeting_room</span>
                                    }
                                    @if (!item.IsSaved)
                                    {
                                        <button type="button" @onclick="() => batchItems.RemoveAt(idx)"
                                                disabled="@isBatchSaving"
                                                class="text-on-surface-variant hover:text-error transition-colors disabled:opacity-40">
                                            <span class="material-symbols-outlined text-sm">close</span>
                                        </button>
                                    }
                                </div>
                                <!-- Editable room code -->
                                <input value="@item.RoomCode"
                                       @oninput="e => item.RoomCode = e.Value?.ToString() ?? string.Empty"
                                       disabled="@(isBatchSaving || item.IsSaved)"
                                       class="w-full text-center font-black text-headline-sm bg-transparent outline-none border-b border-outline-variant focus:border-primary disabled:opacity-80 pb-1"
                                       placeholder="Mã phòng" />
                                @if (item.HasError && !string.IsNullOrEmpty(item.ErrorMessage))
                                {
                                    <p class="text-[10px] text-error font-medium leading-tight">@item.ErrorMessage</p>
                                }
                            </div>
                        }
                    </div>

                    <!-- Progress bar -->
                    @if (isBatchSaving)
                    {
                        <div class="mt-6">
                            <div class="flex justify-between text-caption mb-2">
                                <span class="text-on-surface-variant">Đang tạo phòng...</span>
                                <span class="font-bold text-primary">@batchProgress / @batchItems.Count</span>
                            </div>
                            <div class="w-full bg-surface-container rounded-full h-3">
                                <div class="bg-primary h-3 rounded-full transition-all duration-300"
                                     style="width: @(batchItems.Count > 0 ? (batchProgress * 100 / batchItems.Count) : 0)%"></div>
                            </div>
                        </div>
                    }
                </section>
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-16 gap-4 bg-surface-container-lowest rounded-2xl border-2 border-dashed border-outline-variant">
                    <span class="material-symbols-outlined text-on-surface-variant text-5xl">add_home_work</span>
                    <p class="text-on-surface-variant font-medium">Bấm <strong>"Tạo danh sách phòng"</strong> để xem trước các phòng sẽ được tạo</p>
                </div>
            }

            <!-- Batch Actions -->
            <div class="flex items-center justify-end gap-4 pt-4 mb-16">
                <button @onclick="GoBack"
                        class="px-8 py-3 rounded-xl border border-outline text-on-surface font-bold hover:bg-surface-container-high transition-all"
                        disabled="@isBatchSaving">
                    Hủy
                </button>
                <button @onclick="GenerateBatchRooms"
                        class="px-6 py-3 rounded-xl border border-secondary text-secondary font-bold hover:bg-secondary-container transition-all flex items-center gap-2"
                        disabled="@isBatchSaving">
                    <span class="material-symbols-outlined text-sm">refresh</span>
                    Làm mới
                </button>
                <button @onclick="HandleBatchSubmit"
                        disabled="@(isBatchSaving || batchItems.Count == 0)"
                        class="px-10 py-3 rounded-xl bg-secondary text-on-secondary font-bold shadow-lg hover:opacity-90 hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2 disabled:opacity-60">
                    @if (isBatchSaving)
                    {
                        <span class="material-symbols-outlined animate-spin">sync</span>
                        <span>Đang tạo @batchProgress/@batchItems.Count...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined">rocket_launch</span>
                        <span>Tạo @batchItems.Count phòng</span>
                    }
                </button>
            </div>

        </div>
        } <!-- end batch mode -->

    </div>
</main>

<!-- Background Decoration -->
<div class="fixed top-0 right-0 -z-10 w-[500px] h-[500px] bg-primary-fixed/20 rounded-full blur-[120px] pointer-events-none"></div>
<div class="fixed bottom-0 left-72 -z-10 w-[300px] h-[300px] bg-secondary-fixed/30 rounded-full blur-[100px] pointer-events-none"></div>

