@page "/tao-phong"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject IJSRuntime JS

<PageTitle>SOTRO - Thêm Phòng Mới</PageTitle>

<style>
    /* Hide number input arrows */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
    body { font-family: 'Inter', sans-serif; }
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .form-input {
        width: 100%;
        background: white;
        border: 1px solid var(--md-sys-color-outline-variant, #cad4e0);
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-input:focus {
        outline: none;
        border-color: #003f87;
        box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.1);
    }
    .price-input-wrap { position: relative; }
    .price-input-wrap input {
        padding-right: 5rem;
        font-size: 1.2rem;
        font-weight: 700;
        color: #003f87;
    }
    .price-input-wrap .unit {
        position: absolute; right: 1rem; top: 50%; transform: translateY(-50%);
        font-size: 0.75rem; color: #6b7280; pointer-events: none;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 0.8s linear infinite; display:inline-block; }
    .shared-badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        background: #e8f0fe; color: #1a56db;
        font-size: 0.7rem; font-weight: 700; letter-spacing: 0.05em;
        padding: 0.15rem 0.6rem; border-radius: 9999px;
    }
</style>

<HeaderDashboard/>
<SideNavBar />

<main class="min-h-screen ml-64 h-[calc(100vh-64px)] overflow-y-auto">
    <div class="p-margin-desktop max-w-[1000px] mx-auto">
        <!-- Breadcrumb -->
        <div class="mb-8 flex items-center gap-2 text-label-md text-on-surface-variant">
            <button @onclick="GoBack" class="hover:text-primary transition-colors">Quản lý phòng</button>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="text-primary font-bold">Thêm phòng mới</span>
        </div>
        <!-- Page Title -->
        <div class="mb-10">
            <h2 class="font-headline-md text-headline-md text-on-surface">Thêm Phòng Mới</h2>
            <p class="font-body-md text-body-md text-on-surface-variant">
                Tòa nhà: <span class="font-bold text-primary">@buildingName</span>
            </p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-6 p-4 bg-error-container text-on-error-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <p>@errorMessage</p>
            </div>
        }
        @if (successMessage)
        {
            <div class="mb-6 p-4 bg-secondary-container text-on-secondary-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <p>Tạo phòng thành công! Đang chuyển về danh sách...</p>
            </div>
        }

        <div class="grid grid-cols-1 gap-8">

            <!-- ══════════════════════════════════════════
                 SECTION 1: THÔNG TIN RIÊNG CỦA PHÒNG
                 (Mỗi phòng khác nhau)
            ═══════════════════════════════════════════ -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-10 h-10 rounded-lg bg-primary-fixed flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">meeting_room</span>
                    </div>
                    <div>
                        <h3 class="font-headline-sm text-headline-sm text-on-surface">Thông tin phòng</h3>
                        <p class="text-caption text-on-surface-variant">Thông tin riêng của từng phòng</p>
                    </div>
                </div>
                <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Mã phòng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Mã / Số phòng <span class="text-error">*</span></label>
                        <input @bind="request.RoomCode" class="form-input" placeholder="VD: P101" type="text" />
                    </div>
                    <!-- Tên phòng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Tên phòng</label>
                        <input @bind="request.RoomName" class="form-input" placeholder="VD: Phòng cao cấp" type="text" />
                    </div>
                    <!-- Tầng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Tầng</label>
                        <input @bind="request.FloorNumber" class="form-input" placeholder="1" type="number" />
                    </div>
                    <!-- Khu vực -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Khu vực / Zone</label>
                        <input @bind="request.Zone" class="form-input" placeholder="VD: Khu A" type="text" />
                    </div>
                    <!-- Sức chứa -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Sức chứa (người)</label>
                        <input @bind="request.Capacity" class="form-input" placeholder="2" type="number" min="1" />
                    </div>
                    <!-- Trạng thái -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Trạng thái</label>
                        <select @bind="request.Status" class="form-input">
                            <option value="Available">Trống</option>
                            <option value="Occupied">Đang thuê</option>
                            <option value="Maintenance">Bảo trì</option>
                        </select>
                    </div>
                </div>

                <!-- Tiền phòng – nổi bật vì mỗi phòng khác nhau -->
                <div class="mt-8 p-6 rounded-xl bg-primary-fixed/20 border-2 border-primary/20">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <span class="font-label-md font-bold text-on-surface uppercase tracking-wider">Tiền phòng <span class="text-error">*</span></span>
                            <p class="text-caption text-on-surface-variant mt-0.5">Giá thuê riêng cho phòng này</p>
                        </div>
                        <span class="material-symbols-outlined text-primary text-3xl">home</span>
                    </div>
                    <div class="price-input-wrap">
                        <input value="@basePriceDisplay"
                               @oninput="OnBasePriceInput"
                               class="form-input"
                               type="text" inputmode="numeric" placeholder="0" />
                        <span class="unit">đ/tháng</span>
                    </div>
                </div>
            </section>

            <!-- ══════════════════════════════════════════
                 SECTION 2: PHÍ DỊCH VỤ CHUNG CỦA TÒA
                 (Cấu hình 1 lần, áp dụng cho mọi phòng)
            ═══════════════════════════════════════════ -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border-2 border-secondary/20">
                <div class="flex items-start justify-between gap-4 mb-2">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center">
                            <span class="material-symbols-outlined text-secondary">settings</span>
                        </div>
                        <div>
                            <div class="flex items-center gap-2">
                                <h3 class="font-headline-sm text-headline-sm text-on-surface">Phí dịch vụ chung</h3>
                                <span class="shared-badge">
                                    <span class="material-symbols-outlined text-[14px]">sync</span>
                                    Áp dụng cho mọi phòng
                                </span>
                            </div>
                            <p class="text-caption text-on-surface-variant mt-0.5">
                                Cấu hình 1 lần — tự động lưu lại cho lần tạo phòng tiếp theo
                            </p>
                        </div>
                    </div>
                    @if (sharedFeesSaved)
                    {
                        <span class="text-caption text-secondary flex items-center gap-1 shrink-0">
                            <span class="material-symbols-outlined text-sm">check_circle</span> Đã lưu
                        </span>
                    }
                </div>

                <div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Tiền điện -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá điện</span>
                            <span class="material-symbols-outlined text-amber-500">bolt</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@electricPriceDisplay"
                                   @oninput="OnElectricPriceInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/kWh</span>
                        </div>
                    </div>
                    <!-- Tiền nước -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá nước</span>
                            <span class="material-symbols-outlined text-blue-500">water_drop</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@waterPriceDisplay"
                                   @oninput="OnWaterPriceInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/m³</span>
                        </div>
                    </div>
                    <!-- Phí dịch vụ -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Phí dịch vụ</span>
                            <span class="material-symbols-outlined text-purple-500">handyman</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@serviceFeeDisplay"
                                   @oninput="OnServiceFeeInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/tháng</span>
                        </div>
                    </div>
                    <!-- Ngày thu tiền -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Ngày thu tiền</span>
                            <span class="material-symbols-outlined text-green-600">event</span>
                        </div>
                        <div class="relative flex items-center">
                            <input @bind="request.BillingDay"
                                   @onblur="SaveSharedFees"
                                   class="form-input pr-10" type="number" placeholder="1" min="1" max="15" />
                            <div class="absolute right-3 flex items-center justify-center w-6 h-6 pointer-events-none text-on-surface-variant">
                                <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                            </div>
                            <input type="date" @onchange="OnBillingDateChanged" 
                                   class="absolute right-3 w-6 h-6 opacity-0 cursor-pointer" />
                        </div>
                        <p class="text-caption text-on-surface-variant">Ngày trong tháng (1–15)</p>
                    </div>
                    <!-- Ghi chú -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3 md:col-span-2">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Ghi chú</span>
                            <span class="material-symbols-outlined text-on-surface-variant">notes</span>
                        </div>
                        <textarea @bind="request.Note" class="form-input resize-none" rows="2" placeholder="Ghi chú thêm về phòng..."></textarea>
                    </div>
                </div>
            </section>

            <!-- Actions -->
            <div class="flex items-center justify-end gap-4 pt-4 mb-16">
                <button @onclick="GoBack"
                        class="px-8 py-3 rounded-xl border border-outline text-on-surface font-bold hover:bg-surface-container-high transition-all"
                        disabled="@isSaving">
                    Hủy
                </button>
                <button @onclick="HandleSubmit"
                        class="px-12 py-3 rounded-xl bg-primary text-white font-bold shadow-lg hover:opacity-90 hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2 disabled:opacity-60"
                        disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="material-symbols-outlined animate-spin">sync</span>
                        <span>Đang lưu...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined">save</span>
                        <span>Lưu thông tin</span>
                    }
                </button>
            </div>
        </div>
    </div>
</main>

<!-- Background Decoration -->
<div class="fixed top-0 right-0 -z-10 w-[500px] h-[500px] bg-primary-fixed/20 rounded-full blur-[120px] pointer-events-none"></div>
<div class="fixed bottom-0 left-72 -z-10 w-[300px] h-[300px] bg-secondary-fixed/30 rounded-full blur-[100px] pointer-events-none"></div>

@code {
    private CreateRoomRequest request = new() { Status = "Available" };
    private bool isSaving;
    private bool successMessage;
    private bool sharedFeesSaved;
    private string? errorMessage;
    private int buildingId;
    private string buildingName = "—";

    // ── Formatted display strings ──
    private string basePriceDisplay     = "";
    private string electricPriceDisplay = "";
    private string waterPriceDisplay    = "";
    private string serviceFeeDisplay    = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var name  = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
            buildingName = name ?? "—";
            int.TryParse(idStr, out buildingId);

            // Load shared fees từ localStorage (đã lưu lần trước)
            await LoadSharedFeesFromStorage();
            StateHasChanged();
        }
    }

    private async Task LoadSharedFeesFromStorage()
    {
        var elec    = await JS.InvokeAsync<string>("localStorage.getItem", "shared_electric_price");
        var water   = await JS.InvokeAsync<string>("localStorage.getItem", "shared_water_price");
        var service = await JS.InvokeAsync<string>("localStorage.getItem", "shared_service_fee");
        var billing = await JS.InvokeAsync<string>("localStorage.getItem", "shared_billing_day");

        if (decimal.TryParse(elec, out var e))    { request.ElectricPrice = e; electricPriceDisplay = FormatNumber(e); }
        if (decimal.TryParse(water, out var w))   { request.WaterPrice    = w; waterPriceDisplay    = FormatNumber(w); }
        if (decimal.TryParse(service, out var s)) { request.ServiceFee    = s; serviceFeeDisplay    = FormatNumber(s); }
        if (int.TryParse(billing, out var b))     { request.BillingDay    = b; }
    }

    private async Task SaveSharedFees()
    {
        try
        {
            if (request.ElectricPrice.HasValue) await JS.InvokeVoidAsync("localStorage.setItem", "shared_electric_price", request.ElectricPrice.Value.ToString());
            if (request.WaterPrice.HasValue)    await JS.InvokeVoidAsync("localStorage.setItem", "shared_water_price",    request.WaterPrice.Value.ToString());
            if (request.ServiceFee.HasValue)    await JS.InvokeVoidAsync("localStorage.setItem", "shared_service_fee",    request.ServiceFee.Value.ToString());
            if (request.BillingDay.HasValue)    await JS.InvokeVoidAsync("localStorage.setItem", "shared_billing_day",    request.BillingDay.Value.ToString());

            sharedFeesSaved = true;
            StateHasChanged();
            await Task.Delay(2000);
            sharedFeesSaved = false;
        }
        catch { }
    }

    private void OnBasePriceInput(ChangeEventArgs e)
    {
        var raw = ParseRawNumber(e.Value?.ToString());
        request.BasePrice = raw;
        basePriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnElectricPriceInput(ChangeEventArgs e)
    {
        var raw = ParseRawNumber(e.Value?.ToString());
        request.ElectricPrice = raw;
        electricPriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnWaterPriceInput(ChangeEventArgs e)
    {
        var raw = ParseRawNumber(e.Value?.ToString());
        request.WaterPrice = raw;
        waterPriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnServiceFeeInput(ChangeEventArgs e)
    {
        var raw = ParseRawNumber(e.Value?.ToString());
        request.ServiceFee = raw;
        serviceFeeDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(request.RoomCode))
        {
            errorMessage = "Vui lòng nhập mã phòng.";
            return;
        }
        if (request.BasePrice == null)
        {
            errorMessage = "Vui lòng nhập tiền phòng.";
            return;
        }
        if (request.BasePrice <= 0)
        {
            errorMessage = "Tiền phòng phải lớn hơn 0.";
            return;
        }
        if (request.BillingDay.HasValue && (request.BillingDay < 1 || request.BillingDay > 15))
        {
            errorMessage = "Ngày thu tiền phải từ ngày 1 đến ngày 15.";
            return;
        }
        if (buildingId <= 0)
        {
            errorMessage = "Không tìm thấy thông tin tòa nhà. Vui lòng quay lại và chọn tòa nhà.";
            return;
        }

        isSaving = true;
        try
        {
            // Lưu shared fees trước khi submit
            await SaveSharedFees();

            var result = await RoomApiService.CreateRoomAsync(buildingId, request);
            if (result.Success)
            {
                successMessage = true;
                await Task.Delay(1500);
                Navigation.NavigateTo("/quan-ly-phong");
            }
            else
            {
                errorMessage = result.Message ?? "Tạo phòng thất bại. Vui lòng thử lại.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/quan-ly-phong");

    private async Task OnBillingDateChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            request.BillingDay = date.Day;
            await SaveSharedFees();
        }
    }

    // ── Helpers format số tiền ──
    private static string FormatNumber(decimal value)
        => value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"));

    private static decimal? ParseRawNumber(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        // Bỏ dấu chấm/phẩy phân cách hàng nghìn
        var cleaned = input.Replace(".", "").Replace(",", "");
        return decimal.TryParse(cleaned, out var d) ? d : null;
    }
}