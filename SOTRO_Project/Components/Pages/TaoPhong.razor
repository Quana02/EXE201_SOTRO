        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        request.WaterPrice = raw;
        waterPriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnServiceFeeInput(ChangeEventArgs e)
    {
        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        request.ServiceFee = raw;
        serviceFeeDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }

    private async Task ScrollToError()
    {
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval", "document.getElementById('error-message-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })");
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(request.RoomCode))
        {
            errorMessage = "Vui lòng nhập mã phòng.";
            await ScrollToError();
            return;
        }
        if (request.BasePrice == null)
        {
            errorMessage = "Vui lòng nhập tiền phòng.";
            await ScrollToError();
            return;
        }
        if (request.BasePrice <= 0)
        {
            errorMessage = "Tiền phòng phải lớn hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.ElectricPrice.HasValue && request.ElectricPrice < 0)
        {
            errorMessage = "Đơn giá điện không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.WaterPrice.HasValue && request.WaterPrice < 0)
        {
            errorMessage = "Đơn giá nước không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.ServiceFee.HasValue && request.ServiceFee < 0)
        {
            errorMessage = "Phí dịch vụ không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.Capacity.HasValue && request.Capacity <= 0)
        {
            errorMessage = "Sức chứa phải lớn hơn 0.";
            await ScrollToError();
            return;
        }
        // Validate số người thuê khi phòng đang được thuê
        if (request.Status == "Occupied")
        {
            if (!request.Capacity.HasValue || request.Capacity <= 0)
            {
                errorMessage = "Khi phòng đang thuê, vui lòng nhập sức chứa tối đa của phòng.";
                await ScrollToError();
                return;
            }
            if (!request.CurrentTenantCount.HasValue || request.CurrentTenantCount <= 0)
            {
                errorMessage = "Khi phòng đang thuê, bắt buộc phải nhập số người đang thuê (lớn hơn 0).";
                await ScrollToError();
                return;
            }
            if (request.CurrentTenantCount > request.Capacity)
            {
                errorMessage = $"Số người đang thuê ({request.CurrentTenantCount}) không được vượt quá sức chứa ({request.Capacity} người).";
                await ScrollToError();
                return;
            }
        }
        if (request.Status == "Maintenance" && request.CurrentTenantCount.HasValue && request.CurrentTenantCount < 0)
        {
            errorMessage = "Số người đang ở không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.BillingDay.HasValue && (request.BillingDay < 1 || request.BillingDay > 15))
        {
            errorMessage = "Ngày thu tiền phải từ ngày 1 đến ngày 15.";
            await ScrollToError();
            return;
        }
        if (buildingId <= 0)
        {
            errorMessage = "Không tìm thấy thông tin tòa nhà. Vui lòng quay lại và chọn tòa nhà.";
            await ScrollToError();
            return;
        }

        isSaving = true;
        try
        {
            // Lưu shared fees trước khi submit (silent, không delay)
            await SaveSharedFeesSilent();

            var result = await RoomApiService.CreateRoomAsync(buildingId, request);
            if (result.Success)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_create_room_guided_seen", "true");
                successMessage = true;
                await Task.Delay(1500);
                Navigation.NavigateTo("/quan-ly-phong");
            }
            else
            {
                errorMessage = result.Message ?? "Tạo phòng thất bại. Vui lòng thử lại.";
                await ScrollToError();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
            await ScrollToError();
        }
        finally
        {
            isSaving = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/quan-ly-phong");

    // ── Batch mode methods ──
    private async Task GenerateBatchRooms()
    {
        if (buildingId <= 0) return;
        var count = Math.Max(1, Math.Min(50, batchCount));
        batchItems.Clear();

        // Find highest existing numeric room code across ALL rooms (not just this floor)
        int startCode = (request.FloorNumber ?? 1) * 100 + 1;
        try
        {
            var roomsResp = await RoomApiService.GetRoomsByBuildingAsync(buildingId);
            if (roomsResp.Success && roomsResp.Data != null)
            {
                var allNums = roomsResp.Data
                    .Select(r => new string(r.RoomCode.Where(char.IsDigit).ToArray()))
                    .Where(s => !string.IsNullOrEmpty(s) && int.TryParse(s, out _))
                    .Select(int.Parse)
                    .ToList();
                if (allNums.Count > 0)
                    startCode = allNums.Max() + 1;
            }
        }
        catch { }

        for (int i = 0; i < count; i++)
        {
            batchItems.Add(new BatchRoomItem { RoomCode = (startCode + i).ToString() });
        }
        StateHasChanged();
    }

    private async Task HandleBatchSubmit()
    {
        errorMessage = null;
        if (buildingId <= 0)
        {
            errorMessage = "Không tìm thấy thông tin tòa nhà. Vui lòng quay lại và chọn tòa nhà.";
            await ScrollToError(); return;
        }
        if (batchItems.Count == 0)
        {
            errorMessage = "Vui lòng tạo danh sách phòng trước.";
            await ScrollToError(); return;
        }
        if (request.BasePrice == null || request.BasePrice <= 0)
        {
            errorMessage = "Vui lòng nhập tiền phòng hợp lệ (lớn hơn 0).";
            await ScrollToError(); return;
        }
        if (batchRoomModel == "Shared" && batchTotalBeds <= 0)
        {
            errorMessage = "Số giường phải lớn hơn 0.";
            await ScrollToError(); return;
        }
        // Validate all codes not empty
        if (batchItems.Any(r => string.IsNullOrWhiteSpace(r.RoomCode)))
        {
            errorMessage = "Một số phòng chưa có mã phòng. Vui lòng kiểm tra lại.";
            await ScrollToError(); return;
        }
        // Validate unique codes within batch
        var dupCode = batchItems
            .GroupBy(r => r.RoomCode.Trim().ToUpper())
            .FirstOrDefault(g => g.Count() > 1);
        if (dupCode != null)
        {
            errorMessage = $"Mã phòng '{dupCode.Key}' bị trùng trong danh sách. Vui lòng chỉnh sửa.";
            await ScrollToError(); return;
        }

        // Validate số người thuê khi phòng đang được thuê (Batch mode)
        if (request.Status == "Occupied")
        {
            int? maxCap = batchRoomModel == "Shared" ? batchTotalBeds : request.Capacity;
            if (!maxCap.HasValue || maxCap <= 0)
            {
                errorMessage = batchRoomModel == "Shared" 
                    ? "Vui lòng nhập số giường tối đa của phòng."
                    : "Khi phòng đang thuê, vui lòng nhập sức chứa tối đa của phòng.";
                await ScrollToError();
                return;
            }
            if (!request.CurrentTenantCount.HasValue || request.CurrentTenantCount <= 0)
            {
                errorMessage = "Khi phòng đang thuê, bắt buộc phải nhập số người đang thuê (lớn hơn 0).";
                await ScrollToError();
                return;
            }
            if (request.CurrentTenantCount > maxCap)
            {
                errorMessage = batchRoomModel == "Shared"
                    ? $"Số người đang thuê ({request.CurrentTenantCount}) không được vượt quá số giường ({maxCap} giường)."
                    : $"Số người đang thuê ({request.CurrentTenantCount}) không được vượt quá sức chứa ({maxCap} người).";
                await ScrollToError();
                return;
            }
        }
        if (request.Status == "Maintenance" && request.CurrentTenantCount.HasValue && request.CurrentTenantCount < 0)
        {
            errorMessage = "Số người đang ở không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }

        isBatchSaving = true;
        batchProgress = 0;
        batchComplete = false;
        // Reset all error states
        foreach (var item in batchItems) { item.IsSaved = false; item.HasError = false; item.ErrorMessage = null; }

        try
        {
            await SaveSharedFeesSilent();

            for (int i = 0; i < batchItems.Count; i++)
            {
                var item = batchItems[i];
                var noteObj = new
                {
                    RoomModel = batchRoomModel,
                    TotalBeds = batchRoomModel == "Shared" ? (int?)batchTotalBeds : null,
                    UserNote = request.Note
                };
                var noteJson = System.Text.Json.JsonSerializer.Serialize(noteObj);

                var req = new CreateRoomRequest
                {
                    RoomCode        = item.RoomCode.Trim(),
                    FloorNumber     = request.FloorNumber,
                    BasePrice       = request.BasePrice,
                    ElectricPrice   = request.ElectricPrice,
                    WaterPrice      = request.WaterPrice,
                    ServiceFee      = request.ServiceFee,
                    Capacity        = batchRoomModel == "Shared" ? batchTotalBeds : request.Capacity,
                    Status          = request.Status,
                    BillingDay      = request.BillingDay,
                    Zone            = request.Zone,
                    CurrentTenantCount = request.Status == "Available" ? 0 : request.CurrentTenantCount,
                    Note            = noteJson
                };

                var result = await RoomApiService.CreateRoomAsync(buildingId, req);
                if (result.Success)
                {
                    item.IsSaved = true;
                }
                else
                {
                    item.HasError = true;
                    item.ErrorMessage = result.Message ?? "Lỗi không xác định";
                }
                batchProgress = i + 1;
                StateHasChanged();
            }

            var savedCount  = batchItems.Count(r => r.IsSaved);
            var failCount   = batchItems.Count(r => r.HasError);

            if (failCount == 0)
            {
                batchComplete = true;
                StateHasChanged();
                await Task.Delay(1800);
                Navigation.NavigateTo("/quan-ly-phong");
            }
            else
            {
                errorMessage = $"Đã tạo {savedCount}/{batchItems.Count} phòng. {failCount} phòng gặp lỗi - kiểm tra trong danh sách bên dưới.";
                await ScrollToError();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
            await ScrollToError();
        }
        finally
        {
            isBatchSaving = false;
        }
    }

    private async Task OnBillingDateChanged(ChangeEventArgs e)
    {
        errorMessage = null;
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            request.BillingDay = date.Day;
            await SaveSharedFees();
        }
    }

    // ── Helpers format số tiền ──
    private static string FormatNumber(decimal value)
        => value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"));

    private static decimal? ParseRawNumber(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        // Bỏ dấu chấm/phẩy phân cách hàng nghìn
        var cleaned = input.Replace(".", "").Replace(",", "");
        return decimal.TryParse(cleaned, out var d) ? d : null;
    }
