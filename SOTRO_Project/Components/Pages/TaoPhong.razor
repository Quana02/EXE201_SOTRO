@page "/tao-phong"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject IBuildingApiService BuildingApiService
@inject IJSRuntime JS

<PageTitle>SOTRO - Thêm Phòng Mới</PageTitle>

<style>
    /* Hide number input arrows */
    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    input[type=number] {
        -moz-appearance: textfield;
    }

    body {
        font-family: 'Inter', sans-serif;
    }

    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .form-input {
        width: 100%;
        background: white;
        border: 1px solid var(--md-sys-color-outline-variant, #cad4e0);
        border-radius: 0.5rem;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

        .form-input:focus {
            outline: none;
            border-color: #003f87;
            box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.1);
        }

    .price-input-wrap {
        position: relative;
    }

        .price-input-wrap input {
            padding-right: 5rem;
            font-size: 1.2rem;
            font-weight: 700;
            color: #003f87;
        }

        .price-input-wrap .unit {
            position: absolute;
            right: 1rem;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.75rem;
            color: #6b7280;
            pointer-events: none;
        }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .animate-spin {
        animation: spin 0.8s linear infinite;
        display: inline-block;
    }

    .shared-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: #e8f0fe;
        color: #1a56db;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 0.15rem 0.6rem;
        border-radius: 9999px;
    }
</style>

<HeaderDashboard OnHelpClicked="OpenCreateRoomTour" />
<SideNavBar />

<main class="min-h-[calc(100vh-64px)] ml-64 pb-10">
    <div class="p-margin-desktop max-w-[1000px] mx-auto">
        <!-- Breadcrumb -->
        <div class="mb-8 flex items-center gap-2 text-label-md text-on-surface-variant">
            <button @onclick="GoBack" class="hover:text-primary transition-colors">Quản lý phòng</button>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="text-primary font-bold">Thêm phòng mới</span>
        </div>
        <!-- Page Title -->
        <div class="mb-10">
            <h2 class="font-headline-md text-headline-md text-on-surface">Thêm Phòng Mới</h2>
            <p class="font-body-md text-body-md text-on-surface-variant">
                Tòa nhà: <span class="font-bold text-primary">@buildingName</span>
            </p>
        </div>

        <!-- Mode Toggle -->
        @{
            var singleTabClass = createMode == "single"
                ? "bg-primary text-on-primary shadow"
                : "text-on-surface-variant hover:bg-surface-container";
            var batchTabClass = createMode == "batch"
                ? "bg-secondary text-on-secondary shadow"
                : "text-on-surface-variant hover:bg-surface-container";
        }
        <div class="mb-8 flex items-center gap-2 p-1 bg-surface-container-low rounded-full border border-outline-variant w-fit">
            <button id="room-single-mode-tab" @onclick='() => SetMode("single")'
                    class="px-5 py-2.5 rounded-full text-label-md font-bold transition-all flex items-center gap-2 @singleTabClass">
                <span class="material-symbols-outlined text-sm">meeting_room</span>
                Thêm 1 phòng
            </button>
            <button @onclick='() => SetMode("batch")'
                    class="px-5 py-2.5 rounded-full text-label-md font-bold transition-all flex items-center gap-2 @batchTabClass">
                <span class="material-symbols-outlined text-sm">add_home_work</span>
                Thêm nhiều phòng
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div id="error-message-container" class="mb-6 p-4 bg-error-container text-on-error-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">error</span>
                <p>@errorMessage</p>
            </div>
        }
        @if (successMessage)
        {
            <div class="mb-6 p-4 bg-secondary-container text-on-secondary-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <p>Tạo phòng thành công! Đang chuyển về danh sách...</p>
            </div>
        }
        @if (batchComplete)
        {
            <div class="mb-6 p-4 bg-secondary-container text-on-secondary-container rounded-xl flex items-center gap-3">
                <span class="material-symbols-outlined">check_circle</span>
                <p>Đã tạo thành công @(batchItems.Count(r => r.IsSaved)) phòng! Đang chuyển về danh sách...</p>
            </div>
        }

        @if (createMode == "single")
        {
        <div class="grid grid-cols-1 gap-8">

            <!-- ══════════════════════════════════════════
                 SECTION 1: THÔNG TIN RIÊNG CỦA PHÒNG
                 (Mỗi phòng khác nhau)
            ═══════════════════════════════════════════ -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-10 h-10 rounded-lg bg-primary-fixed flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">meeting_room</span>
                    </div>
                    <div>
                        <h3 class="font-headline-sm text-headline-sm text-on-surface">Thông tin phòng</h3>
                        <p class="text-caption text-on-surface-variant">Thông tin riêng của từng phòng</p>
                    </div>
                </div>
                <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Mã phòng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Mã / Số phòng <span class="text-error">*</span></label>
                        <input id="room-code-input" value="@request.RoomCode" @oninput="OnRoomCodeInput" class="form-input" placeholder="VD: P101" type="text" />
                    </div>
                    <!-- Tên phòng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Tên phòng</label>
                        <input @bind="request.RoomName" class="form-input" placeholder="VD: Phòng cao cấp" type="text" />
                    </div>
                    <!-- Tầng / Dãy -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">@(IsBasicLevel ? "Dãy" : "Tầng") <span class="text-error">*</span></label>
                        <select id="room-floor-input" value="@request.FloorNumber" @onchange="OnFloorChanged" class="form-input bg-white">
                            @for (int f = 1; f <= totalFloors; f++)
                            {
                                <option value="@f">@GetFloorLabel(f)</option>
                            }
                        </select>
                    </div>
                    <!-- Khu vực -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Khu vực / Zone</label>
                        <input @bind="request.Zone" class="form-input" placeholder="VD: Khu A" type="text" />
                    </div>
                    <!-- Sức chứa -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Sức chứa (người)</label>
                        <input id="room-capacity-input" value="@request.Capacity" @oninput="OnCapacityInput" class="form-input" placeholder="2" type="number" min="1" />
                    </div>
                    <!-- Trạng thái -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Trạng thái</label>
                        <select value="@request.Status" @onchange="OnStatusChanged" class="form-input bg-white">
                            <option value="Available">Trống</option>
                            <option value="Occupied">Đang thuê</option>
                            <option value="Maintenance">Bảo trì</option>
                        </select>
                    </div>
                    <!-- Số người đang thuê (chỉ hiện khi không phải Trống) -->
                    @if (request.Status != "Available")
                    {
                        <div class="space-y-2">
                            <label class="font-label-md text-label-md text-on-surface-variant">
                                Số người đang thuê
                                <span class="text-on-surface-variant text-[11px] font-normal ml-1">
                                    / @(request.Capacity?.ToString() ?? "?")
                                </span>
                            </label>
                            <input value="@request.CurrentTenantCount" @oninput="OnCurrentTenantCountInput"
                                   class="form-input" type="number" min="0"
                                   max="@request.Capacity"
                                   placeholder="0" />
                            <p class="text-caption text-on-surface-variant">Nhập số người hiện đang ở trong phòng</p>
                        </div>
                    }
                </div>

                <!-- Tiền phòng – nổi bật vì mỗi phòng khác nhau -->
                <div class="mt-8 p-6 rounded-xl bg-primary-fixed/20 border-2 border-primary/20">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <span class="font-label-md font-bold text-on-surface uppercase tracking-wider">Tiền phòng <span class="text-error">*</span></span>
                            <p class="text-caption text-on-surface-variant mt-0.5">Giá thuê riêng cho phòng này</p>
                        </div>
                        <span class="material-symbols-outlined text-primary text-3xl">home</span>
                    </div>
                    <div class="price-input-wrap">
                        <input value="@basePriceDisplay"
                               id="room-base-price-input"
                               @oninput="OnBasePriceInput"
                               class="form-input"
                               type="text" inputmode="numeric" placeholder="0" />
                        <span class="unit">đ/tháng</span>
                    </div>
                </div>
            </section>

            <!-- ══════════════════════════════════════════
                 SECTION 2: PHÍ DỊCH VỤ CHUNG CỦA TÒA
                 (Cấu hình 1 lần, áp dụng cho mọi phòng)
            ═══════════════════════════════════════════ -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border-2 border-secondary/20">
                <div class="flex items-start justify-between gap-4 mb-2">
                    <div class="flex items-center gap-3">
                        <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center">
                            <span class="material-symbols-outlined text-secondary">settings</span>
                        </div>
                        <div>
                            <div class="flex items-center gap-2">
                                <h3 class="font-headline-sm text-headline-sm text-on-surface">Phí dịch vụ chung</h3>
                                <span class="shared-badge">
                                    <span class="material-symbols-outlined text-[14px]">sync</span>
                                    Áp dụng cho mọi phòng
                                </span>
                            </div>
                            <p class="text-caption text-on-surface-variant mt-0.5">
                                Cấu hình 1 lần — tự động lưu lại cho lần tạo phòng tiếp theo
                            </p>
                        </div>
                    </div>
                    @if (sharedFeesSaved)
                    {
                        <span class="text-caption text-secondary flex items-center gap-1 shrink-0">
                            <span class="material-symbols-outlined text-sm">check_circle</span> Đã lưu
                        </span>
                    }
                </div>

                <div class="mt-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <!-- Tiền điện -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá điện</span>
                            <span class="material-symbols-outlined text-amber-500">bolt</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@electricPriceDisplay"
                                   id="room-electric-price-input"
                                   @oninput="OnElectricPriceInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/kWh</span>
                        </div>
                    </div>
                    <!-- Tiền nước -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Đơn giá nước</span>
                            <span class="material-symbols-outlined text-blue-500">water_drop</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@waterPriceDisplay"
                                   id="room-water-price-input"
                                   @oninput="OnWaterPriceInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/m³</span>
                        </div>
                    </div>
                    <!-- Phí dịch vụ -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Phí dịch vụ</span>
                            <span class="material-symbols-outlined text-purple-500">handyman</span>
                        </div>
                        <div class="price-input-wrap">
                            <input value="@serviceFeeDisplay"
                                   id="room-service-fee-input"
                                   @oninput="OnServiceFeeInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input" type="text" inputmode="numeric" placeholder="0" />
                            <span class="unit">đ/tháng</span>
                        </div>
                    </div>
                    <!-- Ngày thu tiền -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Ngày thu tiền</span>
                            <span class="material-symbols-outlined text-green-600">event</span>
                        </div>
                        <div class="relative flex items-center">
                            <input id="room-billing-day-input" value="@request.BillingDay" @oninput="OnBillingDayInput"
                                   @onblur="SaveSharedFees"
                                   class="form-input pr-10" type="number" placeholder="1" min="1" max="15" />
                            <div class="absolute right-3 flex items-center justify-center w-6 h-6 pointer-events-none text-on-surface-variant">
                                <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                            </div>
                            <input type="date" @onchange="OnBillingDateChanged"
                                   class="absolute right-3 w-6 h-6 opacity-0 cursor-pointer" />
                        </div>
                        <p class="text-caption text-on-surface-variant">Ngày trong tháng (1–15)</p>
                    </div>
                    <!-- Ghi chú -->
                    <div class="p-5 rounded-xl bg-surface-container-low border border-outline-variant space-y-3 md:col-span-2">
                        <div class="flex justify-between items-center">
                            <span class="font-label-md font-bold text-on-surface uppercase text-[11px] tracking-wider">Ghi chú</span>
                            <span class="material-symbols-outlined text-on-surface-variant">notes</span>
                        </div>
                        <textarea @bind="request.Note" class="form-input resize-none" rows="2" placeholder="Ghi chú thêm về phòng..."></textarea>
                    </div>
                </div>
            </section>

            <!-- Actions -->
            <div class="flex items-center justify-end gap-4 pt-4 mb-16">
                <button @onclick="GoBack"
                        class="px-8 py-3 rounded-xl border border-outline text-on-surface font-bold hover:bg-surface-container-high transition-all"
                        disabled="@isSaving">
                    Hủy
                </button>
                <button id="save-room-submit" @onclick="HandleSubmit"
                        class="px-12 py-3 rounded-xl bg-primary text-white font-bold shadow-lg hover:opacity-90 hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2 disabled:opacity-60"
                        disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="material-symbols-outlined animate-spin">sync</span>
                        <span>Đang lưu...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined">save</span>
                        <span>Lưu thông tin</span>
                    }
                </button>
            </div>
        </div>
        } <!-- end single mode -->

        <!-- ══════════════════════════════════════════
             BATCH MODE — Thêm nhiều phòng
        ═══════════════════════════════════════════ -->
        @if (createMode == "batch")
        {
        <div class="grid grid-cols-1 gap-8">

            <!-- Section: Cấu hình phòng hàng loạt -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border-2 border-secondary/20">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-secondary-container flex items-center justify-center">
                        <span class="material-symbols-outlined text-secondary">add_home_work</span>
                    </div>
                    <div>
                        <h3 class="font-headline-sm text-headline-sm text-on-surface">Cấu hình phòng hàng loạt</h3>
                        <p class="text-caption text-on-surface-variant">Mã phòng tự động tăng — bạn có thể chỉnh sửa trong danh sách bên dưới</p>
                    </div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <!-- Tầng / Dãy -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">@(IsBasicLevel ? "Dãy" : "Tầng") <span class="text-error">*</span></label>
                        <select value="@request.FloorNumber" @onchange="OnFloorChanged" class="form-input bg-white">
                            @for (int f = 1; f <= totalFloors; f++)
                            {
                                <option value="@f">@GetFloorLabel(f)</option>
                            }
                        </select>
                    </div>
                    <!-- Số phòng -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Số phòng muốn tạo <span class="text-error">*</span></label>
                        <input @bind="batchCount" class="form-input" type="number" min="1" max="50" placeholder="5" />
                        <p class="text-caption text-on-surface-variant">Tối đa 50 phòng mỗi lần</p>
                    </div>
                    <!-- Khu vực -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Khu vực / Zone</label>
                        <input @bind="request.Zone" class="form-input" type="text" placeholder="VD: Khu A" />
                    </div>

                    <!-- Loại phòng -->
                    <div class="space-y-2 col-span-1 md:col-span-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Loại phòng</label>
                        <div class="flex gap-4">
                            <button type="button" @onclick='() => SetBatchRoomModel("Private")'
                                    class="flex-1 py-3 px-4 rounded-xl border-2 transition-all flex items-center justify-center gap-2 @(batchRoomModel == "Private" ? "border-primary bg-primary-fixed/10 text-primary font-bold" : "border-outline-variant hover:bg-surface-container-low text-on-surface-variant")">
                                <span class="material-symbols-outlined text-base">meeting_room</span>
                                Phòng riêng
                            </button>
                            <button type="button" @onclick='() => SetBatchRoomModel("Shared")'
                                    class="flex-1 py-3 px-4 rounded-xl border-2 transition-all flex items-center justify-center gap-2 @(batchRoomModel == "Shared" ? "border-primary bg-primary-fixed/10 text-primary font-bold" : "border-outline-variant hover:bg-surface-container-low text-on-surface-variant")">
                                <span class="material-symbols-outlined text-base">people</span>
                                Phòng chung / ở ghép
                            </button>
                        </div>
                    </div>

                    <!-- Sức chứa / Số giường -->
                    @if (batchRoomModel == "Private")
                    {
                        <div class="space-y-2">
                            <label class="font-label-md text-label-md text-on-surface-variant">Sức chứa (người)</label>
                            <input @bind="request.Capacity" class="form-input" type="number" min="1" placeholder="2" />
                        </div>
                    }
                    else
                    {
                        <div class="space-y-2">
                            <label class="font-label-md text-label-md text-on-surface-variant">Số giường <span class="text-error">*</span></label>
                            <input @bind="batchTotalBeds" class="form-input" type="number" min="1" placeholder="4" />
                            <p class="text-caption text-on-surface-variant">Số giường tối đa trong phòng</p>
                        </div>
                    }

                    <!-- Trạng thái -->
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Trạng thái</label>
                        <select value="@request.Status" @onchange="OnStatusChanged" class="form-input bg-white">
                            <option value="Available">Trống</option>
                            <option value="Occupied">Đang thuê</option>
                            <option value="Maintenance">Bảo trì</option>
                        </select>
                    </div>
                    <!-- Số người đang thuê (chỉ hiện khi không phải Trống) -->
                    @if (request.Status != "Available")
                    {
                        <div class="space-y-2">
                            <label class="font-label-md text-label-md text-on-surface-variant">
                                Số người đang thuê
                                <span class="text-on-surface-variant text-[11px] font-normal ml-1">
                                    / @(batchRoomModel == "Shared" ? batchTotalBeds.ToString() : (request.Capacity?.ToString() ?? "?"))
                                </span>
                            </label>
                            <input value="@request.CurrentTenantCount" @oninput="OnCurrentTenantCountInput"
                                   class="form-input" type="number" min="0"
                                   max="@(batchRoomModel == "Shared" ? batchTotalBeds : request.Capacity)"
                                   placeholder="0" />
                            <p class="text-caption text-on-surface-variant">Nhập số người hiện đang ở trong phòng</p>
                        </div>
                    }
                    <!-- Generate button -->
                    <div class="flex items-end @(request.Status == "Available" ? "md:col-span-2" : "")">
                        <button type="button" @onclick="GenerateBatchRooms"
                                class="w-full py-3 bg-secondary text-on-secondary rounded-xl font-bold flex items-center justify-center gap-2 hover:opacity-90 transition-all shadow-sm">
                            <span class="material-symbols-outlined text-sm">refresh</span>
                            Tạo danh sách phòng
                        </button>
                    </div>
                </div>

                <!-- Tiền phòng -->
                <div class="mt-8 p-6 rounded-xl bg-primary-fixed/20 border-2 border-primary/20">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <span class="font-label-md font-bold text-on-surface uppercase tracking-wider">Tiền phòng <span class="text-error">*</span></span>
                            <p class="text-caption text-on-surface-variant mt-0.5">Áp dụng đồng nhất cho tất cả phòng</p>
                        </div>
                        <span class="material-symbols-outlined text-primary text-3xl">home</span>
                    </div>
                    <div class="price-input-wrap">
                        <input value="@basePriceDisplay"
                               @oninput="OnBasePriceInput"
                               class="form-input"
                               type="text" inputmode="numeric" placeholder="0" />
                        <span class="unit">đ/tháng</span>
                    </div>
                </div>
            </section>

            <!-- Section: Phí dịch vụ chung -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border-2 border-secondary/20">
