            "Click nút Lưu thông tin sau khi đã nhập đủ mã phòng và tiền phòng.",
            true)
    };
    private int totalFloors = 1;
    private BuildingResponse? building;
    private bool IsBasicLevel => building?.Description?.Contains("[Level:Basic]", StringComparison.OrdinalIgnoreCase) ?? false;

    // ── Batch mode state ──
    private string createMode = "single"; // "single" | "batch"
    private int batchCount = 5;
    private List<BatchRoomItem> batchItems = new();
    private bool isBatchSaving = false;
    private int batchProgress = 0;
    private bool batchComplete = false;
    private string batchRoomModel = "Private"; // "Private" | "Shared"
    private int batchTotalBeds = 4;

    private void SetBatchRoomModel(string model)
    {
        batchRoomModel = model;
        StateHasChanged();
    }

    private class BatchRoomItem
    {
        public string RoomCode { get; set; } = "";
        public bool IsSaved { get; set; } = false;
        public bool HasError { get; set; } = false;
        public string? ErrorMessage { get; set; }
    }

    private void SetMode(string mode)
    {
        createMode = mode;
        errorMessage = null;
        successMessage = false;
        batchComplete = false;
        if (mode == "batch" && batchItems.Count == 0)
        {
            // auto-generate on switch if empty
            _ = GenerateBatchRooms();
        }
    }

    // ── Formatted display strings ──
    private string basePriceDisplay = "";
    private string electricPriceDisplay = "";
    private string waterPriceDisplay = "";
    private string serviceFeeDisplay = "";

    private string GetFloorLabel(int floorNum)
    {
        if (IsBasicLevel) return $"Dãy {floorNum}";
        if (floorNum == 1) return "Tầng 1 (Trệt)";
        return $"Tầng {floorNum}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var name = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
            buildingName = name ?? "—";
            int.TryParse(idStr, out buildingId);

            // Load shared fees từ localStorage (đã lưu lần trước)
            await LoadSharedFeesFromStorage();

            if (buildingId > 0)
            {
                var buildingResp = await BuildingApiService.GetBuildingByIdAsync(buildingId);
                if (buildingResp.Success && buildingResp.Data != null)
                {
                    building = buildingResp.Data;
                    totalFloors = building.TotalFloors ?? 1;

                    // Use building's actual BillingDay (overrides any stale localStorage value)
                    if (buildingResp.Data.BillingDay.HasValue)
                        request.BillingDay = buildingResp.Data.BillingDay.Value;

                    var desc = buildingResp.Data.Description;
                    if (!string.IsNullOrEmpty(desc))
                    {
                        if (desc.Contains("[RoomModel:Shared]", StringComparison.OrdinalIgnoreCase))
                        {
                            batchRoomModel = "Shared";
                        }
                        else if (desc.Contains("[RoomModel:Private]", StringComparison.OrdinalIgnoreCase))
                        {
                            batchRoomModel = "Private";
                        }
                    }
                }
            }

            if (UrlFloorNumber.HasValue)
            {
                request.FloorNumber = UrlFloorNumber.Value;
                await AutoGenerateRoomCode(UrlFloorNumber.Value);
            }
            else
            {
                request.FloorNumber = 1;
                await AutoGenerateRoomCode(1);
            }
            await StartCreateRoomTourIfNeeded();
            StateHasChanged();
        }
    }

    private async Task StartCreateRoomTourIfNeeded()
    {
        if (hasCheckedCreateRoomTour)
        {
            return;
        }

        hasCheckedCreateRoomTour = true;

        try
        {
            var dismissed = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_create_room_guided_seen");
            showCreateRoomTour = string.IsNullOrWhiteSpace(dismissed) && createMode == "single";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Create room guided tour error: {ex.Message}");
        }
    }

    private void CloseCreateRoomTour()
    {
        showCreateRoomTour = false;
    }

    private void OpenCreateRoomTour()
    {
        showCreateRoomTour = createMode == "single";
        StateHasChanged();
    }

    private async Task OnFloorChanged(ChangeEventArgs e)
    {
        errorMessage = null;
        if (int.TryParse(e.Value?.ToString(), out var floorNum))
        {
            request.FloorNumber = floorNum;
            await AutoGenerateRoomCode(floorNum);
        }
        else
        {
            request.FloorNumber = null;
        }
    }

    private async Task AutoGenerateRoomCode(int floorNum)
    {
        try
        {
            if (buildingId <= 0) return;
            var roomsResp = await RoomApiService.GetRoomsByBuildingAsync(buildingId);
            if (roomsResp.Success && roomsResp.Data != null)
            {
                var floorRooms = roomsResp.Data
                    .Where(r => r.FloorNumber == floorNum)
                    .Select(r => r.RoomCode)
                    .ToList();

                var numericCodes = new List<int>();
                foreach (var code in floorRooms)
                {
                    var digitsOnly = new string(code.Where(char.IsDigit).ToArray());
                    if (int.TryParse(digitsOnly, out var num))
                    {
                        numericCodes.Add(num);
                    }
                }

                int nextNum;
                if (numericCodes.Count > 0)
                {
                    nextNum = numericCodes.Max() + 1;
                }
                else
                {
                    nextNum = floorNum * 100 + 1;
                }

                request.RoomCode = nextNum.ToString();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error auto-generating room code: {ex.Message}");
        }
    }

    private async Task LoadSharedFeesFromStorage()
    {
        var elec = await JS.InvokeAsync<string>("localStorage.getItem", "shared_electric_price");
        var water = await JS.InvokeAsync<string>("localStorage.getItem", "shared_water_price");
        var service = await JS.InvokeAsync<string>("localStorage.getItem", "shared_service_fee");
        var billing = await JS.InvokeAsync<string>("localStorage.getItem", "shared_billing_day");

        if (decimal.TryParse(elec, out var e)) { request.ElectricPrice = e; electricPriceDisplay = FormatNumber(e); }
        if (decimal.TryParse(water, out var w)) { request.WaterPrice = w; waterPriceDisplay = FormatNumber(w); }
        if (decimal.TryParse(service, out var s)) { request.ServiceFee = s; serviceFeeDisplay = FormatNumber(s); }
        if (int.TryParse(billing, out var b)) { request.BillingDay = b; }
    }

    private async Task SaveSharedFees()
    {
        await SaveSharedFeesSilent();
        sharedFeesSaved = true;
        StateHasChanged();
        await Task.Delay(2000);
        sharedFeesSaved = false;
    }

    // Phiên bản không hiện toast và không delay — dùng trước khi submit
    private async Task SaveSharedFeesSilent()
    {
        try
        {
            if (request.ElectricPrice.HasValue) await JS.InvokeVoidAsync("localStorage.setItem", "shared_electric_price", request.ElectricPrice.Value.ToString());
            if (request.WaterPrice.HasValue) await JS.InvokeVoidAsync("localStorage.setItem", "shared_water_price", request.WaterPrice.Value.ToString());
            if (request.ServiceFee.HasValue) await JS.InvokeVoidAsync("localStorage.setItem", "shared_service_fee", request.ServiceFee.Value.ToString());
            if (request.BillingDay.HasValue) await JS.InvokeVoidAsync("localStorage.setItem", "shared_billing_day", request.BillingDay.Value.ToString());
        }
        catch { }
    }

    private void OnRoomCodeInput(ChangeEventArgs e)
    {
        errorMessage = null;
        request.RoomCode = e.Value?.ToString() ?? "";
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        errorMessage = null;
        var newStatus = e.Value?.ToString();
        request.Status = newStatus ?? "Available";
        if (newStatus == "Occupied")
        {
            if (!request.Capacity.HasValue || request.Capacity <= 0)
            {
                request.Capacity = 2;
            }
            if (!request.CurrentTenantCount.HasValue || request.CurrentTenantCount <= 0)
            {
                request.CurrentTenantCount = 1;
            }
        }
        else if (newStatus == "Available")
        {
            request.CurrentTenantCount = 0;
        }
    }

    private void OnCapacityInput(ChangeEventArgs e)
