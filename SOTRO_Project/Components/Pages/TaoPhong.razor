<HeaderDashboard/>
<SideNavBar />

<main class="min-h-screen ml-64 h-[calc(100vh-64px)] overflow-y-auto">

    <!-- Canvas Area -->
    <div class="p-margin-desktop max-w-[1000px] mx-auto">
        <!-- Breadcrumb -->
        <div class="mb-8 flex items-center gap-2 text-label-md text-on-surface-variant">
            <span>Quản lý phòng</span>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="text-primary font-bold">Thêm phòng mới</span>
        </div>
        <!-- Page Title -->
        <div class="mb-10">
            <h2 class="font-headline-md text-headline-md text-on-surface">Thêm Phòng Mới</h2>
            <p class="font-body-md text-body-md text-on-surface-variant">Vui lòng điền đầy đủ các thông tin chi tiết của phòng bên dưới.</p>
        </div>
        <div class="grid grid-cols-1 gap-8">
            <!-- Form Section: Thông tin cơ bản -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-primary-fixed flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary">info</span>
                    </div>
                    <h3 class="font-headline-sm text-headline-sm text-on-surface">Thông tin cơ bản</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Tên / Số phòng</label>
                        <input class="w-full bg-white border border-outline-variant rounded-lg p-3 form-focus-ring text-body-md" placeholder="Ví dụ: P.402" type="text">
                    </div>
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Loại phòng</label>
                        <select class="w-full bg-white border border-outline-variant rounded-lg p-3 form-focus-ring text-body-md">
                            <option>Phòng Đơn</option>
                            <option>Phòng Đôi</option>
                            <option>Studio</option>
                            <option>Căn hộ dịch vụ</option>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="font-label-md text-label-md text-on-surface-variant">Tầng</label>
                        <input class="w-full bg-white border border-outline-variant rounded-lg p-3 form-focus-ring text-body-md" placeholder="4" type="number">
                    </div>
                </div>
            </section>
            <!-- Form Section: Cấu hình giá (Highlight) -->
            <section class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border-2 border-primary-fixed">
                <div class="flex items-center gap-3 mb-6">
                    <div class="w-10 h-10 rounded-lg bg-tertiary-fixed flex items-center justify-center">
                        <span class="material-symbols-outlined text-tertiary">payments</span>
                    </div>
                    <h3 class="font-headline-sm text-headline-sm text-on-surface">Cấu hình đơn giá</h3>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <!-- Tiền phòng -->
                    <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant space-y-4">
                        <div class="flex justify-between items-start">
                            <span class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider">Tiền Phòng</span>
                            <span class="material-symbols-outlined text-on-surface-variant">home</span>
                        </div>
                        <div class="relative">
                            <input class="w-full bg-white border border-outline-variant rounded-lg p-4 pr-16 text-headline-sm text-primary font-bold form-focus-ring" type="text" value="3.500.000">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 font-label-md text-on-surface-variant">đ/tháng</span>
                        </div>
                    </div>
                    <!-- Tiền điện -->
                    <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant space-y-4">
                        <div class="flex justify-between items-start">
                            <span class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider">Đơn giá điện</span>
                            <span class="material-symbols-outlined text-on-surface-variant">bolt</span>
                        </div>
                        <div class="relative">
                            <input class="w-full bg-white border border-outline-variant rounded-lg p-4 pr-16 text-headline-sm text-on-surface font-bold form-focus-ring" type="text" value="3.500">
                            <span class="absolute right-4 top-1/2 -translate-y-1/2 font-label-md text-on-surface-variant">đ/kWh</span>
                        </div>
                    </div>
                    <!-- Tiền nước -->
                    <div class="p-6 rounded-xl bg-surface-container-low border border-outline-variant space-y-4">
                        <div class="flex justify-between items-start">
                            <span class="font-label-md text-label-md font-bold text-on-surface uppercase tracking-wider">Đơn giá nước</span>
                            <span class="material-symbols-outlined text-on-surface-variant">water_drop</span>
                        </div>
                        <div class="space-y-3">
                            <div class="relative">
                                <input class="w-full bg-white border border-outline-variant rounded-lg p-4 pr-16 text-headline-sm text-on-surface font-bold form-focus-ring" type="text" value="25.000">
                                <span class="absolute right-4 top-1/2 -translate-y-1/2 font-label-md text-on-surface-variant">VNĐ</span>
                            </div>
                            <div class="flex gap-2">
                                <button class="flex-1 py-2 rounded-full border border-primary bg-primary-fixed text-primary font-bold text-caption transition-all">Theo m3</button>
                                <button class="flex-1 py-2 rounded-full border border-outline-variant text-on-surface-variant font-medium text-caption hover:bg-surface transition-all">Theo người</button>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- Actions -->
            <div class="flex items-center justify-end gap-4 pt-4 mb-16">
                <button class="px-8 py-3 rounded-xl border border-outline text-on-surface font-bold hover:bg-surface-container-high transition-all">
                    Hủy
                </button>
                <button class="px-12 py-3 rounded-xl bg-primary text-white font-bold shadow-lg hover:bg-primary-container hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined">save</span>
                    Lưu thông tin
                </button>
            </div>
        </div>
    </div>
</main>

<!-- Main Content Area -->

<!-- Visual Polish: Background Decoration -->
<div class="fixed top-0 right-0 -z-10 w-[500px] h-[500px] bg-primary-fixed/20 rounded-full blur-[120px] pointer-events-none"></div>
<div class="fixed bottom-0 left-72 -z-10 w-[300px] h-[300px] bg-secondary-fixed/30 rounded-full blur-[100px] pointer-events-none"></div>
<script>
        // Simple micro-interaction for water price toggle
        const toggleButtons = document.querySelectorAll('.flex-1.py-2');
        toggleButtons.forEach(btn => {
            btn.addEventListener('click', function() {
                toggleButtons.forEach(b => {
                    b.classList.remove('bg-primary-fixed', 'text-primary', 'font-bold', 'border-primary');
                    b.classList.add('border-outline-variant', 'text-on-surface-variant', 'font-medium');
                });
                this.classList.add('bg-primary-fixed', 'text-primary', 'font-bold', 'border-primary');
                this.classList.remove('border-outline-variant', 'text-on-surface-variant', 'font-medium');
            });
        });

        // Numeric input formatting simulation (just visual focus)
        const inputs = document.querySelectorAll('input[type="text"]');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.parentElement.parentElement.classList.add('ring-2', 'ring-primary-fixed-dim');
            });
            input.addEventListener('blur', () => {
                input.parentElement.parentElement.classList.remove('ring-2', 'ring-primary-fixed-dim');
            });
        });
    </script>


@code {
    private const string CustomStyles = "TaoPhong";
