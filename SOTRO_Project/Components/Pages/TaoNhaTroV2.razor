    // ── Lookup data ──
    private List<BuildingTypeResponse> buildingTypes = new();
    private DotNetObjectReference<TaoNhaTroV2>? dotNetHelper;

    // ── Level definitions ──
    private record LevelOption(string Key, string Label, string Description, string Icon,
        string Badge, string BadgeClass, string SelectedBg, string SelectedIcon);

    private readonly List<LevelOption> levels = new()
    {
        new("Basic", "Nhà trọ truyền thống", "Phòng trọ giá bình dân, tiện nghi cơ bản",
            "home", "Phổ biến", "bg-blue-50 text-blue-700", "bg-blue-100", "text-blue-600"),
        new("MiniApartment", "Chung cư mini", "Có phòng bếp riêng, tiện nghi đầy đủ hơn",
            "apartment", "", "", "bg-violet-100", "text-violet-600"),
    };

    private record ServiceOption(string Key, string Label, string Icon);
    private readonly List<ServiceOption> serviceOptions = new()
    {
        new("electricity", "Điện", "bolt"),
        new("water", "Nước", "water_drop"),
        new("wifi", "Wifi", "wifi"),
        new("cleaning", "Vệ sinh", "cleaning"),
        new("security", "Bảo vệ", "security"),
        new("parking", "Giữ xe", "local_parking"),
    };

    private class ImagePreview
    {
        public byte[] FileData { get; set; } = Array.Empty<byte>();
        public string FileName { get; set; } = string.Empty;
        public string ContentType { get; set; } = string.Empty;
        public long FileSize { get; set; }
        public string? PreviewUrl { get; set; }
    }

    // ── Computed ──
    private bool CanProceed => currentStep switch
    {
        1 => !string.IsNullOrEmpty(selectedRoomModel),
        2 => !string.IsNullOrEmpty(selectedLevel),
        3 => true,
        4 => !string.IsNullOrWhiteSpace(model.BuildingName)
             && !string.IsNullOrWhiteSpace(model.Address)
             && model.TotalFloors.HasValue
             && selectedImages.Count > 0,
        _ => false
    };

    private string StepHintIcon => currentStep switch
    {
        1 => "meeting_room",
        2 => "apartment",
        3 => "room_service",
        4 => "photo_library",
        _ => "info"
    };

    private string StepHintText => currentStep switch
    {
        1 => "Bạn có thể thay đổi cài đặt này sau khi tạo nhà trọ.",
        2 => "Phân khúc giúp hệ thống gợi ý mẫu hóa đơn phù hợp.",
        3 => "Dịch vụ sẽ được hiện trong mẫu hóa đơn hàng tháng.",
        4 => "Ảnh đầu tiên sẽ được dùng làm ảnh đại diện nhà trọ.",
        _ => ""
    };

    protected override async Task OnInitializedAsync()
    {
        var resp = await BuildingApiService.GetBuildingTypesAsync();
        if (resp.Success && resp.Data != null)
        {
            buildingTypes = resp.Data
                .Where(t => t.BuildingTypeId == 1 || t.BuildingTypeId == 2)
                .ToList();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetHelper = DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("window.initAddressAutocomplete",
                    "address-input-v2", dotNetHelper, nameof(OnAddressSelected));
            }
            catch { /* autocomplete optional */ }

            await StartBuildingTourIfNeeded();
        }
    }

    private async Task StartBuildingTourIfNeeded()
    {
        if (hasCheckedBuildingTour)
        {
            return;
        }

        hasCheckedBuildingTour = true;

        try
        {
            var forceTour = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_force_create_building_tour");
            if (!string.IsNullOrWhiteSpace(forceTour))
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_force_create_building_tour");
                showBuildingTour = true;
                StateHasChanged();
                return;
            }

            var dismissed = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_create_building_guided_seen");
            if (string.IsNullOrWhiteSpace(dismissed))
            {
                showBuildingTour = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Create building guided tour error: {ex.Message}");
        }
    }

    private void CloseBuildingTour()
    {
        showBuildingTour = false;
    }

    private void OpenBuildingTour()
    {
        showBuildingTour = true;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnAddressSelected(string address)
    {
        model.Address = address;
        StateHasChanged();
    }

    [JSInvokable]
    public async Task<List<string>> GetSuggestions(string query)
    {
        try
        {
            var response = await BuildingApiService.SuggestAddressAsync(query);
            if (response.Success && response.Data != null)
                return response.Data;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[AddressAutocomplete] Error: {ex.Message}");
        }
        return new List<string>();
    }

    private async Task NextStep()
    {
        if (!CanProceed) return;
        errorMessage = null;
        if (currentStep < 4) currentStep++;
        // Re-initialize address autocomplete when reaching step 4
        if (currentStep == 4)
        {
            StateHasChanged();
            await Task.Delay(200);
            try
            {
                await JS.InvokeVoidAsync("window.initAddressAutocomplete",
                    "address-input-v2", dotNetHelper, nameof(OnAddressSelected));
            }
            catch { }
        }
    }

    private void PreviousStep()
    {
        errorMessage = null;
        if (currentStep > 1) currentStep--;
    }

    private void ToggleService(string key)
    {
        if (!selectedServices.Add(key))
            selectedServices.Remove(key);
    }

    private void OnDefaultElectricPriceInput(ChangeEventArgs e)
    {
        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        defaultElectricPrice = raw;
        defaultElectricPriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnDefaultWaterPriceInput(ChangeEventArgs e)
    {
        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        defaultWaterPrice = raw;
        defaultWaterPriceDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }
    private void OnDefaultServiceFeeInput(ChangeEventArgs e)
    {
        errorMessage = null;
        var raw = ParseRawNumber(e.Value?.ToString());
        defaultServiceFee = raw;
        defaultServiceFeeDisplay = raw.HasValue ? FormatNumber(raw.Value) : "";
    }

    private static string FormatNumber(decimal value)
        => value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"));

    private static decimal? ParseRawNumber(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var cleaned = input.Replace(".", "").Replace(",", "");
        return decimal.TryParse(cleaned, out var d) ? d : null;
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        foreach (var file in e.GetMultipleFiles(10))
        {
            if (file.Size > 5 * 1024 * 1024) { errorMessage = $"'{file.Name}' vượt 5MB."; continue; }
            try
            {
                var buf = new byte[file.Size];
                await file.OpenReadStream(5 * 1024 * 1024).ReadExactlyAsync(buf);
                selectedImages.Add(new ImagePreview
                {
                    FileData = buf, FileName = file.Name,
                    ContentType = file.ContentType, FileSize = file.Size,
                    PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buf)}"
                });
                StateHasChanged();
            }
            catch (Exception ex) { errorMessage = $"Lỗi đọc file: {ex.Message}"; }
        }
        StateHasChanged();
    }

    private void RemoveImage(int index)
    {
        if (index >= 0 && index < selectedImages.Count)
            selectedImages.RemoveAt(index);
    }

    private async Task ShowError(string msg)
    {
        errorMessage = msg;
        StateHasChanged();
        await Task.Delay(60);
        await JS.InvokeVoidAsync("eval",
            "document.getElementById('v2-error-banner')?.scrollIntoView({ behavior: 'smooth', block: 'center' })");
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;

        // Validate required fields
        if (string.IsNullOrWhiteSpace(model.BuildingName)) { await ShowError("Vui lòng nhập tên nhà trọ."); return; }
        if (string.IsNullOrWhiteSpace(model.Address)) { await ShowError("Vui lòng nhập địa chỉ nhà trọ."); return; }
        if (!model.TotalFloors.HasValue || model.TotalFloors <= 0) { await ShowError("Vui lòng nhập số tầng hợp lệ (≥ 1)."); return; }
        if (!model.BillingDay.HasValue) { await ShowError("Vui lòng chọn ngày lập hóa đơn hàng tháng."); return; }
        if (!model.DueDay.HasValue) { await ShowError("Vui lòng chọn ngày hạn thanh toán."); return; }
        if (model.BillingDay >= model.DueDay) { await ShowError($"Ngày lập hóa đơn (ngày {model.BillingDay}) phải nhỏ hơn ngày hạn thanh toán (ngày {model.DueDay})."); return; }
        if (selectedImages.Count == 0) { await ShowError("Vui lòng tải lên ít nhất 1 ảnh nhà trọ."); return; }

        // ── Mapping: RoomModel + Level + HasService → BuildingTypeId ──
        model.BuildingTypeId = MapToBuildingTypeId();

        // ── Enrich description with new fields ──
        var descParts = new List<string>();
        if (!string.IsNullOrWhiteSpace(model.Description))
            descParts.Add(model.Description.Trim());

        descParts.Add($"[RoomModel:{selectedRoomModel}]");
        descParts.Add($"[Level:{selectedLevel}]");
        if (hasService && selectedServices.Count > 0)
            descParts.Add($"[Services:{string.Join(",", selectedServices)}]");
        else if (hasService)
            descParts.Add("[Services:yes]");

        model.Description = string.Join(" | ", descParts);

        // BillingDay and DueDay are validated and required (handled above)

        isSubmitting = true;
        try
        {
            var imageFiles = selectedImages
                .Select(img => ((Stream)new MemoryStream(img.FileData), img.FileName))
                .ToList();

            var response = await BuildingApiService.CreateBuildingAsync(model, imageFiles);
            if (response.Success)
            {
                // Sync defaults to localStorage so TaoPhong can pre-fill room prices
                try
                {
                    if (response.Data != null)
                    {
                        await JS.InvokeVoidAsync("localStorage.setItem", "active_building_id", response.Data.BuildingId.ToString());
                        await JS.InvokeVoidAsync("localStorage.setItem", "active_building_name", response.Data.BuildingName);
                    }
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_create_building_guided_seen", "true");
                    await JS.InvokeVoidAsync("localStorage.setItem", "shared_billing_day", model.BillingDay!.Value.ToString());
                    if (defaultElectricPrice.HasValue)
                        await JS.InvokeVoidAsync("localStorage.setItem", "shared_electric_price", defaultElectricPrice.Value.ToString());
                    if (defaultWaterPrice.HasValue)
                        await JS.InvokeVoidAsync("localStorage.setItem", "shared_water_price", defaultWaterPrice.Value.ToString());
                    if (defaultServiceFee.HasValue)
                        await JS.InvokeVoidAsync("localStorage.setItem", "shared_service_fee", defaultServiceFee.Value.ToString());
                }
                catch { }
                isSuccess = true;
                StateHasChanged();
                await Task.Delay(1800);
                Navigation.NavigateTo("/quan-ly-phong");
            }
            else
            {
                await ShowError(response.Message ?? "Tạo nhà trọ thất bại. Vui lòng thử lại.");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Maps (RoomModel, Level, HasService) → BuildingTypeId from API lookup.
    /// Falls back to first available type if no match found.
    /// </summary>
    private int MapToBuildingTypeId()
    {
        // Map level to type name keywords
        var keyword = selectedLevel switch
        {
            "MiniApartment"     => "mini",
            _                   => "nhà trọ"
        };

        var match = buildingTypes.FirstOrDefault(t =>
            t.TypeName.Contains(keyword, StringComparison.OrdinalIgnoreCase));

        return match?.BuildingTypeId ?? buildingTypes.FirstOrDefault()?.BuildingTypeId ?? 1;
    }

    public void Dispose() => dotNetHelper?.Dispose();
}
