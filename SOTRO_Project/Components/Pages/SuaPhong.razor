    private static string FormatNumber(decimal value)
        => value.ToString("N0", System.Globalization.CultureInfo.GetCultureInfo("vi-VN"));

    private static decimal? ParseRawNumber(string? input)
    {
        if (string.IsNullOrWhiteSpace(input)) return null;
        var cleaned = input.Replace(".", "").Replace(",", "");
        return decimal.TryParse(cleaned, out var d) ? d : null;
    }
