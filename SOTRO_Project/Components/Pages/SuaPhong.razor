                                </div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-label-md text-label-md text-on-surface-variant">Tiền điện (VNĐ/kWh)</label>
                                <div class="relative">
                                    <input class="w-full px-4 py-3 rounded-lg border border-outline focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all font-body-md pr-12" type="text" value="4,000" />
                                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-on-surface-variant font-label-md">VNĐ</span>
                                </div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <label class="font-label-md text-label-md text-on-surface-variant">Tiền nước (VNĐ/m3)</label>
                                <div class="relative">
                                    <input class="w-full px-4 py-3 rounded-lg border border-outline focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all font-body-md pr-12" type="text" value="25,000" />
