@page "/sua-phong/{RoomId:int}"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject IBuildingApiService BuildingApiService
@inject IJSRuntime JS

<PageTitle>Chỉnh sửa phòng - SOTRO Admin</PageTitle>

<style>
    /* Hide number input arrows */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        display: inline-block;
        vertical-align: middle;
    }
    body { background-color: #f8f9fa; font-family: 'Inter', sans-serif; }
    .form-input {
        width: 100%; background: white;
        border: 1px solid var(--md-sys-color-outline-variant, #cad4e0);
        border-radius: 0.5rem; padding: 0.75rem 1rem; font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
    }
    .form-input:focus {
        outline: none; border-color: #003f87;
        box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.1);
    }
    .price-wrap { position: relative; }
    .price-wrap input { padding-right: 4rem; font-weight: 700; }
    .price-wrap .unit {
        position: absolute; right: 0.75rem; top: 50%; transform: translateY(-50%);
        font-size: 0.75rem; color: #6b7280; pointer-events: none;
    }
    .shared-badge {
        display: inline-flex; align-items: center; gap: 0.3rem;
        background: #e8f0fe; color: #1a56db;
        font-size: 0.7rem; font-weight: 700;
        padding: 0.15rem 0.6rem; border-radius: 9999px;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 0.8s linear infinite; display:inline-block; }
</style>

<HeaderDashboard />
<SideNavBar />

<main class="flex-grow flex flex-col min-h-screen md:ml-64 pb-24 md:pb-0">
    <div class="p-margin-mobile md:p-margin-desktop flex-grow max-w-[1000px] mx-auto w-full">

        <!-- Breadcrumbs -->
        <nav class="flex items-center gap-2 mb-6 text-on-surface-variant font-label-md">
            <button @onclick="GoBack" class="hover:text-primary transition-colors">Quản lý phòng</button>
            <span class="material-symbols-outlined text-sm">chevron_right</span>
            <span class="text-on-surface font-semibold">Chỉnh sửa phòng @(room?.RoomCode ?? "")</span>
        </nav>

        @if (isLoading)
        {
            <div class="flex flex-col items-center justify-center py-24 gap-4">
                <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
                <p class="text-on-surface-variant">Đang tải thông tin phòng...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(loadError))
        {
            <div class="flex flex-col items-center justify-center py-24 gap-4">
                <span class="material-symbols-outlined text-error text-5xl">error</span>
                <p class="text-error font-bold">@loadError</p>
                <button @onclick="LoadRoom" class="px-6 py-2 bg-primary text-white rounded-full text-label-md">Thử lại</button>
            </div>
        }
        else
        {
            <div class="mb-8">
                <h2 class="font-headline-md text-headline-md text-on-surface">Chỉnh sửa phòng @(room?.RoomCode)</h2>
                <p class="text-body-md text-on-surface-variant">Cập nhật thông tin chi tiết và trạng thái của phòng.</p>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div id="error-message-container" class="mb-6 p-4 bg-error-container text-on-error-container rounded-xl flex items-center gap-3">
                    <span class="material-symbols-outlined">error</span>
                    <p>@errorMessage</p>
                </div>
            }

            @if (successMessage)
            {
                <div class="mb-6 p-4 bg-secondary-container text-on-secondary-container rounded-xl flex items-center gap-3">
                    <span class="material-symbols-outlined">check_circle</span>
                    <p>Cập nhật thành công!</p>
                </div>
            }

            <!-- Edit Form Card -->
            <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
                <div class="p-6 md:p-8">
                    <div class="space-y-8">
                        <!-- Basic Info Section -->
                        <section>
                            <div class="flex items-center gap-2 mb-6 pb-2 border-b border-outline-variant">
                                <span class="material-symbols-outlined text-primary">info</span>
                                <h3 class="font-headline-sm text-headline-sm">Thông tin cơ bản</h3>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Mã phòng <span class="text-error">*</span></label>
                                    <input value="@request.RoomCode" @oninput="OnRoomCodeInput"
                                           class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                           placeholder="VD: P101" type="text" />
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Tên phòng</label>
                                    <input @bind="request.RoomName"
                                           class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                           placeholder="VD: Phòng cao cấp" type="text" />
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">@(isBasicLevel ? "Dãy" : "Tầng") <span class="text-error">*</span></label>
                                    <select @bind="request.FloorNumber"
                                            class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md bg-white">
                                        @for (int f = 1; f <= totalFloors; f++)
                                        {
                                            <option value="@f">@GetFloorLabel(f)</option>
                                        }
                                    </select>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Khu vực / Zone</label>
                                    <input @bind="request.Zone"
                                           class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                           placeholder="VD: Khu A" type="text" />
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Loại phòng</label>
                                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
                                        <button type="button" @onclick='() => SetRoomModel("Private")'
                                                class="flex-1 py-3 px-4 rounded-xl border-2 transition-all flex items-center justify-center gap-2 @(editRoomModel == "Private" ? "border-primary bg-primary-fixed/10 text-primary font-bold" : "border-outline-variant hover:bg-surface-container-low text-on-surface-variant")">
                                            <span class="material-symbols-outlined text-base">meeting_room</span>
                                            Phòng riêng
                                        </button>
                                        <button type="button" @onclick='() => SetRoomModel("Shared")'
                                                class="flex-1 py-3 px-4 rounded-xl border-2 transition-all flex items-center justify-center gap-2 @(editRoomModel == "Shared" ? "border-primary bg-primary-fixed/10 text-primary font-bold" : "border-outline-variant hover:bg-surface-container-low text-on-surface-variant")">
                                            <span class="material-symbols-outlined text-base">people</span>
                                            Phòng chung / ở ghép
                                        </button>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Trạng thái phòng</label>
                                    <select value="@request.Status" @onchange="OnStatusChanged"
                                            class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md bg-white">
                                        <option value="Available">Trống</option>
                                        <option value="Occupied">Đang thuê</option>
                                        <option value="Maintenance">Bảo trì</option>
                                    </select>
                                </div>
                                @if (editRoomModel == "Private")
                                {
                                    <div class="flex flex-col gap-2">
                                        <label class="font-label-md text-label-md text-on-surface-variant">Sức chứa (người)</label>
                                        <input value="@request.Capacity" @oninput="OnCapacityInput"
                                               class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                               type="number" placeholder="2" min="1" />
                                    </div>
                                }
                                else
                                {
                                    <div class="flex flex-col gap-2">
                                        <label class="font-label-md text-label-md text-on-surface-variant">Số giường <span class="text-error">*</span></label>
                                        <input value="@editTotalBeds" @oninput="OnTotalBedsInput"
                                               class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                               type="number" min="1" placeholder="4" />
                                    </div>
                                }
                                @if (request.Status != "Available")
                                {
                                    <div class="flex flex-col gap-2 md:col-span-2">
                                        <label class="font-label-md text-label-md text-on-surface-variant">
                                            Số người đang thuê
                                            <span class="text-on-surface-variant text-[11px] font-normal ml-1">
                                                / @(editRoomModel == "Shared" ? editTotalBeds.ToString() : (request.Capacity?.ToString() ?? "?"))
                                            </span>
                                        </label>
                                        <input value="@request.CurrentTenantCount" @oninput="OnCurrentTenantCountInput"
                                               class="px-4 py-3 rounded-lg border border-outline form-focus-ring font-body-md"
                                               type="number" min="0" max="@(editRoomModel == "Shared" ? editTotalBeds : request.Capacity)" placeholder="0" />
                                        <p class="text-caption text-on-surface-variant">Nhập số người hiện đang ở trong phòng</p>
                                    </div>
                                }
                            </div>
                        </section>

                        <!-- Tiền phòng – riêng từng phòng -->
                        <section>
                            <div class="flex items-center gap-2 mb-6 pb-2 border-b border-outline-variant">
                                <span class="material-symbols-outlined text-primary">home</span>
                                <h3 class="font-headline-sm text-headline-sm">Giá thuê phòng</h3>
                                <span class="text-caption text-on-surface-variant">(riêng từng phòng)</span>
                            </div>
                            <div class="p-5 rounded-xl bg-primary-fixed/20 border-2 border-primary/20">
                                <label class="font-label-md text-label-md text-on-surface-variant">Tiền phòng (đ/Tháng) <span class="text-error">*</span></label>
                                <div class="price-wrap mt-2">
                                    <input value="@basePriceDisplay" @oninput="OnBasePriceInput"
                                           class="form-input" type="text" inputmode="numeric" placeholder="0" />
                                    <span class="unit">đ/tháng</span>
                                </div>
                            </div>
                        </section>

                        <!-- Phí dịch vụ chung -->
                        <section>
                            <div class="flex items-center gap-2 mb-6 pb-2 border-b border-outline-variant">
                                <span class="material-symbols-outlined text-secondary">settings</span>
                                <h3 class="font-headline-sm text-headline-sm">Phí dịch vụ chung</h3>
                                <span class="shared-badge">
                                    <span class="material-symbols-outlined text-[14px]">sync</span> Áp dụng cho mọi phòng
                                </span>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Điện (đ/kWh)</label>
                                    <div class="price-wrap">
                                        <input value="@electricPriceDisplay" @oninput="OnElectricPriceInput"
                                               class="form-input" type="text" inputmode="numeric" placeholder="0" />
                                        <span class="unit">đ</span>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Nước</label>
                                    <div class="price-wrap">
                                        <input value="@waterPriceDisplay" @oninput="OnWaterPriceInput"
                                               class="form-input" type="text" inputmode="numeric" placeholder="0" />
                                        <span class="unit">đ</span>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Phí dịch vụ (đ/tháng)</label>
                                    <div class="price-wrap">
                                        <input value="@serviceFeeDisplay" @oninput="OnServiceFeeInput"
                                               class="form-input" type="text" inputmode="numeric" placeholder="0" />
                                        <span class="unit">đ</span>
                                    </div>
                                </div>
                                <div class="flex flex-col gap-2">
                                    <label class="font-label-md text-label-md text-on-surface-variant">Ngày thu tiền (1–15)</label>
                                    <div class="relative flex items-center">
                                        <input value="@request.BillingDay" @oninput="OnBillingDayInput" class="form-input pr-10" type="number" min="1" max="15" />
                                        <div class="absolute right-3 flex items-center justify-center w-6 h-6 pointer-events-none text-on-surface-variant">
                                            <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                                        </div>
                                        <input type="date" @onchange="OnBillingDateChanged" 
                                               class="absolute right-3 w-6 h-6 opacity-0 cursor-pointer" />
                                    </div>
                                </div>
                                 <div class="flex flex-col gap-2 md:col-span-2">
                                     <label class="font-label-md text-label-md text-on-surface-variant">Ghi chú</label>
                                     <textarea @bind="userNote" class="form-input resize-none" rows="2" placeholder="Ghi chú thêm..."></textarea>
                                 </div>
                            </div>
                        </section>

                        <!-- Action Buttons -->
                        <div class="pt-8 flex flex-col md:flex-row items-center justify-end gap-4 border-t border-outline-variant">
                            <button @onclick="GoBack"
                                    class="w-full md:w-auto px-8 py-3 rounded-full font-label-md text-on-surface-variant hover:bg-surface-container-high transition-all"
                                    disabled="@isSaving">
                                Hủy thay đổi
                            </button>
                            <button @onclick="HandleSubmit"
                                    class="w-full md:w-auto px-10 py-3 rounded-full bg-primary text-on-primary font-bold shadow-lg hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2 disabled:opacity-60"
                                    disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="material-symbols-outlined animate-spin">sync</span>
                                    <span>Đang lưu...</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined">save</span>
                                    <span>Cập nhật thay đổi</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Toast -->
        <div class="fixed bottom-8 right-8 bg-on-secondary-fixed text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 transition-all duration-500 z-50 @(showToast ? "translate-y-0 opacity-100" : "translate-y-24 opacity-0")" id="toast">
            <span class="material-symbols-outlined text-green-400">check_circle</span>
            <p class="font-label-md">Cập nhật thông tin phòng thành công!</p>
        </div>
    </div>
    <footer class="mt-auto py-8 text-center text-on-surface-variant border-t border-outline-variant">
        <p class="font-label-md">© 2024 SOTRO Management Platform. All rights reserved.</p>
    </footer>
</main>

@code {
    [Parameter] public int RoomId { get; set; }

    private RoomDetailResponse? room;
    private UpdateRoomRequest request = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool successMessage;
    private bool showToast;
    private string? loadError;
    private string? errorMessage;
    private int totalFloors = 1;
    private bool isBasicLevel;

    private string editRoomModel = "Private";
    private int editTotalBeds = 4;
    private string userNote = "";

    // Formatted display strings
    private string basePriceDisplay     = "";
    private string electricPriceDisplay = "";
    private string waterPriceDisplay    = "";
    private string serviceFeeDisplay    = "";

    private string GetFloorLabel(int floorNum)
    {
        if (isBasicLevel) return $"Dãy {floorNum}";
        if (floorNum == 1) return "Tầng 1 (Trệt)";
        return $"Tầng {floorNum}";
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadRoom();
    }

    private async Task LoadRoom()
    {
        isLoading = true;
        loadError = null;
        try
        {
            var result = await RoomApiService.GetRoomByIdAsync(RoomId);
            if (result.Success && result.Data != null)
            {
                room = result.Data;
                // Map to UpdateRoomRequest
                request = new UpdateRoomRequest
                {
                    RoomCode       = room.RoomCode,
                    RoomName       = room.RoomName,
                    Zone           = room.Zone,
                    FloorNumber    = room.FloorNumber,
                    RoomTypeId     = room.RoomTypeId,
                    Status         = room.Status,
                    BasePrice      = room.BasePrice,
                    ElectricPrice  = room.ElectricPrice,
                    WaterPrice     = room.WaterPrice,
                    ServiceFee     = room.ServiceFee,
                    Capacity       = room.Capacity,
                    CurrentTenantCount = room.CurrentTenantCount,
                    BillingDay     = room.BillingDay,
                    PaymentDueDay  = room.PaymentDueDay,
                    BankName       = room.BankName,
                    BankAccountNumber = room.BankAccountNumber,
                    Note           = room.Note,
                };

                // Extract room model and beds from Note JSON if present
                editRoomModel = "Private";
                editTotalBeds = 4;
                userNote = room.Note ?? "";

                if (!string.IsNullOrWhiteSpace(room.Note))
                {
                    try
                    {
                        var parsed = System.Text.Json.JsonSerializer.Deserialize<RoomNoteData>(room.Note);
                        if (parsed != null && (parsed.RoomModel == "Private" || parsed.RoomModel == "Shared"))
                        {
                            editRoomModel = parsed.RoomModel;
                            if (parsed.TotalBeds.HasValue)
                            {
                                editTotalBeds = parsed.TotalBeds.Value;
                            }
                            userNote = parsed.UserNote ?? "";
                        }
                    }
                    catch
                    {
                        // Note is not JSON, leave as is
                    }
                }

                if (editRoomModel == "Shared")
                {
                    request.Capacity = editTotalBeds;
                }

                // Init formatted display
                basePriceDisplay     = request.BasePrice.HasValue ? FormatNumber(request.BasePrice.Value) : "";
                electricPriceDisplay = request.ElectricPrice.HasValue ? FormatNumber(request.ElectricPrice.Value) : "";
                waterPriceDisplay    = request.WaterPrice.HasValue ? FormatNumber(request.WaterPrice.Value) : "";
                serviceFeeDisplay    = request.ServiceFee.HasValue ? FormatNumber(request.ServiceFee.Value) : "";

                // Fetch building floors
                if (room.BuildingId.HasValue)
                {
                    var buildingResp = await BuildingApiService.GetBuildingByIdAsync(room.BuildingId.Value);
                    if (buildingResp.Success && buildingResp.Data != null)
                    {
                        totalFloors = buildingResp.Data.TotalFloors ?? 1;
                        isBasicLevel = buildingResp.Data.Description?.Contains("[Level:Basic]", StringComparison.OrdinalIgnoreCase) ?? false;
                    }
                }
            }
            else
            {
                loadError = result.Message ?? "Không tìm thấy thông tin phòng.";
            }
        }
        catch (Exception ex)
        {
            loadError = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ScrollToError()
    {
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval", "document.getElementById('error-message-container')?.scrollIntoView({ behavior: 'smooth', block: 'center' })");
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(request.RoomCode))
        {
            errorMessage = "Vui lòng nhập mã phòng.";
            await ScrollToError();
            return;
        }
        if (request.BasePrice == null)
        {
            errorMessage = "Vui lòng nhập tiền phòng.";
            await ScrollToError();
            return;
        }
        if (request.BasePrice <= 0)
        {
            errorMessage = "Tiền phòng phải lớn hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.ElectricPrice.HasValue && request.ElectricPrice < 0)
        {
            errorMessage = "Đơn giá điện không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.WaterPrice.HasValue && request.WaterPrice < 0)
        {
            errorMessage = "Đơn giá nước không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.ServiceFee.HasValue && request.ServiceFee < 0)
        {
            errorMessage = "Phí dịch vụ không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }

        if (editRoomModel == "Shared")
        {
            request.Capacity = editTotalBeds;
            if (editTotalBeds <= 0)
            {
                errorMessage = "Số giường phải lớn hơn 0.";
                await ScrollToError();
                return;
            }
        }
        else
        {
            if (request.Capacity.HasValue && request.Capacity <= 0)
            {
                errorMessage = "Sức chứa phải lớn hơn 0.";
                await ScrollToError();
                return;
            }
        }

        // Validate số người thuê khi phòng đang được thuê
        if (request.Status == "Occupied")
        {
            if (!request.Capacity.HasValue || request.Capacity <= 0)
            {
                errorMessage = editRoomModel == "Shared" 
                    ? "Khi phòng đang thuê, vui lòng nhập số giường tối đa của phòng."
                    : "Khi phòng đang thuê, vui lòng nhập sức chứa tối đa của phòng.";
                await ScrollToError();
                return;
            }
            if (!request.CurrentTenantCount.HasValue || request.CurrentTenantCount <= 0)
            {
                errorMessage = "Khi phòng đang thuê, bắt buộc phải nhập số người đang thuê (lớn hơn 0).";
                await ScrollToError();
                return;
            }
            if (request.CurrentTenantCount > request.Capacity)
            {
                errorMessage = editRoomModel == "Shared"
                    ? $"Số người đang thuê ({request.CurrentTenantCount}) không được vượt quá số giường ({request.Capacity} giường)."
                    : $"Số người đang thuê ({request.CurrentTenantCount}) không được vượt quá sức chứa ({request.Capacity} người).";
                await ScrollToError();
                return;
            }
        }
        if (request.Status == "Maintenance" && request.CurrentTenantCount.HasValue && request.CurrentTenantCount < 0)
        {
            errorMessage = "Số người đang ở không được nhỏ hơn 0.";
            await ScrollToError();
            return;
        }
        if (request.BillingDay.HasValue && (request.BillingDay < 1 || request.BillingDay > 15))
        {
            errorMessage = "Ngày thu tiền phải từ ngày 1 đến ngày 15.";
            await ScrollToError();
            return;
        }

        // Serialize Note fields to JSON
        var noteObj = new RoomNoteData
        {
            RoomModel = editRoomModel,
            TotalBeds = editRoomModel == "Shared" ? (int?)editTotalBeds : null,
            UserNote = userNote
        };
        request.Note = System.Text.Json.JsonSerializer.Serialize(noteObj);

        isSaving = true;
        try
        {
            var result = await RoomApiService.UpdateRoomAsync(RoomId, request);
            if (result.Success)
            {
                successMessage = true;
                showToast = true;
                StateHasChanged();
                await Task.Delay(2500);
                showToast = false;
                Navigation.NavigateTo("/quan-ly-phong");
            }
            else
            {
                errorMessage = result.Message ?? "Cập nhật thất bại. Vui lòng thử lại.";
                await ScrollToError();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi: {ex.Message}";
            await ScrollToError();
        }
        finally
        {
            isSaving = false;
        }
    }

