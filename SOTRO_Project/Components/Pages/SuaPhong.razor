                                <span class="font-label-md text-on-surface-variant">Thêm ảnh</span>
                            </div>
                            <div class="col-span-1 row-span-1 rounded-xl overflow-hidden relative group">
                                <img class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" data-alt="A bright and clean bathroom featuring modern tiling and premium fixtures. The lighting is high-key, reinforcing the feeling of safety and cleanliness. This image captures the essence of a well-maintained SaaS managed property, using a palette of blues and pristine whites." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBYkONFTiNP8ww17XjImgpfTX4qIIe7czXqBHll7WvurZIiDbz9Ts9m5CTEzNSLeBLIoyZ_rLIeowpPDhacgw8OjiRR9ME7EeOhPoX932T7QjBq74-AKnjopzUXtB622BYbE6V93JTDl1TUhu5AKIS39_xvO5dihsX2-H8ZQodOSpiq7jpkhN0XMNGizj7llB1N5A2LknAZn653WsBRH7Msd0FzGi3y5ip9GcaN-Sj2KiR9fbaS_efsRU_VGfInbtkwOXZRu8-V7LDH" />
                                <button class="absolute top-2 right-2 bg-surface/80 p-1.5 rounded-full shadow hover:bg-white transition-colors">
                                    <span class="material-symbols-outlined text-sm">close</span>
                                </button>
                            </div>
                        </div>
                    </section>
                    <!-- Action Buttons -->
                    <div class="pt-8 flex flex-col md:flex-row items-center justify-end gap-4 border-t border-outline-variant">
                        <button class="w-full md:w-auto px-8 py-3 rounded-full font-label-md text-on-surface-variant hover:bg-surface-container-high transition-all" type="button">
                            Hủy thay đổi
                        </button>
                        <button class="w-full md:w-auto px-10 py-3 rounded-full bg-primary text-on-primary font-bold shadow-lg hover:bg-primary-container active:scale-95 transition-all flex items-center justify-center gap-2" type="button">
                            <span class="material-symbols-outlined">save</span>
                            Cập nhật thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <!-- Micro-interaction Toast Placeholder (Hidden) -->
        <div class="fixed bottom-8 right-8 bg-on-secondary-fixed text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 translate-y-24 opacity-0 transition-all duration-500 z-50" id="toast">
            <span class="material-symbols-outlined text-green-400">check_circle</span>
            <p class="font-label-md">Cập nhật thông tin phòng thành công!</p>
        </div>
    </div>
    <footer class="mt-auto py-8 text-center text-on-surface-variant border-t border-outline-variant">
        <p class="font-label-md">© 2024 SOTRO Management Platform. All rights reserved.</p>
    </footer>
</main>
<script>
        // Simple micro-interaction for the "Update" button
        const updateBtn = document.querySelector('button.bg-primary');
        const toast = document.getElementById('toast');

        updateBtn.addEventListener('click', () => {
            // Simulate loading
            updateBtn.innerHTML = `<span class="material-symbols-outlined animate-spin">sync</span> Äang lÆ°u...`;
            updateBtn.disabled = true;

            setTimeout(() => {
                updateBtn.innerHTML = `<span class="material-symbols-outlined">save</span> Cáº­p nháº­t thay Ä‘á»•i`;
                updateBtn.disabled = false;
                
                // Show toast
                toast.classList.remove('translate-y-24', 'opacity-0');
                
                setTimeout(() => {
                    toast.classList.add('translate-y-24', 'opacity-0');
                }, 3000);
            }, 1000);
        });

        // Toggle logic for the room status switch
        const statusButtons = document.querySelectorAll('button.font-label-md');
        statusButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                statusButtons.forEach(b => {
                    b.classList.remove('bg-white', 'shadow-sm', 'text-primary', 'border');
                    b.classList.add('text-on-surface-variant', 'hover:bg-surface-variant');
                });
                btn.classList.remove('text-on-surface-variant', 'hover:bg-surface-variant');
                btn.classList.add('bg-white', 'shadow-sm', 'text-primary', 'border', 'border-outline-variant');
            });
        });
    </script>


@code {
    private const string CustomStyles = "SuaPhong";
}