    private void OnBillingDateChanged(ChangeEventArgs e)
    {
        errorMessage = null;
        if (DateTime.TryParse(e.Value?.ToString(), out var date))
        {
            request.BillingDay = date.Day;
        }
    }

    private void OnRoomCodeInput(ChangeEventArgs e)
    {
        errorMessage = null;
        request.RoomCode = e.Value?.ToString() ?? "";
    }

    private void SetRoomModel(string model)
    {
        editRoomModel = model;
        if (model == "Shared")
        {
            request.Capacity = editTotalBeds;
        }
        else
        {
            if (!request.Capacity.HasValue || request.Capacity <= 0)
            {
                request.Capacity = 2;
            }
        }
    }

    private void OnTotalBedsInput(ChangeEventArgs e)
    {
        errorMessage = null;
        if (int.TryParse(e.Value?.ToString(), out var val))
        {
            editTotalBeds = val;
            if (editRoomModel == "Shared")
            {
                request.Capacity = val;
            }
        }
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        errorMessage = null;
        var newStatus = e.Value?.ToString();
        request.Status = newStatus;
        if (newStatus == "Occupied")
        {
            if (editRoomModel == "Private")
            {
                if (!request.Capacity.HasValue || request.Capacity <= 0)
                {
                    request.Capacity = 2;
                }
            }
            else
            {
                request.Capacity = editTotalBeds;
            }
            if (!request.CurrentTenantCount.HasValue || request.CurrentTenantCount <= 0)
            {
                request.CurrentTenantCount = 1;
            }
        }
        else if (newStatus == "Available")
        {
            request.CurrentTenantCount = 0;
        }
    }

    private void OnCapacityInput(ChangeEventArgs e)
    {
