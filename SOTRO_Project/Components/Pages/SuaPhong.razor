@page "/sua-phong"
@layout EmptyLayout

<PageTitle>Chỉnh sửa phòng - SOTRO Admin</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            vertical-align: middle;
        }
        body {
            background-color: #f8f9fa;
            font-family: 'Inter', sans-serif;
        }
        .sidebar-active {
            background-color: #dae4ee; /* secondary-container */
            color: #131d24; /* on-secondary-fixed */
            font-weight: 700;
        }
    

    </style>
}

<!-- TopNavBar Shell -->
<HeaderDashboard />
<!-- SideNavBar Shell -->
<SideNavBar />
<!-- Main Content Canvas -->
<!-- Main Content Area -->
<main class="flex-grow flex flex-col min-h-screen ml-64">
    <!-- Page Content -->
