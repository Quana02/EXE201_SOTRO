<script>
        function switchTab(tab) {
            const floorPlanTab = document.getElementById('tab-floor-plan');
            const roomListTab = document.getElementById('tab-room-list');
            const btnFloorPlan = document.getElementById('btn-floor-plan');
            const btnRoomList = document.getElementById('btn-room-list');

            if (tab === 'floor-plan') {
                floorPlanTab.classList.remove('hidden');
                roomListTab.classList.add('hidden');
                btnFloorPlan.classList.add('bg-primary', 'text-on-primary', 'font-medium');
                btnFloorPlan.classList.remove('text-on-surface-variant');
                btnRoomList.classList.add('text-on-surface-variant');
                btnRoomList.classList.remove('bg-primary', 'text-on-primary', 'font-medium');
            } else {
                floorPlanTab.classList.add('hidden');
                roomListTab.classList.remove('hidden');
                btnRoomList.classList.add('bg-primary', 'text-on-primary', 'font-medium');
                btnRoomList.classList.remove('text-on-surface-variant');
                btnFloorPlan.classList.add('text-on-surface-variant');
                btnFloorPlan.classList.remove('bg-primary', 'text-on-primary', 'font-medium');
            }
        }
    </script>


