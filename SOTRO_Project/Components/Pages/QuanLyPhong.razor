@page "/quan-ly-phong"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject IBuildingApiService BuildingApiService
@inject IJSRuntime JS

<PageTitle>SOTRO - Quản lý phòng</PageTitle>

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }

    .scrollbar-hide::-webkit-scrollbar {
        display: none;
    }

    .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
    }

    .transition-transform-layout {
        transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .room-card-available {
        background: rgba(var(--md-sys-color-surface-container-rgb,240,240,240),0.3);
        border-color: var(--md-sys-color-outline-variant,#ccc);
    }

    .room-card-occupied {
        background: rgba(var(--md-sys-color-primary-fixed-rgb,198,228,255),0.3);
        border-color: var(--md-sys-color-primary,#003f87);
    }

    .room-card-maintenance {
        background: rgba(255,220,198,0.3);
        border-color: #a0522d;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .animate-spin {
        animation: spin 0.8s linear infinite;
        display: inline-block;
    }
</style>

<!-- TopNavBar Shell -->
<HeaderDashboard OnHelpClicked="OpenRoomManagementTour" />
<!-- SideNavBar Shell -->
<SideNavBar />
<!-- Main Content Canvas -->
<main class="ml-64 min-h-[calc(100vh-64px)] bg-surface pb-10">
    <div class="max-w-[1200px] mx-auto p-8 space-y-8">

        @if (isLoading)
        {
            <!-- Loading State -->
            <div class="flex flex-col items-center justify-center py-24 gap-4">
                <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
                <p class="text-on-surface-variant">Đang tải danh sách phòng...</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="flex flex-col items-center justify-center py-24 gap-4">
                <span class="material-symbols-outlined text-error text-5xl">error</span>
                <p class="text-error font-bold">@errorMessage</p>
                <button @onclick="LoadData" class="px-6 py-2 bg-primary text-white rounded-full text-label-md">Thử lại</button>
            </div>
        }
        else
        {
            <!-- Header Summary & Quick Filters -->
            <div id="room-management-summary" class="flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <h1 class="font-headline-sm text-headline-sm text-on-surface mb-2">Quản lý phòng</h1>
                    <div class="flex items-center gap-8">
                        <div class="flex flex-col">
                            <span class="text-caption text-on-surface-variant">Tòa nhà hiện tại</span>
                            <span class="text-headline-sm font-bold text-primary">@buildingName</span>
                        </div>
                        <div class="h-10 w-px bg-outline-variant"></div>
                        <div class="flex items-center gap-4">
                            <div class="flex flex-col items-center">
                                <span class="text-label-md font-bold text-primary">@stats?.TotalRooms</span>
                                <span class="text-[10px] text-on-surface-variant uppercase">Tổng phòng</span>
                            </div>
                            <div class="flex flex-col items-center">
                                <span class="text-label-md font-bold text-error">@stats?.AvailableRooms</span>
                                <span class="text-[10px] text-on-surface-variant uppercase">Trống</span>
                            </div>
                            <div class="flex flex-col items-center">
                                <span class="text-label-md font-bold text-secondary">@stats?.OccupiedRooms</span>
                                <span class="text-[10px] text-on-surface-variant uppercase">Đã thuê</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex flex-wrap items-center gap-3">
                    <button id="room-management-create-room" @onclick="GoToCreateRoom"
                            class="bg-primary text-on-primary px-6 py-2.5 rounded-full flex items-center gap-2 font-label-md shadow-md hover:opacity-90 transition-all">
                        <span class="material-symbols-outlined text-sm">add</span>
                        Thêm phòng
                    </button>
                    <div id="room-management-view-tabs" class="flex bg-surface-container-low p-1 rounded-full border border-outline-variant">
                        <button class="px-4 py-1.5 rounded-full text-label-md transition-all @(activeTab == "floor-plan" ? "bg-primary text-on-primary font-medium" : "text-on-surface-variant hover:text-primary")"
                                @onclick='() => activeTab = "floor-plan"'>
                            Sơ đồ mặt bằng
                        </button>
                        <button class="px-4 py-1.5 rounded-full text-label-md transition-all @(activeTab == "room-list" ? "bg-primary text-on-primary font-medium" : "text-on-surface-variant hover:text-primary")"
                                @onclick='() => activeTab = "room-list"'>
                            Danh sách phòng
                        </button>
                    </div>
                </div>
            </div>

            <!-- Global Status Filter -->
            <div id="room-management-status-filter" class="flex items-center gap-4 overflow-x-auto scrollbar-hide pb-2">
                <button @onclick='() => filterStatus = ""'
                        class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
                    Tất cả <span class="px-2 rounded-full @(filterStatus == "" ? "bg-white/20" : "")">@rooms.Count</span>
                </button>
                <button @onclick='() => filterStatus = "Occupied"'
                        class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Occupied" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
                    Đã thuê <span class="font-bold @(filterStatus == "Occupied" ? "" : "text-primary")">@rooms.Count(r => r.Status == "Occupied")</span>
                </button>
                <button @onclick='() => filterStatus = "Available"'
                        class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Available" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
                    Trống <span class="font-bold @(filterStatus == "Available" ? "" : "text-error")">@rooms.Count(r => r.Status == "Available")</span>
                </button>
                <button @onclick='() => filterStatus = "Maintenance"'
                        class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Maintenance" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
                    Bảo trì <span class="font-bold @(filterStatus == "Maintenance" ? "" : "text-tertiary")">@rooms.Count(r => r.Status == "Maintenance")</span>
                </button>
            </div>

            @if (rooms.Count == 0 && activeTab == "room-list")
            {
                <div class="flex flex-col items-center justify-center py-24 gap-4 bg-surface-container-low rounded-2xl border border-dashed border-outline-variant">
                    <span class="material-symbols-outlined text-on-surface-variant text-5xl">meeting_room</span>
                    <p class="text-on-surface-variant font-bold text-body-lg">Chưa có phòng nào</p>
                    <p class="text-caption text-on-surface-variant">Chuyển sang “Sơ đồ mặt bằng” để thêm phòng vào từng tầng</p>
                    <button @onclick="GoToCreateRoom" class="mt-2 px-6 py-2.5 bg-primary text-white rounded-full text-label-md font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">add</span> Thêm phòng
                    </button>
                </div>
            }
            else
            {
                <!-- Tab: Floor Plan -->
                @if (activeTab == "floor-plan")
                {
                    <div class="grid grid-cols-1 lg:grid-cols-4 gap-6 items-start">

                        <!-- Left Panel: KHU VỰC / TẦNG -->
                        <div id="room-management-floor-panel" class="lg:col-span-1 bg-white p-5 rounded-2xl border border-outline-variant shadow-sm space-y-4">
                            <h3 class="font-label-md font-bold text-on-surface-variant uppercase tracking-wider text-xs">
                                @(IsBasicLevel ? "Khu vực / Dãy" : "Khu vực / Tầng")
                            </h3>

                            <div class="flex flex-col gap-2">
                                @for (int f = 1; f <= totalFloors; f++)
                                {
                                    var floorNum = f;
                                    var isSelected = floorNum == selectedFloor;
                                    var roomCountOnThisFloor = rooms.Count(r => r.FloorNumber == floorNum);

                                    <div class="group flex items-center justify-between p-3.5 rounded-xl border transition-all cursor-pointer @(isSelected ? "border-primary bg-primary/5 text-primary font-bold shadow-sm" : "border-outline-variant hover:border-primary/50 hover:bg-surface-container-low text-on-surface")"
                                         @onclick="() => selectedFloor = floorNum">
                                        <div class="flex items-center gap-3">
                                            <span class="material-symbols-outlined @(isSelected ? "text-primary" : "text-secondary")">layers</span>
                                            <div class="flex flex-col">
                                                <span class="text-body-md">@GetFloorLabel(floorNum)</span>
                                                <span class="text-[11px] text-on-surface-variant font-normal">@roomCountOnThisFloor Phòng</span>
                                            </div>
                                        </div>

                                        <button type="button" @onclick:stopPropagation="true" @onclick="() => DeleteFloor(floorNum)"
                                                class="p-1 text-on-surface-variant hover:bg-error-container hover:text-error rounded transition-colors opacity-0 group-hover:opacity-100 focus:opacity-100"
                                                title='@(IsBasicLevel ? "Xóa dãy này" : "Xóa tầng này")'>
                                            <span class="material-symbols-outlined text-sm">close</span>
                                        </button>
                                    </div>
                                }
                            </div>

                            <button id="room-management-add-floor" type="button" @onclick="AddFloor" disabled="@isUpdatingFloors"
                                    class="w-full py-3 border-2 border-dashed border-outline-variant hover:border-primary hover:text-primary rounded-xl flex items-center justify-center gap-2 text-label-md font-bold transition-all text-on-surface-variant bg-surface-container-lowest">
                                @if (isUpdatingFloors)
                                {
                                    <span class="material-symbols-outlined animate-spin text-sm">sync</span>
                                    <span>Đang xử lý...</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-sm">add</span>
                                    <span>@(IsBasicLevel ? "Thêm dãy" : "Thêm tầng")</span>
                                }
                            </button>
                        </div>

                        <!-- Right Panel: Room Grid of Selected Floor -->
                        <div id="room-management-floor-grid" class="lg:col-span-3 bg-white p-6 rounded-2xl shadow-sm border border-outline-variant space-y-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-6">
                                    <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-primary"></div><span class="text-caption font-medium">Đã thuê</span></div>
                                    <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-outline"></div><span class="text-caption font-medium">Trống</span></div>
                                    <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-tertiary"></div><span class="text-caption font-medium">Bảo trì</span></div>
                                </div>
                                <span class="text-caption font-semibold text-primary">@GetFloorLabel(selectedFloor) - @floorRooms.Count phòng</span>
                            </div>

                            @if (floorRooms.Count == 0)
                            {
                                <div class="flex flex-col items-center justify-center py-16 gap-3 bg-surface-container-low rounded-xl border border-dashed border-outline-variant">
                                    <span class="material-symbols-outlined text-on-surface-variant text-4xl">meeting_room</span>
                                    <p class="text-on-surface-variant font-medium text-body-md">@(IsBasicLevel ? "Chưa có phòng nào ở dãy này" : "Chưa có phòng nào ở tầng này")</p>
                                    <a href="/tao-phong?floor=@selectedFloor" class="px-5 py-2 bg-primary text-white text-xs font-bold rounded-full flex items-center gap-1.5 shadow-sm hover:opacity-90 transition-all">
                                        <span class="material-symbols-outlined text-xs">add</span> @(IsBasicLevel ? "Thêm phòng vào dãy" : "Thêm phòng vào tầng")
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
                                    @foreach (var room in floorRooms)
                                    {
                                        var borderClass = room.Status switch
                                        {
                                            "Occupied" => "border-2 border-primary",
                                            "Maintenance" => "border-2 border-tertiary",
                                            _ => "border border-outline-variant"
                                        };

                                        var textClass = room.Status switch
                                        {
                                            "Occupied" => "text-primary",
                                            "Maintenance" => "text-tertiary",
                                            _ => "text-on-surface-variant"
                                        };

                                        var labelText = room.Status == "Occupied" ? "ĐÃ THUÊ" : room.StatusLabel.ToUpper();

                                        // Occupancy badge logic
                                        var showOccupancy = room.Status != "Available";
                                        var currentCount = room.CurrentTenantCount ?? 0;
                                        var isFull = room.Capacity.HasValue && currentCount >= room.Capacity;
                                        var occupancyBadgeClass = isFull
                                            ? "bg-primary text-white"
                                            : (room.Status == "Maintenance" ? "bg-tertiary/80 text-white" : "bg-primary/20 text-primary font-bold");
                                        var occupancyLabel = room.Capacity.HasValue
                                            ? $"{currentCount}/{room.Capacity}"
                                            : $"{currentCount} người";

                                        <div @onclick="() => GoToEditRoom(room.RoomId)"
                                             class="h-28 bg-white @borderClass rounded-xl flex flex-col items-center justify-center cursor-pointer transition-all group relative hover:scale-105 hover:shadow-md">
                                            <!-- Occupancy badge: top-left, only when not Available -->
                                            @if (showOccupancy)
                                            {
                                                <span class="absolute top-1.5 left-2 text-[10px] font-bold px-1.5 py-0.5 rounded-full @occupancyBadgeClass leading-tight">
                                                    @occupancyLabel
                                                </span>
                                            }
                                            <span class="text-headline-sm font-black @textClass mb-1">@room.RoomCode</span>
                                            <span class="text-[10px] font-bold @textClass uppercase">@labelText</span>
                                            @if (IsSharedRoom(room.Note))
                                            {
                                                <span class="mt-1 text-[9px] font-bold px-2 py-0.5 rounded-full bg-violet-100 text-violet-700 uppercase tracking-wider">
                                                    Ở ghép
                                                </span>
                                            }
                                            @if (room.FloorNumber.HasValue)
                                            {
                                                <span class="absolute top-1.5 right-2 text-[9px] text-on-surface-variant font-medium">@(IsBasicLevel ? "D" : "T")@(room.FloorNumber)</span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                    </div>
                }
            }

                <!-- Tab: Room List -->
                @if (activeTab == "room-list")
                {
                    @if (filteredRooms.Count == 0 && rooms.Count > 0)
                    {
                        <div class="flex flex-col items-center justify-center py-16 gap-3 bg-surface-container-low rounded-xl border border-dashed border-outline-variant">
                            <span class="material-symbols-outlined text-on-surface-variant text-4xl">search_off</span>
                            <p class="text-on-surface-variant font-medium">Không có phòng nào khớp bộ lọc hiện tại</p>
                        </div>
                    }
                    else
                    {
                    <div id="room-management-list" class="flex flex-col gap-4">
                        @foreach (var room in filteredRooms)
                        {
                            <div class="bg-white p-5 rounded-2xl shadow-sm border @GetListCardBorderClass(room.Status) flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-md transition-shadow relative overflow-hidden">
                                @if (room.Status == "Occupied")
                                {
                                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                                }
                                else if (room.Status == "Maintenance")
                                {
                                    <div class="absolute left-0 top-0 bottom-0 w-1 bg-tertiary"></div>
                                }
                                <div class="flex items-center gap-6 w-full md:w-auto">
                                    <div class="w-16 h-16 rounded-xl @GetRoomCardClass(room.Status) flex flex-col items-center justify-center border-2 @GetRoomBorderClass(room.Status) shrink-0">
                                        <span class="text-headline-sm font-black @GetRoomTextClass(room.Status)">@room.RoomCode</span>
                                    </div>
                                    <div class="space-y-1">
                                        <div class="flex items-center gap-2">
                                            <h4 class="text-body-lg font-bold">
                                                @(room.PrimaryTenant != null ? room.PrimaryTenant.FullName : (room.Status == "Available" ? "Phòng trống" : room.RoomName ?? room.RoomCode))
                                            </h4>
                                            <span class="px-2 py-0.5 @GetStatusBadgeClass(room.Status) text-[10px] font-bold rounded-full uppercase">@room.StatusLabel</span>
                                            @if (IsSharedRoom(room.Note))
                                            {
                                                <span class="px-2 py-0.5 bg-violet-100 text-violet-700 text-[10px] font-bold rounded-full uppercase">Ở ghép</span>
                                            }
                                        </div>
                                        <div class="flex items-center gap-4 text-caption text-on-surface-variant">
                                            @if (room.PrimaryTenant?.StartDate != null)
                                            {
                                                <span class="flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">calendar_today</span>
                                                    @room.PrimaryTenant.StartDate.Value.ToString("dd/MM/yyyy")
                                                </span>
                                            }
                                            @if (room.CurrentTenantCount.HasValue && room.CurrentTenantCount > 0)
                                            {
                                                <span class="flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">person</span>
                                                    @room.CurrentTenantCount người
                                                </span>
                                            }
                                            @if (room.FloorNumber.HasValue)
                                            {
                                                <span class="flex items-center gap-1">
                                                    <span class="material-symbols-outlined text-sm">layers</span>
                                                    @(IsBasicLevel ? "Dãy" : "Tầng") @room.FloorNumber
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                                <div class="flex-1 grid grid-cols-2 md:grid-cols-3 gap-8 w-full">
                                    <div>
                                        <p class="text-[10px] uppercase text-on-surface-variant mb-1">Giá thuê</p>
                                        <p class="text-label-md font-bold">@FormatPrice(room.BasePrice)đ</p>
                                    </div>
                                    @if (room.ElectricPrice.HasValue)
                                    {
                                        <div>
                                            <p class="text-[10px] uppercase text-on-surface-variant mb-1">Điện/kWh</p>
                                            <p class="text-label-md font-bold">@FormatPrice(room.ElectricPrice)đ</p>
                                        </div>
                                    }
                                    @if (room.Area.HasValue)
                                    {
                                        <div class="hidden md:block">
                                            <p class="text-[10px] uppercase text-on-surface-variant mb-1">Diện tích</p>
                                            <p class="text-label-md font-bold">@room.Area m²</p>
                                        </div>
                                    }
                                </div>
                                <div class="flex items-center gap-2 shrink-0">
                                    <button @onclick="() => GoToEditRoom(room.RoomId)"
                                            class="p-2 text-on-surface-variant hover:bg-surface-container rounded-lg transition-colors" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined">edit</span>
                                    </button>
                                    <button @onclick="() => ConfirmDeleteRoom(room)"
                                            class="p-2 text-on-surface-variant hover:bg-error-container hover:text-error rounded-lg transition-colors" title="Xóa phòng">
                                        <span class="material-symbols-outlined">delete</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                    }
                }

                <!-- Occupancy Stats -->
                @if (stats != null && stats.TotalRooms > 0)
                {
                    <div id="room-management-occupancy-stats" class="bg-white p-8 rounded-2xl border border-outline-variant shadow-sm flex flex-col items-center text-center">
                        <div class="w-full max-w-2xl mx-auto">
                            <h3 class="text-label-md font-bold text-on-surface mb-6">Hiệu suất lấp đầy</h3>
                            <div class="flex items-center justify-center gap-3 mb-6">
                                <span class="text-display-lg font-display-lg text-primary">@stats.OccupancyRate.ToString("0")<span class="text-headline-md">%</span></span>
                            </div>
                            <div class="w-full bg-surface-container rounded-full h-4 mb-6">
                                <div class="bg-primary h-4 rounded-full transition-all duration-1000" style="width: @(stats.OccupancyRate.ToString("0"))%"></div>
                            </div>
                            <p class="text-body-md text-on-surface-variant">
                                @stats.OccupiedRooms / @stats.TotalRooms phòng đang có người thuê
                            </p>
                        </div>
                    </div>
                }
            
        }

    </div>
</main>

<GuidedOnboarding IsVisible="showRoomManagementTour"
                  Steps="roomManagementGuidedSteps"
                  StorageKey="sotro_room_management_guided_seen"
                  AllowSkip="true"
                  OnCompleted="CloseRoomManagementTour"
                  OnSkipped="CloseRoomManagementTour" />

@code {
    private List<RoomResponse> rooms = new();
    private RoomStatsModel? stats;
    private string activeTab = "floor-plan";
    private string filterStatus = "";
    private bool isLoading = true;
    private string? errorMessage;
    private bool showRoomManagementTour;
    private int buildingId;
    private string buildingName = "—";

    private BuildingResponse? building;
    private int totalFloors = 1;
    private int selectedFloor = 1;
    private bool isUpdatingFloors = false;

    private List<RoomResponse> filteredRooms =>
        string.IsNullOrEmpty(filterStatus)
            ? rooms
            : rooms.Where(r => r.Status == filterStatus).ToList();

    private List<RoomResponse> floorRooms =>
        rooms.Where(r => r.FloorNumber == selectedFloor &&
                         (string.IsNullOrEmpty(filterStatus) || r.Status == filterStatus))
             .ToList();

    // True when the building is Basic level (dãy trọ) — show flat grid instead of floor-tabbed layout
    private bool IsBasicLevel =>
        building?.Description?.Contains("[Level:Basic]", StringComparison.OrdinalIgnoreCase) ?? false;

    private IReadOnlyList<GuidedOnboarding.GuidedStep> roomManagementGuidedSteps => BuildRoomManagementGuidedSteps();

    private IReadOnlyList<GuidedOnboarding.GuidedStep> BuildRoomManagementGuidedSteps()
    {
        var floorLabel = IsBasicLevel ? "dãy" : "tầng";
        var steps = new List<GuidedOnboarding.GuidedStep>
        {
            new(
                "#room-management-summary",
                "Tổng quan quản lý phòng",
                "Khu vực này cho biết nhà trọ đang chọn, tổng số phòng, số phòng trống và số phòng đã thuê. Đây là nơi kiểm tra nhanh tình trạng vận hành trước khi thao tác.",
                "Xem các chỉ số này để biết bạn cần thêm phòng, xử lý phòng trống hay kiểm tra phòng đang thuê."),
            new(
                "#room-management-create-room",
                "Thêm phòng mới",
                "Nút này đưa bạn sang form tạo phòng. Nếu đang ở tab sơ đồ mặt bằng, hệ thống sẽ tạo phòng theo tầng hoặc dãy đang chọn.",
                "Click Thêm phòng khi cần tạo phòng mới cho nhà trọ."),
            new(
                "#room-management-view-tabs",
                "Chọn cách xem phòng",
