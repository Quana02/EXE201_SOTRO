@page "/quan-ly-phong"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject IRoomApiService RoomApiService
@inject IJSRuntime JS

<PageTitle>SOTRO - Quản lý phòng</PageTitle>

<style>
    .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .transition-transform-layout { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .room-card-available { background: rgba(var(--md-sys-color-surface-container-rgb,240,240,240),0.3); border-color: var(--md-sys-color-outline-variant,#ccc); }
    .room-card-occupied  { background: rgba(var(--md-sys-color-primary-fixed-rgb,198,228,255),0.3); border-color: var(--md-sys-color-primary,#003f87); }
    .room-card-maintenance { background: rgba(255,220,198,0.3); border-color: #a0522d; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    .animate-spin { animation: spin 0.8s linear infinite; display:inline-block; }
</style>

<!-- TopNavBar Shell -->
<HeaderDashboard/>
<!-- SideNavBar Shell -->
<SideNavBar/>
<!-- Main Content Canvas -->
<main class="ml-64 h-[calc(100vh-64px)] overflow-y-auto bg-surface">
<div class="max-w-[1200px] mx-auto p-8 space-y-8">

@if (isLoading)
{
    <!-- Loading State -->
    <div class="flex flex-col items-center justify-center py-24 gap-4">
        <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
        <p class="text-on-surface-variant">Đang tải danh sách phòng...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="flex flex-col items-center justify-center py-24 gap-4">
        <span class="material-symbols-outlined text-error text-5xl">error</span>
        <p class="text-error font-bold">@errorMessage</p>
        <button @onclick="LoadData" class="px-6 py-2 bg-primary text-white rounded-full text-label-md">Thử lại</button>
    </div>
}
else
{
    <!-- Header Summary & Quick Filters -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <h1 class="font-headline-sm text-headline-sm text-on-surface mb-2">Quản lý phòng</h1>
            <div class="flex items-center gap-8">
                <div class="flex flex-col">
                    <span class="text-caption text-on-surface-variant">Tòa nhà hiện tại</span>
                    <span class="text-headline-sm font-bold text-primary">@buildingName</span>
                </div>
                <div class="h-10 w-px bg-outline-variant"></div>
                <div class="flex items-center gap-4">
                    <div class="flex flex-col items-center">
                        <span class="text-label-md font-bold text-primary">@stats?.TotalRooms</span>
                        <span class="text-[10px] text-on-surface-variant uppercase">Tổng phòng</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-label-md font-bold text-error">@stats?.AvailableRooms</span>
                        <span class="text-[10px] text-on-surface-variant uppercase">Trống</span>
                    </div>
                    <div class="flex flex-col items-center">
                        <span class="text-label-md font-bold text-secondary">@stats?.OccupiedRooms</span>
                        <span class="text-[10px] text-on-surface-variant uppercase">Đã thuê</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="flex flex-wrap items-center gap-3">
            <button @onclick="GoToCreateRoom"
                    class="bg-primary text-on-primary px-6 py-2.5 rounded-full flex items-center gap-2 font-label-md shadow-md hover:opacity-90 transition-all">
                <span class="material-symbols-outlined text-sm">add</span>
                Thêm phòng
            </button>
            <div class="flex bg-surface-container-low p-1 rounded-full border border-outline-variant">
                <button class="px-4 py-1.5 rounded-full text-label-md transition-all @(activeTab == "floor-plan" ? "bg-primary text-on-primary font-medium" : "text-on-surface-variant hover:text-primary")"
                        @onclick='() => activeTab = "floor-plan"'>Sơ đồ mặt bằng</button>
                <button class="px-4 py-1.5 rounded-full text-label-md transition-all @(activeTab == "room-list" ? "bg-primary text-on-primary font-medium" : "text-on-surface-variant hover:text-primary")"
                        @onclick='() => activeTab = "room-list"'>Danh sách phòng</button>
            </div>
        </div>
    </div>

    <!-- Global Status Filter -->
    <div class="flex items-center gap-4 overflow-x-auto scrollbar-hide pb-2">
        <button @onclick='() => filterStatus = ""'
                class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
            Tất cả <span class="px-2 rounded-full @(filterStatus == "" ? "bg-white/20" : "")">@rooms.Count</span>
        </button>
        <button @onclick='() => filterStatus = "Occupied"'
                class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Occupied" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
            Đã thuê <span class="font-bold @(filterStatus == "Occupied" ? "" : "text-primary")">@rooms.Count(r => r.Status == "Occupied")</span>
        </button>
        <button @onclick='() => filterStatus = "Available"'
                class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Available" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
            Trống <span class="font-bold @(filterStatus == "Available" ? "" : "text-error")">@rooms.Count(r => r.Status == "Available")</span>
        </button>
        <button @onclick='() => filterStatus = "Maintenance"'
                class="flex items-center gap-2 px-4 py-1.5 rounded-full text-label-md whitespace-nowrap transition-all @(filterStatus == "Maintenance" ? "bg-primary-fixed text-on-primary-fixed-variant" : "bg-surface border border-outline-variant text-on-surface-variant hover:bg-surface-container")">
            Bảo trì <span class="font-bold @(filterStatus == "Maintenance" ? "" : "text-tertiary")">@rooms.Count(r => r.Status == "Maintenance")</span>
        </button>
    </div>

    @if (filteredRooms.Count == 0)
    {
        <div class="flex flex-col items-center justify-center py-24 gap-4 bg-surface-container-low rounded-2xl border border-dashed border-outline-variant">
            <span class="material-symbols-outlined text-on-surface-variant text-5xl">meeting_room</span>
            <p class="text-on-surface-variant font-bold text-body-lg">Chưa có phòng nào</p>
            <p class="text-caption text-on-surface-variant">Bấm "Thêm phòng" để tạo phòng đầu tiên cho tòa nhà này</p>
            <button @onclick="GoToCreateRoom" class="mt-2 px-6 py-2.5 bg-primary text-white rounded-full text-label-md font-bold flex items-center gap-2">
                <span class="material-symbols-outlined text-sm">add</span> Thêm phòng
            </button>
        </div>
    }
    else
    {
        <!-- Tab: Floor Plan -->
        @if (activeTab == "floor-plan")
        {
            <div class="space-y-6">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-outline-variant">
                    <div class="flex items-center justify-between mb-8">
                        <div class="flex items-center gap-6">
                            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-primary"></div><span class="text-caption font-medium">Đã thuê</span></div>
                            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-outline"></div><span class="text-caption font-medium">Trống</span></div>
                            <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-tertiary"></div><span class="text-caption font-medium">Bảo trì</span></div>
                        </div>
                        <span class="text-caption text-on-surface-variant">@filteredRooms.Count phòng</span>
                    </div>
                    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 gap-4">
                        @foreach (var room in filteredRooms)
                        {
                            <div @onclick="() => GoToEditRoom(room.RoomId)"
                                 class="aspect-square @GetRoomCardClass(room.Status) border-2 rounded-xl flex flex-col items-center justify-center cursor-pointer transition-all group relative hover:scale-105">
                                <span class="text-headline-sm font-black @GetRoomTextClass(room.Status) mb-1">@room.RoomCode</span>
                                <span class="text-[10px] font-bold @GetRoomLabelClass(room.Status) uppercase">@room.StatusLabel</span>
                                @if (room.FloorNumber.HasValue)
                                {
                                    <span class="absolute top-1 right-2 text-[9px] text-on-surface-variant">T@room.FloorNumber</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- Tab: Room List -->
        @if (activeTab == "room-list")
        {
            <div class="flex flex-col gap-4">
                @foreach (var room in filteredRooms)
                {
                    <div class="bg-white p-5 rounded-2xl shadow-sm border @GetListCardBorderClass(room.Status) flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-md transition-shadow relative overflow-hidden">
                        @if (room.Status == "Occupied")
                        {
                            <div class="absolute left-0 top-0 bottom-0 w-1 bg-primary"></div>
                        }
                        else if (room.Status == "Maintenance")
                        {
                            <div class="absolute left-0 top-0 bottom-0 w-1 bg-tertiary"></div>
                        }
                        <div class="flex items-center gap-6 w-full md:w-auto">
                            <div class="w-16 h-16 rounded-xl @GetRoomCardClass(room.Status) flex flex-col items-center justify-center border-2 @GetRoomBorderClass(room.Status) shrink-0">
                                <span class="text-headline-sm font-black @GetRoomTextClass(room.Status)">@room.RoomCode</span>
                            </div>
                            <div class="space-y-1">
                                <div class="flex items-center gap-2">
                                    <h4 class="text-body-lg font-bold">
                                        @(room.PrimaryTenant != null ? room.PrimaryTenant.FullName : (room.Status == "Available" ? "Phòng trống" : room.RoomName ?? room.RoomCode))
                                    </h4>
                                    <span class="px-2 py-0.5 @GetStatusBadgeClass(room.Status) text-[10px] font-bold rounded-full uppercase">@room.StatusLabel</span>
                                </div>
                                <div class="flex items-center gap-4 text-caption text-on-surface-variant">
                                    @if (room.PrimaryTenant?.StartDate != null)
                                    {
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">calendar_today</span>
                                            @room.PrimaryTenant.StartDate.Value.ToString("dd/MM/yyyy")
                                        </span>
                                    }
                                    @if (room.CurrentTenantCount.HasValue && room.CurrentTenantCount > 0)
                                    {
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">person</span>
                                            @room.CurrentTenantCount người
                                        </span>
                                    }
                                    @if (room.FloorNumber.HasValue)
                                    {
                                        <span class="flex items-center gap-1">
                                            <span class="material-symbols-outlined text-sm">layers</span>
                                            Tầng @room.FloorNumber
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="flex-1 grid grid-cols-2 md:grid-cols-3 gap-8 w-full">
                            <div>
                                <p class="text-[10px] uppercase text-on-surface-variant mb-1">Giá thuê</p>
                                <p class="text-label-md font-bold">@FormatPrice(room.BasePrice)đ</p>
                            </div>
                            @if (room.ElectricPrice.HasValue)
                            {
                                <div>
                                    <p class="text-[10px] uppercase text-on-surface-variant mb-1">Điện/kWh</p>
                                    <p class="text-label-md font-bold">@FormatPrice(room.ElectricPrice)đ</p>
                                </div>
                            }
                            @if (room.Area.HasValue)
                            {
                                <div class="hidden md:block">
                                    <p class="text-[10px] uppercase text-on-surface-variant mb-1">Diện tích</p>
                                    <p class="text-label-md font-bold">@room.Area m²</p>
                                </div>
                            }
                        </div>
                        <div class="flex items-center gap-2 shrink-0">
                            <button @onclick="() => GoToEditRoom(room.RoomId)"
                                    class="p-2 text-on-surface-variant hover:bg-surface-container rounded-lg transition-colors" title="Chỉnh sửa">
                                <span class="material-symbols-outlined">edit</span>
                            </button>
                            <button @onclick="() => ConfirmDeleteRoom(room)"
                                    class="p-2 text-on-surface-variant hover:bg-error-container hover:text-error rounded-lg transition-colors" title="Xóa phòng">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Occupancy Stats -->
        @if (stats != null && stats.TotalRooms > 0)
        {
            <div class="bg-white p-8 rounded-2xl border border-outline-variant shadow-sm flex flex-col items-center text-center">
                <div class="w-full max-w-2xl mx-auto">
                    <h3 class="text-label-md font-bold text-on-surface mb-6">Hiệu suất lấp đầy</h3>
                    <div class="flex items-center justify-center gap-3 mb-6">
                        <span class="text-display-lg font-display-lg text-primary">@stats.OccupancyRate.ToString("0")<span class="text-headline-md">%</span></span>
                    </div>
                    <div class="w-full bg-surface-container rounded-full h-4 mb-6">
                        <div class="bg-primary h-4 rounded-full transition-all duration-1000" style="width: @(stats.OccupancyRate.ToString("0"))%"></div>
                    </div>
                    <p class="text-body-md text-on-surface-variant">
                        @stats.OccupiedRooms / @stats.TotalRooms phòng đang có người thuê
                    </p>
                </div>
            </div>
        }
    }
}

</div>
</main>

@code {
    private List<RoomResponse> rooms = new();
    private RoomStatsModel? stats;
    private string activeTab = "floor-plan";
    private string filterStatus = "";
    private bool isLoading = true;
    private string? errorMessage;
    private int buildingId;
    private string buildingName = "—";

    private List<RoomResponse> filteredRooms =>
        string.IsNullOrEmpty(filterStatus)
            ? rooms
            : rooms.Where(r => r.Status == filterStatus).ToList();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var name  = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
            buildingName = name ?? "—";

            if (!int.TryParse(idStr, out buildingId) || buildingId <= 0)
            {
                errorMessage = "Không tìm thấy tòa nhà. Vui lòng chọn lại từ trang Nhà trọ.";
                return;
            }

            var roomsResp = await RoomApiService.GetRoomsByBuildingAsync(buildingId);
            if (roomsResp.Success && roomsResp.Data != null)
                rooms = roomsResp.Data;
            else
                errorMessage = roomsResp.Message ?? "Không tải được danh sách phòng.";

            var statsResp = await RoomApiService.GetRoomStatsAsync(buildingId);
            if (statsResp.Success && statsResp.Data != null)
                stats = statsResp.Data;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToCreateRoom() => Navigation.NavigateTo("/tao-phong");

    private void GoToEditRoom(int roomId) => Navigation.NavigateTo($"/sua-phong/{roomId}");

    private async Task ConfirmDeleteRoom(RoomResponse room)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa phòng '{room.RoomCode}'? Hành động này không thể hoàn tác.");
        if (!confirmed) return;

        var result = await RoomApiService.DeleteRoomAsync(room.RoomId);
        if (result.Success)
            await LoadData();
        else
            await JS.InvokeVoidAsync("alert", $"Không thể xóa: {result.Message}");
    }

    // ── Helpers ──
    private static string FormatPrice(decimal? price) =>
        price.HasValue ? price.Value.ToString("N0") : "—";

    private static string GetRoomCardClass(string? status) => status switch
    {
        "Occupied"    => "bg-primary-fixed/30",
        "Maintenance" => "bg-tertiary-container/30",
        _             => "bg-surface-container/30",
    };

    private static string GetRoomBorderClass(string? status) => status switch
    {
        "Occupied"    => "border-primary/20",
        "Maintenance" => "border-tertiary/20",
        _             => "border-outline/20",
    };

    private static string GetRoomTextClass(string? status) => status switch
    {
        "Occupied"    => "text-primary",
        "Maintenance" => "text-tertiary",
        _             => "text-outline",
    };

    private static string GetRoomLabelClass(string? status) => status switch
    {
        "Occupied"    => "text-on-primary-fixed-variant",
        "Maintenance" => "text-tertiary",
        _             => "text-outline",
    };

    private static string GetStatusBadgeClass(string? status) => status switch
    {
        "Occupied"    => "bg-secondary-container text-on-secondary-container",
        "Maintenance" => "bg-tertiary-container text-on-tertiary-container",
        _             => "bg-error-container text-on-error-container",
    };

    private static string GetListCardBorderClass(string? status) => status switch
    {
        "Occupied"    => "border-outline-variant",
        "Maintenance" => "border-2 border-tertiary/20",
        _             => "border-dashed border-outline-variant",
    };
}