    private void OpenRoomManagementTour()
    {
        showRoomManagementTour = !isLoading && string.IsNullOrEmpty(errorMessage);
        StateHasChanged();
    }

    private void CloseRoomManagementTour()
    {
        showRoomManagementTour = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadData();
            StateHasChanged();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var name = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
            buildingName = name ?? "—";

            if (!int.TryParse(idStr, out buildingId) || buildingId <= 0)
            {
                errorMessage = "Không tìm thấy tòa nhà. Vui lòng chọn lại từ trang Nhà trọ.";
                return;
            }

            var buildingResp = await BuildingApiService.GetBuildingByIdAsync(buildingId);
            if (buildingResp.Success && buildingResp.Data != null)
            {
                building = buildingResp.Data;
                buildingName = building.BuildingName;
                totalFloors = building.TotalFloors ?? 1;
            }

            var roomsResp = await RoomApiService.GetRoomsByBuildingAsync(buildingId);
            if (roomsResp.Success && roomsResp.Data != null)
                rooms = roomsResp.Data;
            else
                errorMessage = roomsResp.Message ?? "Không tải được danh sách phòng.";

            var statsResp = await RoomApiService.GetRoomStatsAsync(buildingId);
            if (statsResp.Success && statsResp.Data != null)
                stats = statsResp.Data;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi kết nối: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetFloorLabel(int floorNum)
    {
        if (IsBasicLevel) return $"Dãy {floorNum}";
        if (floorNum == 1) return "Tầng 1 (Trệt)";
        return $"Tầng {floorNum}";
    }

    private async Task AddFloor()
    {
        if (building == null) return;
        var msg = IsBasicLevel 
            ? "Bạn có chắc chắn muốn thêm 1 dãy mới cho tòa nhà?"
            : "Bạn có chắc chắn muốn thêm 1 tầng mới cho tòa nhà?";
        var confirmed = await JS.InvokeAsync<bool>("confirm", msg);
        if (!confirmed) return;

        isUpdatingFloors = true;
        try
        {
            var newTotal = totalFloors + 1;
            var updateRequest = new CreateBuildingRequest
            {
                BuildingName = building.BuildingName,
                BuildingTypeId = building.BuildingTypeId ?? 0,
                Address = building.Address ?? "",
                Description = building.Description ?? "",
                TotalFloors = newTotal,
                BillingDay = building.BillingDay,
                DueDay = building.DueDay
            };

            var response = await BuildingApiService.UpdateBuildingAsync(buildingId, updateRequest, null);
            if (response.Success)
            {
                totalFloors = newTotal;
                selectedFloor = newTotal;
                if (building != null) building.TotalFloors = newTotal;
            }
            else
            {
                var errMsg = IsBasicLevel ? $"Không thể thêm dãy: {response.Message}" : $"Không thể thêm tầng: {response.Message}";
                await JS.InvokeVoidAsync("alert", errMsg);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
        }
        finally
        {
            isUpdatingFloors = false;
        }
    }

    private async Task DeleteFloor(int floorNum)
    {
        if (building == null) return;

        var roomCountOnFloor = rooms.Count(r => r.FloorNumber == floorNum);
        if (roomCountOnFloor > 0)
        {
            var alertMsg = IsBasicLevel
                ? $"Không thể xóa dãy này vì đang có {roomCountOnFloor} phòng. Vui lòng xóa hoặc di chuyển các phòng trước."
                : $"Không thể xóa tầng này vì đang có {roomCountOnFloor} phòng. Vui lòng xóa hoặc di chuyển các phòng trước.";
            await JS.InvokeVoidAsync("alert", alertMsg);
            return;
        }

        var confirmMsg = IsBasicLevel
            ? $"Bạn có chắc chắn muốn xóa Dãy {floorNum}?"
            : $"Bạn có chắc chắn muốn xóa {GetFloorLabel(floorNum)}?";
        var confirmed = await JS.InvokeAsync<bool>("confirm", confirmMsg);
        if (!confirmed) return;

        isUpdatingFloors = true;
        try
        {
            var newTotal = Math.Max(1, totalFloors - 1);
            var updateRequest = new CreateBuildingRequest
            {
                BuildingName = building.BuildingName,
                BuildingTypeId = building.BuildingTypeId ?? 0,
                Address = building.Address ?? "",
                Description = building.Description ?? "",
                TotalFloors = newTotal,
                BillingDay = building.BillingDay,
                DueDay = building.DueDay
            };

            var response = await BuildingApiService.UpdateBuildingAsync(buildingId, updateRequest, null);
            if (response.Success)
            {
                totalFloors = newTotal;
                if (selectedFloor > totalFloors)
                {
                    selectedFloor = totalFloors;
                }
                if (building != null) building.TotalFloors = newTotal;
                await LoadData();
            }
            else
            {
                var errMsg = IsBasicLevel ? $"Không thể xóa dãy: {response.Message}" : $"Không thể xóa tầng: {response.Message}";
                await JS.InvokeVoidAsync("alert", errMsg);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
        }
        finally
        {
            isUpdatingFloors = false;
        }
    }

    private void GoToCreateRoom()
    {
        if (activeTab == "floor-plan")
        {
            Navigation.NavigateTo($"/tao-phong?floor={selectedFloor}");
        }
        else
        {
            Navigation.NavigateTo("/tao-phong");
        }
    }

    private void GoToEditRoom(int roomId) => Navigation.NavigateTo($"/sua-phong/{roomId}");

    private async Task ConfirmDeleteRoom(RoomResponse room)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc muốn xóa phòng '{room.RoomCode}'? Hành động này không thể hoàn tác.");
        if (!confirmed) return;

        var result = await RoomApiService.DeleteRoomAsync(room.RoomId);
        if (result.Success)
            await LoadData();
        else
            await JS.InvokeVoidAsync("alert", $"Không thể xóa: {result.Message}");
    }

