    private bool IsSharedRoom(string? note)
    {
        if (string.IsNullOrWhiteSpace(note)) return false;
        try
        {
            var data = System.Text.Json.JsonSerializer.Deserialize<RoomNoteData>(note);
            return data?.RoomModel == "Shared";
        }
        catch
        {
            return false;
        }
    }

    public class RoomNoteData
    {
        public string? RoomModel { get; set; }
        public int? TotalBeds { get; set; }
        public string? UserNote { get; set; }
    }
