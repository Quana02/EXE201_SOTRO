@page "/quen-mat-khau"
@layout EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Navigation

<PageTitle>Quên mật khẩu - Sổ trọ</PageTitle>

<HeaderLanding />

<main class="pt-32 pb-16 flex-grow flex items-center justify-center px-margin-mobile py-12">
    <div class="w-full max-w-md bg-surface-container-lowest p-8 rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-fixed rounded-full mb-6">
                <span class="material-symbols-outlined text-primary text-4xl">lock_reset</span>
            </div>
            <h1 class="font-headline-md text-headline-md text-on-surface mb-2">Quên mật khẩu?</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">
                Nhập email tài khoản để nhận link đặt lại mật khẩu.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="mb-5 rounded-lg border px-4 py-3 @(IsSuccess ? "border-green-200 bg-green-50 text-green-700" : "border-red-200 bg-red-50 text-red-700")">
                @Message
            </div>
        }

        <form class="space-y-6" @onsubmit="SubmitForgotPassword" @onsubmit:preventDefault>
            <div class="space-y-2">
                <label class="font-label-md text-label-md text-on-surface-variant" for="identity">Email</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-xl">mail</span>
                    <input @bind="Request.Email"
                           class="w-full pl-10 pr-4 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all font-body-md text-body-md"
                           id="identity"
                           placeholder="example@gmail.com"
                           required
                           type="email" />
                </div>
            </div>

            <button disabled="@IsLoading"
                    class="w-full py-3 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:bg-primary-container transition-colors shadow-sm active:scale-[0.98] disabled:opacity-60"
                    type="submit">
                @(IsLoading ? "Đang gửi..." : "Gửi yêu cầu")
            </button>
        </form>

        <div class="mt-8 text-center border-t border-outline-variant pt-6">
            <a class="inline-flex items-center gap-2 font-label-md text-label-md text-primary hover:underline transition-all" href="/dang-nhap">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Quay lại Đăng nhập
            </a>
        </div>
    </div>
</main>

<FooterLanding />

@code {
    private ForgotPasswordSendOtpRequest Request { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool IsSuccess { get; set; }
    private string? Message { get; set; }

    private async Task SubmitForgotPassword()
    {
        IsLoading = true;
        Message = null;

        var response = await AuthApi.SendForgotPasswordOtpAsync(Request);
        IsSuccess = response.Success;
        Message = response.Message;

        if (response.Success)
        {
            Message = "Mã OTP đã được gửi đến email của bạn.";
            await Task.Delay(1200);
            Navigation.NavigateTo($"/xac-thuc-otp?email={Uri.EscapeDataString(Request.Email)}&purpose=ForgotPassword");
        }

        IsLoading = false;
    }
}
