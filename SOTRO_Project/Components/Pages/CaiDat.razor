@page "/cai-dat"
@layout EmptyLayout
@inject IJSRuntime JS
@inject IBuildingApiService BuildingApiService
@inject IRoomApiService RoomApiService
@inject ISubscriptionApiService SubscriptionApiService
@using System.IO
@using SOTRO_Project.Models.Room

<PageTitle>Cài đặt - SOTRO</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            transition: font-variation-settings 0.2s ease;
        }
        .active-icon {
            font-variation-settings: 'FILL' 1;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
        /* Custom Toggle Switch Style */
        .toggle-checkbox:checked + .toggle-label {
            background-color: #0056b3;
        }
        .toggle-checkbox:checked + .toggle-label .toggle-dot {
            transform: translateX(100%);
        }
    </style>
}

<HeaderDashboard/>
<SideNavBar />

<main class="sotro-main-content min-h-[calc(100vh-64px)] bg-surface pb-24 md:pb-10">
    <div class="sotro-page-container">
        <div class="mb-10">
            <h1 class="font-headline-sm text-headline-sm text-on-surface mb-2">Cài đặt hệ thống</h1>
            <p class="text-on-surface-variant font-body-md text-body-md">Quản lý các thiết lập vận hành, tự động hóa và thông tin cơ sở kinh doanh của bạn.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Navigation Anchors -->
            <div class="lg:col-span-3">
                <div class="sticky top-24 space-y-2">
                    <button @onclick='() => ScrollToSection("thong-tin-chung")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "thong-tin-chung" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Thông tin chung</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "thong-tin-chung" ? "font-variation-settings: 'FILL' 1;" : "")">info</span>
                    </button>
                    <button @onclick='() => ScrollToSection("cau-hinh-dich-vu-chung")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "cau-hinh-dich-vu-chung" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Cấu hình dịch vụ</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "cau-hinh-dich-vu" ? "font-variation-settings: 'FILL' 1;" : "")">settings_input_component</span>
                    </button>
                    <button @onclick='() => ScrollToSection("tu-dong-hoa")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "tu-dong-hoa" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Tự động hóa</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "tu-dong-hoa" ? "font-variation-settings: 'FILL' 1;" : "")">auto_awesome</span>
                    </button>

                </div>
            </div>

            <!-- Right Column: Settings Forms -->
            <div class="lg:col-span-9 space-y-8">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-4 bg-red-50 text-red-700 rounded-lg border border-red-200 text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-red-600">error</span>
                        <span>@errorMessage</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="p-4 bg-green-50 text-green-700 rounded-lg border border-green-200 text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-green-600">check_circle</span>
                        <span>@successMessage</span>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant p-12 flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
                        <p class="text-on-surface-variant font-medium">Đang tải thông tin cấu hình nhà trọ...</p>
                    </div>
                }
                else
                {
                    <!-- Section 1: Thông tin chung -->
                    <section id="thong-tin-chung" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                        <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">info</span>
                            <h3 class="font-headline-sm text-headline-sm text-primary">Cài đặt chung thông tin</h3>
                        </div>
                        <div class="p-6 space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="col-span-1 md:col-span-2">
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tên cơ sở kinh doanh</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="text" @bind="buildingName">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Hotline quản lý</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="tel" @bind="hotline">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Email nhận báo cáo</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="email" @bind="email">
                                </div>
                                <div class="col-span-1 md:col-span-2">
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Địa chỉ chính</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="text" @bind="address">
                                </div>
                                <div>
                                    <div class="flex items-center gap-2 mb-2 h-6">
                                        <label class="block text-xs font-bold text-on-surface-variant uppercase">Ngày khởi tạo hóa đơn</label>
                                    </div>
                                    <input min="1" max="28" class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="number" @bind="invoiceCreationDay">
                                    <p class="text-xs text-on-surface-variant mt-1">Ngày hệ thống tự tạo bill hằng tháng.</p>
                                </div>
                                <div>
                                    <div class="flex items-center gap-2 mb-2 h-6">
                                        <label class="block text-xs font-bold text-on-surface-variant uppercase">Ngày xuất/gửi hóa đơn</label>
                                        @if (!hasPremiumAccess)
                                        {
                                            <span class="inline-flex items-center h-5 text-[10px] leading-none font-bold px-2 rounded-full bg-amber-100 text-amber-700 border border-amber-200">Premium</span>
                                        }
                                    </div>
                                    <input min="1" max="28" disabled="@(!hasPremiumAccess)" class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all disabled:bg-surface-container disabled:text-on-surface-variant disabled:cursor-not-allowed" type="number" @bind="invoiceSendDay">
                                    @if (!hasPremiumAccess)
                                    {
                                        <p class="text-xs text-amber-700 mt-1">Tài khoản Free chỉ được dùng ngày khởi tạo hóa đơn. Nâng cấp Premium để dùng ngày xuất/gửi hóa đơn tự động.</p>
                                    }
                                    else
                                    {
                                        <p class="text-xs text-on-surface-variant mt-1">Ngày chủ trọ gửi bill cho người thuê qua Zalo.</p>
                                    }
                                </div>
                            </div>
                            <div class="flex flex-col sm:flex-row sm:items-center gap-4 p-4 bg-surface-container-low rounded-lg">
                                <InputFile OnChange="HandleLogoSelected" id="logo-upload" class="hidden" accept=".jpg,.jpeg,.png,.webp,.gif" />
                                <label for="logo-upload" class="w-24 h-24 rounded-lg bg-surface-variant flex-shrink-0 relative group cursor-pointer overflow-hidden block">
                                    @if (!string.IsNullOrEmpty(imageUrl))
                                    {
                                        <img alt="Building Logo" class="w-full h-full object-cover" src="@imageUrl">
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center bg-gray-100 border border-dashed border-gray-300 rounded-lg">
                                            <span class="material-symbols-outlined text-gray-400">add_photo_alternate</span>
                                        </div>
                                    }
                                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                        <span class="material-symbols-outlined text-white">photo_camera</span>
                                    </div>
                                </label>
                                <div class="flex-1">
                                    <h5 class="text-sm font-bold text-on-surface">Logo &amp; Hình ảnh thương hiệu</h5>
                                    <p class="text-xs text-on-surface-variant mt-1">Logo này sẽ được in trên các hóa đơn và tin nhắn gửi cho khách thuê. Kích thước khuyến nghị 512x512px.</p>
                                    <label for="logo-upload" class="mt-2 inline-block text-xs font-bold text-primary hover:underline cursor-pointer">Thay đổi hình ảnh</label>
                                </div>
                            </div>
                            <div id="bank-qr-settings" class="grid grid-cols-1 lg:grid-cols-[180px_1fr] gap-5 p-4 bg-blue-50/70 border border-blue-100 rounded-lg">
                                <InputFile OnChange="HandleBankQrSelected" id="bank-qr-upload" class="hidden" accept=".jpg,.jpeg,.png,.webp" />
                                <label for="bank-qr-upload" class="w-full max-w-44 h-44 rounded-xl bg-white border border-dashed border-blue-300 flex-shrink-0 relative group cursor-pointer overflow-hidden flex items-center justify-center">
                                    @if (!string.IsNullOrWhiteSpace(EffectiveBankQrDataUrl))
                                    {
                                        <img alt="QR chuyển khoản ngân hàng" class="w-full h-full object-contain p-2" src="@EffectiveBankQrDataUrl">
                                    }
                                    else
                                    {
                                        <div class="text-center px-4">
                                            <span class="material-symbols-outlined text-blue-500 text-4xl">qr_code_2</span>
                                            <p class="text-xs text-blue-700 font-bold mt-2">Thêm QR bank</p>
                                        </div>
                                    }
                                    <div class="absolute inset-0 bg-blue-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                        <span class="material-symbols-outlined text-white">upload</span>
                                    </div>
                                </label>
                                <div class="space-y-4">
                                    <div>
                                        <h5 class="text-sm font-bold text-on-surface">Thông tin chuyển khoản &amp; QR thanh toán</h5>
                                        <p class="text-xs text-on-surface-variant mt-1">Chọn cách tạo QR thanh toán cho hóa đơn: hệ thống tự tạo từ số tài khoản hoặc bạn tự tải ảnh QR có sẵn.</p>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                        <label class="flex items-start gap-3 p-3 rounded-lg border cursor-pointer transition-colors @(bankQrMode == "auto" ? "border-primary bg-white shadow-sm" : "border-blue-100 bg-white/60")">
                                            <input type="radio" class="mt-1 accent-blue-700" name="bankQrMode" checked="@(bankQrMode == "auto")" @onchange='() => bankQrMode = "auto"' />
                                            <span>
                                                <span class="block text-sm font-bold text-on-surface">Web tự tạo QR</span>
                                                <span class="block text-xs text-on-surface-variant mt-1">Nhập ngân hàng, STK và họ tên chủ tài khoản.</span>
                                            </span>
                                        </label>
                                        <label class="flex items-start gap-3 p-3 rounded-lg border cursor-pointer transition-colors @(bankQrMode == "upload" ? "border-primary bg-white shadow-sm" : "border-blue-100 bg-white/60")">
                                            <input type="radio" class="mt-1 accent-blue-700" name="bankQrMode" checked="@(bankQrMode == "upload")" @onchange='() => bankQrMode = "upload"' />
                                            <span>
                                                <span class="block text-sm font-bold text-on-surface">Tự upload ảnh QR</span>
                                                <span class="block text-xs text-on-surface-variant mt-1">Dùng ảnh QR bank đã tạo sẵn từ ứng dụng ngân hàng.</span>
                                            </span>
                                        </label>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                        <div>
                                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Ngân hàng / mã bank</label>
                                            <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="VD: VCB, MB, TCB" type="text" @bind="bankName">
                                        </div>
                                        <div>
                                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Số tài khoản</label>
                                            <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="VD: 0123456789" type="text" @bind="bankAccountNumber">
                                        </div>
                                        <div>
                                            <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Họ tên chủ STK</label>
                                            <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="VD: NGUYEN VAN A" type="text" @bind="bankAccountHolder">
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(EffectiveBankQrDataUrl))
                                    {
                                        <button type="button" @onclick="() => showBankQrPreview = true" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-xs font-bold hover:shadow-md transition-all">
                                            <span class="material-symbols-outlined text-[16px]">qr_code_2</span>
                                            <span>Xem QR chuyển khoản</span>
                                        </button>
                                    }
                                    @if (bankQrMode == "auto")
                                    {
                                        <div class="text-xs text-on-surface-variant bg-white/70 border border-blue-100 rounded-lg p-3">
                                            Hệ thống sẽ tự tạo QR từ thông tin trên. Mã ngân hàng nên dùng mã VietQR như VCB, MB, TCB, ACB, BIDV, VPB để ảnh QR hiển thị đúng.
                                        </div>
                                    }
                                    else
                                    {
                                        <label for="bank-qr-upload" class="inline-flex items-center gap-2 text-xs font-bold text-primary hover:underline cursor-pointer">
                                            <span class="material-symbols-outlined text-[16px]">add_photo_alternate</span>
                                            <span>Chọn ảnh QR chuyển khoản</span>
                                        </label>
                                    }
                                </div>
                            </div>
                        </div>
                    </section>

                <!-- Section 2: Cấu hình dịch vụ -->
                <section id="cau-hinh-dich-vu" class="hidden">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">settings_input_component</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Cấu hình dịch vụ</h3>
                    </div>
                    <div class="p-6 space-y-6">
                        <p class="text-sm text-on-surface-variant leading-relaxed">Thiết lập đơn giá cho các dịch vụ cố định hàng tháng.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền rác (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền mạng / Internet (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền vệ sinh hành lang (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Phí quản lý / Chung (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Section 3: Tự động hóa VIP (đứng liền dưới Cấu hình dịch vụ) -->
                <section id="cau-hinh-dich-vu-chung" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">payments</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Thông số dịch vụ chung</h3>
                    </div>
                    <div class="p-6 space-y-6">
                        <p class="text-sm text-on-surface-variant leading-relaxed">Các khoản này áp dụng chung cho tất cả phòng và được cộng vào hóa đơn mới khi hệ thống tạo bill.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền rác chung</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="number" min="0" step="1000" @bind="commonTrashFee">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền internet chung</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="number" min="0" step="1000" @bind="commonInternetFee">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền vệ sinh chung</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="number" min="0" step="1000" @bind="commonCleaningFee">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Phí quản lý chung</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="number" min="0" step="1000" @bind="commonManagementFee">
                            </div>
                        </div>
                        <div class="rounded-lg border border-primary/15 bg-primary/5 p-4 flex flex-col md:flex-row md:items-center md:justify-between gap-2">
                            <div>
                                <p class="text-sm font-bold text-on-surface">Tổng phí dịch vụ chung áp dụng cho tất cả phòng</p>
                                <p class="text-xs text-on-surface-variant">Giá trị thực tế sẽ được lưu và dùng cho hóa đơn tháng mới.</p>
                            </div>
                            <div class="text-2xl font-bold text-primary">@FormatCurrency(CommonServiceTotal)</div>
                        </div>
                    </div>
                </section>

                <section id="tu-dong-hoa" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Tự động hóa VIP</h3>
                        @if (!hasPremiumAccess)
                        {
                            <span class="inline-flex items-center h-6 text-[11px] leading-none font-bold px-2 rounded-full bg-amber-100 text-amber-700 border border-amber-200">Premium</span>
                        }
                    </div>
                    <div class="p-6 space-y-8">
                        <!-- Zalo/SMS Reminder -->
                        @if (!hasPremiumAccess)
                        {
                            <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 flex items-start gap-3">
                                <span class="material-symbols-outlined text-amber-700">lock</span>
                                <div>
                                    <p class="text-sm font-bold text-on-surface">Chỉ có thể mở khi nâng cấp dịch vụ "Premium"</p>
                                </div>
                            </div>
                        }
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Tự động nhắc nợ qua Zalo</h4>
                                <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">Hệ thống sẽ tự động gửi tin nhắn thông báo tiền phòng định kỳ đến khách thuê qua tài khoản Zalo Official. Giảm thiểu việc chậm thanh toán.</p>
                                <div class="mt-3 flex gap-4">
                                    <label class="flex items-center gap-2 cursor-pointer">
