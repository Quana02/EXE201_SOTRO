@page "/cai-dat"
@layout EmptyLayout
@inject IJSRuntime JS
@inject IBuildingApiService BuildingApiService
@using System.IO

<PageTitle>Cài đặt - SOTRO</PageTitle>

@if (!string.IsNullOrEmpty(CustomStyles))
{
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            transition: font-variation-settings 0.2s ease;
        }
        .active-icon {
            font-variation-settings: 'FILL' 1;
        }
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
        }
        /* Custom Toggle Switch Style */
        .toggle-checkbox:checked + .toggle-label {
            background-color: #0056b3;
        }
        .toggle-checkbox:checked + .toggle-label .toggle-dot {
            transform: translateX(100%);
        }
    </style>
}

<HeaderDashboard/>
<SideNavBar />

<main class="flex-1 md:ml-64 bg-surface min-h-screen pb-20">
    <div class="max-w-container-max-width mx-auto px-6 py-8">
        <div class="mb-10">
            <h1 class="font-headline-sm text-headline-sm text-on-surface mb-2">Cài đặt hệ thống</h1>
            <p class="text-on-surface-variant font-body-md text-body-md">Quản lý các thiết lập vận hành, tự động hóa và thông tin cơ sở kinh doanh của bạn.</p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
            <!-- Left Column: Navigation Anchors -->
            <div class="lg:col-span-3">
                <div class="sticky top-24 space-y-2">
                    <button @onclick='() => ScrollToSection("thong-tin-chung")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "thong-tin-chung" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Thông tin chung</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "thong-tin-chung" ? "font-variation-settings: 'FILL' 1;" : "")">info</span>
                    </button>
                    <button @onclick='() => ScrollToSection("cau-hinh-dich-vu")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "cau-hinh-dich-vu" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Cấu hình dịch vụ</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "cau-hinh-dich-vu" ? "font-variation-settings: 'FILL' 1;" : "")">settings_input_component</span>
                    </button>
                    <button @onclick='() => ScrollToSection("tu-dong-hoa")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "tu-dong-hoa" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Tự động hóa</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "tu-dong-hoa" ? "font-variation-settings: 'FILL' 1;" : "")">auto_awesome</span>
                    </button>
                    <button @onclick='() => ScrollToSection("bao-mat-tai-khoan")'
                            class="w-full text-left px-4 py-2.5 rounded-lg font-label-md text-label-md flex items-center justify-between transition-all duration-200 @(activeSection == "bao-mat-tai-khoan" ? "bg-primary/10 text-primary font-bold shadow-sm" : "text-on-surface-variant hover:bg-surface-container")">
                        <span>Bảo mật &amp; Tài khoản</span>
                        <span class="material-symbols-outlined text-sm" style="@(activeSection == "bao-mat-tai-khoan" ? "font-variation-settings: 'FILL' 1;" : "")">shield</span>
                    </button>
                </div>
            </div>

            <!-- Right Column: Settings Forms -->
            <div class="lg:col-span-9 space-y-8">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="p-4 bg-red-50 text-red-700 rounded-lg border border-red-200 text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-red-600">error</span>
                        <span>@errorMessage</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="p-4 bg-green-50 text-green-700 rounded-lg border border-green-200 text-sm flex items-center gap-2">
                        <span class="material-symbols-outlined text-green-600">check_circle</span>
                        <span>@successMessage</span>
                    </div>
                }

                @if (isLoading)
                {
                    <div class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant p-12 flex flex-col items-center justify-center gap-4">
                        <span class="material-symbols-outlined text-primary text-5xl animate-spin">sync</span>
                        <p class="text-on-surface-variant font-medium">Đang tải thông tin cấu hình nhà trọ...</p>
                    </div>
                }
                else
                {
                    <!-- Section 1: Thông tin chung -->
                    <section id="thong-tin-chung" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                        <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                            <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">info</span>
                            <h3 class="font-headline-sm text-headline-sm text-primary">Cài đặt chung thông tin</h3>
                        </div>
                        <div class="p-6 space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="col-span-1 md:col-span-2">
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tên cơ sở kinh doanh</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="text" @bind="buildingName">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Hotline quản lý</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="tel" @bind="hotline">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Email nhận báo cáo</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="email" @bind="email">
                                </div>
                                <div class="col-span-1 md:col-span-2">
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Địa chỉ chính</label>
                                    <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" type="text" @bind="address">
                                </div>
                            </div>
                            <div class="flex items-center gap-4 p-4 bg-surface-container-low rounded-lg">
                                <InputFile OnChange="HandleLogoSelected" id="logo-upload" class="hidden" accept=".jpg,.jpeg,.png,.webp,.gif" />
                                <label for="logo-upload" class="w-24 h-24 rounded-lg bg-surface-variant flex-shrink-0 relative group cursor-pointer overflow-hidden block">
                                    @if (!string.IsNullOrEmpty(imageUrl))
                                    {
                                        <img alt="Building Logo" class="w-full h-full object-cover" src="@imageUrl">
                                    }
                                    else
                                    {
                                        <div class="w-full h-full flex items-center justify-center bg-gray-100 border border-dashed border-gray-300 rounded-lg">
                                            <span class="material-symbols-outlined text-gray-400">add_photo_alternate</span>
                                        </div>
                                    }
                                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                        <span class="material-symbols-outlined text-white">photo_camera</span>
                                    </div>
                                </label>
                                <div class="flex-1">
                                    <h5 class="text-sm font-bold text-on-surface">Logo &amp; Hình ảnh thương hiệu</h5>
                                    <p class="text-xs text-on-surface-variant mt-1">Logo này sẽ được in trên các hóa đơn và tin nhắn gửi cho khách thuê. Kích thước khuyến nghị 512x512px.</p>
                                    <label for="logo-upload" class="mt-2 inline-block text-xs font-bold text-primary hover:underline cursor-pointer">Thay đổi hình ảnh</label>
                                </div>
                            </div>
                        </div>
                    </section>

                <!-- Section 2: Cấu hình dịch vụ -->
                <section id="cau-hinh-dich-vu" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">settings_input_component</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Cấu hình dịch vụ</h3>
                    </div>
                    <div class="p-6 space-y-6">
                        <p class="text-sm text-on-surface-variant leading-relaxed">Thiết lập đơn giá cho các dịch vụ cố định hàng tháng.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền rác (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền mạng / Internet (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Tiền vệ sinh hành lang (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Phí quản lý / Chung (VNĐ/tháng)</label>
                                <input class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Nhập số tiền" type="number">
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Section 3: Tự động hóa VIP (đứng liền dưới Cấu hình dịch vụ) -->
                <section id="tu-dong-hoa" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Tự động hóa VIP</h3>
                    </div>
                    <div class="p-6 space-y-8">
                        <!-- Zalo/SMS Reminder -->
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Tự động nhắc nợ qua Zalo</h4>
                                <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">Hệ thống sẽ tự động gửi tin nhắn thông báo tiền phòng định kỳ đến khách thuê qua tài khoản Zalo Official. Giảm thiểu việc chậm thanh toán.</p>
                                <div class="mt-3 flex gap-4">
                                    <label class="flex items-center gap-2 cursor-pointer">
                                        <input checked="" class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary-container" type="checkbox">
                                        <span class="text-sm font-medium">Zalo Official Account</span>
                                    </label>
                                </div>
                            </div>
                            <div class="relative inline-block w-12 align-middle select-none transition duration-200 ease-in">
                                <input checked="" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer border-transparent right-6 checked:right-0 transition-all duration-300" id="toggle-debt" name="toggle" type="checkbox">
                                <label class="toggle-label block overflow-hidden h-6 rounded-full bg-outline-variant cursor-pointer transition-colors duration-300" for="toggle-debt"></label>
                            </div>
                        </div>
                        <hr class="border-outline-variant">
                        <!-- Auto Posting -->
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Tự động nhắc nợ qua Zalo</h4>
                                <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">Hệ thống sẽ tự động gửi tin nhắn thông báo tiền phòng định kỳ đến khách thuê qua tài khoản Zalo Official. Giảm thiểu việc chậm thanh toán.</p>
                            </div>
                            <div class="relative inline-block w-12 align-middle select-none transition duration-200 ease-in">
                                <input class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer border-transparent right-6 checked:right-0 transition-all duration-300" id="toggle-post" name="toggle" type="checkbox">
                                <label class="toggle-label block overflow-hidden h-6 rounded-full bg-outline-variant cursor-pointer transition-colors duration-300" for="toggle-post"></label>
                            </div>
                        </div>
                        <hr class="border-outline-variant">
                        <!-- Meter Reading Cycle -->
                        <div class="space-y-4">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-secondary">calendar_today</span>
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Cấu hình ngày chốt điện nước định kỳ</h4>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Ngày chốt số hàng tháng</label>
                                    <select class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                                        <option>Ngày 25 hàng tháng</option>
                                        <option selected="">Ngày 30 hàng tháng</option>
                                        <option>Ngày 01 hàng tháng</option>
                                        <option>Tùy chỉnh...</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Thông báo cho khách trước</label>
                                    <select class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all">
                                        <option>Không thông báo</option>
                                        <option selected="">1 ngày</option>
                                        <option>2 ngày</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Section 4: Bảo mật & Tài khoản -->
                <section id="bao-mat-tai-khoan" class="bg-white rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant overflow-hidden scroll-mt-24">
                    <div class="bg-primary/5 px-6 py-4 border-b border-outline-variant flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">shield</span>
                        <h3 class="font-headline-sm text-headline-sm text-primary">Bảo mật &amp; Tài khoản</h3>
                    </div>
                    <div class="p-6 space-y-8">
                        <!-- Linked Accounts Section -->
                        <div class="space-y-4">
                            <h4 class="font-label-md text-label-md font-bold text-on-surface">Liên kết tài khoản</h4>
                            <div class="flex items-center justify-between p-4 border border-outline-variant rounded-lg">
                                <div class="flex items-center gap-3">
                                    <img alt="Google Logo" class="w-6 h-6" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAN0XIl7E0xXC3JchogkZgfQhBM0qrBeO0BCgyu7-kjoTGN8SfzaM7UUB_gQ05OzSoUkgU_kwSDjEJQFNsXPrAOe2iAAhiyHRlGMuTNR1UJSRmwr5IzSojJZHlxoudAqCZWSaCKPCQtJszdBB1HbqCRuib5o_A9ELSlSx-cMAcnV7EZRLj0A_1XlaKWrB5Pdo8i_Tee0mPvvw7DgKeua2xpuhs9YMrNMuObj0Wl_tchx4tXw4mzFhIbsg5F5TvW7rJLd9VS1Md8DkYQ">
                                    <div>
                                        <p class="text-sm font-bold">Tài khoản Google</p>
                                        <p class="text-xs text-on-surface-variant">Đăng nhập nhanh chóng bằng Google</p>
                                    </div>
                                </div>
                                <button class="px-4 py-1.5 border border-outline text-xs font-bold rounded-lg hover:bg-surface-container transition-colors">Liên kết</button>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Footer Actions -->
                <div class="flex items-center justify-end gap-4 pb-12">
                    <button @onclick="CancelChanges" type="button" class="px-6 py-2.5 rounded-lg border border-outline-variant text-on-surface font-label-md text-label-md hover:bg-surface-container transition-colors">Hủy thay đổi</button>
                    <button @onclick="SaveSettings" disabled="@isSaving" type="button" class="px-8 py-2.5 rounded-lg bg-primary text-white font-label-md text-label-md hover:shadow-lg hover:bg-primary-container transition-all flex items-center gap-2">
                        @if (isSaving)
                        {
                            <span class="material-symbols-outlined text-sm animate-spin">sync</span>
                            <span>Đang lưu...</span>
                        }
                        else
                        {
                            <span>Lưu cài đặt</span>
                        }
                    </button>
                </div>
                }
            </div>
        </div>
    </div>
</main>

<!-- BottomNavBar for Mobile (Logic: Hidden on md:flex) -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 bg-surface border-t border-outline-variant flex justify-around items-center h-16 z-50">
    <a class="flex flex-col items-center justify-center text-on-surface-variant" href="#">
        <span class="material-symbols-outlined" data-icon="home_work">home_work</span>
        <span class="text-[10px] mt-1">Phòng</span>
    </a>
    <a class="flex flex-col items-center justify-center text-on-surface-variant" href="#">
        <span class="material-symbols-outlined" data-icon="receipt_long">receipt_long</span>
        <span class="text-[10px] mt-1">Hóa đơn</span>
    </a>
    <a class="flex flex-col items-center justify-center text-primary" href="#">
        <span class="material-symbols-outlined active-icon" data-icon="settings" style="font-variation-settings: 'FILL' 1;">settings</span>
        <span class="text-[10px] mt-1 font-bold">Cài đặt</span>
    </a>
    <a class="flex flex-col items-center justify-center text-on-surface-variant" href="#">
        <span class="material-symbols-outlined" data-icon="person">person</span>
        <span class="text-[10px] mt-1">Tôi</span>
    </a>
</nav>

<script>
    // Global function to scroll smoothly with offset for header
    window.sotroScrollTo = (elementId) => {
        const element = document.getElementById(elementId);
        if (element) {
            const yOffset = -96; // 64px header height + padding
            const y = element.getBoundingClientRect().top + window.pageYOffset + yOffset;
            window.scrollTo({ top: y, behavior: 'smooth' });
        }
    };
</script>

@code {
    private const string CustomStyles = "CaiDat";
    private string activeSection = "thong-tin-chung";

    private int buildingId;
    private BuildingResponse? activeBuilding;
    private string buildingName = string.Empty;
    private string address = string.Empty;
    private string hotline = string.Empty;
    private string email = string.Empty;
    private string imageUrl = string.Empty;
    private string description = string.Empty;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;

    // File upload state for new logo
    private byte[]? newLogoBytes;
    private string newLogoFileName = string.Empty;

    private async Task ScrollToSection(string elementId)
    {
        activeSection = elementId;
        await JS.InvokeVoidAsync("sotroScrollTo", elementId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBuildingData();
            StateHasChanged();
        }
    }

    private async Task LoadBuildingData()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var userPhone = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_phone_number");
            var userEmail = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_email");

            hotline = userPhone ?? string.Empty;
            email = userEmail ?? string.Empty;

            if (int.TryParse(idStr, out buildingId) && buildingId > 0)
            {
                var response = await BuildingApiService.GetBuildingByIdAsync(buildingId);
                if (response.Success && response.Data != null)
                {
                    activeBuilding = response.Data;
                    buildingName = activeBuilding.BuildingName ?? string.Empty;
                    address = activeBuilding.Address ?? string.Empty;
                    imageUrl = activeBuilding.ImageUrl ?? string.Empty;
                    description = activeBuilding.Description ?? string.Empty;
                }
                else
                {
                    errorMessage = response.Message ?? "Không tải được thông tin tòa nhà.";
                }
            }
            else
            {
                errorMessage = "Chưa chọn tòa nhà hoạt động. Vui lòng chọn một tòa nhà từ trang Nhà trọ.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogoSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        successMessage = null;
        var file = e.File;
        if (file != null)
        {
            if (file.Size > 5 * 1024 * 1024)
            {
                errorMessage = "Ảnh logo không được vượt quá 5MB.";
                return;
            }

            var allowedTypes = new[] { "image/jpeg", "image/png", "image/webp", "image/gif" };
            if (!allowedTypes.Contains(file.ContentType.ToLower()))
            {
                errorMessage = "Chỉ chấp nhận file ảnh hợp lệ (jpg, png, webp, gif).";
                return;
            }

            try
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(5 * 1024 * 1024).ReadExactlyAsync(buffer);
                newLogoBytes = buffer;
                newLogoFileName = file.Name;
                imageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                errorMessage = $"Lỗi đọc file logo: {ex.Message}";
            }
        }
    }

    private async Task SaveSettings()
    {
        if (activeBuilding == null || buildingId <= 0)
        {
            errorMessage = "Không tìm thấy tòa nhà hoạt động.";
            return;
        }

        if (string.IsNullOrWhiteSpace(buildingName))
        {
            errorMessage = "Tên cơ sở kinh doanh không được để trống.";
            return;
        }

        if (string.IsNullOrWhiteSpace(address))
        {
            errorMessage = "Địa chỉ chính không được để trống.";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Prepare update request
            var request = new CreateBuildingRequest
            {
                BuildingName = buildingName.Trim(),
                BuildingTypeId = activeBuilding.BuildingTypeId ?? 1,
                Address = address.Trim(),
                Description = string.IsNullOrWhiteSpace(description) ? (activeBuilding.Description ?? "Mô tả nhà trọ") : description.Trim(),
                TotalFloors = activeBuilding.TotalFloors ?? 1,
                BillingDay = activeBuilding.BillingDay ?? 30,
                DueDay = activeBuilding.DueDay ?? 5
            };

            List<(Stream Stream, string FileName)>? imageFiles = null;
            if (newLogoBytes != null)
            {
                imageFiles = new List<(Stream Stream, string FileName)>
                {
                    (new MemoryStream(newLogoBytes), newLogoFileName)
                };
            }

            var response = await BuildingApiService.UpdateBuildingAsync(buildingId, request, imageFiles);
            if (response.Success && response.Data != null)
            {
                successMessage = "Cập nhật cấu hình thông tin chung thành công!";
                activeBuilding = response.Data;
                imageUrl = activeBuilding.ImageUrl ?? string.Empty;
                newLogoBytes = null; // Clear selected logo

                // Sync new name with active_building_name in localStorage
                await JS.InvokeVoidAsync("localStorage.setItem", "active_building_name", buildingName.Trim());

                // Sync hotline & email in localStorage if changed
                if (!string.IsNullOrWhiteSpace(hotline))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_phone_number", hotline.Trim());
                }
                if (!string.IsNullOrWhiteSpace(email))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_email", email.Trim());
                }
            }
            else
            {
                errorMessage = response.Message ?? "Không thể lưu thông tin trọ.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi lưu cấu hình: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelChanges()
    {
        errorMessage = null;
        successMessage = null;
        if (activeBuilding != null)
        {
            buildingName = activeBuilding.BuildingName ?? string.Empty;
            address = activeBuilding.Address ?? string.Empty;
            imageUrl = activeBuilding.ImageUrl ?? string.Empty;
            description = activeBuilding.Description ?? string.Empty;
            newLogoBytes = null;
        }
    }
}