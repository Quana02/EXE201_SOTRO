<script>
    // Global function to scroll smoothly with offset for header
    window.sotroScrollTo = (elementId) => {
        const element = document.getElementById(elementId);
        if (element) {
            const yOffset = -96; // 64px header height + padding
            const y = element.getBoundingClientRect().top + window.pageYOffset + yOffset;
            window.scrollTo({ top: y, behavior: 'smooth' });
        }
    };
</script>

@code {
    private const string CustomStyles = "CaiDat";
    private string activeSection = "thong-tin-chung";

    private int buildingId;
    private BuildingResponse? activeBuilding;
    private string buildingName = string.Empty;
    private string address = string.Empty;
    private string hotline = string.Empty;
    private string email = string.Empty;
    private string imageUrl = string.Empty;
    private string description = string.Empty;
    private string bankQrMode = "auto";
    private string bankName = string.Empty;
    private string bankAccountNumber = string.Empty;
    private string bankAccountHolder = string.Empty;
    private string bankQrDataUrl = string.Empty;
    private int invoiceCreationDay = 1;
    private int invoiceSendDay = 5;
    private decimal commonTrashFee;
    private decimal commonInternetFee;
    private decimal commonCleaningFee;
    private decimal commonManagementFee;
    private bool showBankQrPreview;
    private bool hasPremiumAccess;
    private string currentPlanName = "Free";
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private string? successMessage;

    private decimal CommonServiceTotal => commonTrashFee + commonInternetFee + commonCleaningFee + commonManagementFee;

    // File upload state for new logo
    private byte[]? newLogoBytes;
    private string newLogoFileName = string.Empty;

    private async Task ScrollToSection(string elementId)
    {
        activeSection = elementId;
        await JS.InvokeVoidAsync("sotroScrollTo", elementId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBuildingData();
            StateHasChanged();
        }
    }

    private async Task LoadBuildingData()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var idStr = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
            var userPhone = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_phone_number");
            var userEmail = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_email");
            int.TryParse(idStr, out buildingId);

            await LoadSubscriptionStatus();

            hotline = userPhone ?? string.Empty;
            email = userEmail ?? string.Empty;
            bankQrMode = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_qr_mode")) ?? "auto";
            bankName = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_name")) ?? string.Empty;
            bankAccountNumber = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_account_number")) ?? string.Empty;
            bankAccountHolder = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_account_holder")) ?? string.Empty;
            bankQrDataUrl = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey("sotro_bank_qr_data_url")) ?? string.Empty;
            commonTrashFee = await GetDecimalSetting("sotro_common_trash_fee");
            commonInternetFee = await GetDecimalSetting("sotro_common_internet_fee");
            commonCleaningFee = await GetDecimalSetting("sotro_common_cleaning_fee");
            commonManagementFee = await GetDecimalSetting("sotro_common_management_fee");

            if (buildingId > 0)
            {
                var response = await BuildingApiService.GetBuildingByIdAsync(buildingId);
                if (response.Success && response.Data != null)
                {
                    activeBuilding = response.Data;
                    buildingName = activeBuilding.BuildingName ?? string.Empty;
                    address = activeBuilding.Address ?? string.Empty;
                    imageUrl = activeBuilding.ImageUrl ?? string.Empty;
                    description = activeBuilding.Description ?? string.Empty;
                    invoiceCreationDay = Math.Clamp(activeBuilding.BillingDay ?? 1, 1, 28);
                    invoiceSendDay = Math.Clamp(activeBuilding.DueDay ?? 5, 1, 28);
                }
                else
                {
                    errorMessage = response.Message ?? "Không tải được thông tin tòa nhà.";
                }
            }
            else
            {
                errorMessage = "Chưa chọn tòa nhà hoạt động. Vui lòng chọn một tòa nhà từ trang Nhà trọ.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleLogoSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        successMessage = null;
        var file = e.File;
        if (file != null)
        {
            if (file.Size > 5 * 1024 * 1024)
            {
                errorMessage = "Ảnh logo không được vượt quá 5MB.";
                return;
            }

            var allowedTypes = new[] { "image/jpeg", "image/png", "image/webp", "image/gif" };
            if (!allowedTypes.Contains(file.ContentType.ToLower()))
            {
                errorMessage = "Chỉ chấp nhận file ảnh hợp lệ (jpg, png, webp, gif).";
                return;
            }

            try
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(5 * 1024 * 1024).ReadExactlyAsync(buffer);
                newLogoBytes = buffer;
                newLogoFileName = file.Name;
                imageUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                errorMessage = $"Lỗi đọc file logo: {ex.Message}";
            }
        }
    }

    private async Task LoadSubscriptionStatus()
    {
        try
        {
            var response = await SubscriptionApiService.GetCurrentSubscriptionAsync();
            hasPremiumAccess = response.Success && response.Data?.IsPremium == true;
            currentPlanName = response.Data?.PlanName ?? "Free";
        }
        catch
        {
            hasPremiumAccess = false;
            currentPlanName = "Free";
        }
    }

    private async Task HandleBankQrSelected(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        successMessage = null;
        var file = e.File;
        if (file == null)
        {
            return;
        }

        if (file.Size > 5 * 1024 * 1024)
        {
            errorMessage = "Ảnh QR bank không được vượt quá 5MB.";
            return;
        }

        var allowedTypes = new[] { "image/jpeg", "image/png", "image/webp" };
        if (!allowedTypes.Contains(file.ContentType.ToLower()))
        {
            errorMessage = "Chỉ chấp nhận ảnh QR định dạng jpg, png hoặc webp.";
            return;
        }

        try
        {
            var buffer = new byte[file.Size];
            await file.OpenReadStream(5 * 1024 * 1024).ReadExactlyAsync(buffer);
            bankQrDataUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            bankQrMode = "upload";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi đọc ảnh QR bank: {ex.Message}";
        }
    }

    private async Task SaveSettings()
    {
        if (activeBuilding == null || buildingId <= 0)
        {
            errorMessage = "Không tìm thấy tòa nhà hoạt động.";
            return;
        }

        if (string.IsNullOrWhiteSpace(buildingName))
        {
            errorMessage = "Tên cơ sở kinh doanh không được để trống.";
            return;
        }

        if (string.IsNullOrWhiteSpace(address))
        {
            errorMessage = "Địa chỉ chính không được để trống.";
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            // Prepare update request
            var request = new CreateBuildingRequest
            {
                BuildingName = buildingName.Trim(),
                BuildingTypeId = activeBuilding.BuildingTypeId ?? 1,
                Address = address.Trim(),
                Description = string.IsNullOrWhiteSpace(description) ? (activeBuilding.Description ?? "Mô tả nhà trọ") : description.Trim(),
                TotalFloors = activeBuilding.TotalFloors ?? 1,
                BillingDay = Math.Clamp(invoiceCreationDay, 1, 28),
                DueDay = hasPremiumAccess ? Math.Clamp(invoiceSendDay, 1, 28) : (activeBuilding.DueDay ?? 5)
            };

            List<(Stream Stream, string FileName)>? imageFiles = null;
            if (newLogoBytes != null)
            {
                imageFiles = new List<(Stream Stream, string FileName)>
                {
                    (new MemoryStream(newLogoBytes), newLogoFileName)
                };
            }

            var response = await BuildingApiService.UpdateBuildingAsync(buildingId, request, imageFiles);
            if (response.Success && response.Data != null)
            {
                successMessage = "Cập nhật cấu hình thông tin chung thành công!";
                activeBuilding = response.Data;
                imageUrl = activeBuilding.ImageUrl ?? string.Empty;
                newLogoBytes = null; // Clear selected logo

                // Sync new name with active_building_name in localStorage
                await JS.InvokeVoidAsync("localStorage.setItem", "active_building_name", buildingName.Trim());

                // Sync hotline & email in localStorage if changed
                if (!string.IsNullOrWhiteSpace(hotline))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_phone_number", hotline.Trim());
                }
                if (!string.IsNullOrWhiteSpace(email))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_email", email.Trim());
                }

                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_bank_qr_mode"), bankQrMode);
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_bank_name"), bankName.Trim());
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_bank_account_number"), bankAccountNumber.Trim());
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_bank_account_holder"), bankAccountHolder.Trim());
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_common_trash_fee"), commonTrashFee.ToString(System.Globalization.CultureInfo.InvariantCulture));
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_common_internet_fee"), commonInternetFee.ToString(System.Globalization.CultureInfo.InvariantCulture));
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_common_cleaning_fee"), commonCleaningFee.ToString(System.Globalization.CultureInfo.InvariantCulture));
                await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_common_management_fee"), commonManagementFee.ToString(System.Globalization.CultureInfo.InvariantCulture));
                if (!string.IsNullOrWhiteSpace(bankQrDataUrl))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", ScopedSettingKey("sotro_bank_qr_data_url"), bankQrDataUrl);
                }

                var roomApplyResult = await ApplyCommonServiceFeeToRoomsAsync();
                successMessage = roomApplyResult;
            }
            else
            {
                errorMessage = response.Message ?? "Không thể lưu thông tin trọ.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi lưu cấu hình: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelChanges()
    {
        errorMessage = null;
        successMessage = null;
        if (activeBuilding != null)
        {
            buildingName = activeBuilding.BuildingName ?? string.Empty;
            address = activeBuilding.Address ?? string.Empty;
            imageUrl = activeBuilding.ImageUrl ?? string.Empty;
            description = activeBuilding.Description ?? string.Empty;
            invoiceCreationDay = Math.Clamp(activeBuilding.BillingDay ?? 1, 1, 28);
            invoiceSendDay = Math.Clamp(activeBuilding.DueDay ?? 5, 1, 28);
            newLogoBytes = null;
        }
    }

    private async Task<string> ApplyCommonServiceFeeToRoomsAsync()
    {
        var roomsResponse = await RoomApiService.GetRoomsByBuildingAsync(buildingId);
        if (!roomsResponse.Success || roomsResponse.Data == null)
        {
            return "Đã lưu cài đặt, nhưng chưa áp dụng được phí dịch vụ chung cho phòng.";
        }

        var failedCount = 0;
        foreach (var room in roomsResponse.Data)
        {
            var updateRequest = new UpdateRoomRequest
            {
                RoomCode = room.RoomCode,
                RoomName = room.RoomName,
                Zone = room.Zone,
                FloorNumber = room.FloorNumber,
                RoomTypeId = room.RoomTypeId,
                Status = room.Status,
                BasePrice = room.BasePrice,
                ElectricPrice = room.ElectricPrice,
                WaterPrice = room.WaterPrice,
                ServiceFee = CommonServiceTotal,
                IncidentFee = room.IncidentFee,
                Capacity = room.Capacity,
                CurrentTenantCount = room.CurrentTenantCount,
                BillingDay = room.BillingDay,
                PaymentDueDay = room.PaymentDueDay,
                BankName = room.BankName,
                BankAccountNumber = room.BankAccountNumber,
                BankQrUrl = room.BankQrUrl,
                Note = room.Note
            };

            var updateResponse = await RoomApiService.UpdateRoomAsync(room.RoomId, updateRequest);
            if (!updateResponse.Success)
            {
                failedCount++;
            }
        }

        return failedCount == 0
            ? $"Đã lưu cài đặt và áp dụng {FormatCurrency(CommonServiceTotal)} phí dịch vụ chung cho tất cả phòng."
            : $"Đã lưu cài đặt, nhưng có {failedCount} phòng chưa áp dụng được phí dịch vụ chung.";
    }

    private async Task<decimal> GetDecimalSetting(string key)
    {
        var rawValue = await JS.InvokeAsync<string>("localStorage.getItem", ScopedSettingKey(key));
        if (decimal.TryParse(rawValue, System.Globalization.NumberStyles.Number, System.Globalization.CultureInfo.InvariantCulture, out var value))
        {
            return value;
        }

        return decimal.TryParse(rawValue, out value) ? value : 0m;
    }

    private string ScopedSettingKey(string key) => buildingId > 0 ? $"{key}_b{buildingId}" : key;

    private static string FormatCurrency(decimal value) => $"{value:N0}đ";

    private string EffectiveBankQrDataUrl => bankQrMode == "auto" ? BuildGeneratedBankQrUrl() : bankQrDataUrl;

    private string BuildGeneratedBankQrUrl()
    {
        if (string.IsNullOrWhiteSpace(bankName) || string.IsNullOrWhiteSpace(bankAccountNumber) || string.IsNullOrWhiteSpace(bankAccountHolder))
        {
            return string.Empty;
        }

        var bankCode = Uri.EscapeDataString(bankName.Trim().ToUpperInvariant());
        var accountNumber = Uri.EscapeDataString(bankAccountNumber.Trim().Replace(" ", ""));
        var accountName = Uri.EscapeDataString(bankAccountHolder.Trim().ToUpperInvariant());
        return $"https://img.vietqr.io/image/{bankCode}-{accountNumber}-compact2.png?accountName={accountName}";
    }
}
