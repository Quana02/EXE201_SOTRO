                        <!-- Auto Posting -->
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex-1">
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Tự động nhắc nợ qua Zalo</h4>
                                <p class="text-sm text-on-surface-variant mt-1 leading-relaxed">Hệ thống sẽ tự động gửi tin nhắn thông báo tiền phòng định kỳ đến khách thuê qua tài khoản Zalo Official. Giảm thiểu việc chậm thanh toán.</p>
                            </div>
                            <div class="relative inline-block w-12 align-middle select-none transition duration-200 ease-in">
                                <input disabled="@(!hasPremiumAccess)" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer border-transparent right-6 checked:right-0 transition-all duration-300 disabled:cursor-not-allowed disabled:opacity-60" id="toggle-post" name="toggle" type="checkbox">
                                <label class="toggle-label block overflow-hidden h-6 rounded-full bg-outline-variant cursor-pointer transition-colors duration-300" for="toggle-post"></label>
                            </div>
                        </div>
                        <hr class="border-outline-variant">
                        <!-- Meter Reading Cycle -->
                        <div class="space-y-4">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-secondary">calendar_today</span>
                                <h4 class="font-label-md text-label-md font-bold text-on-surface">Cấu hình ngày chốt điện nước định kỳ</h4>
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Ngày chốt số hàng tháng</label>
                                    <select disabled="@(!hasPremiumAccess)" class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all disabled:bg-surface-container disabled:text-on-surface-variant disabled:cursor-not-allowed">
                                        <option>Ngày 25 hàng tháng</option>
                                        <option selected="">Ngày 30 hàng tháng</option>
                                        <option>Ngày 01 hàng tháng</option>
                                        <option>Tùy chỉnh...</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-on-surface-variant uppercase mb-2">Thông báo cho khách trước</label>
                                    <select disabled="@(!hasPremiumAccess)" class="w-full bg-white border border-outline-variant rounded-lg px-4 py-2.5 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all disabled:bg-surface-container disabled:text-on-surface-variant disabled:cursor-not-allowed">
                                        <option>Không thông báo</option>
                                        <option selected="">1 ngày</option>
                                        <option>2 ngày</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>



                <!-- Footer Actions -->
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-end gap-3 sm:gap-4 pb-20 md:pb-12">
                    <button @onclick="CancelChanges" type="button" class="w-full sm:w-auto px-6 py-2.5 rounded-lg border border-outline-variant text-on-surface font-label-md text-label-md hover:bg-surface-container transition-colors">Hủy thay đổi</button>
                    <button @onclick="SaveSettings" disabled="@isSaving" type="button" class="w-full sm:w-auto justify-center px-8 py-2.5 rounded-lg bg-primary text-white font-label-md text-label-md hover:shadow-lg hover:bg-primary-container transition-all flex items-center gap-2">
                        @if (isSaving)
                        {
                            <span class="material-symbols-outlined text-sm animate-spin">sync</span>
                            <span>Đang lưu...</span>
                        }
                        else
                        {
                            <span>Lưu cài đặt</span>
                        }
                    </button>
                </div>
                }
            </div>
        </div>
    </div>
</main>

