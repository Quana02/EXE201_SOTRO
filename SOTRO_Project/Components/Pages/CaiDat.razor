                            <div class="relative inline-block w-12 align-middle select-none transition duration-200 ease-in">
                                <input checked="@hasPremiumAccess" disabled="@(!hasPremiumAccess)" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer border-transparent right-6 checked:right-0 transition-all duration-300 disabled:cursor-not-allowed disabled:opacity-60" id="toggle-debt" name="toggle" type="checkbox">
                                <label class="toggle-label block overflow-hidden h-6 rounded-full bg-outline-variant cursor-pointer transition-colors duration-300" for="toggle-debt"></label>
                            </div>
                        </div>
