<script>
        // Micro-interaction for form inputs and toggles
        document.querySelectorAll('input[type="checkbox"]').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (this.checked) {
                    console.log('Setting updated: Enabled');
                } else {
                    console.log('Setting updated: Disabled');
                }
            });
        });

        // Simple smooth scroll effect for side links
        document.querySelectorAll('button[class*="text-left"]').forEach(btn => {
            btn.addEventListener('click', function() {
                // In a real app, this would navigate or scroll to section
                this.parentElement.querySelectorAll('button').forEach(b => {
                    b.classList.remove('bg-primary-container/10', 'text-primary', 'font-bold');
                    b.classList.add('text-on-surface-variant');
                });
                this.classList.remove('text-on-surface-variant');
                this.classList.add('bg-primary-container/10', 'text-primary', 'font-bold');
            });
        });
    </script>


