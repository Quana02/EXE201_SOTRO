@page "/nha-tro"
@inject NavigationManager Navigation
@inject IBuildingApiService BuildingApiService
@inject IJSRuntime JS

<PageTitle>Sổ trọ</PageTitle>

<main class="min-h-screen flex flex-col bg-gray-50">

    <HeaderDashboard OnSearch="HandleSearch" SearchPlaceholder="Tìm kiếm nhà trọ (tên, địa chỉ, loại)..." SearchQuery="@searchQuery" OnHelpClicked="OpenOnboarding" />

    <div class="p-4 md:p-10 flex-1">

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10">
            <div>
                <h2 class="text-3xl font-bold text-gray-800 mb-2">
                    Danh sách Nhà trọ của bạn
                </h2>
                <p class="text-gray-500">
                    Quản lý và theo dõi hiệu suất các cơ sở kinh doanh của bạn
                </p>
            </div>

            <button @onclick="GoToCreateHouse"
                    id="create-house-primary"
                    class="flex items-center justify-center gap-3 bg-primary text-on-primary bg-blue-700 text-white px-8 py-4 rounded-xl font-bold shadow-lg hover:shadow-primary/20 active:scale-95 transition-all group cursor-pointer">
                <span class="material-symbols-outlined text-2xl group-hover:rotate-90 transition-transform">
                    add_circle
                </span>
                <span>Tạo nhà trọ mới</span>
            </button>
        </div>

        <div id="building-overview-stats" class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">

            <div class="bg-white p-6 rounded-2xl border shadow-sm flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center text-blue-700">
                    <span class="material-symbols-outlined">apartment</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wider">Tổng số nhà</p>
                    <p class="text-2xl font-bold">@Houses.Count</p>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl border shadow-sm flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-green-100 flex items-center justify-center text-green-700">
                    <span class="material-symbols-outlined">fact_check</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wider">Tỷ lệ lấp đầy</p>
                    <p class="text-2xl font-bold">@OccupancyRate%</p>
                </div>
            </div>

            <div class="bg-white p-6 rounded-2xl border shadow-sm flex items-center gap-4">
                <div class="w-12 h-12 rounded-full bg-amber-100 flex items-center justify-center text-amber-700">
                    <span class="material-symbols-outlined">pending_actions</span>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wider">Phòng trống</p>
                    <p class="text-2xl font-bold">@EmptyRooms</p>
                </div>
            </div>

        </div>

        <div id="building-list-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

            @if (isLoading)
            {
                <div class="col-span-1 md:col-span-3 py-20 flex flex-col items-center justify-center">
                    <span class="material-symbols-outlined text-5xl text-blue-700 animate-spin">progress_activity</span>
                    <p class="text-gray-500 mt-4">Đang tải danh sách nhà trọ...</p>
                </div>
            }
            else if (Houses.Count == 0)
            {
                <div class="col-span-1 md:col-span-3 bg-white p-12 rounded-2xl border text-center flex flex-col items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">apartment</span>
                    <h3 class="text-xl font-bold text-gray-700 mb-2">Bạn chưa có nhà trọ nào</h3>
                    <p class="text-gray-500 mb-6 max-w-md">Bắt đầu bằng việc tạo nhà trọ đầu tiên để quản lý phòng, dịch vụ, hóa đơn và khách thuê của bạn.</p>
                    <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
                        <button @onclick="GoToCreateHouse" class="bg-primary text-white bg-blue-700 px-6 py-3 rounded-xl font-bold hover:bg-blue-800 transition-all flex items-center gap-2 cursor-pointer">
                            <span class="material-symbols-outlined">add_circle</span>
                            Tạo nhà trọ mới
                        </button>
                        <button @onclick="OpenOnboarding" class="px-6 py-3 rounded-xl font-bold text-blue-700 border border-blue-200 hover:bg-blue-50 transition-all flex items-center gap-2 cursor-pointer bg-white">
                            <span class="material-symbols-outlined">tips_and_updates</span>
                            Xem hướng dẫn
                        </button>
                    </div>
                </div>
            }
            else
            {
                @if (filteredHouses.Count == 0)
                {
                    <div class="col-span-1 md:col-span-3 bg-white p-12 rounded-2xl border text-center flex flex-col items-center justify-center">
                        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">search_off</span>
                        <h3 class="text-xl font-bold text-gray-700 mb-2">Không tìm thấy kết quả phù hợp</h3>
                        <p class="text-gray-500 mb-6 max-w-md">Vui lòng thử tìm kiếm với từ khóa khác (ví dụ: tên nhà trọ, địa chỉ...).</p>
                    </div>
                }
                else
                {
                    @foreach (var house in filteredHouses)
                    {
                        var progressPercent = house.TotalRooms > 0 
                            ? (int)Math.Round((double)house.OccupiedRooms.GetValueOrDefault() * 100 / house.TotalRooms.Value) 
                            : 0;
                        var progressClass = progressPercent == 100 ? "bg-green-500 h-full rounded-full" : "bg-blue-700 h-full rounded-full";
                        
                        var statusText = house.Status switch
                        {
                            "Active" => "Đang hoạt động",
                            "Maintenance" => "Đang bảo trì",
                            _ => "Ngừng hoạt động"
                        };

                        var statusClass = house.Status switch
                        {
                            "Active" => "absolute top-4 right-4 bg-white/90 backdrop-blur px-3 py-1 rounded-full text-xs font-bold text-green-700 shadow-sm border border-green-100",
                            "Maintenance" => "absolute top-4 right-4 bg-amber-100 px-3 py-1 rounded-full text-xs font-bold text-amber-700 shadow-sm border border-amber-200",
                            _ => "absolute top-4 right-4 bg-gray-100 px-3 py-1 rounded-full text-xs font-bold text-gray-700 shadow-sm border border-gray-200"
                        };

                        var imageUrl = !string.IsNullOrEmpty(house.ImageUrl) 
                            ? house.ImageUrl 
                            : "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80";

                        var isFirstHouse = filteredHouses.IndexOf(house) == 0;

                        <div id="@(isFirstHouse ? "first-building-card" : null)" class="group bg-white rounded-2xl border overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                            <div class="relative h-48">
                                <img alt="@house.BuildingName"
                                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                                     src="@imageUrl" />

                                <div class="@statusClass">
                                    @statusText
                                </div>
                            </div>

                            <div class="p-6">
                                <span class="text-[10px] font-bold text-blue-700 bg-blue-50 px-2.5 py-1 rounded-full uppercase mb-2 inline-block">
                                    @(house.BuildingTypeName ?? "Chưa phân loại")
                                </span>
                                <h3 class="text-lg font-bold text-gray-800 mb-1 truncate">
                                    @house.BuildingName
                                </h3>

                                <p class="flex items-center gap-1.5 text-gray-500 text-sm mb-6 truncate" title="@house.Address">
                                    <span class="material-symbols-outlined text-base">location_on</span>
                                    @house.Address
                                </p>

                                <div class="space-y-4 mb-6">
                                    <div class="flex justify-between items-end">
                                        <div>
                                            <p class="text-[10px] uppercase font-bold text-gray-500 mb-1">
                                                Số lượng phòng
                                            </p>
                                            <p class="text-sm font-bold">
                                                @house.TotalRooms phòng
                                            </p>
                                        </div>

                                        <div class="text-right">
                                            <p class="text-[10px] uppercase font-bold text-gray-500 mb-1">
                                                Tỷ lệ lấp đầy
                                            </p>
                                            <p class="text-sm font-bold text-blue-700">
                                                @house.OccupiedRooms/@house.TotalRooms đang thuê
                                            </p>
                                        </div>
                                    </div>

                                    <div class="w-full bg-gray-200 h-2 rounded-full overflow-hidden">
                                        <div class="@progressClass" style="width:@progressPercent%"></div>
                                    </div>
                                </div>

                                <div class="flex gap-2">
                                    <button id="@(isFirstHouse ? "first-building-manage" : null)" type="button" class="flex-grow flex-1 text-center py-2.5 border-2 border-blue-700 text-blue-700 font-bold rounded-xl hover:bg-blue-700 hover:text-white transition-all text-sm bg-transparent cursor-pointer"
                                            @onclick="() => GoToDetail(house)">
                                        Quản lý chi tiết
                                    </button>
                                    <button id="@(isFirstHouse ? "first-building-delete" : null)" type="button" @onclick="() => ConfirmDelete(house)" class="px-3 border border-red-200 hover:border-red-600 rounded-xl text-red-500 hover:bg-red-50 transition-all flex items-center justify-center cursor-pointer">
                                        <span class="material-symbols-outlined text-lg">delete</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                    <button id="create-house-secondary" @onclick="GoToCreateHouse"
                            class="flex flex-col items-center justify-center h-[430px] border-2 border-dashed border-gray-300 rounded-2xl hover:bg-gray-100 hover:border-blue-700 transition-all group bg-white cursor-pointer">
                        <div class="w-16 h-16 rounded-full bg-gray-100 flex items-center justify-center mb-4 group-hover:bg-blue-100 group-hover:scale-110 transition-all">
                            <span class="material-symbols-outlined text-4xl text-gray-500 group-hover:text-blue-700">add_home</span>
                        </div>
                        <p class="font-bold text-gray-600 group-hover:text-blue-700">
                            Thêm nhà trọ mới
                        </p>
                        <p class="text-xs text-gray-400 mt-2 px-10 text-center">
                             Bắt đầu quản lý cơ sở kinh doanh mới ngay hôm nay
                        </p>
                    </button>
                }
            }

        </div>
    </div>

</main>

<GuidedOnboarding IsVisible="showOnboarding"
                  Steps="currentNhaTroGuidedSteps"
                  StorageKey="sotro_nha_tro_guided_seen"
                  AllowSkip="true"
                  OnCompleted="CloseOnboarding"
                  OnSkipped="CloseOnboarding" />

@code {
    private List<BuildingResponse> Houses = new();
    private bool isLoading = true;
    private string searchQuery = string.Empty;
    private bool showOnboarding;
    private bool hasCheckedOnboardingStorage;
    private bool includeHelpButtonIntro;
    private bool showHelpButtonIntroInCurrentTour;
    private string helpButtonIntroStorageKey = string.Empty;
    private IReadOnlyList<GuidedOnboarding.GuidedStep> currentNhaTroGuidedSteps =>
        Houses.Count == 0
            ? (showHelpButtonIntroInCurrentTour ? nhaTroFirstTimeGuidedSteps : nhaTroGuidedSteps)
            : nhaTroManagementGuidedSteps;

    private readonly IReadOnlyList<GuidedOnboarding.GuidedStep> nhaTroFirstTimeGuidedSteps = new[]
    {
        new GuidedOnboarding.GuidedStep(
            "#header-help-button",
            "Đây là nút hướng dẫn",
            "Dấu ? trên thanh header dùng để mở hướng dẫn cho trang hiện tại. Khi không nhớ thao tác tiếp theo, bạn có thể bấm vào đây để xem lại từng bước.",
            "Hãy ghi nhớ vị trí dấu ?. Bước giới thiệu này chỉ hiển thị một lần cho tài khoản của bạn, sau đó hệ thống sẽ chuyển sang hướng dẫn tạo nhà trọ."),
        new GuidedOnboarding.GuidedStep(
            "#create-house-primary",
            "Bắt đầu bằng nhà trọ đầu tiên",
            "Tài khoản mới cần tạo một nhà trọ trước. Đây là dữ liệu gốc để hệ thống biết bạn đang quản lý cơ sở nào, sau đó mới tạo phòng, thêm người thuê, xem thống kê và bật các cài đặt nâng cao.",
            "Click đúng nút đang sáng để tạo nhà trọ mới. Bạn cũng có thể bấm Bỏ qua nếu đã quen luồng.",
            true)
    };

    private readonly IReadOnlyList<GuidedOnboarding.GuidedStep> nhaTroGuidedSteps = new[]
    {
        new GuidedOnboarding.GuidedStep(
            "#create-house-primary",
            "Bắt đầu bằng nhà trọ đầu tiên",
            "Tài khoản mới cần tạo một nhà trọ trước. Đây là dữ liệu gốc để hệ thống biết bạn đang quản lý cơ sở nào, sau đó mới tạo phòng, thêm người thuê, xem thống kê và bật các cài đặt nâng cao.",
            "Click đúng nút đang sáng để tạo nhà trọ mới. Bạn cũng có thể bấm Bỏ qua nếu đã quen luồng.",
            true)
    };

    private readonly IReadOnlyList<GuidedOnboarding.GuidedStep> nhaTroManagementGuidedSteps = new[]
    {
        new GuidedOnboarding.GuidedStep(
            "#building-overview-stats",
            "Theo dõi tổng quan nhà trọ",
            "Ba ô này cho biết tổng số nhà trọ, tỷ lệ lấp đầy và số phòng trống trên toàn bộ cơ sở bạn đang quản lý.",
            "Xem khu vực này trước để biết tình hình vận hành hiện tại."),
        new GuidedOnboarding.GuidedStep(
            "#first-building-card",
            "Một thẻ nhà trọ",
            "Mỗi thẻ đại diện cho một cơ sở, gồm ảnh, trạng thái hoạt động, loại nhà trọ, địa chỉ, số phòng và tỷ lệ lấp đầy.",
            "Dùng thẻ này để nhận diện nhanh cơ sở cần quản lý."),
        new GuidedOnboarding.GuidedStep(
            "#first-building-manage",
            "Quản lý chi tiết",
            "Nút này mở cơ sở đang chọn để bạn vào dashboard, quản lý phòng, người thuê, hóa đơn và các cài đặt liên quan.",
            "Click Quản lý chi tiết khi muốn làm việc với nhà trọ này."),
        new GuidedOnboarding.GuidedStep(
            "#first-building-delete",
            "Xóa nhà trọ",
            "Nút thùng rác dùng để xóa nhà trọ. Chỉ dùng khi bạn chắc chắn không còn cần dữ liệu của cơ sở này.",
            "Khi bấm xóa, hệ thống sẽ hỏi xác nhận trước khi thực hiện."),
        new GuidedOnboarding.GuidedStep(
            "#create-house-primary",
            "Thêm nhà trọ tiếp theo",
            "Sau khi đã có một cơ sở, bạn vẫn có thể tạo thêm nhà trọ mới để quản lý nhiều địa điểm trong cùng tài khoản.",
            "Click ô Thêm nhà trọ mới hoặc nút Tạo nhà trọ mới ở đầu trang để tạo cơ sở mới.")
    };

    private List<BuildingResponse> filteredHouses =>
        string.IsNullOrWhiteSpace(searchQuery)
            ? Houses
            : Houses.Where(h =>
                (h.BuildingName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (h.Address?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (h.BuildingTypeName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ?? false)
            ).ToList();

    private void HandleSearch(string query)
    {
        searchQuery = query;
        StateHasChanged();
    }

    private int TotalRooms => Houses.Sum(h => h.TotalRooms ?? 0);
    private int OccupiedRooms => Houses.Sum(h => h.OccupiedRooms ?? 0);
    private int EmptyRooms => TotalRooms - OccupiedRooms;
    private int OccupancyRate => TotalRooms > 0 ? (int)Math.Round((double)OccupiedRooms * 100 / TotalRooms) : 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadBuildings();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || hasCheckedOnboardingStorage)
        {
            return;
        }

        hasCheckedOnboardingStorage = true;

        try
        {
            await LoadHelpButtonIntroStateAsync();

            if (!isLoading && Houses.Count == 0)
            {
                await StartOnboardingAsync();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Guided onboarding init error: {ex.Message}");
        }
    }

    private async Task LoadBuildings()
    {
        isLoading = true;
        try
        {
            var response = await BuildingApiService.GetBuildingsAsync();
            if (response.Success && response.Data != null)
            {
                Houses = response.Data;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading buildings: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GoToCreateHouse()
    {
        if (Houses.Count == 0)
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_force_create_building_tour", "true");
                await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_create_building_guided_seen");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Prepare create building tour error: {ex.Message}");
            }
        }

        Navigation.NavigateTo("/tao-nha-tro-v2");
    }

    private async Task OpenOnboarding()
    {
        if (Houses.Count > 0)
        {
            searchQuery = string.Empty;
        }

        await LoadHelpButtonIntroStateAsync();
        await StartOnboardingAsync();
        StateHasChanged();
    }

    private void CloseOnboarding()
    {
        showOnboarding = false;
        showHelpButtonIntroInCurrentTour = false;
    }

    private async Task LoadHelpButtonIntroStateAsync()
    {
        if (Houses.Count > 0)
        {
            includeHelpButtonIntro = false;
            return;
        }

        try
        {
            var userEmail = await JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_email");
            var accountKey = string.IsNullOrWhiteSpace(userEmail) ? "anonymous" : userEmail.Trim().ToLowerInvariant();
            helpButtonIntroStorageKey = $"sotro_header_help_intro_seen_v3_{accountKey}";
            var seen = await JS.InvokeAsync<string>("localStorage.getItem", helpButtonIntroStorageKey);
            includeHelpButtonIntro = string.IsNullOrWhiteSpace(seen);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Help button intro state error: {ex.Message}");
            includeHelpButtonIntro = false;
        }
    }

    private async Task StartOnboardingAsync()
    {
        showHelpButtonIntroInCurrentTour = includeHelpButtonIntro;
        showOnboarding = true;

        if (showHelpButtonIntroInCurrentTour && !string.IsNullOrWhiteSpace(helpButtonIntroStorageKey))
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.setItem", helpButtonIntroStorageKey, "true");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Help button intro save error: {ex.Message}");
            }

            includeHelpButtonIntro = false;
        }
    }

    private async Task GoToDetail(BuildingResponse house)
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "active_building_id", house.BuildingId.ToString());
            await JS.InvokeVoidAsync("localStorage.setItem", "active_building_name", house.BuildingName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving building context: {ex.Message}");
        }
        Navigation.NavigateTo("/dashboard");
    }

    private async Task ConfirmDelete(BuildingResponse house)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc chắn muốn xóa nhà trọ '{house.BuildingName}'? Hành động này không thể hoàn tác.");
        if (confirmed)
        {
            try
            {
                var result = await BuildingApiService.DeleteBuildingAsync(house.BuildingId);
                if (result.Success)
                {
                    await LoadBuildings();
                }
                else
                {
                    await JS.InvokeVoidAsync("alert", $"Không thể xóa: {result.Message}");
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Lỗi khi xóa: {ex.Message}");
            }
        }
    }
}
