@page "/"
@layout EmptyLayout
@inject IJSRuntime JS

<PageTitle>Sổ trọ - Giải pháp quản lý phòng trọ chuyên nghiệp</PageTitle>

<HeaderLanding />

<main class="pt-16 hero-gradient overflow-hidden">
    <!-- Hero Section -->
    <section id="home" class="relative scroll-mt-24 px-margin-mobile md:px-margin-desktop py-20 md:py-32 max-w-container-max-width mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="z-10">
                <span class="inline-block px-4 py-1.5 mb-6 rounded-full bg-secondary-container text-on-tertiary-fixed-variant font-label-md text-label-md">
                    Nền tảng quản lý tin cậy số 1
                </span>
                <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg text-primary mb-6 leading-tight">
                    Sổ trọ - Giải pháp quản lý phòng trọ chuyên nghiệp
                </h1>
                <p class="font-body-lg text-body-lg text-on-surface-variant mb-10 max-w-lg">
                    Quản lý khách thuê, hợp đồng, và hóa đơn dễ dàng, chính xác ngay trên điện thoại và máy tính. Đơn giản hóa mọi quy trình hành chính của bạn.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="/dang-ky" class="px-8 py-4 bg-primary text-white rounded-xl font-label-md text-label-md hover:shadow-lg transition-all transform hover:-translate-y-1">
                        Đăng ký ngay
                    </a>
                    <button class="px-8 py-4 border-2 border-primary text-primary rounded-xl font-label-md text-label-md hover:bg-primary-fixed transition-all">
                        Xem bản demo
                    </button>
                </div>
                <div class="mt-8 flex items-center gap-4 text-on-surface-variant font-caption text-caption">
                    <div class="flex -space-x-2">
                        <div class="w-8 h-8 rounded-full border-2 border-white bg-surface-container-high flex items-center justify-center overflow-hidden">
                            <img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAMbpngLakAJz15sGqp2jiDCdwS7-aEM0g4PkzKjfKzTG8WyaQwPOdFrS3gSGK3xl58Nj1yE10DvxXnSl3dhdaLxafWJp7Nnc7KaMMXR_CHtEDJ6vCU_6UciDvGkBrfqTgEZWJkZvXxK3zfaXuMNJxI8-7rQt-HBXClJRVYl3knzsVndNYQ2y_cEpQYLYFVvavK4iyrz33Qf3s9Ll8cPTdCYPFSpaRz75KP2Ke6vM2gqlJKzAnBBLW2Dy3BL1q2RTzzHF0QYsI1zdVj" />
                        </div>
                        <div class="w-8 h-8 rounded-full border-2 border-white bg-surface-container-high flex items-center justify-center overflow-hidden">
                            <img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBLEtcqPTt6JPY-uQ0OX7YxXYael9dqaZXZZ18cYsqTFdl1D4m7yYuQOJPWbE06X2UqqejoOu800qDYCm9bWAvEtCs2k5xC5K4hyCx6U_BM0mGPrqr26lGE2XpoTdUwCXTgIetr4XXfI5g1in9FXpY8WIEI2ZMWl7-1LDW2V3PYZs6IgpE02kbvtYY5JHG9RQWGLhDB1N3Y6SoucyDw8gbe_0MTs-tGIUROEcD8m0ificeXfvuOqNiuv4yKovT7GonmbukCtnZ1j41Y" />
                        </div>
                        <div class="w-8 h-8 rounded-full border-2 border-white bg-surface-container-high flex items-center justify-center overflow-hidden">
                            <img alt="User" class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBdbK9PPYhCJooaHJ_HnqIuOyG13FpoQzQxuKs8cGNN3WU0cTTAQFCE62ha-YTSB6Ndg-iagW5KjEcYgyG1uKH0A64oqyFxfAHP1BzypAc9oRLMzpBtejhwD8Merw-k2RDhfV5T66ra-r2tNkSSRg5ag9AIgaG3zGUeZbCBhN0SPCh5g5B2TFe4RYsNJrTxYQWHyp4FluDBq_44ONoi-BS1mJI4WhqQ9KmBRiD8cKFO-F04selUOO4goaS7gTMeLe_RpMFiBQt3v55e" />
                        </div>
                    </div>
                    <span>+2,000 chủ trọ đã tin dùng</span>
                </div>
            </div>
            <div class="relative">
                <div class="absolute -inset-4 bg-primary-fixed opacity-20 blur-3xl rounded-full"></div>
                <div class="relative glass-card p-4 rounded-xl shadow-xl transform md:rotate-2 transition-all duration-700">
                    <img alt="Dashboard Preview" class="rounded-lg w-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBazDFlLldQFMR4RFkkfv3kUTjAAG8Op7m5qlBY4pkUFJ0SXGbIIPWNywhZXWvlYu6yJREluL3RzYyqInVMCp4qfeXGhovFHJqK_SqaUeecJ5KHFcvSBt5JuLO5qdLBmy1qwlLJ8bPYHNftZAeXBY2Forn-Wq33gAdrg8cOleRPVMpGn9YaJt92aHHYVw3bb0Qn8HaBrFmg_jGTQi-oXJKSk0LSfPt3BmihBQWpBZnUNV_72FtUHmAHBHmmloPLL8Cj4IR73TeSpRhl" />
                    <!-- Floating Card -->
                    <div class="absolute -bottom-6 -left-6 glass-card p-4 rounded-xl shadow-lg animate-bounce">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-white">
                                <span class="material-symbols-outlined">payments</span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface">Tiền nhà đã nhận</p>
                                <p class="font-headline-sm text-headline-sm text-primary">45.000.000đ</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Quick Links Section -->
    <section id="features" class="scroll-mt-24 px-margin-mobile md:px-margin-desktop py-16 max-w-container-max-width mx-auto">
        <div class="text-center max-w-3xl mx-auto mb-12">
            <span class="inline-block px-4 py-1.5 mb-4 rounded-full bg-secondary-container text-on-secondary-container font-label-md text-label-md">Tính năng</span>
            <h2 class="font-headline-md text-headline-md text-on-surface mb-4">Mọi công cụ quản lý nhà trọ trong một nơi</h2>
            <p class="font-body-lg text-body-lg text-on-surface-variant">Theo dõi vận hành, lập hóa đơn, nhắc thanh toán và xem báo cáo mà không phải chuyển qua nhiều file rời rạc.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-all">
                <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-primary">dashboard</span>
                </div>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Dashboard Tổng quan</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Theo dõi dòng tiền và tình trạng phòng tức thì.</p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-all">
                <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-primary">receipt_long</span>
                </div>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Tự động hóa hóa đơn</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Gửi hóa đơn điện nước qua Zalo, Email chỉ với 1 chạm.</p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm hover:shadow-md transition-all">
                <div class="w-12 h-12 rounded-xl bg-primary-fixed flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-primary">security</span>
                </div>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Bảo mật dữ liệu</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Dữ liệu được mã hóa và lưu trữ an toàn tuyệt đối.</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8">
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm">
                <span class="material-symbols-outlined text-primary text-4xl mb-4">groups</span>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Quản lý người thuê</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Lưu thông tin liên hệ, phòng đang ở, hợp đồng và trạng thái thanh toán theo từng người thuê.</p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm">
                <span class="material-symbols-outlined text-primary text-4xl mb-4">request_quote</span>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Hóa đơn và QR thanh toán</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Tạo bill theo tháng, đính kèm QR ngân hàng và hỗ trợ gửi nhắc thanh toán nhanh.</p>
            </div>
            <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm">
                <span class="material-symbols-outlined text-primary text-4xl mb-4">campaign</span>
                <h3 class="font-headline-sm text-headline-sm text-on-surface mb-2">Marketing phòng trống</h3>
                <p class="font-body-md text-body-md text-on-surface-variant">Theo dõi phòng sắp trống và chuẩn bị nội dung đăng tin để giảm thời gian bỏ trống.</p>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section id="pricing" class="scroll-mt-24 px-margin-mobile md:px-margin-desktop py-20 bg-surface-container-low">
        <div class="max-w-container-max-width mx-auto">
            <div class="text-center max-w-3xl mx-auto mb-12">
                <span class="inline-block px-4 py-1.5 mb-4 rounded-full bg-primary-fixed text-primary font-label-md text-label-md">Bảng giá</span>
                <h2 class="font-headline-md text-headline-md text-on-surface mb-4">Chọn gói phù hợp với quy mô vận hành</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant">Bắt đầu miễn phí, nâng cấp khi bạn cần tự động hóa sâu hơn.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm flex flex-col">
                    <span class="text-primary font-label-md text-label-md uppercase tracking-wider">Tiết kiệm</span>
                    <h3 class="font-headline-sm text-headline-sm mt-2 mb-4">Gói Basic</h3>
                    <div class="mb-4"><span class="font-display-lg text-display-lg text-primary">0</span><span class="text-on-surface-variant">đ/tháng</span></div>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-6">Phù hợp chủ trọ mới bắt đầu.</p>
                    <ul class="space-y-3 mb-8 flex-1">
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Quản lý tối đa 10 phòng</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Quản lý người thuê và phòng</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Theo dõi hóa đơn cơ bản</span></li>
                    </ul>
                    <a href="/dang-ky" class="w-full text-center border-2 border-primary text-primary py-3 rounded-lg font-label-md text-label-md hover:bg-primary-fixed transition-colors">Bắt đầu ngay</a>
                </div>

                <div class="bg-surface-container-lowest p-8 rounded-xl border-2 border-primary shadow-lg flex flex-col relative overflow-hidden">
                    <div class="absolute top-4 right-[-36px] bg-primary text-white py-1 px-12 rotate-45 font-label-md text-[10px] uppercase font-bold">Phổ biến</div>
                    <span class="text-primary font-label-md text-label-md uppercase tracking-wider">Tối ưu</span>
                    <h3 class="font-headline-sm text-headline-sm mt-2 mb-4">Gói Premium</h3>
                    <div class="mb-4"><span class="font-headline-sm text-headline-sm text-primary">Liên hệ</span></div>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-6">Dành cho chủ trọ muốn tự động hóa gửi bill.</p>
                    <ul class="space-y-3 mb-8 flex-1">
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Không giới hạn phòng</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Ngày xuất/gửi hóa đơn tự động</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Nhắc nợ và xuất báo cáo nâng cao</span></li>
                    </ul>
                    <a href="#contact" class="w-full text-center bg-primary text-white py-3 rounded-lg font-label-md text-label-md hover:shadow-lg transition-all">Liên hệ tư vấn</a>
                </div>

                <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm flex flex-col">
                    <span class="text-primary font-label-md text-label-md uppercase tracking-wider">Toàn diện</span>
                    <h3 class="font-headline-sm text-headline-sm mt-2 mb-4">Gói Doanh nghiệp</h3>
                    <div class="mb-4"><span class="font-headline-sm text-headline-sm text-primary">Liên hệ</span></div>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-6">Phù hợp chuỗi căn hộ và đội vận hành.</p>
                    <ul class="space-y-3 mb-8 flex-1">
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Tất cả tính năng Premium</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Phân quyền nhân viên</span></li>
                        <li class="flex gap-2"><span class="material-symbols-outlined text-primary">check_circle</span><span>Hỗ trợ riêng 24/7</span></li>
                    </ul>
                    <a href="#contact" class="w-full text-center border-2 border-primary text-primary py-3 rounded-lg font-label-md text-label-md hover:bg-primary-fixed transition-colors">Liên hệ tư vấn</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="scroll-mt-24 px-margin-mobile md:px-margin-desktop py-20 bg-white">
        <div class="max-w-container-max-width mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
            <div>
                <span class="inline-block px-4 py-1.5 mb-4 rounded-full bg-secondary-container text-on-secondary-container font-label-md text-label-md">Liên hệ</span>
                <h2 class="font-headline-md text-headline-md text-on-surface mb-4">Cần tư vấn triển khai Sổ Trọ?</h2>
                <p class="font-body-lg text-body-lg text-on-surface-variant mb-8">Đội ngũ hỗ trợ sẽ giúp bạn chọn gói phù hợp và thiết lập quy trình quản lý ban đầu.</p>
                <div class="space-y-5">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-primary-fixed rounded-full flex items-center justify-center text-primary"><span class="material-symbols-outlined">call</span></div>
                        <div><p class="font-label-md text-label-md text-on-surface-variant uppercase">Điện thoại</p><p class="font-body-lg text-body-lg">1900 xxxx</p></div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-primary-fixed rounded-full flex items-center justify-center text-primary"><span class="material-symbols-outlined">mail</span></div>
                        <div><p class="font-label-md text-label-md text-on-surface-variant uppercase">Email</p><p class="font-body-lg text-body-lg">ho-tro@sotro.vn</p></div>
                    </div>
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 bg-primary-fixed rounded-full flex items-center justify-center text-primary"><span class="material-symbols-outlined">schedule</span></div>
                        <div><p class="font-label-md text-label-md text-on-surface-variant uppercase">Giờ làm việc</p><p class="font-body-lg text-body-lg">Thứ 2 - Thứ 6, 08:00 - 17:30</p></div>
                    </div>
                </div>
            </div>

            <form class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant shadow-sm space-y-5" onsubmit="return false">
                <h3 class="font-headline-sm text-headline-sm text-on-surface">Gửi yêu cầu tư vấn</h3>
                <input class="w-full px-4 py-3 border border-outline rounded-lg bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Họ và tên" type="text">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <input class="w-full px-4 py-3 border border-outline rounded-lg bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Email" type="email">
                    <input class="w-full px-4 py-3 border border-outline rounded-lg bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Số điện thoại" type="tel">
                </div>
                <textarea class="w-full px-4 py-3 border border-outline rounded-lg bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Bạn cần tư vấn nội dung gì?" rows="5"></textarea>
                <button class="w-full bg-primary text-white py-4 rounded-lg font-headline-sm text-headline-sm hover:shadow-lg active:scale-[0.98] transition-all flex items-center justify-center gap-2">
                    <span>Gửi yêu cầu</span>
                    <span class="material-symbols-outlined">send</span>
                </button>
            </form>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="bg-primary py-20">
        <div class="px-margin-mobile md:px-margin-desktop max-w-container-max-width mx-auto text-center">
            <h2 class="font-headline-md text-headline-md text-white mb-6">Sẵn sàng để chuyên nghiệp hóa việc quản lý?</h2>
            <p class="font-body-lg text-body-lg text-primary-fixed mb-10 max-w-2xl mx-auto">Gia nhập cộng đồng hơn 2,000 chủ trọ đang tối ưu hóa doanh thu và thời gian cùng Sổ trọ.</p>
            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="/dang-ky" class="px-10 py-4 bg-white text-primary rounded-xl font-headline-sm text-headline-sm hover:bg-primary-fixed transition-all">
                    Bắt đầu dùng thử miễn phí
                </a>
                <a href="#contact" class="px-10 py-4 border border-white text-white rounded-xl font-headline-sm text-headline-sm hover:bg-white/10 transition-all">
                    Liên hệ tư vấn
                </a>
            </div>
        </div>
    </section>
</main>

<FooterLanding />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("sotroLanding.scrollToCurrentHash");
        }
    }
}
