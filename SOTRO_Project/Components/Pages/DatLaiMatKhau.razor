@page "/dat-lai-mat-khau"
@using SOTRO_Project.Components.Layout
@inject NavigationManager Navigation
@inject IAuthApiService AuthApi

<PageTitle>Đặt lại mật khẩu - Sổ trọ</PageTitle>

<HeaderLanding />

<main class="pt-28 pb-16 min-h-screen flex items-center justify-center px-4 bg-gray-50 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full opacity-10 pointer-events-none">
        <div class="absolute top-[-10%] left-[-5%] w-[40%] h-[40%] bg-blue-700 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[40%] h-[40%] bg-blue-900 rounded-full blur-[120px]"></div>
    </div>

    <div class="w-full max-w-[480px] z-10">
        <div class="bg-white p-8 md:p-10 rounded-xl shadow border border-gray-200">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-bold text-blue-700 mb-2">Đặt lại mật khẩu</h1>
                <p class="text-gray-600">Nhập mật khẩu mới của bạn để tiếp tục sử dụng ứng dụng Sổ trọ.</p>
            </div>

            @if (!HasResetInfo)
            {
                <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-red-700">
                    Thiếu thông tin xác thực đặt lại mật khẩu.
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(Message))
            {
                <div class="mb-6 rounded-lg border px-4 py-3 @(IsSuccess ? "border-green-200 bg-green-50 text-green-700" : "border-red-200 bg-red-50 text-red-700")">
                    @Message
                </div>
            }

            <form class="space-y-6" @onsubmit="ResetPassword" @onsubmit:preventDefault>
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-gray-600 block">Mật khẩu mới</label>
                    <div class="relative">
                        <input @bind="Request.NewPassword"
                               class="w-full px-4 py-3 pr-11 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-700 focus:border-blue-700 outline-none"
                               placeholder="••••••••"
                               type="@(_showResetNewPassword ? "text" : "password")" />
                        <button @onclick="() => _showResetNewPassword = !_showResetNewPassword" type="button" tabindex="-1"
                                class="absolute right-3 top-1/2 -translate-y-1/2 p-0.5 rounded-lg text-gray-400 hover:text-blue-700 transition-colors">
                            <span class="material-symbols-outlined text-xl">@(_showResetNewPassword ? "visibility" : "visibility_off")</span>
                        </button>
                    </div>
                    @ShowFieldError(nameof(Request.NewPassword))
                </div>

                <div class="space-y-3">
                    <div class="flex justify-between items-center">
                        <span class="text-xs text-gray-500 uppercase tracking-wider">Độ mạnh mật khẩu</span>
                        <span class="text-xs text-gray-500">@PasswordStrengthLabel</span>
                    </div>
                    <div class="h-1.5 w-full bg-gray-200 rounded-full overflow-hidden">
                        <div class="h-full @PasswordStrengthWidth @PasswordStrengthColor"></div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2 mt-4 text-gray-600 text-sm">
                        <div>○ Tối thiểu 8 ký tự</div>
                        <div>○ Chữ hoa A-Z</div>
                        <div>○ Chữ số 0-9</div>
                        <div>○ Ký tự đặc biệt</div>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold text-gray-600 block">Xác nhận mật khẩu mới</label>
                    <div class="relative">
                        <input @bind="Request.ConfirmPassword"
                               class="w-full px-4 py-3 pr-11 bg-white border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-700 focus:border-blue-700 outline-none"
                               placeholder="••••••••"
                               type="@(_showResetConfirmPassword ? "text" : "password")" />
                        <button @onclick="() => _showResetConfirmPassword = !_showResetConfirmPassword" type="button" tabindex="-1"
                                class="absolute right-3 top-1/2 -translate-y-1/2 p-0.5 rounded-lg text-gray-400 hover:text-blue-700 transition-colors">
                            <span class="material-symbols-outlined text-xl">@(_showResetConfirmPassword ? "visibility" : "visibility_off")</span>
                        </button>
                    </div>
                    @ShowFieldError(nameof(Request.ConfirmPassword))
                </div>

                <button disabled="@(!HasResetInfo || IsLoading)"
                        class="w-full bg-blue-700 text-white py-3.5 rounded-lg text-base font-bold hover:bg-blue-800 shadow-md transition-all disabled:opacity-60"
                        type="submit">
                    @(IsLoading ? "Đang cập nhật..." : "Cập nhật mật khẩu")
                </button>
            </form>

            <div class="mt-8 text-center">
                <a class="text-blue-700 text-sm font-semibold hover:underline inline-flex items-center gap-1" href="/dang-nhap">
                    ← Quay lại trang Đăng nhập
                </a>
            </div>
        </div>
    </div>
</main>

<FooterLanding />

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "resetPasswordToken")]
    public string? ResetPasswordToken { get; set; }

    private ResetPasswordRequest Request { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool IsSuccess { get; set; }
    private bool _showResetNewPassword;
    private bool _showResetConfirmPassword;
    private string? Message { get; set; }
    private Dictionary<string, string> Errors { get; set; } = new();
    private bool HasResetInfo => !string.IsNullOrWhiteSpace(Request.Email) && !string.IsNullOrWhiteSpace(Request.ResetPasswordToken);

    private const string PasswordError = "Mật khẩu phải có ít nhất 8 ký tự, gồm 1 chữ in hoa, 1 chữ thường, 1 chữ số và 1 ký tự đặc biệt.";
    private const string ConfirmPasswordError = "Mật khẩu xác nhận không khớp.";

    private string PasswordStrengthLabel => PasswordScore switch
    {
        >= 4 => "Mạnh",
        3 => "Khá",
        2 => "Trung bình",
        _ => "Yếu"
    };

    private string PasswordStrengthWidth => PasswordScore switch
    {
        >= 4 => "w-full",
        3 => "w-3/4",
        2 => "w-1/2",
        _ => "w-1/4"
    };

    private string PasswordStrengthColor => PasswordScore switch
    {
        >= 4 => "bg-green-500",
        3 => "bg-blue-500",
        2 => "bg-yellow-500",
        _ => "bg-red-500"
    };

    private int PasswordScore
    {
        get
        {
            var password = Request.NewPassword ?? string.Empty;
            var score = 0;
            if (password.Length >= 8) score++;
            if (password.Any(char.IsUpper)) score++;
            if (password.Any(char.IsLower)) score++;
            if (password.Any(char.IsDigit)) score++;
            if (password.Any(ch => !char.IsLetterOrDigit(ch))) score++;
            return Math.Min(score, 4);
        }
    }

    protected override void OnParametersSet()
    {
        Request.Email = Email ?? string.Empty;
        Request.ResetPasswordToken = ResetPasswordToken ?? string.Empty;
    }

    private async Task ResetPassword()
    {
        if (!ValidateResetPassword())
        {
            IsSuccess = false;
            Message = null;
            return;
        }

        IsLoading = true;
        Message = null;

        var response = await AuthApi.ResetPasswordAsync(Request);
        IsSuccess = response.Success;
        Message = response.Message;

        if (response.Success)
        {
            Message = "Đổi mật khẩu thành công. Vui lòng đăng nhập lại.";
            await Task.Delay(1500);
            Navigation.NavigateTo("/dang-nhap");
        }

        IsLoading = false;
    }

    private bool ValidateResetPassword()
    {
        Errors = new Dictionary<string, string>();

        if (string.IsNullOrWhiteSpace(Request.NewPassword) ||
            !System.Text.RegularExpressions.Regex.IsMatch(Request.NewPassword, @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$"))
        {
            Errors[nameof(Request.NewPassword)] = PasswordError;
        }

        if (string.IsNullOrWhiteSpace(Request.ConfirmPassword) ||
            Request.ConfirmPassword != Request.NewPassword)
        {
            Errors[nameof(Request.ConfirmPassword)] = ConfirmPasswordError;
        }

        return Errors.Count == 0;
    }

    private RenderFragment ShowFieldError(string fieldName) => builder =>
    {
        if (!Errors.TryGetValue(fieldName, out var error))
        {
            return;
        }

        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "mt-1 text-sm text-red-600");
        builder.AddContent(2, error);
        builder.CloseElement();
    };
}
