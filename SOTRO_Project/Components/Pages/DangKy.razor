@page "/dang-ky"
@using SOTRO_Project.Components.Layout
@inject NavigationManager Navigation
@inject IAuthApiService AuthApi

<PageTitle>Đăng ký - Sổ trọ</PageTitle>

<HeaderLanding />

<main class="min-h-screen pt-28 pb-16 flex items-center justify-center bg-gray-50">
    <div class="w-full max-w-7xl mx-auto px-4 md:px-10">
        <div class="bg-white rounded-xl overflow-hidden shadow border border-gray-200 grid grid-cols-1 md:grid-cols-2">
            <div class="relative hidden md:block bg-blue-800 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-blue-800 via-blue-900 to-blue-950 opacity-90 z-10"></div>
                <img class="absolute inset-0 w-full h-full object-cover opacity-40"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuDfa-SbEePg5AuYxK9mYl2NWZDx1TrOYqYwmNb_ukIKkjYizahUEX9UqxJIW_j4XHDariE-cJ8aVJVEX4dGKjNUdjhChwwlArtyFqpeqrvioVukWUUA2sJ3SuQGdKZn-Usc6EVQs30sKfk9OvtTRsIZ_ULCjQg7osCECQauzzJ1utb_x6jUVuT1bmvAmqRPfTuRpFdXyRp9bmZR4xbgAlhB_gZ5Rw6Ej0opEuvoyuHzbyU1NvrDmn8BzMLS43UPku5O9Oij6OAEkeiz"
                     alt="Sổ trọ" />
                <div class="relative z-20 h-full flex flex-col justify-center p-12 text-white">
                    <h1 class="text-4xl font-bold mb-6 leading-tight">Quản lý trọ thông minh cùng Sổ trọ</h1>
                    <p class="text-lg text-blue-100 mb-10">
                        Hệ sinh thái toàn diện giúp chủ trọ tối ưu hóa quy trình vận hành,
                        quản lý doanh thu và chăm sóc người thuê chuyên nghiệp hơn.
                    </p>
                    <div class="space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">📊</div>
                            <div>
                                <h3 class="text-lg font-bold">Dashboard Tổng quan</h3>
                                <p class="text-sm text-blue-100">Theo dõi dòng tiền và tình trạng phòng tức thì.</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">🧾</div>
                            <div>
                                <h3 class="text-lg font-bold">Tự động hóa hóa đơn</h3>
                                <p class="text-sm text-blue-100">Gửi hóa đơn điện nước qua Zalo, Email chỉ với 1 chạm.</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">🔒</div>
                            <div>
                                <h3 class="text-lg font-bold">Bảo mật dữ liệu</h3>
                                <p class="text-sm text-blue-100">Dữ liệu được mã hóa và lưu trữ an toàn tuyệt đối.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-8 md:p-14 flex flex-col justify-center bg-white">
                <div class="mb-8">
                    <h2 class="text-3xl font-bold text-blue-700 mb-2">Bắt đầu ngay hôm nay</h2>
                    <p class="text-gray-600">Trở thành một trong hàng nghìn chủ trọ hiện đại đang tin dùng Sổ trọ.</p>
                </div>

                @if (!string.IsNullOrWhiteSpace(Message))
                {
                    <div class="mb-5 rounded-lg border px-4 py-3 @(IsSuccess ? "border-green-200 bg-green-50 text-green-700" : "border-red-200 bg-red-50 text-red-700")">
                        @Message
                    </div>
                }

                <form class="space-y-5" @onsubmit="Register" @onsubmit:preventDefault>
                    <div>
                        <label class="text-sm font-semibold text-gray-600 block mb-2">Họ tên</label>
                        <input @bind="RegisterModel.FullName"
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-2 focus:ring-blue-100 outline-none"
                               placeholder="Nguyễn Văn A"
                               type="text" />
                        @ShowFieldError(nameof(RegisterModel.FullName))
                    </div>

                    <div>
                        <label class="text-sm font-semibold text-gray-600 block mb-2">Số điện thoại</label>
                        <input @bind="RegisterModel.PhoneNumber"
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-2 focus:ring-blue-100 outline-none"
                               placeholder="0901234567"
                               type="tel" />
                        @ShowFieldError(nameof(RegisterModel.PhoneNumber))
                    </div>

                    <div>
                        <label class="text-sm font-semibold text-gray-600 block mb-2">Email</label>
                        <input @bind="RegisterModel.Email"
                               class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-2 focus:ring-blue-100 outline-none"
                               placeholder="example@sotro.vn"
                               type="email" />
                        @ShowFieldError(nameof(RegisterModel.Email))
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label class="text-sm font-semibold text-gray-600 block mb-2">Mật khẩu</label>
                            <input @bind="RegisterModel.Password"
                                   class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-2 focus:ring-blue-100 outline-none"
                                   placeholder="••••••••"
                                   type="password" />
                            @ShowFieldError(nameof(RegisterModel.Password))
                        </div>

                        <div>
                            <label class="text-sm font-semibold text-gray-600 block mb-2">Nhập lại mật khẩu</label>
                            <input @bind="RegisterModel.ConfirmPassword"
                                   class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-blue-700 focus:ring-2 focus:ring-blue-100 outline-none"
                                   placeholder="••••••••"
                                   type="password" />
                            @ShowFieldError(nameof(RegisterModel.ConfirmPassword))
                        </div>
                    </div>

                    <div class="flex items-start gap-3 py-2">
                        <input @bind="AcceptedTerms"
                               class="mt-1 w-5 h-5 rounded border-gray-300 text-blue-700"
                               id="terms"
                               type="checkbox" />
                        <label class="text-sm text-gray-600 cursor-pointer select-none" for="terms">
                            Tôi đồng ý với
                            <a class="text-blue-700 hover:underline" href="/dieu-khoan">Điều khoản dịch vụ</a>
                            và
                            <a class="text-blue-700 hover:underline" href="/chinh-sach-bao-mat">Chính sách bảo mật</a>
                            của Sổ trọ.
                        </label>
                    </div>

                    <button disabled="@IsLoading"
                            class="w-full bg-blue-700 text-white py-4 rounded-lg font-bold shadow-lg hover:bg-blue-800 transition-all disabled:opacity-60"
                            type="submit">
                        @(IsLoading ? "Đang đăng ký..." : "Đăng ký ngay")
                    </button>

                    <p class="text-center text-gray-600 mt-6">
                        Đã có tài khoản?
                        <a class="text-blue-700 font-bold hover:underline" href="/dang-nhap">Đăng nhập</a>
                    </p>
                </form>
            </div>
        </div>
    </div>
</main>

<FooterLanding />

@code {
    private RegisterSendOtpRequest RegisterModel { get; set; } = new();
    private bool AcceptedTerms { get; set; }
    private bool IsLoading { get; set; }
    private bool IsSuccess { get; set; }
    private string? Message { get; set; }
    private Dictionary<string, string> Errors { get; set; } = new();

    private const string PasswordError = "Mật khẩu phải có ít nhất 8 ký tự, gồm 1 chữ in hoa, 1 chữ thường, 1 chữ số và 1 ký tự đặc biệt.";
    private const string ConfirmPasswordError = "Mật khẩu xác nhận không khớp.";
    private const string FullNameError = "Họ tên không được để trống và chỉ được chứa chữ cái, khoảng trắng.";
    private const string FullNameMinLengthError = "Họ tên phải có ít nhất 2 ký tự.";
    private const string PhoneError = "Số điện thoại không hợp lệ. Số điện thoại phải bắt đầu bằng 0 và gồm 10 chữ số.";

    private async Task Register()
    {
        if (!ValidateRegister())
        {
            IsSuccess = false;
            Message = null;
            return;
        }

        if (!AcceptedTerms)
        {
            IsSuccess = false;
            Message = "Vui lòng đồng ý điều khoản dịch vụ trước khi đăng ký.";
            return;
        }

        RegisterModel.FullName = RegisterModel.FullName.Trim();
        RegisterModel.Email = RegisterModel.Email.Trim();
        RegisterModel.PhoneNumber = RegisterModel.PhoneNumber?.Trim();

        IsLoading = true;
        Message = null;

        var response = await AuthApi.SendRegisterOtpAsync(RegisterModel);
        IsSuccess = response.Success;
        Message = response.Message;

        if (response.Success)
        {
            Message = "Mã OTP đã được gửi đến email của bạn.";
            await Task.Delay(1200);
            Navigation.NavigateTo($"/xac-thuc-otp?email={Uri.EscapeDataString(RegisterModel.Email)}&purpose=Register");
        }

        IsLoading = false;
    }

    private bool ValidateRegister()
    {
        Errors = new Dictionary<string, string>();

        var fullName = RegisterModel.FullName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(fullName))
        {
            Errors[nameof(RegisterModel.FullName)] = FullNameError;
        }
        else if (fullName.Length < 2)
        {
            Errors[nameof(RegisterModel.FullName)] = FullNameMinLengthError;
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(fullName, @"^[a-zA-ZÀ-ỹ\s]{2,100}$"))
        {
            Errors[nameof(RegisterModel.FullName)] = FullNameError;
        }

        if (string.IsNullOrWhiteSpace(RegisterModel.Email))
        {
            Errors[nameof(RegisterModel.Email)] = "Email không được để trống.";
        }
        else if (!System.Text.RegularExpressions.Regex.IsMatch(RegisterModel.Email.Trim(), @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
        {
            Errors[nameof(RegisterModel.Email)] = "Email không đúng định dạng.";
        }

        if (string.IsNullOrWhiteSpace(RegisterModel.PhoneNumber) ||
            !System.Text.RegularExpressions.Regex.IsMatch(RegisterModel.PhoneNumber.Trim(), @"^0\d{9}$"))
        {
            Errors[nameof(RegisterModel.PhoneNumber)] = PhoneError;
        }

        if (string.IsNullOrWhiteSpace(RegisterModel.Password) ||
            !System.Text.RegularExpressions.Regex.IsMatch(RegisterModel.Password, @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$"))
        {
            Errors[nameof(RegisterModel.Password)] = PasswordError;
        }

        if (string.IsNullOrWhiteSpace(RegisterModel.ConfirmPassword) ||
            RegisterModel.ConfirmPassword != RegisterModel.Password)
        {
            Errors[nameof(RegisterModel.ConfirmPassword)] = ConfirmPasswordError;
        }

        return Errors.Count == 0;
    }

    private RenderFragment ShowFieldError(string fieldName) => builder =>
    {
        if (!Errors.TryGetValue(fieldName, out var error))
        {
            return;
        }

        builder.OpenElement(0, "p");
        builder.AddAttribute(1, "class", "mt-1 text-sm text-red-600");
        builder.AddContent(2, error);
        builder.CloseElement();
    };
}
