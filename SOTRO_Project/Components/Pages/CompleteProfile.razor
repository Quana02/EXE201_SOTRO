@page "/complete-profile"
@layout EmptyLayout
@inject IAuthApiService AuthApi
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Hoàn tất hồ sơ - Sổ trọ</PageTitle>

<HeaderLanding />

<main class="pt-32 pb-16 flex-grow flex items-center justify-center px-margin-mobile py-12">
    <div class="w-full max-w-md bg-surface-container-lowest p-8 rounded-xl shadow-[0px_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant">
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary-fixed rounded-full mb-6">
                <span class="material-symbols-outlined text-primary text-4xl">person</span>
            </div>
            <h1 class="font-headline-md text-headline-md text-on-surface mb-2">Hoàn tất hồ sơ</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">
                Vui lòng bổ sung số điện thoại để tiếp tục sử dụng Sổ trọ.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="mb-5 rounded-lg border px-4 py-3 @(IsSuccess ? "border-green-200 bg-green-50 text-green-700" : "border-red-200 bg-red-50 text-red-700")">
                @Message
            </div>
        }

        <form class="space-y-6" @onsubmit="SubmitCompleteProfile" @onsubmit:preventDefault>
            <div class="space-y-2">
                <label class="font-label-md text-label-md text-on-surface-variant" for="phone">Số điện thoại</label>
                <input @bind="Request.PhoneNumber"
                       class="w-full px-4 py-3 bg-surface-container-lowest border border-outline-variant rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all font-body-md text-body-md"
                       id="phone"
                       placeholder="0901234567"
                       type="tel" />
                @if (!string.IsNullOrWhiteSpace(PhoneError))
                {
                    <p class="text-sm text-red-600">@PhoneError</p>
                }
            </div>

            <button disabled="@IsLoading"
                    class="w-full py-3 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:bg-primary-container transition-colors shadow-sm active:scale-[0.98] disabled:opacity-60"
                    type="submit">
                @(IsLoading ? "Đang cập nhật..." : "Hoàn tất")
            </button>
        </form>
    </div>
</main>

<FooterLanding />

@code {
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    private CompleteProfileRequest Request { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool IsSuccess { get; set; }
    private string? Message { get; set; }
    private string? PhoneError { get; set; }

    protected override void OnParametersSet()
    {
        Request.Email = Email ?? string.Empty;
    }

    private async Task SubmitCompleteProfile()
    {
        PhoneError = null;

        if (string.IsNullOrWhiteSpace(Request.PhoneNumber) ||
            !System.Text.RegularExpressions.Regex.IsMatch(Request.PhoneNumber.Trim(), @"^0\d{9}$"))
        {
            PhoneError = "Số điện thoại không hợp lệ. Số điện thoại phải bắt đầu bằng 0 và gồm 10 chữ số.";
            return;
        }

        Request.PhoneNumber = Request.PhoneNumber.Trim();
        IsLoading = true;
        Message = null;

        var response = await AuthApi.CompleteProfileAsync(Request);
        IsSuccess = response.Success;
        Message = response.Message;

        if (response.Success && response.Data != null)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_token", response.Data.Token);
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_email", response.Data.Email);
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_name", response.Data.FullName ?? "");
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_phone_number", response.Data.PhoneNumber ?? "");
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_avatar_url", response.Data.User?.AvatarUrl ?? "");
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_provider", response.Data.User?.Provider ?? "");
            Navigation.NavigateTo("/nha-tro");
        }

        IsLoading = false;
    }
}
