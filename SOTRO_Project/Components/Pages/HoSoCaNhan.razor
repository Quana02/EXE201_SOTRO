    private byte[]? _avatarBytes;
    private string _avatarFileName = string.Empty;

    // Password Backing Variables
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;

    // Password visibility toggles
    private bool _showCurrentPassword;
    private bool _showNewPassword;
    private bool _showConfirmPassword;

    // Password strength visual states
    private int _passwordStrength = 0;
    private string _passwordStrengthText = "Không có";
    private string _passwordStrengthColorClass = "bg-gray-200 w-0";
    private string _passwordStrengthTextClass = "text-gray-400";

    // Duplicate password check
    private bool _isNewPasswordSameAsCurrent => 
        !string.IsNullOrEmpty(_newPassword) && 
        !string.IsNullOrEmpty(_currentPassword) && 
        _newPassword == _currentPassword;

    // Operations states
    private bool _isSavingProfile;
    private bool _isSavingPassword;
    private bool _showPasswordSuccessModal;
    private CancellationTokenSource? _logoutCts;
    private string? _errorMessage;
    private string? _successMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var nameTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_name");
                var emailTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_email");
                var phoneTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_phone_number");
                var avatarTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_avatar_url");
                var providerTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_provider");

                await Task.WhenAll(nameTask.AsTask(), emailTask.AsTask(), phoneTask.AsTask(), avatarTask.AsTask(), providerTask.AsTask());

                _fullName = nameTask.Result ?? string.Empty;
                _email = emailTask.Result ?? string.Empty;
                _phoneNumber = phoneTask.Result ?? string.Empty;
                _avatarPreviewUrl = avatarTask.Result ?? string.Empty;
                _provider = providerTask.Result ?? string.Empty;

                _originalFullName = _fullName;
                _originalPhoneNumber = _phoneNumber;
                _originalAvatarUrl = _avatarPreviewUrl;

                _isInitialized = true;
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _errorMessage = $"Lỗi khi tải thông tin hồ sơ: {ex.Message}";
                _isInitialized = true;
                StateHasChanged();
            }
        }
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
        _errorMessage = null;
        _successMessage = null;
    }

    private async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        _errorMessage = null;
        _successMessage = null;
        var file = e.File;
        if (file != null)
        {
            if (file.Size > 5 * 1024 * 1024)
            {
                _errorMessage = "Kích thước ảnh đại diện không được vượt quá 5MB.";
                return;
            }

            var allowedTypes = new[] { "image/jpeg", "image/png", "image/webp", "image/gif" };
            if (!allowedTypes.Contains(file.ContentType.ToLower()))
            {
                _errorMessage = "Chỉ chấp nhận file ảnh hợp lệ (jpg, png, webp, gif).";
                return;
            }

            try
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(5 * 1024 * 1024).ReadExactlyAsync(buffer);
                _avatarBytes = buffer;
                _avatarFileName = file.Name;
                _avatarPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _errorMessage = $"Lỗi đọc file ảnh: {ex.Message}";
            }
        }
    }

    private void ResetProfileFields()
    {
        _fullName = _originalFullName;
        _phoneNumber = _originalPhoneNumber;
        _avatarPreviewUrl = _originalAvatarUrl;
        _avatarBytes = null;
        _avatarFileName = string.Empty;
        _errorMessage = null;
        _successMessage = null;
    }

    private async Task SaveProfile()
    {
        _errorMessage = null;
        _successMessage = null;

        var name = _fullName?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(name))
        {
            _errorMessage = "Họ và tên không được để trống.";
            return;
        }
        if (name.Length < 2)
        {
            _errorMessage = "Họ và tên phải có ít nhất 2 ký tự.";
            return;
        }

        var phone = _phoneNumber?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(phone) || !System.Text.RegularExpressions.Regex.IsMatch(phone, @"^0\d{9}$"))
        {
            _errorMessage = "Số điện thoại không hợp lệ. Số điện thoại phải bắt đầu bằng 0 và gồm 10 chữ số.";
            return;
        }

        _isSavingProfile = true;
        StateHasChanged();

        try
        {
            var req = new UpdateProfileRequest
            {
                Email = _email,
                FullName = name,
                PhoneNumber = phone
            };

            MemoryStream? ms = null;
            if (_avatarBytes != null)
            {
                ms = new MemoryStream(_avatarBytes);
            }

            var response = await AuthApi.UpdateProfileAsync(req, ms, _avatarFileName);
            if (response.Success && response.Data != null)
            {
                _successMessage = response.Message ?? "Cập nhật hồ sơ cá nhân thành công!";
                
                // Save updated values back to original tracking states
                _originalFullName = response.Data.FullName ?? name;
                _originalPhoneNumber = response.Data.PhoneNumber ?? phone;
                _fullName = _originalFullName;
                _phoneNumber = _originalPhoneNumber;

                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_name", _originalFullName);
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_phone_number", _originalPhoneNumber);

                if (response.Data.User != null && !string.IsNullOrWhiteSpace(response.Data.User.AvatarUrl))
                {
                    _originalAvatarUrl = response.Data.User.AvatarUrl;
                    _avatarPreviewUrl = _originalAvatarUrl;
                    await JS.InvokeVoidAsync("localStorage.setItem", "sotro_avatar_url", _originalAvatarUrl);
                }

                _avatarBytes = null;
                _avatarFileName = string.Empty;

                // Sync the header layout in real-time
                await JS.InvokeVoidAsync("sotroSyncHeaderUser", _originalFullName, _originalAvatarUrl);
            }
            else
            {
                _errorMessage = response.Message ?? "Không thể cập nhật hồ sơ cá nhân.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Lỗi lưu hồ sơ: {ex.Message}";
        }
        finally
        {
            _isSavingProfile = false;
            StateHasChanged();
        }
    }

    private void OnCurrentPasswordInput(ChangeEventArgs e)
    {
        _currentPassword = e.Value?.ToString() ?? "";
    }

    private void OnNewPasswordInput(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        _newPassword = val;
        CalculatePasswordStrength(val);
    }

    private void CalculatePasswordStrength(string pwd)
    {
        if (string.IsNullOrEmpty(pwd))
        {
            _passwordStrength = 0;
            _passwordStrengthText = "Không có";
            _passwordStrengthColorClass = "bg-gray-200 w-0";
            _passwordStrengthTextClass = "text-gray-400";
            return;
        }

        int score = 0;
        if (pwd.Length >= 8) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, @"[a-z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, @"[A-Z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, @"\d")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, @"[^A-Za-z\d]")) score++;

        _passwordStrength = score;
        if (score <= 2)
        {
            _passwordStrengthText = "Mật khẩu yếu";
            _passwordStrengthColorClass = "bg-red-500 w-1/3";
            _passwordStrengthTextClass = "text-red-500";
        }
        else if (score <= 4)
        {
            _passwordStrengthText = "Mật khẩu trung bình";
            _passwordStrengthColorClass = "bg-amber-500 w-2/3";
            _passwordStrengthTextClass = "text-amber-500";
        }
        else
        {
            _passwordStrengthText = "Mật khẩu mạnh";
            _passwordStrengthColorClass = "bg-green-500 w-full";
            _passwordStrengthTextClass = "text-green-500";
        }
    }

    private void ClearPasswordFields()
    {
        _currentPassword = string.Empty;
        _newPassword = string.Empty;
        _confirmPassword = string.Empty;
        _showCurrentPassword = false;
        _showNewPassword = false;
        _showConfirmPassword = false;
        _passwordStrength = 0;
        _passwordStrengthText = "Không có";
        _passwordStrengthColorClass = "bg-gray-200 w-0";
        _passwordStrengthTextClass = "text-gray-400";
        _errorMessage = null;
        _successMessage = null;
    }

    private async Task ChangePassword()
    {
        _errorMessage = null;
        _successMessage = null;

        if (string.IsNullOrEmpty(_currentPassword))
        {
            _errorMessage = "Vui lòng nhập mật khẩu hiện tại.";
            return;
        }

        if (string.IsNullOrEmpty(_newPassword))
        {
            _errorMessage = "Vui lòng nhập mật khẩu mới.";
            return;
        }

        if (_isNewPasswordSameAsCurrent)
        {
            _errorMessage = "Mật khẩu mới không được trùng với mật khẩu hiện tại.";
            return;
        }

        if (_newPassword.Length < 8)
        {
            _errorMessage = "Mật khẩu mới phải có tối thiểu 8 ký tự.";
            return;
        }

        if (!System.Text.RegularExpressions.Regex.IsMatch(_newPassword, @"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$"))
        {
            _errorMessage = "Mật khẩu phải có ít nhất 8 ký tự, gồm 1 chữ in hoa, 1 chữ thường, 1 chữ số và 1 ký tự đặc biệt.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _errorMessage = "Xác nhận mật khẩu mới không trùng khớp.";
            return;
        }

        _isSavingPassword = true;
        StateHasChanged();

        try
        {
            var req = new ChangePasswordRequest
            {
                Email = _email,
                CurrentPassword = _currentPassword,
                NewPassword = _newPassword,
                ConfirmPassword = _confirmPassword
            };

            var response = await AuthApi.ChangePasswordAsync(req);
            if (response.Success)
            {
                ClearPasswordFields();
                _isSavingPassword = false;
                _showPasswordSuccessModal = true;
                StateHasChanged();

                // Auto-logout sau 3 giây
                _logoutCts?.Cancel();
                _logoutCts = new CancellationTokenSource();
                var token = _logoutCts.Token;
                _ = Task.Run(async () =>
                {
                    try
                    {
                        await Task.Delay(3000, token);
                        await InvokeAsync(async () => await PerformLogout());
                    }
                    catch (TaskCanceledException) { /* bỏ qua nếu đã đóng bằng tay */ }
                });
                return;
            }
            else
            {
                _errorMessage = response.Message ?? "Không thể đổi mật khẩu.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Lỗi đổi mật khẩu: {ex.Message}";
        }
        finally
        {
            _isSavingPassword = false;
            StateHasChanged();
        }
    }

    // Google Link variables
    private bool _isLinkingGoogle;
    private DotNetObjectReference<HoSoCaNhan>? _googleCallbackRef;

    private async Task LinkWithGoogle()
    {
        _errorMessage = null;
        _successMessage = null;

        var clientId = Configuration["Authentication:Google:ClientId"];
        if (string.IsNullOrWhiteSpace(clientId) || clientId == "YOUR_GOOGLE_CLIENT_ID")
        {
            _errorMessage = "Chưa cấu hình Google ClientId trong appsettings.json.";
            return;
        }

        _googleCallbackRef = DotNetObjectReference.Create(this);
        var initialized = await JS.InvokeAsync<bool>("sotroGoogleAuth.init", clientId, _googleCallbackRef);
        if (!initialized)
        {
            _errorMessage = "Không thể khởi tạo Google Login. Vui lòng tải lại trang và thử lại.";
            return;
        }

        _isLinkingGoogle = true;
        StateHasChanged();

        var prompted = await JS.InvokeAsync<bool>("sotroGoogleAuth.prompt");
        if (!prompted)
        {
            _errorMessage = "Không thể mở liên kết tài khoản Google. Vui lòng thử lại.";
            _isLinkingGoogle = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task HandleGoogleCredential(string credential)
    {
        try
        {
            _errorMessage = null;
            _successMessage = null;
            _isLinkingGoogle = true;
            await InvokeAsync(StateHasChanged);

            var parts = credential.Split('.');
            if (parts.Length < 2)
            {
                _errorMessage = "Mã xác thực Google không hợp lệ.";
                return;
            }

            var payload = parts[1].Replace('-', '+').Replace('_', '/');
            payload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));
            using var document = System.Text.Json.JsonDocument.Parse(json);
            var root = document.RootElement;

            var googleEmail = root.TryGetProperty("email", out var emailElement) ? emailElement.GetString() : null;
            var name = root.TryGetProperty("name", out var nameElement) ? nameElement.GetString() : null;
            var sub = root.TryGetProperty("sub", out var subElement) ? subElement.GetString() : null;
            var picture = root.TryGetProperty("picture", out var pictureElement) ? pictureElement.GetString() : null;

            if (string.IsNullOrWhiteSpace(googleEmail) || string.IsNullOrWhiteSpace(sub))
            {
                _errorMessage = "Không lấy được thông tin email Google.";
                return;
            }

            var response = await AuthApi.LinkGoogleAsync(new LinkGoogleRequest
            {
                CurrentEmail = _email,
                GoogleEmail = googleEmail,
                GoogleId = sub,
                AvatarUrl = picture
            });

            if (response.Success && response.Data != null)
            {
                _successMessage = "Liên kết tài khoản Google thành công!";
                
                // Cập nhật thông tin tài khoản hiện tại
                _email = response.Data.User?.Email ?? response.Data.Email;
                _fullName = response.Data.User?.FullName ?? response.Data.FullName ?? _fullName;
                _provider = response.Data.User?.Provider ?? "Google";
                _originalFullName = _fullName;

                if (!string.IsNullOrWhiteSpace(response.Data.User?.AvatarUrl))
                {
                    _avatarPreviewUrl = response.Data.User.AvatarUrl;
                    _originalAvatarUrl = _avatarPreviewUrl;
                }

                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_token", response.Data.Token);
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_email", _email);
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_user_name", _fullName);
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_avatar_url", _avatarPreviewUrl);
                await JS.InvokeVoidAsync("localStorage.setItem", "sotro_provider", _provider);

                await JS.InvokeVoidAsync("sotroSyncHeaderUser", _fullName, _avatarPreviewUrl);
            }
            else
            {
                _errorMessage = response.Message ?? "Liên kết tài khoản Google thất bại.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Lỗi liên kết Google: {ex.Message}";
        }
        finally
        {
            _isLinkingGoogle = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ForceLogoutNow()
    {
        _logoutCts?.Cancel();
        await PerformLogout();
    }

    private async Task PerformLogout()
    {
        _showPasswordSuccessModal = false;
        StateHasChanged();

        // Xóa toàn bộ dữ liệu phiên đăng nhập
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_token");
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_user_email");
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_user_name");
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_phone_number");
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_avatar_url");
        await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_provider");

        Navigation.NavigateTo("/dang-nhap", forceLoad: true);
    }

    public void Dispose()
    {
        _logoutCts?.Cancel();
        _logoutCts?.Dispose();
        _googleCallbackRef?.Dispose();
    }
