        (!string.IsNullOrWhiteSpace(_email) && _email.EndsWith("@gmail.com", StringComparison.OrdinalIgnoreCase));

    // Reset variables
    private string _originalFullName = string.Empty;
    private string _originalPhoneNumber = string.Empty;
    private string _originalAvatarUrl = string.Empty;

