@page "/thanh-vien-phong"

<PageTitle>SOTRO - Thành viên phòng</PageTitle>

<HeaderDashboard />
<SideNavBar />

<main class="flex-1 ml-0 md:ml-64 p-6 md:p-10 min-h-screen bg-gray-50">

    <div class="max-w-4xl mx-auto">

        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">
                    Chỉnh sửa Phòng 302
                </h1>
                <p class="text-gray-500">
                    Khu trọ: Sunny House - Quận 7
                </p>
            </div>

            <div class="flex gap-3">
                <button class="px-6 py-2 border border-gray-300 text-gray-700 rounded-full hover:bg-gray-100">
                    Cancel
                </button>

                <button class="px-6 py-2 bg-blue-700 text-white rounded-full hover:bg-blue-800">
                    Save Changes
                </button>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 space-y-6">

                <section class="bg-white rounded-xl shadow-sm border overflow-hidden">

                    <div class="p-6 border-b flex justify-between items-center">
                        <h2 class="text-2xl font-bold text-blue-700">
                            Danh sách người ở
                        </h2>

                        <label class="flex items-center gap-2 cursor-pointer">
                            <input class="w-5 h-5"
                                   type="checkbox" />
                            <span class="text-gray-600">
                                Trống phòng
                            </span>
                        </label>
                    </div>

                    <div class="p-6 space-y-4">

                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center">
                                    👤
                                </div>

                                <div>
                                    <h3 class="font-bold text-gray-800">
                                        Nguyễn Văn An
                                    </h3>
                                    <p class="text-sm text-gray-500">
                                        090 123 4567
                                    </p>
                                </div>
                            </div>

                            <button class="p-2 text-red-600 hover:bg-red-50 rounded-full">
                                🗑️
                            </button>
                        </div>

                        <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg border">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-blue-100 flex items-center justify-center">
                                    👤
                                </div>

                                <div>
                                    <h3 class="font-bold text-gray-800">
                                        Trần Thị Bích
                                    </h3>
                                    <p class="text-sm text-gray-500">
                                        098 765 4321
                                    </p>
                                </div>
                            </div>

                            <button class="p-2 text-red-600 hover:bg-red-50 rounded-full">
                                🗑️
                            </button>
                        </div>

                    </div>

                    <div class="p-6 bg-gray-50 border-t">
                        <button @onclick="ToggleAddForm"
                                class="w-full py-3 flex items-center justify-center gap-2 border-2 border-dashed border-gray-300 rounded-xl text-blue-700 font-semibold hover:border-blue-700 hover:bg-blue-50 transition-all">
                            <span>➕</span>
                            Thêm người ở
                        </button>
                    </div>

                </section>

                @if (ShowAddForm)
                {
                    <section class="bg-white rounded-xl shadow-sm border p-6 space-y-6">

                        <h2 class="text-2xl font-bold text-blue-700">
                            Thông tin người mới
                        </h2>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

                            <div>
                                <label class="text-sm font-semibold text-gray-600">
                                    Họ và tên
                                </label>
                                <input class="w-full p-3 rounded-lg border mt-1"
                                       placeholder="Nhập tên"
                                       type="text" />
                            </div>

                            <div>
                                <label class="text-sm font-semibold text-gray-600">
                                    Số điện thoại
                                </label>
                                <input class="w-full p-3 rounded-lg border mt-1"
                                       placeholder="Nhập SĐT"
                                       type="tel" />
                            </div>

                            <div>
                                <label class="text-sm font-semibold text-gray-600">
                                    Số CMND/CCCD
                                </label>
                                <input class="w-full p-3 rounded-lg border mt-1"
                                       placeholder="Nhập số định danh"
                                       type="text" />
                            </div>

                            <div>
                                <label class="text-sm font-semibold text-gray-600">
                                    Ngày sinh
                                </label>
                                <input class="w-full p-3 rounded-lg border mt-1"
                                       type="date" />
                            </div>

                        </div>

                        <div class="flex justify-end gap-3 pt-4 border-t">

                            <button @onclick="ToggleAddForm"
                                    class="px-4 py-2 text-gray-600 hover:bg-gray-100 rounded-lg">
                                Hủy
                            </button>

                            <button class="px-6 py-2 bg-blue-100 text-blue-700 font-semibold rounded-lg hover:bg-blue-200">
                                Xác nhận
                            </button>

                        </div>

                    </section>
                }

            </div>

            <div class="space-y-6">

                <div class="bg-white rounded-xl shadow-sm border p-6">

                    <h3 class="font-bold text-gray-800 mb-4">
                        Tổng quan phòng
                    </h3>

                    <div class="relative w-full aspect-video rounded-lg overflow-hidden mb-4">
                        <img alt="Room Preview"
                             class="w-full h-full object-cover"
                             src="https://lh3.googleusercontent.com/aida-public/AB6AXuB-cE1cN4-SJ7QgzIXpZOwrOoUd79oBpLquiFXaiiAwy2YNjDXOH_SER8AgxCmTkXDRWq-NEIexPRHHpJS7KrOo_eFjVtHzl3mpA_9Qz7LFqDpHQKgy9RmR4Ov7w8wtJc9cPIQ6N1d7cuMjMAB0eb1d7AYWoqw0IbIe3CiQrhE5uD8EAVaTVmPo81nqNi3jttSyV7iRzZkEX8-Ox93bPI-vtZsDMnp_taePAui0fMMu9jsyOCLUOANc7eGa8Wh0ak_IfW9dTiRI4GSx" />

                        <div class="absolute top-2 right-2 bg-blue-700 text-white text-xs px-3 py-1 rounded-full">
                            Đang thuê
                        </div>
                    </div>

                    <div class="space-y-3">

                        <div class="flex justify-between py-2 border-b">
                            <span class="text-gray-500">Giá phòng</span>
                            <span class="font-bold text-blue-700">3,500,000đ</span>
                        </div>

                        <div class="flex justify-between py-2 border-b">
                            <span class="text-gray-500">Tiền điện/kWh</span>
                            <span>3,500đ</span>
                        </div>

                        <div class="flex justify-between py-2 border-b">
                            <span class="text-gray-500">Tiền nước/m3</span>
                            <span>20,000đ</span>
                        </div>

                    </div>

                    <button class="w-full mt-6 py-2 text-blue-700 font-semibold border border-blue-700 rounded-lg hover:bg-blue-50">
                        Sửa thông tin giá
                    </button>

                </div>

            </div>

        </div>

    </div>

</main>

@code {
    private bool ShowAddForm = false;

    private void ToggleAddForm()
    {
        ShowAddForm = !ShowAddForm;
    }
}