@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IBuildingApiService BuildingApiService
@implements IDisposable

<header class="flex justify-between items-center h-16 px-margin-mobile md:px-margin-desktop w-full sticky top-0 z-50 bg-surface border-b border-outline-variant shadow-sm">
    <div class="flex items-center mr-4">
        <div class="flex items-center gap-3">
            <a href="/" class="flex items-center cursor-pointer transition-opacity hover:opacity-85" title="Về trang chủ">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDhYXYem8pnyf-x-_Q-OAYvvYT0Eoie3QgsyWlMQv2uEKGvKUp3z6Dbcw9UNfefANq1wABhAS-3ivWQk_fd6YnvgsbRlzbSfL68H4ewsArldRQEyArQD3FljdvTKCm_2ijqMAcHsjfWpBHqpB4T84JuU75OjyVyrjaohxLJmkhMz4OSU_WnfAAq-05ZQvzH7w9KvGBY6PJ7LqpOLwJdwUBAWlrvmRfYzxU7kVNQ4DiIDlk72cWywGIrDHYXL81x1HVYNT6X3BKj98a6" alt="Sổ Trọ Logo" class="h-10 w-auto object-contain">
            </a>
            <a href="/nha-tro" class="text-primary font-semibold text-headline-sm font-headline-sm cursor-pointer transition-colors hover:text-blue-800" title="Chọn nhà trọ">
                Sổ Trọ
            </a>
        </div>
    </div>
    <div class="flex items-center gap-4">
        <button class="hidden">
            <span class="material-symbols-outlined">menu</span>
        </button>
        @if (OnSearch.HasDelegate)
        {
            <div class="hidden md:flex bg-surface-container-low rounded-full px-4 py-1.5 items-center gap-2 border border-outline-variant w-80 focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20 transition-all duration-200">
                <span class="material-symbols-outlined text-on-surface-variant text-xl">search</span>
                <input class="bg-transparent border-none focus:ring-0 text-sm w-full placeholder:text-on-surface-variant focus:outline-none" 
                       placeholder="@SearchPlaceholder" 
                       type="text" 
                       value="@_inputText"
                       @oninput="HandleInput">
            </div>
        }
    </div>
    <div class="flex items-center gap-2 md:gap-4">
        <button class="p-2 text-on-surface-variant hover:bg-surface-container-low transition-colors rounded-full relative">
            <span class="material-symbols-outlined">notifications</span>
            <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full"></span>
        </button>
        <div class="hidden md:block relative">
            @if (_showHelpHint && OnHelpClicked.HasDelegate)
            {
                <button type="button"
                        @onclick="HandleHelpClick"
                        class="sotro-help-hint absolute right-12 top-1/2 -translate-y-1/2 whitespace-nowrap rounded-full bg-primary text-white px-3 py-1.5 text-xs font-bold shadow-lg border border-white/70"
                        aria-label="Mở hướng dẫn trang này">
                    Hướng dẫn
                </button>
            }
            <button type="button"
                    id="header-help-button"
                    @onclick="HandleHelpClick"
                    class="flex p-2 text-on-surface-variant hover:bg-surface-container-low transition-colors rounded-full"
                    title="Xem hướng dẫn trang này"
                    aria-label="Xem hướng dẫn trang này">
                <span class="material-symbols-outlined">help_outline</span>
            </button>
        </div>
        <div class="h-8 w-px bg-outline-variant mx-1 hidden md:block"></div>

        @* === Avatar + Dropdown === *@
        <div class="relative">
            <button @onclick="ToggleDropdown"
                    @onclick:stopPropagation="true"
                    class="flex items-center gap-3 pl-2 cursor-pointer rounded-full hover:bg-surface-container-low transition-colors duration-200 p-1"
                    aria-haspopup="true"
                    aria-expanded="@_isDropdownOpen"
                    aria-label="Menu người dùng"
                    id="header-avatar-btn">

                @* Tên + vai trò (ẩn trên mobile) *@
                <div class="text-right hidden sm:block select-none">
                    <p id="header-user-display-name" class="font-label-md text-xs font-bold text-on-surface leading-tight truncate max-w-[140px]">
                        @(string.IsNullOrWhiteSpace(_userName) ? "Chủ trọ" : _userName)
                    </p>
                    <p class="font-caption text-[10px] text-on-surface-variant">Quản lý</p>
                </div>

                @* Avatar hoặc icon mặc định kiểu Facebook *@
                <div id="header-user-avatar-container" class="flex-shrink-0">
                    @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                    {
                        <img alt="Ảnh đại diện"
                             class="w-9 h-9 rounded-full object-cover border-2 border-primary/20 transition-transform duration-200 hover:scale-105"
                             src="@_avatarUrl"
                             loading="lazy"
                             @onerror="HandleAvatarError" />
                    }
                    else
                    {
                        <div class="w-9 h-9 rounded-full bg-surface-container-high border-2 border-outline-variant flex items-center justify-center transition-transform duration-200 hover:scale-105">
                            <span class="material-symbols-outlined text-on-surface-variant text-xl" style="font-variation-settings: 'FILL' 1;">person</span>
                        </div>
                    }
                </div>
            </button>

            @* Overlay vô hình để bắt click bên ngoài — nhẹ hơn JS event listener *@
            @if (_isDropdownOpen)
            {
                <div class="fixed inset-0 z-[99]" @onclick="CloseDropdown"></div>
            }

            @* Dropdown Menu *@
            @if (_isDropdownOpen)
            {
                <div class="absolute right-0 top-full mt-2 w-56 bg-surface-container-lowest rounded-xl shadow-lg border border-outline-variant overflow-hidden z-[100] sotro-dropdown-enter"
                     role="menu"
                     aria-label="Menu tài khoản">

                    @* Thông tin user ở đầu dropdown *@
                    <div class="px-4 py-3 border-b border-outline-variant bg-surface-container-low/50">
                        <p id="header-dropdown-user-name" class="text-sm font-bold text-on-surface truncate">
                            @(string.IsNullOrWhiteSpace(_userName) ? "Chủ trọ" : _userName)
                        </p>
                        <p id="header-dropdown-user-email" class="text-xs text-on-surface-variant truncate">@_userEmail</p>
                    </div>

                    <div class="py-1">
                        @* Hồ sơ cá nhân *@
                        <button @onclick="NavigateToProfile"
                                class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors duration-150 text-left"
                                role="menuitem">
                            <span class="material-symbols-outlined text-on-surface-variant text-xl">person</span>
                            <span>Hồ sơ cá nhân</span>
                        </button>

                        @* Cài đặt *@
                        <button @onclick="NavigateToSettings"
                                class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-on-surface hover:bg-surface-container-low transition-colors duration-150 text-left"
                                role="menuitem">
                            <span class="material-symbols-outlined text-on-surface-variant text-xl">settings</span>
                            <span>Cài đặt</span>
                        </button>
                    </div>

                    <div class="border-t border-outline-variant py-1">
                        @* Đăng xuất *@
                        <button @onclick="Logout"
                                class="w-full flex items-center gap-3 px-4 py-2.5 text-sm text-error hover:bg-error-container/30 transition-colors duration-150 text-left"
                                role="menuitem">
                            <span class="material-symbols-outlined text-error text-xl">logout</span>
                            <span>Đăng xuất</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</header>

@if (_showPopup)
{
    <div class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[200] flex items-center justify-center p-4 transition-all duration-300">
        <div class="bg-white rounded-2xl border border-outline-variant p-8 max-w-sm w-full shadow-2xl relative overflow-hidden transform scale-95 opacity-0 animate-popup-in text-center flex flex-col items-center">
            
            <!-- Close Button -->
            <button @onclick="ClosePopup" type="button" class="absolute top-4 right-4 text-on-surface-variant hover:text-on-surface p-1 hover:bg-surface-container rounded-full transition-all" aria-label="Đóng thông báo">
                <span class="material-symbols-outlined text-xl">close</span>
            </button>

            <!-- Pulse Warn Icon -->
            <div class="w-16 h-16 rounded-full bg-amber-50 flex items-center justify-center mb-5 animate-pulse">
                <span class="material-symbols-outlined text-amber-500 text-4xl" style="font-variation-settings: 'FILL' 1;">warning</span>
            </div>

            <!-- Title -->
            <h3 class="text-lg font-bold text-on-surface mb-2">Chưa có nhà trọ nào!</h3>

            <!-- Message -->
            <p class="text-sm text-on-surface-variant leading-relaxed">
                Vì bạn chưa tạo nhà trọ nào nên chưa thể sử dụng chức năng cài đặt chi tiết này.
            </p>

            <button @onclick="GoToCreateBuilding" type="button" class="w-full mt-6 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary-container transition-all shadow-md active:scale-[0.98] flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-sm font-bold">add</span>
                Tạo nhà trọ ngay
            </button>

            <!-- Countdown Bar -->
            <div class="w-full bg-surface-container-high h-1.5 rounded-full overflow-hidden mt-6 relative">
                <div class="bg-primary h-full transition-all duration-1000 ease-linear absolute left-0 top-0 bottom-0" style="width: @(_countdownSeconds * 20)%;"></div>
            </div>
            <p class="text-[11px] text-on-surface-variant mt-2 font-medium">Tự động chuyển hướng sau <span class="text-primary font-bold">@_countdownSeconds</span> giây</p>
        </div>
    </div>
}

<style>
    /* Animation mượt cho dropdown - CSS thuần, không cần JS, tối ưu GPU */
    .sotro-dropdown-enter {
        animation: sotroDropdownIn 150ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
        transform-origin: top right;
        will-change: transform, opacity;
    }

    @@keyframes sotroDropdownIn {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(-4px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    /* Animation cho popup cảnh báo chưa tạo nhà trọ */
    @@keyframes popupIn {
        from {
            opacity: 0;
            transform: scale(0.9) translateY(12px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }
    .animate-popup-in {
        animation: popupIn 350ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        will-change: transform, opacity;
    }

    .sotro-help-hint {
        animation: sotroHelpHintFloat 1.35s ease-in-out infinite;
    }

    .sotro-help-hint::after {
        content: "";
        position: absolute;
        right: -6px;
        top: 50%;
        width: 12px;
        height: 12px;
        background: #003f87;
        transform: translateY(-50%) rotate(45deg);
        border-top: 1px solid rgba(255,255,255,0.7);
        border-right: 1px solid rgba(255,255,255,0.7);
    }

    @@keyframes sotroHelpHintFloat {
        0%, 100% {
            transform: translateY(-50%) translateY(-3px);
        }
        50% {
            transform: translateY(-50%) translateY(5px);
        }
    }
</style>

@code {
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback OnHelpClicked { get; set; }
    [Parameter] public string SearchPlaceholder { get; set; } = "Tìm kiếm...";
    [Parameter] public string SearchQuery { get; set; } = string.Empty;

    private string _userName = string.Empty;
    private string _userEmail = string.Empty;
    private string _avatarUrl = string.Empty;
    private bool _isDropdownOpen;
    private bool _isInitialized;
    private bool _showPopup;
    private bool _showHelpHint;
    private int _countdownSeconds = 5;
    private System.Threading.CancellationTokenSource? _countdownCts;
    private System.Threading.CancellationTokenSource? _helpHintCts;

    private string _inputText = string.Empty;
    private System.Threading.CancellationTokenSource? _searchCts;

    protected override void OnParametersSet()
    {
        if (_inputText != SearchQuery)
        {
            _inputText = SearchQuery;
        }
    }

    private void HandleInput(ChangeEventArgs e)
    {
        _inputText = e.Value?.ToString() ?? string.Empty;
        
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var token = _searchCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, token);
                if (!token.IsCancellationRequested)
                {
                    await InvokeAsync(async () =>
                    {
                        if (OnSearch.HasDelegate)
                        {
                            await OnSearch.InvokeAsync(_inputText);
                        }
                    });
                }
            }
            catch (TaskCanceledException)
            {
                // Ignored
            }
        }, token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _isInitialized)
        {
            return;
        }

        _isInitialized = true;

        try
        {
            // Đọc song song các key từ localStorage — giảm round-trip JS interop
            var tokenTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_token");
            var nameTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_name");
            var emailTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_user_email");
            var avatarTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_avatar_url");

            await Task.WhenAll(tokenTask.AsTask(), nameTask.AsTask(), emailTask.AsTask(), avatarTask.AsTask());

            var token = tokenTask.Result ?? string.Empty;
            if (!IsTokenUsable(token))
            {
                await RedirectToLoginAsync();
                return;
            }

            _userName = nameTask.Result ?? string.Empty;
            _userEmail = emailTask.Result ?? string.Empty;
            _avatarUrl = avatarTask.Result ?? string.Empty;

            StateHasChanged();

            // Token may still be rejected after deploy if it was issued by another backend/JWT key.
            _ = BuildingApiService.GetBuildingsAsync();
            StartHelpHintTimer();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"HeaderDashboard init error: {ex.Message}");
        }
    }

    private void ToggleDropdown()
    {
        _isDropdownOpen = !_isDropdownOpen;
    }

    private void CloseDropdown()
    {
        _isDropdownOpen = false;
    }

    private async Task HandleHelpClick()
    {
        _showHelpHint = false;
        _helpHintCts?.Cancel();
        if (OnHelpClicked.HasDelegate)
        {
            await OnHelpClicked.InvokeAsync();
        }
    }

    private void StartHelpHintTimer()
    {
        if (!OnHelpClicked.HasDelegate)
        {
            return;
        }

        _helpHintCts?.Cancel();
        _helpHintCts = new System.Threading.CancellationTokenSource();
        var token = _helpHintCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(TimeSpan.FromSeconds(10), token);
                if (token.IsCancellationRequested) return;
                await InvokeAsync(() =>
                {
                    _showHelpHint = true;
                    StateHasChanged();
                });
            }
            catch (TaskCanceledException)
            {
            }
        }, token);
    }

    private void NavigateToProfile()
    {
        _isDropdownOpen = false;
        Navigation.NavigateTo("/ho-so-ca-nhan");
    }

    private async Task NavigateToSettings()
    {
        _isDropdownOpen = false;

        try
        {
            var response = await BuildingApiService.GetBuildingsAsync();
            if (response.Success && response.Data != null && response.Data.Count > 0)
            {
                Navigation.NavigateTo("/cai-dat");
            }
            else
            {
                ShowNoBuildingPopup();
            }
        }
        catch (Exception)
        {
            Navigation.NavigateTo("/cai-dat");
        }
    }

    private void ShowNoBuildingPopup()
    {
        _showPopup = true;
        _countdownSeconds = 5;
        _countdownCts?.Cancel();
        _countdownCts = new System.Threading.CancellationTokenSource();
        var token = _countdownCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                while (_countdownSeconds > 0)
                {
                    await Task.Delay(1000, token);
                    if (token.IsCancellationRequested) return;
                    _countdownSeconds--;
                    await InvokeAsync(StateHasChanged);
                }

                await InvokeAsync(() =>
                {
                    _showPopup = false;
                    Navigation.NavigateTo("/tao-nha-tro-v2");
                });
            }
            catch (TaskCanceledException)
            {
                // Ignored
            }
        }, token);

        StateHasChanged();
    }

    private void ClosePopup()
    {
        _countdownCts?.Cancel();
        _showPopup = false;
        StateHasChanged();
    }

    private void GoToCreateBuilding()
    {
        _countdownCts?.Cancel();
        _showPopup = false;
        Navigation.NavigateTo("/tao-nha-tro-v2");
    }

    private async Task Logout()
    {
        _isDropdownOpen = false;

        await ClearAuthStorageAsync();
        Navigation.NavigateTo("/dang-nhap", forceLoad: true);
    }

    private async Task RedirectToLoginAsync()
    {
        await ClearAuthStorageAsync();
        Navigation.NavigateTo("/dang-nhap", forceLoad: true);
    }

    private async Task ClearAuthStorageAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_token");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_user_email");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_user_name");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_phone_number");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_avatar_url");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_provider");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_role_id");
            await JS.InvokeVoidAsync("localStorage.removeItem", "sotro_role");
            await JS.InvokeVoidAsync("localStorage.removeItem", "active_building_id");
            await JS.InvokeVoidAsync("localStorage.removeItem", "active_building_name");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Auth cleanup error: {ex.Message}");
        }
    }

    private static bool IsTokenUsable(string token)
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            return false;
        }

        try
        {
            var parts = token.Split('.');
            if (parts.Length < 2)
            {
                return false;
            }

            var payload = parts[1].Replace('-', '+').Replace('_', '/');
            payload = payload.PadRight(payload.Length + (4 - payload.Length % 4) % 4, '=');
            var json = System.Text.Encoding.UTF8.GetString(Convert.FromBase64String(payload));

            using var document = System.Text.Json.JsonDocument.Parse(json);
            if (!document.RootElement.TryGetProperty("exp", out var expElement) ||
                !expElement.TryGetInt64(out var exp))
            {
                return false;
            }

            return DateTimeOffset.FromUnixTimeSeconds(exp) > DateTimeOffset.UtcNow.AddSeconds(30);
        }
        catch
        {
            return false;
        }
    }

    private void HandleAvatarError()
    {
        // Nếu ảnh avatar lỗi (404, broken URL), fallback về icon mặc định
        _avatarUrl = string.Empty;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _countdownCts?.Cancel();
        _countdownCts?.Dispose();
        _helpHintCts?.Cancel();
        _helpHintCts?.Dispose();
    }
}
