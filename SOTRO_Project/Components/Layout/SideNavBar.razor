            <div class="flex flex-col">
                <span class="text-label-md font-label-md">Cài đặt</span>
                <span class="text-[10px] text-outline font-medium">Cài đặt tự động VIP</span>
            </div>
        </a>
    </nav>
</aside>

@code {
    private string buildingName = "SOTRO Apartment";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var name = await JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
                if (!string.IsNullOrWhiteSpace(name))
                {
                    buildingName = name;
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading building name: {ex.Message}");
            }
        }
    }
}