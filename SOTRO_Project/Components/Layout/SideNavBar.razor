                <div class="absolute right-0 bottom-0 bg-white border border-outline-variant rounded-full p-1 shadow-sm opacity-0 group-hover:opacity-100 transition-opacity">
                    <span class="material-symbols-outlined text-[16px] text-primary">edit</span>
