@if (showMarketingPopup)
{
    <div class="fixed inset-0 z-[260] bg-black/45 backdrop-blur-sm flex items-center justify-center p-4" @onclick="CloseMarketingPopup">
        <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl border border-outline-variant overflow-hidden" @onclick:stopPropagation="true">
            <div class="px-6 py-5 border-b border-outline-variant flex items-start justify-between gap-4">
                <div>
                    <p class="text-xs font-black uppercase text-primary">Marketing</p>
                    <h3 class="text-xl font-black text-on-surface mt-1">Tính năng đang được cập nhật</h3>
                </div>
                <button type="button" @onclick="CloseMarketingPopup" class="w-10 h-10 rounded-full hover:bg-surface-container flex items-center justify-center" title="Đóng">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6">
                <div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-4">
                    <span class="material-symbols-outlined text-3xl">campaign</span>
                </div>
                <p class="text-body-md text-on-surface-variant leading-7">
                    Khu vực Marketing đang được phát triển để hỗ trợ đăng tin, nhắc phí và chăm sóc người thuê tốt hơn. Bạn có thể quay lại sau khi hệ thống cập nhật xong.
                </p>
                <button type="button" @onclick="CloseMarketingPopup" class="mt-6 w-full px-4 py-3 rounded-xl bg-primary text-white font-bold hover:shadow-md transition-all">
                    Đã hiểu
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string buildingName = "SOTRO Apartment";
    private int? buildingId;
    private bool _isCollapsed;
    private bool showMarketingPopup;
    private string BuildingQuery => buildingId is > 0 ? $"?buildingId={buildingId.Value}" : string.Empty;
    private string DashboardHref => $"/dashboard{BuildingQuery}";
    private string RoomsHref => $"/quan-ly-phong{BuildingQuery}";
    private string TenantsHref => $"/nguoi-thue{BuildingQuery}";
    private string InvoicesHref => $"/hoa-don{BuildingQuery}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var nameTask = JS.InvokeAsync<string>("localStorage.getItem", "active_building_name");
                var idTask = JS.InvokeAsync<string>("localStorage.getItem", "active_building_id");
                var collapsedTask = JS.InvokeAsync<string>("localStorage.getItem", "sotro_sidebar_collapsed");

                await Task.WhenAll(nameTask.AsTask(), idTask.AsTask(), collapsedTask.AsTask());

                var name = nameTask.Result;
                if (!string.IsNullOrWhiteSpace(name))
                {
                    buildingName = name;
                }

                var routeBuildingId = GetBuildingIdFromUrl();
                if (routeBuildingId is > 0)
                {
                    buildingId = routeBuildingId;
                }
                else if (int.TryParse(idTask.Result, out var id) && id > 0)
                {
                    buildingId = id;
                }

                _isCollapsed = collapsedTask.Result == "true";

                // Cập nhật CSS variable cho content margin
                await JS.InvokeVoidAsync("eval", $"document.documentElement.style.setProperty('--sidebar-width', '{(_isCollapsed ? "72px" : "16rem")}')");

                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading sidebar state: {ex.Message}");
            }
        }
    }

    private async Task ToggleSidebar()
    {
        _isCollapsed = !_isCollapsed;

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "sotro_sidebar_collapsed", _isCollapsed ? "true" : "false");
            await JS.InvokeVoidAsync("eval", $"document.documentElement.style.setProperty('--sidebar-width', '{(_isCollapsed ? "72px" : "16rem")}')");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving sidebar state: {ex.Message}");
        }
    }

    private void OpenMarketingPopup()
    {
        showMarketingPopup = true;
    }

    private void CloseMarketingPopup()
    {
        showMarketingPopup = false;
    }

    private int? GetBuildingIdFromUrl()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        return query.TryGetValue("buildingId", out var value) &&
               int.TryParse(value.FirstOrDefault(), out var id) &&
               id > 0
            ? id
            : null;
    }
}
