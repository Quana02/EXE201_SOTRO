        </a>
        <a class="flex items-center gap-3 px-3 py-2 text-on-surface-variant hover:bg-surface-container-high rounded-lg transition-all group" href="/quan-ly-phong">
            <span class="material-symbols-outlined" data-icon="home_work">home_work</span>
            <span class="text-label-md font-label-md">Phòng trọ</span>
